{# B1 — Template du mail de reset password. #}
{# Inline-CSS obligatoire pour compatibilité clients mail (Gmail, Outlook, Apple Mail). #}
<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Réinitialisation de mot de passe</title>
</head>
<body style="margin: 0; padding: 0; background-color: #f1f5f9; font-family: Arial, sans-serif;">
    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #f1f5f9;">
        <tr>
            <td align="center" style="padding: 30px 16px;">
                <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="560" style="max-width: 560px; background-color: #ffffff; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 16px rgba(0,0,0,0.08);">

                    {# Header avec gradient MABB #}
                    <tr>
                        <td style="background: linear-gradient(135deg, #063a55 0%, #0b4fa3 100%); padding: 32px 30px; text-align: center;">
                            <div style="color: #ffffff; font-size: 26px; font-weight: 800; letter-spacing: -0.5px;">
                                🏀 MABB Manager
                            </div>
                            <div style="color: #cbd5e1; font-size: 12px; margin-top: 4px; text-transform: uppercase; letter-spacing: 1.5px;">
                                Métropole Amiénoise Basket-Ball
                            </div>
                        </td>
                    </tr>

                    {# Body #}
                    <tr>
                        <td style="padding: 36px 36px 20px 36px;">
                            <h1 style="margin: 0 0 16px 0; font-size: 22px; color: #0b1f3a; font-weight: 700;">
                                🔐 Réinitialisation de ton mot de passe
                            </h1>
                            <p style="margin: 0 0 14px 0; font-size: 15px; line-height: 1.6; color: #475569;">
                                Bonjour <strong>{{ user.prenom }}</strong>,
                            </p>
                            <p style="margin: 0 0 20px 0; font-size: 15px; line-height: 1.6; color: #475569;">
                                Tu as demandé à réinitialiser ton mot de passe pour ton compte MABB Manager.
                                Clique sur le bouton ci-dessous pour choisir un nouveau mot de passe :
                            </p>

                            {# Bouton CTA #}
                            <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                                <tr>
                                    <td align="center" style="padding: 12px 0 24px 0;">
                                        <a href="{{ reset_url }}"
                                           style="background: linear-gradient(135deg, #1d4ed8, #2563eb); color: #ffffff; text-decoration: none; padding: 14px 32px; border-radius: 10px; font-weight: 700; font-size: 15px; display: inline-block;">
                                            Réinitialiser mon mot de passe
                                        </a>
                                    </td>
                                </tr>
                            </table>

                            {# Note expiration #}
                            <div style="background: #fef3c7; border-left: 4px solid #f59e0b; padding: 12px 14px; border-radius: 6px; font-size: 13px; color: #92400e; margin: 0 0 24px 0;">
                                ⏱️ <strong>Ce lien expire dans {{ expires_in_minutes }} minutes</strong> et ne peut être utilisé qu'une seule fois.
                            </div>

                            {# Fallback URL #}
                            <p style="margin: 0 0 8px 0; font-size: 12px; color: #94a3b8;">
                                Si le bouton ne fonctionne pas, copie-colle ce lien dans ton navigateur :
                            </p>
                            <p style="margin: 0 0 24px 0; font-size: 11px; color: #475569; word-break: break-all; background: #f8fafc; padding: 10px; border-radius: 6px; font-family: monospace;">
                                {{ reset_url }}
                            </p>

                            {# Sécurité info #}
                            <div style="border-top: 1px solid #e2e8f0; padding-top: 18px; margin-top: 8px;">
                                <p style="margin: 0 0 6px 0; font-size: 12px; color: #64748b; line-height: 1.5;">
                                    🛡️ <strong>Tu n'as pas demandé ce mail ?</strong>
                                </p>
                                <p style="margin: 0; font-size: 12px; color: #64748b; line-height: 1.5;">
                                    Ignore-le simplement. Ton mot de passe actuel reste valide et personne ne peut accéder à ton compte sans cliquer sur le lien.
                                </p>
                            </div>
                        </td>
                    </tr>

                    {# Footer #}
                    <tr>
                        <td style="background-color: #0b1f3a; padding: 18px 30px; text-align: center;">
                            <p style="margin: 0; color: #94a3b8; font-size: 11px;">
                                Cet email a été envoyé automatiquement, merci de ne pas y répondre.
                            </p>
                            <p style="margin: 6px 0 0 0; color: #cbd5e1; font-size: 11px;">
                                MABB — Métropole Amiénoise Basket-Ball · <a href="https://mabb.fr" style="color: #93c5fd; text-decoration: none;">mabb.fr</a>
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
