{#
   PIRB V1.3 — Page "Mon équipe" : liste des coéquipiers du user connecté.
   Click sur une card → profil PIRB public du coéquipier.
#}
{% extends 'pirb/base.html.twig' %}

{% block title %}Mon équipe — PIRB MABB{% endblock %}

{% block stylesheets %}
    .equipe-hero {
        text-align: center;
        padding: 22px 16px;
    }
    .equipe-hero h1 {
        margin: 0;
        font-size: 1.4rem;
        font-weight: 800;
    }
    .equipe-hero .sub {
        color: var(--pirb-accent-soft);
        font-weight: 600;
        font-size: 0.92rem;
        margin-top: 4px;
    }
    .equipe-hero .counter {
        display: inline-block;
        margin-top: 12px;
        padding: 6px 14px;
        background: rgba(234,88,12,.15);
        border-radius: 999px;
        font-size: 0.78rem;
        color: var(--pirb-accent);
        font-weight: 700;
    }

    .coequipier-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
        gap: 10px;
    }
    .coequipier-card {
        background: var(--pirb-card);
        border: 1px solid var(--pirb-border);
        border-radius: 12px;
        padding: 14px 10px;
        text-align: center;
        text-decoration: none;
        color: var(--pirb-text);
        transition: all .15s;
        position: relative;
        display: block;
    }
    .coequipier-card:hover {
        border-color: var(--pirb-accent);
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(0,0,0,.3);
    }
    .coequipier-avatar {
        width: 70px; height: 70px;
        border-radius: 50%;
        margin: 0 auto 8px;
        overflow: hidden;
        background: linear-gradient(135deg, var(--pirb-blue), #1e40af);
        display: flex; align-items: center; justify-content: center;
        font-weight: 800; color: #fff; font-size: 1.4rem;
        border: 2px solid var(--pirb-border);
    }
    .coequipier-avatar img { width: 100%; height: 100%; object-fit: cover; }
    .coequipier-nom {
        font-weight: 700;
        font-size: 0.88rem;
        line-height: 1.2;
        margin-bottom: 3px;
    }
    .coequipier-num {
        position: absolute;
        top: 8px; right: 8px;
        background: var(--pirb-accent);
        color: #fff;
        font-size: 0.72rem;
        font-weight: 800;
        padding: 2px 8px;
        border-radius: 999px;
    }
    .coequipier-poste {
        color: var(--pirb-text-muted);
        font-size: 0.7rem;
        margin-top: 2px;
    }
    .coequipier-card .badge-prive {
        position: absolute;
        bottom: 6px; right: 6px;
        font-size: 0.7rem;
        color: var(--pirb-text-muted);
    }

    /* V1.6.1 — Autres équipes (multi-affectation) */
    .autres-equipes-title {
        font-size: 0.78rem;
        font-weight: 700;
        color: var(--pirb-text-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin: 0 0 10px 0;
    }
    .autre-equipe-card {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 14px;
        background: var(--pirb-card);
        border: 1px solid var(--pirb-border);
        border-radius: 10px;
        margin-bottom: 8px;
    }
    .autre-equipe-card .icon {
        font-size: 1.4rem;
        opacity: 0.7;
    }
    .autre-equipe-card .info { flex: 1; }
    .autre-equipe-card .nom {
        font-weight: 700;
        font-size: 0.92rem;
        margin-bottom: 2px;
    }
    .autre-equipe-card .meta {
        color: var(--pirb-text-muted);
        font-size: 0.72rem;
    }
    .autre-equipe-badge {
        padding: 3px 10px;
        border-radius: 999px;
        font-size: 0.66rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        white-space: nowrap;
    }
    .autre-equipe-badge.orange { background: rgba(234,88,12,.18); color: #fdba74; border: 1px solid rgba(234,88,12,.4); }
    .autre-equipe-badge.purple { background: rgba(168,85,247,.18); color: #d8b4fe; border: 1px solid rgba(168,85,247,.4); }
    .autre-equipe-badge.green  { background: rgba(22,163,74,.18); color: #86efac; border: 1px solid rgba(22,163,74,.4); }
    .autre-equipe-badge.gray   { background: rgba(148,163,184,.18); color: #cbd5e1; border: 1px solid rgba(148,163,184,.4); }
{% endblock %}

{% block body %}

    {# Cas : pas de joueur lié OU pas d'équipe #}
    {% if message %}
        <div class="pirb-card" style="text-align:center; padding:32px 20px;">
            <div style="font-size:3rem; margin-bottom:8px;">👥</div>
            <h2 style="margin:0 0 8px 0; font-size:1.1rem;">Mon équipe
                {% if saison is defined and saison %}
                    <span style="font-size:.7rem; color:var(--pirb-text-muted); font-weight:600;">· {{ saison }}</span>
                {% endif %}
            </h2>
            <p style="color:var(--pirb-text-muted); font-size:0.9rem; margin:0;">{{ message }}</p>
            {# [V2.4c] Nouvelle saison pas encore composée → revoir la saison passée #}
            {% if saison_precedente is defined and saison_precedente %}
                <a href="{{ path('pirb_equipe', {saison: saison_precedente}) }}"
                   style="display:inline-block; margin-top:14px; padding:8px 16px; border-radius:20px;
                          background:rgba(59,130,246,.12); border:1px solid rgba(59,130,246,.3);
                          color:#3b82f6; font-weight:700; font-size:.8rem; text-decoration:none;">
                    👀 Revoir mon équipe {{ saison_precedente }}
                </a>
            {% endif %}
        </div>

    {% else %}

        {# === Hero équipe principale === #}
        <div class="pirb-card equipe-hero">
            <div style="font-size:2.5rem; margin-bottom:4px;">🏀</div>
            {# [V2.4c] Badge saison + retour saison courante si on consulte une archive #}
            {% if saison is defined and saison %}
                <div style="font-size:.68rem; color:var(--pirb-text-muted); font-weight:700; margin-bottom:4px;">
                    Saison {{ saison }}
                    {% if app.request.query.get('saison') %}
                        · <a href="{{ path('pirb_equipe') }}" style="color:#3b82f6; text-decoration:none;">retour à aujourd'hui</a>
                    {% endif %}
                </div>
            {% endif %}
            {% if autres_equipes is defined and autres_equipes|length > 0 %}
                <div style="font-size:0.7rem; color:var(--pirb-text-muted); text-transform:uppercase; letter-spacing:.06em; margin-bottom:6px;">
                    Mon équipe de référence
                </div>
            {% endif %}
            <h1>{{ equipe.nom }}</h1>
            {% if equipe.categorie %}
                <div class="sub">{{ equipe.categorie }}</div>
            {% endif %}
            <div class="counter">
                {{ coequipiers|length + 1 }} joueur{{ coequipiers|length > 0 ? 's' : '' }} dans l'équipe
            </div>
        </div>

        {# === V1.6.1 — Autres équipes où je joue (doublage / surclassement / réserve) === #}
        {% if autres_equipes is defined and autres_equipes|length > 0 %}
            <div class="pirb-card">
                <div class="autres-equipes-title">
                    <i class="bi bi-plus-circle"></i> Je joue également dans
                </div>
                {% for ae in autres_equipes %}
                    <div class="autre-equipe-card">
                        <div class="icon">🏀</div>
                        <div class="info">
                            <div class="nom">{{ ae.equipe.nom }}</div>
                            <div class="meta">
                                {{ ae.equipe.categorie }}{% if ae.equipe.niveau %} · {{ ae.equipe.niveau }}{% endif %}
                                {% if ae.notes %}<br><em style="opacity:.85;">{{ ae.notes }}</em>{% endif %}
                            </div>
                        </div>
                        <span class="autre-equipe-badge {{ ae.type_couleur }}">{{ ae.type_label }}</span>
                    </div>
                {% endfor %}
            </div>
        {% endif %}

        {# === Liste coéquipiers === #}
        {% if coequipiers is empty %}
            <div class="pirb-card" style="text-align:center; padding:24px;">
                <p style="margin:0; color:var(--pirb-text-muted); font-size:0.9rem;">
                    Tu es le seul joueur actif dans cette équipe pour l'instant.
                </p>
            </div>
        {% else %}
            <div class="pirb-card">
                <div class="pirb-card-title">Mes coéquipiers</div>
                <div class="coequipier-grid">
                    {% for j in coequipiers %}
                        <a href="{{ path('pirb_joueuse_public', {id: j.id}) }}" class="coequipier-card">
                            {% if j.numeroMaillot is not null %}
                                <span class="coequipier-num">#{{ j.numeroMaillot }}</span>
                            {% endif %}

                            <div class="coequipier-avatar">
                                {% if j.photoPath %}
                                    <img src="{{ asset(j.photoPath) }}" alt="{{ j.prenom }}">
                                {% else %}
                                    {{ j.prenom|first|upper }}{{ j.nom|first|upper }}
                                {% endif %}
                            </div>

                            <div class="coequipier-nom">{{ j.prenom }} {{ j.nom }}</div>

                            {% if j.poste %}
                                <div class="coequipier-poste">{{ j.poste }}</div>
                            {% endif %}

                            {% if not j.profilPublic %}
                                <span class="badge-prive" title="Profil privé — visible parce que tu es dans la même équipe">
                                    <i class="bi bi-lock-fill"></i>
                                </span>
                            {% endif %}
                        </a>
                    {% endfor %}
                </div>
            </div>
        {% endif %}

    {% endif %}

{% endblock %}
