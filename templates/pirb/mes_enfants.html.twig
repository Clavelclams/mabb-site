{% extends 'pirb/base.html.twig' %}
{% block title %}Mes enfants — Venaball{% endblock %}

{% block body %}

    {% for label, messages in app.flashes(['success', 'error', 'info']) %}
        {% for message in messages %}
            <div class="pirb-card" style="padding:12px 14px; margin-bottom:12px;
                border-left:4px solid {{ label == 'success' ? '#16a34a' : (label == 'error' ? '#ef4444' : '#3b82f6') }};
                font-size:0.88rem;">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    <div class="pirb-card" style="text-align:center; padding:24px 16px;">
        <div style="font-size:3rem; margin-bottom:4px;">👨‍👩‍👧</div>
        <h1 style="margin:0; font-size:1.2rem; font-weight:800;">Mes enfants</h1>
        <p style="color:var(--pirb-text-muted); font-size:0.85rem; margin-top:6px;">
            {{ enfants_actifs|length }} enfant{{ enfants_actifs|length > 1 ? 's' : '' }} lié{{ enfants_actifs|length > 1 ? 's' : '' }}
            {% if demandes_pending|length > 0 %}
                · <span style="color:var(--pirb-accent);">{{ demandes_pending|length }} en attente</span>
            {% endif %}
        </p>
        <a href="{{ path('pirb_mes_enfants_ajouter') }}" class="pirb-btn pirb-btn-primary" style="margin-top:14px;">
            <i class="bi bi-plus-lg"></i> Ajouter un enfant
        </a>
    </div>

    {# Demandes en attente #}
    {% if demandes_pending is not empty %}
        <div class="pirb-card">
            <div class="pirb-card-title">En attente de validation</div>
            {% for pj in demandes_pending %}
                <div style="display:flex; align-items:center; gap:12px; padding:10px 0; border-bottom:1px solid var(--pirb-border);">
                    <div style="width:42px; height:42px; flex-shrink:0; border-radius:50%; background:rgba(234,88,12,.15); color:var(--pirb-accent); display:flex; align-items:center; justify-content:center; font-weight:800;">
                        {{ pj.joueur.prenom|first|upper }}{{ pj.joueur.nom|first|upper }}
                    </div>
                    <div style="flex:1;">
                        <div style="font-weight:700;">{{ pj.joueur.prenom }} {{ pj.joueur.nom }}</div>
                        <div style="color:var(--pirb-text-muted); font-size:0.78rem;">
                            Demande envoyée le {{ pj.createdAt|date('d/m/Y') }}
                        </div>
                    </div>
                    <span class="pirb-badge pirb-badge-warning">En attente</span>
                </div>
            {% endfor %}
        </div>
    {% endif %}

    {# Enfants actifs #}
    {% if enfants_actifs is empty and demandes_pending is empty %}
        <div class="pirb-card" style="text-align:center; padding:24px;">
            <p style="margin:0; color:var(--pirb-text-muted); font-size:0.9rem;">
                Aucun enfant lié pour l'instant.<br>
                Click sur <strong>"Ajouter un enfant"</strong> pour demander un lien vers une joueuse du club.
            </p>
        </div>
    {% else %}
        {% for pj in enfants_actifs %}
            {% set j = pj.joueur %}
            <a href="{{ path('pirb_joueuse_public', {id: j.id}) }}" style="text-decoration:none; color:inherit;">
                <div class="pirb-card" style="display:flex; align-items:center; gap:14px;">
                    <div style="width:56px; height:56px; flex-shrink:0; border-radius:50%; overflow:hidden;
                                background:linear-gradient(135deg, var(--pirb-blue), #1e40af);
                                display:flex; align-items:center; justify-content:center;
                                font-weight:800; color:#fff; font-size:1.1rem;">
                        {% if j.photoPath %}
                            <img src="{{ asset(j.photoPath) }}" alt="{{ j.prenom }}" style="width:100%; height:100%; object-fit:cover;">
                        {% else %}
                            {{ j.prenom|first|upper }}{{ j.nom|first|upper }}
                        {% endif %}
                    </div>
                    <div style="flex:1;">
                        <div style="font-weight:700; font-size:1rem;">{{ j.prenom }} {{ j.nom }}</div>
                        {% if j.equipe %}
                            <div style="color:var(--pirb-accent-soft); font-size:0.85rem;">{{ j.equipe.nom }}</div>
                        {% endif %}
                        {% if j.numeroMaillot %}
                            <div style="color:var(--pirb-text-muted); font-size:0.78rem;">N° {{ j.numeroMaillot }}</div>
                        {% endif %}
                    </div>
                    <i class="bi bi-chevron-right" style="color:var(--pirb-text-muted);"></i>
                </div>
            </a>
        {% endfor %}
    {% endif %}

{% endblock %}
