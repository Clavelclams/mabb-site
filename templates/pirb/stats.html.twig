{% extends 'pirb/base.html.twig' %}
{% block title %}Mes stats{% endblock %}

{% block body %}

    {# ====================================================================
       [15/06/2026] Refonte page Stats Venaball en 4 sections selon vision Clavel.
       ====================================================================
       Section 1 : Stats saison (agrégées)
       Section 2 : Stats shoot entraînement (placeholder, B34 à venir)
       Section 3 : Stats par match (liste + drawer interactif au click)
       Section 4 : Position de tir / Shot chart (par match + globalité saison)
    #}

    {# ====================================================================
       BANDEAU EN-TÊTE
       ==================================================================== #}
    <div class="pirb-card" style="text-align:center; padding:22px 16px;">
        <div style="font-size:2.4rem; margin-bottom:6px;">📊</div>
        <h1 style="margin:0; font-size:1.2rem; font-weight:800;">Mes stats</h1>
        <p style="color:var(--pirb-text-muted); font-size:0.85rem; margin-top:6px;">
            {{ stats.nb_matchs }} match{{ stats.nb_matchs > 1 ? 's' : '' }} joué{{ stats.nb_matchs > 1 ? 's' : '' }}
            {% if stats.titulaire > 0 %} · {{ stats.titulaire }} titularisation{{ stats.titulaire > 1 ? 's' : '' }}{% endif %}
            {# [V2.4d] Saison réellement filtrée (suit le sélecteur du header) #}
            · saison {{ saison ?? saison_active() }}
        </p>
    </div>

    {# ====================================================================
       SECTION 1 — STATS SAISON (agrégées)
       ==================================================================== #}
    <div class="pirb-section-header" style="margin:18px 4px 8px; display:flex; align-items:center; gap:8px;">
        <span style="font-size:1.1rem;">📊</span>
        <h2 style="margin:0; font-size:0.95rem; font-weight:800; letter-spacing:.5px; text-transform:uppercase; color:var(--pirb-text-muted);">Stats saison</h2>
    </div>

    {% if stats.nb_matchs == 0 %}
        <div class="pirb-card" style="text-align:center; padding:24px;">
            <p style="margin:0; color:var(--pirb-text-muted); font-size:0.9rem;">
                Pas de données pour la saison {{ saison ?? saison_active() }}.<br>
                <small>Change de saison avec le sélecteur en haut de page pour
                revoir tes stats passées. Les stats de cette saison apparaîtront
                après tes premiers matchs.</small>
            </p>
        </div>
    {% else %}
        {# Moyennes par match #}
        <div class="pirb-card">
            <div class="pirb-card-title">Moyennes par match</div>
            <div style="display:grid; grid-template-columns:repeat(2, 1fr); gap:10px;">
                <div style="background:rgba(234,88,12,0.1); padding:12px; border-radius:10px; text-align:center;">
                    <div style="font-size:1.6rem; font-weight:800; color:var(--pirb-accent);">{{ stats.moyennes.points }}</div>
                    <div style="font-size:0.74rem; color:var(--pirb-text-muted); text-transform:uppercase; letter-spacing:.5px;">Points</div>
                </div>
                <div style="background:rgba(29,78,216,0.1); padding:12px; border-radius:10px; text-align:center;">
                    <div style="font-size:1.6rem; font-weight:800; color:#60a5fa;">{{ stats.moyennes.rebonds }}</div>
                    <div style="font-size:0.74rem; color:var(--pirb-text-muted); text-transform:uppercase; letter-spacing:.5px;">Rebonds</div>
                </div>
                <div style="background:rgba(16,185,129,0.1); padding:12px; border-radius:10px; text-align:center;">
                    <div style="font-size:1.6rem; font-weight:800; color:#34d399;">{{ stats.moyennes.passes }}</div>
                    <div style="font-size:0.74rem; color:var(--pirb-text-muted); text-transform:uppercase; letter-spacing:.5px;">Passes déc.</div>
                </div>
                <div style="background:rgba(245,158,11,0.1); padding:12px; border-radius:10px; text-align:center;">
                    <div style="font-size:1.6rem; font-weight:800; color:#fbbf24;">{{ stats.moyennes.eval }}</div>
                    <div style="font-size:0.74rem; color:var(--pirb-text-muted); text-transform:uppercase; letter-spacing:.5px;">Éval</div>
                </div>
            </div>
        </div>

        {# Tirs réussis (sans % car FFBB ne fournit pas les tirs tentés) #}
        <div class="pirb-card">
            <div class="pirb-card-title">🏀 Tirs réussis (cumul saison)</div>
            <div style="display:grid; grid-template-columns:repeat(3, 1fr); gap:8px;">
                <div style="text-align:center; padding:10px; background:rgba(234,88,12,.08); border-radius:10px;">
                    <div style="font-size:1.6rem; font-weight:800; color:var(--pirb-accent);">{{ stats.reussites.tirs2 ?? 0 }}</div>
                    <div style="font-size:0.72rem; color:var(--pirb-text-muted); text-transform:uppercase;">2pts</div>
                </div>
                <div style="text-align:center; padding:10px; background:rgba(59,130,246,.08); border-radius:10px;">
                    <div style="font-size:1.6rem; font-weight:800; color:#60a5fa;">{{ stats.reussites.tirs3 ?? 0 }}</div>
                    <div style="font-size:0.72rem; color:var(--pirb-text-muted); text-transform:uppercase;">3pts</div>
                </div>
                <div style="text-align:center; padding:10px; background:rgba(245,158,11,.08); border-radius:10px;">
                    <div style="font-size:1.6rem; font-weight:800; color:#fbbf24;">{{ stats.reussites.lf ?? 0 }}</div>
                    <div style="font-size:0.72rem; color:var(--pirb-text-muted); text-transform:uppercase;">Lancers</div>
                </div>
            </div>
            {% if (stats.tentatives.tirs2 ?? 0) > 0 or (stats.tentatives.tirs3 ?? 0) > 0 or (stats.tentatives.lf ?? 0) > 0 %}
                <div style="margin-top:12px; padding-top:10px; border-top:1px solid var(--pirb-border);">
                    <div style="font-size:0.78rem; color:var(--pirb-text-muted); margin-bottom:6px;">⚡ % shooting (depuis Stats Live MABB)</div>
                    <div style="display:flex; gap:14px; justify-content:space-around; font-size:0.82rem; flex-wrap:wrap;">
                        {% if (stats.tentatives.tirs2 ?? 0) > 0 %}
                            <div>2pts <strong>{{ stats.pourcentages.tirs2 }}%</strong> <small>({{ stats.reussites.tirs2 }}/{{ stats.tentatives.tirs2 }})</small></div>
                        {% endif %}
                        {% if (stats.tentatives.tirs3 ?? 0) > 0 %}
                            <div>3pts <strong>{{ stats.pourcentages.tirs3 }}%</strong> <small>({{ stats.reussites.tirs3 }}/{{ stats.tentatives.tirs3 }})</small></div>
                        {% endif %}
                        {% if (stats.tentatives.lf ?? 0) > 0 %}
                            <div>LF <strong>{{ stats.pourcentages.lf }}%</strong> <small>({{ stats.reussites.lf }}/{{ stats.tentatives.lf }})</small></div>
                        {% endif %}
                    </div>
                </div>
            {% else %}
                <p style="margin:10px 0 0; font-size:0.7rem; color:var(--pirb-text-muted); font-style:italic;">
                    ℹ️ % shooting non disponible (la FFBB ne fournit pas les tirs tentés). Apparaîtra si Stats Live MABB est utilisé.
                </p>
            {% endif %}
        </div>

        {# Graph progression Chart.js (10 derniers matchs) #}
        {% if stats.graph_progression|length > 1 %}
            <div class="pirb-card">
                <div class="pirb-card-title">📈 Progression — 10 derniers matchs</div>
                <canvas id="progChart" height="220"></canvas>
                <script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
                <script>
                    const ctx = document.getElementById('progChart');
                    new Chart(ctx, {
                        type: 'line',
                        data: {
                            labels: {{ stats.graph_progression|map(p => p.date)|json_encode|raw }},
                            datasets: [
                                {
                                    label: 'Points',
                                    data: {{ stats.graph_progression|map(p => p.points)|json_encode|raw }},
                                    borderColor: '#ea580c', backgroundColor: 'rgba(234,88,12,.15)',
                                    tension: 0.3, fill: true,
                                },
                                {
                                    label: 'Éval',
                                    data: {{ stats.graph_progression|map(p => p.eval)|json_encode|raw }},
                                    borderColor: '#fbbf24', borderDash: [4,4], tension: 0.3, fill: false,
                                }
                            ]
                        },
                        options: {
                            plugins: { legend: { labels: { color: '#cbd5e1' }}},
                            scales: {
                                x: { ticks: { color: '#94a3b8' }, grid: { color: 'rgba(255,255,255,.06)' }},
                                y: { ticks: { color: '#94a3b8' }, grid: { color: 'rgba(255,255,255,.06)' }, beginAtZero: true }
                            }
                        }
                    });
                </script>
            </div>
        {% endif %}
    {% endif %}

    {# ====================================================================
       SECTION 2 — STATS SHOOT ENTRAÎNEMENT (PLACEHOLDER, B34)
       ==================================================================== #}
    <div class="pirb-section-header" style="margin:24px 4px 8px; display:flex; align-items:center; gap:8px;">
        <span style="font-size:1.1rem;">🎯</span>
        <h2 style="margin:0; font-size:0.95rem; font-weight:800; letter-spacing:.5px; text-transform:uppercase; color:var(--pirb-text-muted);">Stats shoot entraînement</h2>
    </div>
    <div class="pirb-card" style="border-left:4px solid var(--pirb-accent); opacity:.92;">
        <div style="display:flex; gap:14px; align-items:start;">
            <div style="font-size:2rem; flex-shrink:0;">🎯</div>
            <div style="flex:1;">
                <div style="font-weight:800; font-size:1rem; margin-bottom:4px;">À venir — Séances de shoot perso</div>
                <p style="margin:0 0 10px; font-size:0.85rem; color:var(--pirb-text-muted); line-height:1.5;">
                    Saisis tes séances de shoot d'entraînement directement sur un terrain interactif.
                    Tu pointes où tu tires, ça compte tes réussites par zone. Tu travailles tes points faibles
                    et tu visualises tes progrès.
                </p>
                <div style="display:flex; gap:8px; flex-wrap:wrap; font-size:0.74rem; margin-top:8px;">
                    <span style="padding:3px 8px; background:rgba(16,185,129,.15); color:#10b981; border-radius:5px; font-weight:600;">✓ Vérifié par coach</span>
                    <span style="padding:3px 8px; background:rgba(245,158,11,.15); color:#f59e0b; border-radius:5px; font-weight:600;">⏳ En attente validation</span>
                </div>
                <p style="margin:10px 0 0; font-size:0.74rem; color:var(--pirb-text-muted); font-style:italic;">
                    Inspiré de Ball.ia — version IA vidéo en V4/V5.
                </p>
            </div>
        </div>
    </div>

    {# ====================================================================
       SECTION 3 — STATS PAR MATCH (liste + drawer interactif)
       ==================================================================== #}
    <div class="pirb-section-header" style="margin:24px 4px 8px; display:flex; align-items:center; gap:8px;">
        <span style="font-size:1.1rem;">🏀</span>
        <h2 style="margin:0; font-size:0.95rem; font-weight:800; letter-spacing:.5px; text-transform:uppercase; color:var(--pirb-text-muted);">Stats par match</h2>
    </div>

    {% if matchs_equipe is defined and matchs_equipe|length > 0 %}
        <div class="pirb-card">
            <p style="font-size:0.78rem; color:var(--pirb-text-muted); margin:0 0 10px;">
                Tape sur un match pour voir un aperçu et accéder au détail.
            </p>
            {% for r in matchs_equipe %}
                {% set isHome = r.domicile ?? true %}
                {% set scoreEq = r.scoreEquipe ?? null %}
                {% set scoreAdv = r.scoreAdverse ?? null %}
                {% set hasScore = scoreEq is not null and scoreAdv is not null %}
                {% set isVictoire = hasScore and scoreEq > scoreAdv %}

                <div class="pirb-match-row" data-match-id="{{ r.id }}" style="border-bottom:1px solid var(--pirb-border); padding:0;">
                    <div class="pirb-match-toggle" style="display:flex; align-items:center; gap:10px; padding:12px 0; cursor:pointer;">
                        <div style="flex:1; min-width:0;">
                            <div style="font-weight:600; font-size:0.9rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                                vs {{ r.adversaire }}
                            </div>
                            <div style="display:flex; gap:6px; align-items:center; margin-top:3px; flex-wrap:wrap;">
                                <span style="font-size:0.7rem; color:var(--pirb-text-muted);">
                                    {{ r.date|date('d/m/Y') }} · {{ isHome ? '🏠' : '🚗' }}
                                </span>
                                {% if r.isFfbbStatsValidated() %}
                                    <span style="font-size:0.66rem; padding:2px 5px; background:rgba(16,185,129,.15); color:#10b981; border-radius:4px; font-weight:600;">✓ FFBB</span>
                                {% endif %}
                                {% if r.resumePath %}
                                    <span style="font-size:0.66rem; padding:2px 5px; background:rgba(59,130,246,.15); color:#3b82f6; border-radius:4px; font-weight:600;">📄 PDF</span>
                                {% endif %}
                            </div>
                        </div>
                        {% if hasScore %}
                            <div style="text-align:right; font-weight:800; font-size:0.95rem;
                                       color:{{ isVictoire ? '#10b981' : '#ef4444' }};">
                                {{ scoreEq }}-{{ scoreAdv }}
                            </div>
                        {% endif %}
                        <i class="bi bi-chevron-down toggle-icon" style="color:var(--pirb-text-muted); font-size:0.85rem; transition:transform .25s ease;"></i>
                    </div>
                    {# Drawer caché par défaut, s'affiche au click #}
                    <div class="pirb-match-drawer" style="display:none; padding:0 0 12px;">
                        <div style="background:rgba(255,255,255,.04); padding:12px; border-radius:8px; margin-top:4px;">
                            <p style="margin:0 0 10px; font-size:0.8rem; color:var(--pirb-text);">
                                <strong>{{ r.equipe.nom ?? 'MABB' }}</strong>
                                {% if isHome %}reçoit{% else %}à l'extérieur chez{% endif %}
                                <strong>{{ r.adversaire }}</strong>
                                {% if hasScore %}
                                    · résultat <strong style="color:{{ isVictoire ? '#10b981' : '#ef4444' }};">{{ isVictoire ? 'victoire' : 'défaite' }} {{ scoreEq }}-{{ scoreAdv }}</strong>
                                {% endif %}
                            </p>
                            <div style="display:flex; gap:8px; flex-wrap:wrap;">
                                <a href="{{ path('pirb_stats_match', {id: r.id}) }}"
                                   class="pirb-btn-primary" style="display:inline-block; padding:7px 14px; background:var(--pirb-accent); color:white; border-radius:6px; text-decoration:none; font-size:0.82rem; font-weight:600;">
                                    📊 Consulter mes stats détaillées
                                </a>
                                {% if r.resumePath %}
                                    <a href="{{ path('pirb_stats_match_pdf', {id: r.id, type: 'resume'}) }}"
                                       style="display:inline-block; padding:7px 14px; background:rgba(255,255,255,.08); color:var(--pirb-text); border-radius:6px; text-decoration:none; font-size:0.82rem;">
                                        📄 PDF FFBB officiel
                                    </a>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>

        <script>
            (function(){
                document.querySelectorAll('.pirb-match-row').forEach(function(row) {
                    var toggle = row.querySelector('.pirb-match-toggle');
                    var drawer = row.querySelector('.pirb-match-drawer');
                    var icon = row.querySelector('.toggle-icon');
                    if (!toggle || !drawer) return;
                    toggle.addEventListener('click', function(e) {
                        // Ne pas déclencher si on a cliqué sur un lien
                        if (e.target.tagName === 'A') return;
                        var isOpen = drawer.style.display !== 'none';
                        drawer.style.display = isOpen ? 'none' : 'block';
                        if (icon) {
                            icon.style.transform = isOpen ? 'rotate(0deg)' : 'rotate(180deg)';
                        }
                    });
                });
            })();
        </script>
    {% else %}
        <div class="pirb-card" style="text-align:center; padding:20px;">
            <p style="margin:0; color:var(--pirb-text-muted); font-size:0.85rem;">
                Pas de match enregistré pour la saison {{ saison ?? saison_active() }}.<br>
                <small>Tu peux changer de saison avec le sélecteur en haut de page.</small>
            </p>
        </div>
    {% endif %}

    {# ====================================================================
       SECTION 4 — POSITION DE TIR / SHOT CHART
       ==================================================================== #}
    <div class="pirb-section-header" style="margin:24px 4px 8px; display:flex; align-items:center; gap:8px;">
        <span style="font-size:1.1rem;">🎯</span>
        <h2 style="margin:0; font-size:0.95rem; font-weight:800; letter-spacing:.5px; text-transform:uppercase; color:var(--pirb-text-muted);">Position de tir</h2>
    </div>
    <a href="{{ path('pirb_stats_shotchart') }}" style="text-decoration:none; color:inherit; display:block;">
        <div class="pirb-card" style="border-left:4px solid #ea580c;">
            <div style="display:flex; gap:14px; align-items:start;">
                <div style="font-size:2rem; flex-shrink:0;">🎯</div>
                <div style="flex:1;">
                    <div style="font-weight:800; font-size:1rem; margin-bottom:4px;">Mon shot chart</div>
                    <p style="margin:0 0 8px; font-size:0.85rem; color:var(--pirb-text-muted); line-height:1.5;">
                        Visualise où tu tires sur le terrain — par match ou en cumul saison.
                        Repère tes zones fortes (à renforcer) et tes zones à travailler.
                    </p>
                    <span style="color:var(--pirb-accent); font-size:0.82rem; font-weight:600;">
                        Voir le shot chart →
                    </span>
                </div>
            </div>
        </div>
    </a>

{% endblock %}
