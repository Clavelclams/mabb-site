{% extends 'pirb/base.html.twig' %}
{% block title %}Ton avis sur la séance{% endblock %}

{% block body %}

    {% for label, messages in app.flashes(['success', 'warning', 'error']) %}
        {% for message in messages %}
            <div class="pirb-card" style="padding:12px 14px; margin-bottom:12px;
                border-left:4px solid {{ label == 'success' ? '#16a34a' : (label == 'error' ? '#ef4444' : '#f59e0b') }};
                font-size:0.88rem;">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    <div class="pirb-card" style="text-align:center; padding:22px;">
        <h1 style="margin:0; font-size:1.2rem; font-weight:800;">Ton avis sur la séance</h1>
        <p style="color:var(--pirb-text-muted); font-size:0.85rem; margin-top:6px;">
            {{ seance.date|date('D d/m à H:i') }}
            {% if seance.equipe %} · {{ seance.equipe.nom }}{% endif %}
        </p>
    </div>

    {% if deja_repondu %}
        <div class="pirb-card" style="text-align:center;">
            <p style="color:var(--pirb-text-muted); font-size:.88rem; line-height:1.6;">
                Tu as déjà donné ton avis sur cette séance.<br>
                Il est parti sans ton nom, donc on ne peut plus te le remontrer.
                C'est la contrepartie de l'anonymat, et c'est normal.
            </p>
            <a href="{{ path('pirb_dashboard') }}" class="pirb-btn pirb-btn-primary" style="margin-top:10px;">
                <i class="bi bi-arrow-left"></i> Retour
            </a>
        </div>
    {% else %}
        <form method="POST" action="{{ path('pirb_feedback_form', {id: seance.id}) }}" class="pirb-card">
            <input type="hidden" name="_token" value="{{ csrf_token('pirb_feedback_' ~ seance.id) }}">

            <div style="text-align:center; margin-bottom:14px;">
                <div style="color:var(--pirb-text-muted); font-size:0.85rem; margin-bottom:8px;">
                    Comment tu l'as trouvée ?
                </div>
                <div style="display:flex; justify-content:center; gap:4px; font-size:1.8rem;">
                    {% for n in 1..5 %}
                        <label style="cursor:pointer;">
                            <input type="radio" name="note" value="{{ n }}" {% if n == 3 %}checked{% endif %}
                                   style="display:none;" class="pirb-star-radio">
                            <span class="pirb-star" data-n="{{ n }}" style="opacity:0.4; transition:opacity 0.15s;">⭐</span>
                        </label>
                    {% endfor %}
                </div>
                <div style="color:var(--pirb-text-muted); font-size:0.75rem; margin-top:4px;">
                    1, pas terrible · 5, excellente
                </div>
            </div>

            <label style="display:block; color:var(--pirb-text-muted); font-size:0.85rem; margin-bottom:6px;">
                Tu veux ajouter un mot ? (facultatif)
            </label>
            <textarea name="commentaire" rows="3" maxlength="1000"
                      placeholder="Ce qui t'a plu, ce qui t'a moins plu, ce qu'on pourrait changer."
                      style="width:100%; padding:10px;
                             background:rgba(255,255,255,0.05);
                             border:1px solid var(--pirb-border);
                             border-radius:8px; color:var(--pirb-text);
                             font-family:inherit; font-size:0.88rem;
                             box-sizing:border-box; margin-bottom:14px;"></textarea>

            {# L'anonymat est le défaut. Cocher, c'est renoncer à l'anonymat, pas l'obtenir. #}
            <div style="padding:12px; background:rgba(255,255,255,0.04); border:1px solid var(--pirb-border); border-radius:8px; margin-bottom:14px;">
                <div style="font-size:0.82rem; color:var(--pirb-text-muted); line-height:1.6; margin-bottom:10px;">
                    Par défaut, <strong style="color:var(--pirb-text);">ton avis part sans ton nom</strong>.
                    Ton nom n'est enregistré nulle part : ni le coach, ni le staff, ni personne
                    ne peut savoir que c'est toi qui l'as écrit.
                </div>
                <label style="display:flex; align-items:center; gap:10px; cursor:pointer; font-size:0.88rem;">
                    <input type="checkbox" name="signer" value="1"
                           style="width:18px; height:18px; cursor:pointer; flex-shrink:0;">
                    <span>
                        Je préfère signer avec mon prénom
                        <div style="color:var(--pirb-text-muted); font-size:0.78rem; margin-top:2px;">
                            Le coach saura que ça vient de toi.
                        </div>
                    </span>
                </label>
            </div>

            <div style="font-size:0.76rem; color:var(--pirb-text-muted); margin-bottom:14px; line-height:1.5;">
                Le coach ne voit les avis d'une séance qu'à partir de {{ seuil }} réponses.
                En dessous, il saurait de qui ils viennent.
            </div>

            <button type="submit" class="pirb-btn pirb-btn-primary" style="width:100%;">
                <i class="bi bi-send"></i> Envoyer
            </button>

            <a href="{{ path('pirb_dashboard') }}" style="display:block; text-align:center;
                margin-top:10px; color:var(--pirb-text-muted); text-decoration:none; font-size:0.82rem;">
                Annuler
            </a>
        </form>

        <script>
            // Les étoiles ne sont qu'un habillage : la vraie valeur est dans le radio.
            const stars = document.querySelectorAll('.pirb-star');
            const updateStars = (selectedN) => stars.forEach(s => {
                s.style.opacity = parseInt(s.dataset.n, 10) <= selectedN ? '1' : '0.3';
            });
            stars.forEach(s => {
                s.addEventListener('click', () => {
                    const n = parseInt(s.dataset.n, 10);
                    s.parentElement.querySelector('input').checked = true;
                    updateStars(n);
                });
            });
            updateStars(3);
        </script>
    {% endif %}

{% endblock %}
