{# templates/pirb/dashboard.html.twig — STUB Sprint 1 #}
{# Ce template sera remplacé en Phase 4 par le vrai dashboard joueur #}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mon Espace Joueur — MABB PIRB</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body { background: #0b1f3a; font-family: 'Segoe UI', sans-serif; min-height: 100vh; }
        .topbar {
            background: rgba(255,140,0,.1);
            border-bottom: 1px solid rgba(255,140,0,.3);
            color: #fff;
            padding: 14px 28px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .topbar .brand { font-weight: 800; font-size: 1.1rem; color: #ff8c00; }
        .card-stub {
            background: rgba(255,255,255,.05);
            border: 1px solid rgba(255,255,255,.1);
            border-radius: 12px;
            padding: 40px;
            text-align: center;
            margin-top: 50px;
        }
        .card-stub .icon { font-size: 3rem; color: #ff8c00; margin-bottom: 16px; }
        .card-stub h2 { font-weight: 800; color: #fff; }
        .card-stub p { color: #94a3b8; font-size: .95rem; }
        .badge-sprint {
            display: inline-block;
            background: rgba(255,140,0,.2);
            color: #ff8c00;
            border-radius: 20px;
            font-size: .75rem;
            font-weight: 700;
            padding: 4px 14px;
            margin-bottom: 12px;
        }
    </style>
</head>
<body>
    <div class="topbar">
        <span class="brand">🏀 PIRB — Mon Espace</span>
        <a href="{{ path('pirb_logout') }}" class="btn btn-sm btn-outline-warning rounded-pill">
            <i class="bi bi-box-arrow-right me-1"></i>Déconnexion
        </a>
    </div>

    <div class="container">
        <div class="card-stub">
            <div class="icon"><i class="bi bi-graph-up-arrow"></i></div>
            <div class="badge-sprint">Sprint 4 — en cours de développement</div>
            <h2>Espace Joueur</h2>
            <p>
                Salut {{ app.user.prenom ?? 'Joueur' }} 👋<br>
                Tes stats, ton shot chart et ta timeline arrivent bientôt.<br>
                <strong style="color:#ff8c00;">Compte actif</strong> — connexion réussie ✅
            </p>
        </div>
    </div>
</body>
</html>
