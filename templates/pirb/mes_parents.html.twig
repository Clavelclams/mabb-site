{% extends 'pirb/base.html.twig' %}
{% block title %}Mes parents — Venaball{% endblock %}

{% block body %}

    {% for label, messages in app.flashes(['success', 'warning', 'error', 'info']) %}
        {% for message in messages %}
            <div class="pirb-card" style="padding:12px 14px; margin-bottom:12px;
                border-left:4px solid {{ label == 'success' ? '#16a34a' : (label == 'error' ? '#ef4444' : (label == 'info' ? '#3b82f6' : '#f59e0b')) }};
                font-size:0.88rem;">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    <div class="pirb-card" style="text-align:center; padding:22px 16px;">
        <div style="font-size:2.6rem; margin-bottom:4px;">👨‍👩‍👧</div>
        <h1 style="margin:0; font-size:1.2rem; font-weight:800;">Mes parents</h1>
        <p style="color:var(--pirb-text-muted); font-size:0.82rem; margin-top:6px;">
            Déclare tes parents/référents pour que le staff sache qui contacter en cas d'urgence.
        </p>
        <a href="{{ path('pirb_mes_parents_declarer') }}" class="pirb-btn pirb-btn-primary" style="margin-top:14px;">
            <i class="bi bi-plus-lg"></i> Déclarer un parent
        </a>
    </div>

    {# En attente de validation staff #}
    {% if pending|length > 0 %}
        <div class="pirb-card">
            <div class="pirb-card-title">⏳ En attente de validation</div>
            {% for pj in pending %}
                <div style="display:flex; align-items:center; gap:12px; padding:10px 0; border-bottom:1px solid var(--pirb-border);">
                    <div style="width:42px; height:42px; border-radius:50%; background:rgba(234,88,12,.15); color:var(--pirb-accent); display:flex; align-items:center; justify-content:center; font-weight:800;">
                        {{ pj.parentUser.prenom|first|upper }}{{ pj.parentUser.nom|first|upper }}
                    </div>
                    <div style="flex:1;">
                        <div style="font-weight:700;">{{ pj.parentUser.prenom }} {{ pj.parentUser.nom }}</div>
                        <div style="color:var(--pirb-text-muted); font-size:0.78rem;">{{ pj.parentUser.email }}</div>
                    </div>
                    <span class="pirb-badge pirb-badge-warning">En attente</span>
                </div>
            {% endfor %}
        </div>
    {% endif %}

    {# Actifs #}
    {% if actifs|length > 0 %}
        <div class="pirb-card">
            <div class="pirb-card-title">✅ Validés</div>
            {% for pj in actifs %}
                <div style="display:flex; align-items:center; gap:12px; padding:10px 0; border-bottom:1px solid var(--pirb-border);">
                    <div style="width:42px; height:42px; border-radius:50%; background:linear-gradient(135deg, #10b981, #059669); color:#fff; display:flex; align-items:center; justify-content:center; font-weight:800;">
                        {{ pj.parentUser.prenom|first|upper }}{{ pj.parentUser.nom|first|upper }}
                    </div>
                    <div style="flex:1;">
                        <div style="font-weight:700;">{{ pj.parentUser.prenom }} {{ pj.parentUser.nom }}</div>
                        <div style="color:var(--pirb-text-muted); font-size:0.78rem;">{{ pj.parentUser.email }}</div>
                    </div>
                    {% if joueur.dateNaissance and joueur.dateNaissance.diff(date()).y >= 18 %}
                        <form method="POST" action="{{ path('pirb_mes_parents_revoquer', {pjId: pj.id}) }}"
                              onsubmit="return confirm('Révoquer ce lien parent ? Tu pourras le re-déclarer plus tard.');">
                            <input type="hidden" name="_token" value="{{ csrf_token('revoquer_pj_' ~ pj.id) }}">
                            <button type="submit" style="background:transparent; border:none; color:var(--pirb-text-muted); cursor:pointer; font-size:1rem;" title="Révoquer">
                                <i class="bi bi-x-circle"></i>
                            </button>
                        </form>
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    {% endif %}

    {% if actifs|length == 0 and pending|length == 0 %}
        <div class="pirb-card" style="text-align:center; padding:24px;">
            <p style="margin:0; color:var(--pirb-text-muted); font-size:0.9rem;">
                Aucun parent/référent déclaré pour l'instant.<br>
                Clique sur <strong>"Déclarer un parent"</strong> pour ajouter ton père, ta mère ou ton tuteur.
            </p>
        </div>
    {% endif %}

{% endblock %}
