{% extends 'pirb/base.html.twig' %}
{% block title %}Match vs {{ rencontre.adversaire|default('?') }} — PIRB{% endblock %}

{% block body %}

    <div class="pirb-card">
        <div style="display:flex; justify-content:space-between; align-items:center;">
            <a href="{{ path('pirb_stats') }}" style="color:var(--pirb-text-muted); text-decoration:none; font-size:0.85rem;">
                <i class="bi bi-arrow-left"></i> Retour stats
            </a>
            <div style="color:var(--pirb-text-muted); font-size:0.78rem;">
                {{ rencontre.date|date('d/m/Y') }}
            </div>
        </div>
        <h1 style="margin:8px 0 0; font-size:1.15rem; font-weight:800;">
            {% if rencontre.equipe %}{{ rencontre.equipe.nom }}{% endif %}
            {% if rencontre.adversaire %} vs {{ rencontre.adversaire }}{% endif %}
        </h1>
    </div>

    {% if not eval %}
        <div class="pirb-card" style="text-align:center; padding:24px;">
            <p style="margin:0; color:var(--pirb-text-muted);">
                Pas d'évaluation enregistrée pour toi sur ce match.<br>
                <small>Le coach n'a pas encore saisi tes stats individuelles.</small>
            </p>
        </div>
    {% else %}
        {# === Bloc points + éval === #}
        <div class="pirb-card">
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
                <div style="text-align:center; padding:16px; background:rgba(234,88,12,.12); border-radius:12px;">
                    <div style="font-size:2.2rem; font-weight:800; color:var(--pirb-accent);">{{ eval.points }}</div>
                    <div style="font-size:0.78rem; color:var(--pirb-text-muted); text-transform:uppercase;">Points</div>
                </div>
                <div style="text-align:center; padding:16px; background:rgba(245,158,11,.12); border-radius:12px;">
                    <div style="font-size:2.2rem; font-weight:800; color:#fbbf24;">{{ eval.eval }}</div>
                    <div style="font-size:0.78rem; color:var(--pirb-text-muted); text-transform:uppercase;">Éval</div>
                </div>
            </div>
        </div>

        {# === 📋 Stats officielles FFBB (toujours dispo après import OCR Vision)
           IMPORTANT : la FFBB ne fournit QUE les tirs réussis, pas les tentés.
           On affiche "X réussis" et PAS de % shooting (qui serait factuellement faux).
           Les tentés viendront via Stats Live (capture tirs manqués en direct) ou
           saisie manuelle coach via /rencontres/{id}/evals.
        #}
        <div class="pirb-card" style="border-left:4px solid #3b82f6;">
            <div class="pirb-card-title">📋 Stats officielles FFBB</div>
            <p style="font-size:0.74rem; color:var(--pirb-text-muted); margin:0 0 10px;">
                Issues du PDF resume FFBB officiel — capturées par OCR + validées par le coach.
            </p>
            <table style="width:100%; font-size:0.88rem;">
                <tr><td style="padding:4px 0; color:var(--pirb-text-muted);">⏱️ Minutes jouées</td><td style="text-align:right; font-weight:600;">{{ eval.minutesJouees }}'</td></tr>
                <tr><td style="padding:4px 0; color:var(--pirb-text-muted);">🏀 Points</td><td style="text-align:right; font-weight:600;">{{ eval.points }}</td></tr>
                <tr><td style="padding:4px 0; color:var(--pirb-text-muted);">2pts réussis</td><td style="text-align:right; font-weight:600;">{{ eval.tirs2ptReussis }}</td></tr>
                <tr><td style="padding:4px 0; color:var(--pirb-text-muted);">3pts réussis</td><td style="text-align:right; font-weight:600;">{{ eval.tirs3ptReussis }}</td></tr>
                <tr><td style="padding:4px 0; color:var(--pirb-text-muted);">LF réussis</td><td style="text-align:right; font-weight:600;">{{ eval.lancersReussis }}</td></tr>
                <tr><td style="padding:4px 0; color:var(--pirb-text-muted);">Fautes commises</td><td style="text-align:right; font-weight:600;">{{ eval.fautesCommises }}</td></tr>
            </table>
            <p style="font-size:0.7rem; color:var(--pirb-text-muted); margin:10px 0 0; font-style:italic;">
                ℹ️ Les tirs tentés (% shooting) ne sont pas fournis par la FFBB. Disponibles uniquement via Stats Live MABB.
            </p>
        </div>

        {# === ⚡ Stats avancées MABB (Stats Live seulement) ===
           Affiché si AU MOINS UNE des stats avancées est > 0 (donc provient de Stats Live).
           Sinon : message "non capturées" pour ce match (la FFBB ne les donne pas). #}
        {% set has