{% extends 'pirb/base.html.twig' %}
{% block title %}Match vs {{ rencontre.adversaire|default('?') }}{% endblock %}

{% block body %}

    <div class="pirb-card">
        <div style="display:flex; justify-content:space-between; align-items:center;">
            <a href="{{ path('pirb_stats') }}" style="color:var(--pirb-text-muted); text-decoration:none; font-size:0.85rem;">
                <i class="bi bi-arrow-left"></i> Retour stats
            </a>
            <div style="color:var(--pirb-text-muted); font-size:0.78rem;">
                {{ rencontre.date|date('d/m/Y') }}
            </div>
        </div>
        <h1 style="margin:8px 0 0; font-size:1.15rem; font-weight:800;">
            {% if rencontre.equipe %}{{ rencontre.equipe.nom }}{% endif %}
            {% if rencontre.adversaire %} vs {{ rencontre.adversaire }}{% endif %}
        </h1>
    </div>

    {% if not eval %}
        <div class="pirb-card" style="text-align:center; padding:24px;">
            <p style="margin:0; color:var(--pirb-text-muted);">
                Pas d'évaluation enregistrée pour toi sur ce match.<br>
                <small>Le coach n'a pas encore saisi tes stats individuelles.</small>
            </p>
        </div>
    {% else %}
        {# === Bloc points + éval === #}
        <div class="pirb-card">
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
                <div style="text-align:center; padding:16px; background:rgba(234,88,12,.12); border-radius:12px;">
                    <div style="font-size:2.2rem; font-weight:800; color:var(--pirb-accent);">{{ eval.points }}</div>
                    <div style="font-size:0.78rem; color:var(--pirb-text-muted); text-transform:uppercase;">Points</div>
                </div>
                <div style="text-align:center; padding:16px; background:rgba(245,158,11,.12); border-radius:12px;">
                    <div style="font-size:2.2rem; font-weight:800; color:#fbbf24;">{{ eval.eval }}</div>
                    <div style="font-size:0.78rem; color:var(--pirb-text-muted); text-transform:uppercase;">Éval</div>
                </div>
            </div>
        </div>

        {# === Détail === #}
        <div class="pirb-card">
            <div class="pirb-card-title">Détail</div>
            <table style="width:100%; font-size:0.88rem;">
                <tr><td style="padding:4px 0; color:var(--pirb-text-muted);">Tirs 2pts</td><td style="text-align:right; font-weight:600;">{{ eval.tirs2ptReussis }}/{{ eval.tirs2ptTentes }}</td></tr>
                <tr><td style="padding:4px 0; color:var(--pirb-text-muted);">Tirs 3pts</td><td style="text-align:right; font-weight:600;">{{ eval.tirs3ptReussis }}/{{ eval.tirs3ptTentes }}</td></tr>
                <tr><td style="padding:4px 0; color:var(--pirb-text-muted);">Lancers francs</td><td style="text-align:right; font-weight:600;">{{ eval.lancersReussis }}/{{ eval.lancersTentes }}</td></tr>
                <tr><td style="padding:4px 0; color:var(--pirb-text-muted);">Rebonds (O/D)</td><td style="text-align:right; font-weight:600;">{{ eval.rebondsOffensifs }}/{{ eval.rebondsDefensifs }}</td></tr>
                <tr><td style="padding:4px 0; color:var(--pirb-text-muted);">Passes décisives</td><td style="text-align:right; font-weight:600;">{{ eval.passesDecisives }}</td></tr>
                <tr><td style="padding:4px 0; color:var(--pirb-text-muted);">Interceptions</td><td style="text-align:right; font-weight:600;">{{ eval.interceptions }}</td></tr>
                <tr><td style="padding:4px 0; color:var(--pirb-text-muted);">Contres</td><td style="text-align:right; font-weight:600;">{{ eval.contres }}</td></tr>
                <tr><td style="padding:4px 0; color:var(--pirb-text-muted);">Fautes</td><td style="text-align:right; font-weight:600;">{{ eval.fautesCommises }}</td></tr>
                <tr><td style="padding:4px 0; color:var(--pirb-text-muted);">Pertes de balle</td><td style="text-align:right; font-weight:600;">{{ eval.pertesBalle }}</td></tr>
                <tr><td style="padding:4px 0; color:var(--pirb-text-muted);">Minutes jouées</td><td style="text-align:right; font-weight:600;">{{ eval.minutesJouees }}'</td></tr>
            </table>
        </div>

        {% if eval.notesCoach %}
            <div class="pirb-card" style="background:rgba(34,197,94,.06); border-left:4px solid #22c55e;">
                <div class="pirb-card-title">Note du coach</div>
                <p style="margin:0; font-size:0.88rem; line-height:1.5;">{{ eval.notesCoach }}</p>
            </div>
        {% endif %}
    {% endif %}

    {# [B22d 12/06/2026] Stats Live (depuis SessionStatsLive promue officielle) #}
    {% if session_officielle and stats_live_moi %}
        <div class="pirb-card" style="border-left:4px solid #16a34a;">
            <div class="pirb-card-title">⚡ Stats Live (tracking en direct)</div>
            <p style="font-size:0.78rem; color:var(--pirb-text-muted); margin:0 0 12px;">
                Saisies par {{ session_officielle.createdBy ? session_officielle.createdBy.prenom : 'le banc' }}
                pendant le match.
                {% if session_officielle.promotedAt %}
                    Validée officielle le {{ session_officielle.promotedAt|date('d/m/Y') }}.
                {% endif %}
            </p>

            {# Mes stats Live #}
            <div style="background:rgba(22,163,74,.08); padding:14px; border-radius:10px; margin-bottom:14px;">
                <div style="font-size:0.85rem; font-weight:700; margin-bottom:8px;">⚡ Mes stats Live</div>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px; font-size:0.82rem;">
                    <div>⏱️ Min : <strong>{{ stats_live_moi.minutes ?? 0 }}</strong></div>
                    <div>🏀 Pts : <strong>{{ stats_live_moi.points ?? 0 }}</strong></div>
                    <div>2pts : <strong>{{ stats_live_moi.tirs_2pts_reussis ?? 0 }}/{{ stats_live_moi.tirs_2pts_tentes ?? 0 }}</strong></div>
                    <div>3pts : <strong>{{ stats_live_moi.tirs_3pts_reussis ?? 0 }}/{{ stats_live_moi.tirs_3pts_tentes ?? 0 }}</strong></div>
                    <div>LF : <strong>{{ stats_live_moi.lancers_reussis ?? 0 }}/{{ stats_live_moi.lancers_tentes ?? 0 }}</strong></div>
                    <div>Reb O/D : <strong>{{ stats_live_moi.rebonds_offensifs ?? 0 }}/{{ stats_live_moi.rebonds_defensifs ?? 0 }}</strong></div>
                    <div>Pass D : <strong>{{ stats_live_moi.passes_decisives ?? 0 }}</strong></div>
                    <div>Inter : <strong>{{ stats_live_moi.interceptions ?? 0 }}</strong></div>
                    <div>Contres : <strong>{{ stats_live_moi.contres ?? 0 }}</strong></div>
                    <div>Fautes : <strong>{{ stats_live_moi.fautes_commises ?? 0 }}</strong></div>
                    <div>Pertes : <strong>{{ stats_live_moi.pertes_balle ?? 0 }}</strong></div>
                    <div>⭐ Éval : <strong>{{ stats_live_moi.eval ?? 0 }}</strong></div>
                </div>
            </div>

            {# Toggle équipe #}
            {% if stats_live_equipe|length > 0 %}
                <details>
                    <summary style="cursor:pointer; color:#16a34a; font-size:0.85rem; font-weight:700;">
                        📊 Voir Stats Live de l'équipe ({{ stats_live_equipe|length }} joueuses)
                    </summary>
                    <div style="margin-top:10px; max-height:300px; overflow-y:auto;">
                        <table style="width:100%; font-size:0.74rem;">
                            <thead style="background:rgba(255,255,255,0.05);">
                                <tr>
                                    <th style="text-align:left; padding:6px;">Joueuse</th>
                                    <th style="text-align:center;">Pts</th>
                                    <th style="text-align:center;">Reb</th>
                                    <th style="text-align:center;">PD</th>
                                    <th style="text-align:center;">Éval</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for entry in stats_live_equipe %}
                                    {% set s = entry.stats %}
                                    <tr style="border-bottom:1px solid var(--pirb-border);
                                              {% if entry.joueur.id == joueur.id %}background:rgba(22,163,74,.15); font-weight:700;{% endif %}">
                                        <td style="padding:6px;">{{ entry.joueur.prenom }} {{ entry.joueur.nom }}</td>
                                        <td style="text-align:center;">{{ s.points ?? 0 }}</td>
                                        <td style="text-align:center;">{{ (s.rebonds_offensifs ?? 0) + (s.rebonds_defensifs ?? 0) }}</td>
                                        <td style="text-align:center;">{{ s.passes_decisives ?? 0 }}</td>
                                        <td style="text-align:center;">{{ s.eval ?? 0 }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </details>
            {% endif %}
        </div>
    {% endif %}

    {# [B22b 12/06/2026] Stats FFBB officielles (extraites du PDF resume) #}
    {% if stats_ffbb_moi or stats_ffbb_equipe|length > 0 %}
        <div class="pirb-card">
            <div class="pirb-card-title">🏆 Stats FFBB officielles</div>
            <p style="font-size:0.78rem; color:var(--pirb-text-muted); margin:0 0 12px;">
                Extraites du PDF résumé FFBB. Différent des stats coach (saisie manuelle).
            </p>

            {% if stats_ffbb_moi %}
                {# Mes stats à moi #}
                <div style="background:rgba(234,88,12,.08); padding:14px; border-radius:10px; margin-bottom:14px;">
                    <div style="font-size:0.85rem; font-weight:700; margin-bottom:8px;">🎯 Mes stats officielles</div>
                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px; font-size:0.82rem;">
                        <div>⏱️ Min : <strong>{{ stats_ffbb_moi.minutesJouees }}</strong></div>
                        <div>🏀 Pts : <strong>{{ stats_ffbb_moi.points }}</strong></div>
                        <div>2pts : <strong>{{ stats_ffbb_moi.tirs2ptReussis }}/{{ stats_ffbb_moi.tirs2ptTentes }}</strong></div>
                        <div>3pts : <strong>{{ stats_ffbb_moi.tirs3ptReussis }}/{{ stats_ffbb_moi.tirs3ptTentes }}</strong></div>
                        <div>LF : <strong>{{ stats_ffbb_moi.lancersReussis }}/{{ stats_ffbb_moi.lancersTentes }}</strong></div>
                        <div>Reb O/D : <strong>{{ stats_ffbb_moi.rebondsOff }}/{{ stats_ffbb_moi.rebondsDef }}</strong></div>
                        <div>Pass D : <strong>{{ stats_ffbb_moi.passesD }}</strong></div>
                        <div>Inter : <strong>{{ stats_ffbb_moi.interceptions }}</strong></div>
                        <div>Contres : <strong>{{ stats_ffbb_moi.contres }}</strong></div>
                        <div>Fautes : <strong>{{ stats_ffbb_moi.fautesCommises }}</strong></div>
                        <div>Pertes : <strong>{{ stats_ffbb_moi.pertesBalle }}</strong></div>
                        <div>⭐ Éval : <strong>{{ stats_ffbb_moi.evalFfbb }}</strong></div>
                    </div>
                </div>
            {% else %}
                <div style="background:rgba(255,255,255,0.04); padding:12px; border-radius:8px; margin-bottom:14px; font-size:0.78rem; color:var(--pirb-text-muted);">
                    Tes stats individuelles ne sont pas encore disponibles dans le PDF résumé.
                </div>
            {% endif %}

            {# Stats équipe (résumé compact des autres) #}
            {% if stats_ffbb_equipe|length > 0 %}
                <details>
                    <summary style="cursor:pointer; color:var(--pirb-accent); font-size:0.85rem; font-weight:700;">
                        📊 Voir les stats de toute l'équipe ({{ stats_ffbb_equipe|length }} joueuses)
                    </summary>
                    <div style="margin-top:10px; max-height:300px; overflow-y:auto;">
                        <table style="width:100%; font-size:0.74rem;">
                            <thead style="background:rgba(255,255,255,0.05);">
                                <tr>
                                    <th style="text-align:left; padding:6px;">Joueuse</th>
                                    <th style="text-align:center;">Min</th>
                                    <th style="text-align:center;">Pts</th>
                                    <th style="text-align:center;">Reb</th>
                                    <th style="text-align:center;">Éval</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for s in stats_ffbb_equipe %}
                                    <tr style="border-bottom:1px solid var(--pirb-border);
                                              {% if s.joueur and s.joueur.id == joueur.id %}background:rgba(234,88,12,.1); font-weight:700;{% endif %}">
                                        <td style="padding:6px;">{{ s.nomComplet }} {% if s.estStarter %}⭐{% endif %}</td>
                                        <td style="text-align:center;">{{ s.minutesJouees }}</td>
                                        <td style="text-align:center;">{{ s.points }}</td>
                                        <td style="text-align:center;">{{ s.rebondsOff + s.rebondsDef }}</td>
                                        <td style="text-align:center;">{{ s.evalFfbb }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </details>
            {% endif %}

            {# Compteur tirs FFBB de la joueuse #}
            {% if tirs_ffbb_match|length > 0 %}
                <div style="margin-top:12px; padding:10px; background:rgba(29,78,216,0.08); border-radius:8px;">
                    <strong>🎯 {{ tirs_ffbb_match|length }} tir(s) réussi(s)</strong> selon le PDF positions FFBB
                    <a href="{{ path('pirb_stats_shotchart') }}" style="color:var(--pirb-accent); margin-left:8px; font-size:0.82rem;">
                        Voir le shot chart saison →
                    </a>
                </div>
            {% endif %}
        </div>
    {% endif %}

    {# [B22b-bis 14/06/2026] Badge validation Stats FFBB par le coach.
       Quand le coach a explicitement déclaré que sa saisie EvaluationMatch
       correspond au PDF officiel FFBB, on affiche un badge officiel à la joueuse.
       Cf. B22b initial (parser PDF) abandonné car PDFs FFBB scannés. #}
    {% if rencontre.isFfbbStatsValidated() %}
        <div class="pirb-card" style="border-left:4px solid #10b981;">
            <div style="display:flex; align-items:center; gap:10px; margin-bottom:8px;">
                <div style="font-size:1.8rem;">✓</div>
                <div>
                    <div style="font-weight:800; font-size:1rem; color:#10b981;">Stats officielles FFBB validées</div>
                    <div style="font-size:0.78rem; color:var(--pirb-text-muted);">
                        Vérifiées par <strong>{{ rencontre.ffbbStatsValidatedBy.prenom }}</strong>
                        le {{ rencontre.ffbbStatsValidatedAt|date('d/m/Y') }}
                    </div>
                </div>
            </div>
            {% if rencontre.ffbbStatsValidationNote %}
                <div style="margin-top:8px; padding:8px 10px; background:rgba(16,185,129,.08); border-radius:6px; font-size:0.8rem; font-style:italic;">
                    « {{ rencontre.ffbbStatsValidationNote }} »
                </div>
            {% endif %}
            {% if rencontre.resumePath %}
                {# [B22a-sec] Le lien PDF est conditionnel : approuvé = téléchargement direct, sinon demande #}
                {% set d = demandes_acces_pdf['resume'] ?? null %}
                {% if d and d.statut == 'approved' %}
                    <a href="{{ path('pirb_stats_match_pdf', {id: rencontre.id, type: 'resume'}) }}"
                       style="display:inline-block; margin-top:10px; color:var(--pirb-accent); font-size:0.85rem; text-decoration:none; font-weight:600;">
                        <i class="bi bi-file-earmark-pdf"></i> Télécharger le PDF officiel →
                    </a>
                {% elseif d and d.statut == 'pending' %}
                    <span style="display:inline-block; margin-top:10px; font-size:0.82rem; color:#f59e0b; font-weight:500;">
                        <i class="bi bi-clock-history"></i> Accès en attente de validation coach
                    </span>
                {% else %}
                    <form method="post" action="{{ path('pirb_stats_match_pdf_request', {id: rencontre.id, type: 'resume'}) }}" style="display:inline; margin-top:10px;">
                        <input type="hidden" name="_token" value="{{ csrf_token('pdf_request_' ~ rencontre.id ~ '_resume') }}">
                        <button type="submit" style="background:none; border:none; cursor:pointer; color:var(--pirb-accent); font-size:0.85rem; font-weight:600; padding:0;">
                            <i class="bi bi-file-earmark-pdf"></i>
                            {% if d and d.statut == 'rejected' %}Re-demander l'accès au PDF{% else %}Demander l'accès au PDF{% endif %} →
                        </button>
                    </form>
                {% endif %}
            {% endif %}
        </div>
    {% endif %}

    {# [B22a 12/06/2026] Documents FFBB officiels — avec workflow demande/validation #}
    {# [B22a-sec 25/06/2026] Accès contrôlé par le coach via DemandeAccesPdf #}
    {% set has_pdfs = rencontre.feuilleMatchPath or rencontre.resumePath or rencontre.positionsTirsPath %}
    {% if has_pdfs %}
        <div class="pirb-card">
            <div class="pirb-card-title">📄 Documents FFBB officiels</div>
            <p style="font-size:0.78rem; color:var(--pirb-text-muted); margin:0 0 4px;">
                Ces documents officiels sont soumis à validation de ton coach.
            </p>
            <p style="font-size:0.75rem; color:var(--pirb-text-muted); margin:0 0 12px; font-style:italic;">
                Tes stats individuelles restent toujours visibles ci-dessus.
            </p>
            <div style="display:flex; flex-direction:column; gap:8px;">

                {# ─ Macro inline pour chaque bouton PDF ─ #}
                {% for typeKey, typeLabel, typePath, typeColor, typeIcon in [
                    ['feuille',   'Feuille de match',    rencontre.feuilleMatchPath,    '#ef4444', 'bi-file-earmark-pdf'],
                    ['resume',    'Résumé stats',         rencontre.resumePath,          '#3b82f6', 'bi-file-earmark-bar-graph'],
                    ['positions', 'Positions des tirs',   rencontre.positionsTirsPath,   '#ea580c', 'bi-bullseye']
                ] %}
                    {% if typePath %}
                        {% set demande = demandes_acces_pdf[typeKey] ?? null %}

                        {% if demande and demande.statut == 'approved' %}
                            {# ✅ Approuvé → téléchargement direct #}
                            <a href="{{ path('pirb_stats_match_pdf', {id: rencontre.id, type: typeKey}) }}"
                               class="pirb-btn"
                               style="display:flex; align-items:center; gap:10px; background:rgba(16,185,129,.08); border:1px solid rgba(16,185,129,.25); justify-content:flex-start;">
                                <i class="bi {{ typeIcon }}" style="color:{{ typeColor }}; font-size:1.2rem;"></i>
                                <span style="flex:1;">{{ typeLabel }}</span>
                                <span style="font-size:0.75rem; color:#10b981; font-weight:600;">✓ Accès accordé</span>
                                <i class="bi bi-download" style="color:#10b981;"></i>
                            </a>

                        {% elseif demande and demande.statut == 'pending' %}
                            {# ⏳ En attente #}
                            <div style="display:flex; align-items:center; gap:10px; padding:10px 14px; background:rgba(245,158,11,.06); border:1px solid rgba(245,158,11,.2); border-radius:8px;">
                                <i class="bi {{ typeIcon }}" style="color:{{ typeColor }}; font-size:1.2rem; opacity:0.4;"></i>
                                <span style="flex:1; color:var(--pirb-text-muted); font-size:0.9rem;">{{ typeLabel }}</span>
                                <span style="font-size:0.75rem; color:#f59e0b; font-weight:500;">
                                    <i class="bi bi-clock-history"></i> En attente de ton coach
                                </span>
                            </div>

                        {% elseif demande and demande.statut == 'rejected' %}
                            {# ✗ Refusé → possibilité de re-demander #}
                            <form method="post"
                                  action="{{ path('pirb_stats_match_pdf_request', {id: rencontre.id, type: typeKey}) }}"
                                  style="display:block;">
                                <input type="hidden" name="_token" value="{{ csrf_token('pdf_request_' ~ rencontre.id ~ '_' ~ typeKey) }}">
                                <button type="submit"
                                        style="width:100%; display:flex; align-items:center; gap:10px; padding:10px 14px;
                                               background:rgba(239,68,68,.06); border:1px solid rgba(239,68,68,.2);
                                               border-radius:8px; cursor:pointer; text-align:left;">
                                    <i class="bi {{ typeIcon }}" style="color:{{ typeColor }}; font-size:1.2rem; opacity:0.4;"></i>
                                    <span style="flex:1; color:var(--pirb-text-muted); font-size:0.9rem;">{{ typeLabel }}</span>
                                    <span style="font-size:0.75rem; color:#ef4444; font-weight:500;">
                                        ✗ Refusé — Re-demander ?
                                    </span>
                                </button>
                            </form>

                        {% else %}
                            {# Pas de demande → bouton "Demander l'accès" #}
                            <form method="post"
                                  action="{{ path('pirb_stats_match_pdf_request', {id: rencontre.id, type: typeKey}) }}"
                                  style="display:block;">
                                <input type="hidden" name="_token" value="{{ csrf_token('pdf_request_' ~ rencontre.id ~ '_' ~ typeKey) }}">
                                <button type="submit"
                                        style="width:100%; display:flex; align-items:center; gap:10px; padding:10px 14px;
                                               background:rgba(255,255,255,.04); border:1px solid var(--pirb-border);
                                               border-radius:8px; cursor:pointer; text-align:left;">
                                    <i class="bi {{ typeIcon }}" style="color:{{ typeColor }}; font-size:1.2rem;"></i>
                                    <span style="flex:1; color:var(--pirb-text); font-size:0.9rem;">{{ typeLabel }}</span>
                                    <span style="font-size:0.75rem; color:var(--pirb-accent); font-weight:500;">
                                        <i class="bi bi-lock"></i> Demander l'accès
                                    </span>
                                </button>
                            </form>
                        {% endif %}

                    {% endif %}
                {% endfor %}

            </div>
        </div>
    {% endif %}

{% endblock %}
