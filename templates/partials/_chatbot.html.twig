/* ═══════════════════════════════════════════════════════════════
   MOTEUR DE RECHERCHE
   Scoring : chaque mot de la query qui matche un keyword = +2
             correspondance partielle = +1
   Retourne les 3 meilleurs résultats (score > 0)
═══════════════════════════════════════════════════════════════ */

function normalize(s) {
    return s.toLowerCase()
        .normalize('NFD').replace(/[̀-ͯ]/g, '') // retire accents
        .replace(/[^\w\s]/g, ' ');
}

function scoreEntry(entry, queryWords) {
    let score = 0;
    const kws = entry.keywords.map(normalize);
    for (const qw of queryWords) {
        for (const kw of kws) {
            if (kw === qw) { score += 2; break; }
            if (kw.includes(qw) || qw.includes(kw)) { score += 1; }
        }
    }
    return score;
}

function search(query) {
    const words = normalize(query).split(/\s+/).filter(w => w.length > 1);
    if (!words.length) return [];
    return KB
        .map(e => ({ ...e, score: scoreEntry(e, words) }))
        .filter(e => e.score > 0)
        .sort((a, b) => b.score - a.score)
        .slice(0, 3);
}

/* ═══════════════════════════════════════════════════════════════
   RENDU HTML
═══════════════════════════════════════════════════════════════ */

function renderResult(entry) {
    const stepsHtml = entry.steps && entry.steps.length
        ? '<ol style="margin:6px 0 8px 16px; padding:0; font-size:.77rem; color:inherit; opacity:.8;">' +
          entry.steps.map(s => `<li style="margin-bottom:3px;">${s}</li>`).join('') +
          '</ol>'
        : '';
    const linksHtml = entry.links && entry.links.length
        ? '<div class="chat-result-links">' +
          entry.links.map(l => `<a class="chat-result-link" href="${l.url}">→ ${l.label}</a>`).join('') +
          '</div>'
        : '';
    return `<div class="chat-result-card">
        <div class="chat-result-title">${entry.title}</div>
        <div class="chat-result-text">${entry.text}${stepsHtml}</div>
        ${linksHtml}
    </div>`;
}

function renderNoResult() {
    return `<div class="chat-bubble bot">
        😕 Je n'ai pas trouvé de réponse précise.<br>
        Essaie un autre mot-clé, ou contacte directement ton coach / le staff du club.
    </div>`;
}

/* ═══════════════════════════════════════════════════════════════
   INTERACTIONS UI
═══════════════════════════════════════════════════════════════ */

const panel   = document.getElementById('mabb-chat-panel');
const btn     = document.getElementById('mabb-chat-btn');
const icon    = document.getElementById('chatBtnIcon');
const input   = document.getElementById('chatInput');
const msgs    = document.getElementById('chatMessages');
const quick   = document.getElementById('chatQuickBtns');

function togglePanel() {
    const isOpen = panel.classList.toggle('open');
    icon.className = isOpen ? 'bi bi-x-lg' : 'bi bi-chat-dots-fill';
    if (isOpen) { input.focus(); }
}

document.getElementById('chatCloseBtn').addEventListener('click', () => {
    panel.classList.remove('open');
    icon.className = 'bi bi-chat-dots-fill';
});
btn.addEventListener('click', togglePanel);

function appendMessage(html, role) {
    const el = document.createElement('div');
    if (role === 'user') {
        el.className = 'chat-bubble user';
        el.textContent = html;
    } else {
        el.innerHTML = html;
    }
    msgs.appendChild(el);
    msgs.scrollTop = msgs.scrollHeight;
}

window.chatSearch = function(overrideQuery) {
    const query = (overrideQuery || input.value || '').trim();
    if (!query) return;

    // Cache les suggestions rapides dès la 1ère vraie question
    if (quick) quick.style.display = 'none';

    appendMessage(query, 'user');
    input.value = '';

    const results = search(query);
    if (!results.length) {
        appendMessage(renderNoResult(), 'bot');
    } else {
        if (results.length > 1) {
            appendMessage(`<div class="chat-bubble bot">J'ai trouvé <strong>${results.length} rubriques</strong> qui peuvent aider :</div>`, 'bot');
        }
        for (const r of results) {
            appendMessage(renderResult(r), 'bot');
        }
    }
};

// Close on outside click
document.addEventListener('click', e => {
    if (!panel.contains(e.target) && e.target !== btn && !btn.contains(e.target)) {
        panel.classList.remove('open');
        icon.className = 'bi bi-chat-dots-fill';
    }
});

})();
</script>
