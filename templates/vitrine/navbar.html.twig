{# templates/vitrine/navbar.html.twig #}
{# MODIFS vs original :
   1. navbar-light bg-light → navbar-dark navbar-mabb fixed-top (fond bleu)
   2. Ajout bandeau  après le brand
   3. Ajout <li> Membres (après Club) et Formation (après Actualités)
   4. "Espace numérique" disabled → "Numérique" actif
   5. {% if app.user %} déjà en place — conservé tel quel
#}
	<nav class="navbar navbar-expand-xxl navbar-dark navbar-mabb fixed-top"> <div class="container-fluid">
		<a class="navbar-brand" href="/">MABB</a>

		{# Bandeau site en construction — visible sur desktop entre logo et nav #}
		<a href="/clavel" class="nav-build-badge d-none d-xxl-inline-flex align-items-center gap-1 text-decoration-none ms-2" style="background:rgba(255,140,0,.15);border:1px solid rgba(255,140,0,.4);color:#ffb347;border-radius:20px;padding:4px 12px;font-size:.75rem;font-weight:600">
			🚧 Site en construction
		</a>

		<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
			<span class="navbar-toggler-icon"></span>
		</button>

		<div class="collapse navbar-collapse" id="navbarSupportedContent">
			<ul class="navbar-nav me-auto mb-2 mb-xxl-0">
				<li class="nav-item">
					<a class="nav-link active" aria-current="page" href="/">Accueil</a>
				</li>
				<li class="nav-item dropdown">
					<a class="nav-link dropdown-toggle" href="#" id="navbarClubDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">Le Club</a>
					<ul class="dropdown-menu" aria-labelledby="navbarClubDropdown">
						<li>
							<a class="dropdown-item" href="/club">Le Club</a>
						</li>
						<li>
							<a class="dropdown-item" href="/employes">Nos Employés</a>
						</li>
						<li>
							<a class="dropdown-item" href="/victoires">Nos Victoires</a>
						</li>
					</ul>
				</li>
				{# AJOUT : Membres #}
				<li class="nav-item">
					<a class="nav-link" href="/membres">Membres</a>
				</li>
				<li class="nav-item dropdown">
					<a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
						Actualités
					</a>
					<ul class="dropdown-menu" aria-labelledby="navbarDropdown">
						<li>
							<a class="dropdown-item" href="/news">Actualités</a>
						</li>
						<li>
							<a class="dropdown-item" href="/calendrier">Calendrier</a>
						</li>
						<li>
							<a class="dropdown-item" href="/planning">Planning des entraînements</a>
						</li>
						<li><hr class="dropdown-divider"></li>
						<li>
							<a class="dropdown-item" href="/galerie">Galerie du club</a>
						</li>
					</ul>
				</li>
				{# AJOUT : Formation #}
				<li class="nav-item">
					<a class="nav-link" href="/formation">Formation</a>
				</li>
				<li class="nav-item">
					<a class="nav-link" href="/numerique">Numérique</a>
				</li>
				<li class="nav-item">
					<a class="nav-link" href="/equipes">Équipes</a>
				</li>
				<li class="nav-item">
					<a class="nav-link" href="/equipes/3x3">Équipe 3×3</a>
				</li>
				<li class="nav-item">
					<a class="nav-link" href="/contact">Contact</a>
				</li>
			</ul>

			{# Boutons auth — wrapper responsive pour éviter le débordement mobile en mode connecté.
			   Sur mobile/tablette : stack vertical full-width.
			   Sur desktop (xxl+) : layout inline horizontal comme avant. #}
			<div class="d-flex flex-column flex-xxl-row gap-2 align-items-stretch align-items-xxl-center w-100 w-xxl-auto mt-3 mt-xxl-0">

			{# Espace membre — CDC §6.1. Les 3 apps ayant des sessions séparées par
			   sous-domaine, et le rôle (coach/joueuse) étant défini PAR CLUB (non
			   résolu sur le site public), on propose un menu de choix explicite
			   plutôt qu'une redirection automatique peu fiable. #}
			<div class="dropdown">
				<button class="btn btn-outline-light btn-sm rounded-pill dropdown-toggle w-100"
				        type="button" data-bs-toggle="dropdown" aria-expanded="false">
					<i class="bi bi-grid-3x3-gap-fill me-1"></i>Espace membre
				</button>
				<ul class="dropdown-menu dropdown-menu-end">
					<li>
						<a class="dropdown-item" href="https://manager.mabb.fr">
							<i class="bi bi-clipboard-data me-2"></i>Espace staff <span class="text-muted small">(Manager)</span>
						</a>
					</li>
					<li>
						<a class="dropdown-item" href="https://pirb.mabb.fr">
							<i class="bi bi-person-badge me-2"></i>Espace joueuse <span class="text-muted small">(PIRB)</span>
						</a>
					</li>
					<li><hr class="dropdown-divider"></li>
					{# [V2.4h] Pré-inscription licence — formulaire public (ex-Google Form) #}
					<li>
						<a class="dropdown-item" href="{{ path('vitrine_pre_inscription') }}">
							<i class="bi bi-pencil-square me-2"></i>Pré-inscription licence
						</a>
					</li>
				</ul>
			</div>

			{% if app.user %}
				<a href="/compte/mon-compte" class="btn btn-outline-light btn-sm rounded-pill text-truncate"
				   style="max-width:100%">
					<i class="bi bi-person-circle"></i>
					{{ app.user.prenom }}
				</a>
				<a href="{{ path('vitrine_logout') }}" class="btn btn-sm rounded-pill btn-inscription">
					<i class="bi bi-box-arrow-right"></i>
					Déconnexion
				</a>
			{% else %}
				<a href="/compte/se-connecter" class="btn btn-outline-light btn-sm rounded-pill">
					<i class="bi bi-box-arrow-in-right"></i>
					Connexion
				</a>
				<a href="/compte/s-inscrire" class="btn btn-sm rounded-pill btn-inscription">
					<i class="bi bi-person-plus"></i>
					S'inscrire
				</a>
			{% endif %}
			</div>
		</div>
	</div>
</nav>
