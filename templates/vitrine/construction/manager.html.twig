{% extends 'vitrine/base.html.twig' %}
{% block title %}MABB Manager — Bientôt disponible{% endblock %}
{% block meta_description %}MABB Manager, la plateforme de gestion du club Amiens Métropole Basket Ball — en cours de développement.{% endblock %}

{% block body %}
<div class="page-header">
    <div class="container text-center">
        <h1><i class="bi bi-gear-fill me-2"></i>MABB Manager</h1>
        <p style="color:rgba(255,255,255,.75)">Plateforme de gestion du club</p>
        <nav aria-label="breadcrumb" class="mt-3">
            <ol class="breadcrumb justify-content-center">
                <li class="breadcrumb-item"><a href="{{ path('vitrine_accueil') }}" style="color:#fff">Accueil</a></li>
                <li class="breadcrumb-item"><a href="{{ path('vitrine_numerique') }}" style="color:#fff">Numérique</a></li>
                <li class="breadcrumb-item active" style="color:#fc702a;font-weight:600">MABB Manager</li>
            </ol>
        </nav>
    </div>
</div>

<section class="section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 text-center">
                <div class="card card-mabb p-5">
                    <div class="mx-auto mb-4" style="width:120px;height:120px;border-radius:50%;background:rgba(252,112,42,.15);display:flex;align-items:center;justify-content:center">
                        <i class="bi bi-tools" style="font-size:3rem;color:var(--mabb-orange)"></i>
                    </div>
                    <span class="badge mb-3 mx-auto" style="background:var(--mabb-orange);color:#fff;font-size:.85rem;padding:6px 16px">🚧 Site en construction</span>
                    <h2 class="fw-bold mb-3" style="color:var(--mabb-dark)">MABB Manager arrive bientôt</h2>
                    <p class="text-muted">
                        La plateforme de gestion sportive du club (effectifs, matchs, présences, stats, événements)
                        est en cours de développement. Elle sera accessible sur
                        <strong>manager.mabb.fr</strong> à son ouverture.
                    </p>
                    <p class="text-muted mb-4">
                        En attendant, retrouvez toutes les infos du club sur le site vitrine.
                    </p>
                    <div class="d-flex flex-column flex-sm-row justify-content-center gap-3">
                        <a href="{{ path('vitrine_numerique') }}" class="btn btn-mabb rounded-pill px-4">
                            <i class="bi bi-arrow-left me-1"></i>Retour à l'espace Numérique
                        </a>
                        <a href="{{ path('vitrine_accueil') }}" class="btn btn-outline-secondary rounded-pill px-4">
                            <i class="bi bi-house me-1"></i>Accueil
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
