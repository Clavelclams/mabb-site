{% extends 'vitrine/base.html.twig' %}
{% block title %}Équipe 3x3 — MABB Amiens
{% endblock %}
{% block body %}
	<div class="page-header">
		<div class="container text-center">
			<span class="badge-label mb-3">
				<i class="bi bi-trophy-fill me-1"></i>
				Ligue FFBB homologuée</span>
			<h1>Équipe 3x3 MABB</h1>
			<p style="color:rgba(255,255,255,.75)">
				Nos coachs sur le terrain — format exclusif, 100% MABB
			</p>
			<nav aria-label="breadcrumb" class="mt-3">
				<ol class="breadcrumb justify-content-center">
					<li class="breadcrumb-item">
						<a href="{{ path('vitrine_accueil') }}" style="color:#fff">Accueil</a>
					</li>
					<li class="breadcrumb-item">
						<a href="{{ path('vitrine_equipes') }}" style="color:#fff">Équipes</a>
					</li>
					<li class="breadcrumb-item active" style="color:#ff8c00;font-weight:600">
						<i class="bi bi-trophy-fill me-1"></i>Équipe 3x3
					</li>
				</ol>
			</nav>
		</div>
	</div>

	{# Présentation #}
	<section class="section section-gray">
		<div class="container">
			<div class="row align-items-center g-5">
				<div class="col-lg-6">
					<h2 class="section-title">Un format unique</h2>
					<p class="text-muted fs-5 mb-3">
						Le 3x3 MABB c'est une philosophie :
						                    nos
						<strong>coachs jouent aussi</strong>.
							                    Ils ne se limitent pas à entraîner,
							                    ils pratiquent et compétitionnent
							                    sous les couleurs MABB.
					</p>
					<p class="text-muted mb-4">
						Engagement exclusif : les joueurs de cette équipe
						                    ne représentent
						<strong>aucun autre club</strong>
						en 3x3. MABB uniquement.
					</p>
					<div class="d-flex flex-wrap gap-2">
						<span class="badge px-3 py-2 rounded-pill" style="background:#063a5515;color:#063a55;border:1px solid #063a5530;font-size:.85rem">
							🏀 Ligue MABB officielle FFBB
						</span>
						<span class="badge px-3 py-2 rounded-pill" style="background:#ff8c0015;color:#ff8c00;border:1px solid #ff8c0030;font-size:.85rem">
							🔒 Exclusif MABB
						</span>
					</div>
				</div>
				<div class="col-lg-6">
					<div class="card card-mabb p-4" style="background:linear-gradient(135deg,#063a55,#0b4fa3)">
						<h3 class="text-white fw-bold mb-4">
							<i class="bi bi-people-fill me-2"></i>Les joueurs
						</h3>
						<div
							class="d-flex flex-column gap-3">
							{# Ugo #}
							<div class="d-flex align-items-center gap-3 p-3 rounded-3" style="background:rgba(255,255,255,.08)">
								<div style="width:50px;height:50px;border-radius:50%;background:#ff8c00;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:800;font-size:1.1rem;flex-shrink:0">U</div>
								<div>
									<div class="text-white fw-bold">Ugo</div>
									<div style="color:rgba(255,255,255,.65);font-size:.85rem">
										Coach & joueur 3x3<br>
										<span style="color:#ffb347">BPJEPS Spécialité Sport Co</span>
									</div>
								</div>
							</div>
							{# Clavel #}
							<div class="d-flex align-items-center gap-3 p-3 rounded-3" style="background:rgba(255,255,255,.08)">
								<div style="width:50px;height:50px;border-radius:50%;background:#ff8c00;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:800;font-size:1.1rem;flex-shrink:0">C</div>
								<div>
									<div class="text-white fw-bold">Clavel</div>
									<div style="color:rgba(255,255,255,.65);font-size:.85rem">
										Coach & joueur 3x3<br>
										<span style="color:#ffb347">Responsable numérique MABB</span>
									</div>
								</div>
							</div>
							{# Placeholder #}
							<div class="d-flex align-items-center gap-3 p-3 rounded-3" style="background:rgba(255,255,255,.05);border:1px dashed rgba(255,255,255,.2)">
								<div style="width:50px;height:50px;border-radius:50%;background:rgba(255,255,255,.15);display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,.4);font-weight:800;font-size:1.4rem;flex-shrink:0">?</div>
								<div>
									<div style="color:rgba(255,255,255,.5);font-weight:600">3ème joueur</div>
									<div style="color:rgba(255,255,255,.35);font-size:.85rem">
										En recrutement — à compléter
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	{# Catégories qui pratiquent le 3x3 #}
	<section class="section">
		<div class="container">
			<div class="text-center mb-5">
				<h2 class="section-title" style="color:#fff">3x3 dans les
					<span>catégories</span>
				</h2>
				<p class="section-subtitle" style="color:#fff">Le 3x3 est proposé dans toutes nos catégories compétitives</p>
			</div>
			<div class="row g-4">
				{% for cat in [
                {cat: 'U13', desc: 'Initiation au format 3x3 — tournois départementaux', icon: '🌱'},
                {cat: 'U15', desc: 'Deux équipes engagées — tournois régionaux', icon: '⚡'},
                {cat: 'U18', desc: 'Deux équipes — objectif pré-nationale', icon: '🏆'},
                {cat: 'Senior Féminine', desc: 'Compétition régionale et nationale', icon: '⭐'},
                {cat: 'Team Coachs', desc: 'Nos coachs MABB en compétition — exclusif MABB', icon: '🎯'},
            ] %}
					<div class="col-md-6 col-lg-4">
						<div class="card card-mabb text-center p-4 h-100 d-flex flex-column">
							<div style="font-size:2rem;margin-bottom:8px">{{ cat.icon }}</div>
							<h5 class="fw-bold mb-2" style="color:#063a55">{{ cat.cat }}</h5>
							<p class="text-muted small mb-3">{{ cat.desc }}</p>
							<div class="mt-auto">
								<span style="font-size:.75rem;color:#ff8c00;font-weight:600;letter-spacing:.5px;text-transform:uppercase">⏳ À suivre prochainement</span>
							</div>
						</div>
					</div>
				{% endfor %}
			</div>
		</div>
	</section>

	{# CTA retour équipes #}
	<section class="section section-gray">
		<div class="container text-center">
			<a href="{{ path('vitrine_equipes') }}" class="btn btn-outline-secondary rounded-pill px-4 me-3">
				<i class="bi bi-arrow-left me-1"></i>Toutes les équipes
			</a>
			<a href="{{ path('vitrine_contact') }}" class="btn btn-mabb rounded-pill px-4">
				<i class="bi bi-envelope me-1"></i>Nous rejoindre
			</a>
		</div>
	</section>
{% endblock %}
