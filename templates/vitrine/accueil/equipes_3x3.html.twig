{% extends 'vitrine/base.html.twig' %}
{% block title %}Équipe 3x3 — MABB Amiens
{% endblock %}
{% block body %}
	<div class="page-header">
		<div class="container text-center">
			<span class="badge-label mb-3">
				<i class="bi bi-trophy-fill me-1"></i>
				Ligue FFBB homologuée</span>
			<h1>Équipe 3x3 MABB</h1>
			<p style="color:rgba(255,255,255,.75)">
				Nos coachs sur le terrain — format exclusif, 100% MABB
			</p>
			<nav aria-label="breadcrumb" class="mt-3">
				<ol class="breadcrumb justify-content-center">
					<li class="breadcrumb-item">
						<a href="{{ path('vitrine_accueil') }}" style="color:#fff">Accueil</a>
					</li>
					<li class="breadcrumb-item">
						<a href="{{ path('vitrine_equipes') }}" style="color:#fff">Équipes</a>
					</li>
					<li class="breadcrumb-item active" style="color:#fc702a;font-weight:600">
						<i class="bi bi-trophy-fill me-1"></i>Équipe 3x3
					</li>
					<li class="breadcrumb-item">
						<a href="{{ path('vitrine_victoires') }}" style="color:#fff">Nos Victoires</a>
					</li>
				</ol>
			</nav>
		</div>
	</div>

	{# Présentation #}
	<section class="section section-gray">
		<div class="container">
			<div class="row align-items-center g-5">
				<div class="col-lg-6">
					<h2 class="section-title">Un format unique</h2>
					<p class="text-muted fs-5 mb-3">
						Le 3x3 MABB c'est une philosophie :
																		                    nos
						<strong>coachs jouent aussi</strong>.
																					                    Ils ne se limitent pas à entraîner,
																					                    ils pratiquent et compétitionnent
																					                    sous les couleurs MABB.
					</p>
					<p class="text-muted mb-4">
						Engagement exclusif : les joueurs de cette équipe
																		                    ne représentent
						<strong>aucun autre club</strong>
						en 3x3. MABB uniquement.
					</p>
					<div class="d-flex flex-wrap gap-2">
						{# Badge "fierté locale" PLACÉ EN PREMIER pour mettre l'argument différenciant en avant #}
						<span class="badge px-3 py-2 rounded-pill" style="background:#fc702a20;color:#fc702a;border:1.5px solid #fc702a70;font-size:.9rem;font-weight:800">
							⭐ Seul club de la Somme en 3x3 compétition FFBB
						</span>
						<span class="badge px-3 py-2 rounded-pill" style="background:rgba(14,42,84,.08);color:var(--mabb-dark);border:1px solid rgba(14,42,84,.18);font-size:.85rem">
							🏀 Ligue MABB officielle FFBB
						</span>
						<span class="badge px-3 py-2 rounded-pill" style="background:#fc702a08;color:#fc702a;border:1px solid #fc702a25;font-size:.78rem;opacity:.85">
							🔒 Exclusif MABB
						</span>
					</div>
				</div>
				<div class="col-lg-6">
					<div class="card card-mabb p-4" style="background:var(--mabb-blue)" id="team-3x3-card">
						<div class="d-flex justify-content-between align-items-start mb-3 gap-2">
							<h3 class="text-white fw-bold mb-0">
								<i class="bi bi-people-fill me-2"></i><span id="team-3x3-title">U13 — Équipe A</span>
							</h3>
							<span class="badge align-self-center" style="background:#fc702a;color:#fff;font-size:.75rem;flex-shrink:0">Saison 25/26</span>
						</div>
						<div id="team-3x3-roster" class="d-flex flex-column gap-3"></div>
						<div class="d-flex justify-content-between align-items-center mt-4 pt-3 gap-2" style="border-top:1px solid rgba(255,255,255,.15)">
							<button type="button" id="team-3x3-prev" class="btn btn-sm rounded-pill" style="background:rgba(255,255,255,.1);color:#fff;border:1px solid rgba(255,255,255,.3)">
								<i class="bi bi-arrow-left me-1"></i>Précédente
							</button>
							<span id="team-3x3-position" style="color:rgba(255,255,255,.7);font-size:.85rem;font-weight:600">1 / 9</span>
							<button type="button" id="team-3x3-next" class="btn btn-sm rounded-pill" style="background:#fc702a;color:#fff;border:1px solid #fc702a">
								Suivante<i class="bi bi-arrow-right ms-1"></i>
							</button>
						</div>
					</div>
					<script>
					(function(){
						var teams = [
							{cat:"U13",equipe:"A",joueurs:["Laya","Sorena","Soumeya","Wendy"]},
							{cat:"U13",equipe:"B",joueurs:["Mathilde","Princia","Charlie","Fever"]},
							{cat:"U15",equipe:"A",joueurs:["Emeline","Léa","Manon","Bernice"]},
							{cat:"U15",equipe:"B",joueurs:["Lola","Fatou","Mahawa","Marianne"]},
							{cat:"U18",equipe:"A",joueurs:["Genaba","Oumayma","Cler-Mirice","Chloé"]},
							{cat:"U18",equipe:"B",joueurs:["Anna","Nola","Yana","Djaya"]},
							{cat:"Senior F",equipe:"A",joueurs:["Sounkamba","Rec-Prefie","Jody","Laryssa"]},
							{cat:"Senior H",equipe:"A (Coachs)",joueurs:["Ugo","Leny","Tony","Clavel"]},
							{cat:"Senior H",equipe:"B",joueurs:["Albert","Berstelien","Emeryc","Alexis"]}
						];
						var idx = 0;
						function render(){
							var t = teams[idx];
							document.getElementById("team-3x3-title").textContent = t.cat + " — Équipe " + t.equipe;
							document.getElementById("team-3x3-position").textContent = (idx+1) + " / " + teams.length;
							var roster = t.joueurs.map(function(p){
								var initial = p.charAt(0).toUpperCase();
								return '<div class="d-flex align-items-center gap-3 p-3 rounded-3" style="background:rgba(255,255,255,.08)">' +
									'<div style="width:48px;height:48px;border-radius:50%;background:#fc702a;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:800;font-size:1.05rem;flex-shrink:0">' + initial + '</div>' +
									'<div class="text-white fw-bold">' + p + '</div>' +
									'</div>';
							}).join("");
							document.getElementById("team-3x3-roster").innerHTML = roster;
						}
						document.getElementById("team-3x3-prev").addEventListener("click", function(){ idx = (idx - 1 + teams.length) % teams.length; render(); });
						document.getElementById("team-3x3-next").addEventListener("click", function(){ idx = (idx + 1) % teams.length; render(); });
						render();
					})();
					</script>
				</div>
			</div>
		</div>
	</section>

	{# Catégories qui pratiquent le 3x3 #}
	<section class="section">
		<div class="container">
			<div class="text-center mb-5">
				<h2 class="section-title" style="color:#fff">3x3 dans les
					<span>catégories</span>
				</h2>
				<p class="section-subtitle" style="color:#fff">Le 3x3 est proposé dans toutes nos catégories compétitives</p>
			</div>
			<div class="row g-4">
				{% for cat in [
                {cat: 'U13', desc: 'Initiation au format 3x3 — tournois départementaux', icon: '🌱', resultat: '🏆 Finaliste 3x3 Oignies 2026', resultat_color: '#fc702a'},
                {cat: 'U15', desc: 'Deux équipes engagées — tournois régionaux', icon: '⚡', resultat: '🏆 Finaliste 3x3 Oignies 2026', resultat_color: '#fc702a'},
                {cat: 'U18', desc: 'Deux équipes — objectif pré-nationale', icon: '🏆', resultat: '🥉 Demi-finaliste 3x3 Oignies 2026', resultat_color: '#0062a8'},
                {cat: 'Senior Féminine', desc: 'Compétition régionale et nationale', icon: '⭐', resultat: '🥉 Demi-finaliste 3x3 Oignies 2026', resultat_color: '#0062a8'},
                {cat: 'Senior Masculine', desc: 'Coachs MABB en compétition — exclusif MABB', icon: '🎯', resultat: '🏆 Finaliste 3x3 Oignies 2026', resultat_color: '#fc702a'},
            ] %}
					<div class="col-md-6 col-lg-4">
						<div class="card card-mabb text-center p-4 h-100 d-flex flex-column">
							<div style="font-size:2rem;margin-bottom:8px">{{ cat.icon }}</div>
							<h5 class="fw-bold mb-2" style="color:var(--mabb-dark)">{{ cat.cat }}</h5>
							<p class="text-muted small mb-3">{{ cat.desc }}</p>
							<div class="mt-auto">
								<span style="font-size:.78rem;color:{{ cat.resultat_color }};font-weight:700;letter-spacing:.3px">{{ cat.resultat }}</span>
							</div>
						</div>
					</div>
				{% endfor %}
			</div>
		</div>
	</section>

	{# CTA retour équipes #}
	<section class="section section-gray">
		<div class="container">
			<div class="d-flex flex-column flex-sm-row justify-content-center gap-3">
				<a href="{{ path('vitrine_equipes') }}" class="btn btn-outline-secondary rounded-pill px-4">
					<i class="bi bi-arrow-left me-1"></i>Toutes les équipes
				</a>
				<a href="{{ path('vitrine_contact') }}" class="btn btn-mabb rounded-pill px-4">
					<i class="bi bi-envelope me-1"></i>Nous rejoindre
				</a>
			</div>
	</section>
{% endblock %}
