{% extends 'vitrine/base.html.twig' %}

{% block title %}Galerie — MABB Amiens{% endblock %}
{% block meta_description %}Galerie photos et vidéos de la MABB : matchs, entraînements, événements et vie du club.{% endblock %}

{% block body %}

<div class="page-header">
    <div class="container">
        <h1>Galerie</h1>
        <nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="{{ path('vitrine_accueil') }}">Accueil</a></li><li class="breadcrumb-item active">Galerie</li></ol></nav>
    </div>
</div>

<section class="section">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="section-title">La MABB <span>en images</span></h2>
            <p class="section-subtitle text-white-force">Matchs, entraînements, tournois et moments de vie</p>
        </div>

        {% if medias|length > 0 %}
        <div class="row g-3">
            {% for media in medias %}
            <div class="col-6 col-md-4 col-lg-3">
                <div class="card card-mabb overflow-hidden"
                     style="cursor:pointer"
                     onclick="document.getElementById('modal-{{ media.id }}').style.display='flex'">
                    <img src="{{ asset('uploads/galerie/' ~ media.path) }}"
                         alt="{{ media.legende ?? 'Photo MABB' }}"
                         style="height:220px;object-fit:cover;width:100%"
                         loading="lazy">
                    {% if media.legende %}
                        <div class="p-2">
                            <small class="text-muted">{{ media.legende }}</small>
                        </div>
                    {% endif %}
                </div>

                {# Lightbox simple #}
                <div id="modal-{{ media.id }}"
                     style="display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.9);z-index:9999;align-items:center;justify-content:center"
                     onclick="this.style.display='none'">
                    <img src="{{ asset('uploads/galerie/' ~ media.path) }}"
                         alt="{{ media.legende ?? 'Photo MABB' }}"
                         style="max-width:90vw;max-height:90vh;border-radius:8px">
                </div>
            </div>
            {% endfor %}
        </div>

        {% else %}
        {# Affichage si aucune photo uploadée #}
        <div class="text-center py-5">
            <div class="card card-mabb p-5 d-inline-block">
                <i class="bi bi-camera" style="font-size:3rem;color:var(--mabb-orange)"></i>
                <h5 class="fw-bold mt-3">Photos à venir</h5>
                <p class="text-muted mb-3">La galerie sera alimentée avec les photos du club.</p>
                <div class="d-flex gap-2 justify-content-center">
                    <a href="https://www.instagram.com/_m_a_b_b_/"
                       class="btn btn-outline-mabb btn-sm" target="_blank">
                        <i class="bi bi-instagram me-1"></i>Instagram
                    </a>
                    <a href="https://www.facebook.com/mabb.fr/"
                       class="btn btn-outline-mabb btn-sm" target="_blank">
                        <i class="bi bi-facebook me-1"></i>Facebook
                    </a>
                </div>
            </div>
        </div>
        {% endif %}
    </div>
</section>

{% endblock %}
