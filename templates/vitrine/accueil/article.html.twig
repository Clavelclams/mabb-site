{% extends 'vitrine/base.html.twig' %}
{% block title %}{{ article.titre }}{% endblock %}
{% block meta_description %}{{ article.contenu|striptags|slice(0, 160) }}{% endblock %}

{% block body %}

<div class="page-header">
    <div class="container text-center">
        <h1>{{ article.titre }}</h1>
        <p style="color:rgba(255,255,255,.75)">
            <i class="bi bi-calendar3 me-1"></i>
            {{ article.publishedAt ? article.publishedAt|date('d/m/Y') : '' }}
            {% if article.auteur %}
                — par {{ article.auteur.prenom }} {{ article.auteur.nom }}
            {% endif %}
        </p>
    </div>
</div>

<section class="section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">

                {% if article.imagePath %}
                    <img src="{{ asset('uploads/articles/' ~ article.imagePath) }}"
                         alt="{{ article.titre }}"
                         class="img-fluid rounded-4 mb-4 w-100"
                         style="max-height:400px;object-fit:cover">
                {% endif %}

                {# Contenu HTML (Quill) #}
                <div class="article-content">
                    {{ article.contenu|raw }}
                </div>

                {# Partage réseaux sociaux — URL = page courante (absolue) #}
                <div class="article-partage d-flex align-items-center flex-wrap gap-2 mt-4">
                    <span class="text-muted small me-1"><i class="bi bi-share-fill me-1"></i>Partager :</span>
                    <a class="btn btn-sm rounded-pill" style="background:#1877f2;color:#fff;border:none;"
                       target="_blank" rel="noopener" aria-label="Partager sur Facebook"
                       href="https://www.facebook.com/sharer/sharer.php?u={{ app.request.uri|url_encode }}">
                        <i class="bi bi-facebook"></i>
                    </a>
                    <a class="btn btn-sm rounded-pill" style="background:#000;color:#fff;border:none;"
                       target="_blank" rel="noopener" aria-label="Partager sur X"
                       href="https://twitter.com/intent/tweet?url={{ app.request.uri|url_encode }}&amp;text={{ article.titre|url_encode }}">
                        <i class="bi bi-twitter-x"></i>
                    </a>
                    <a class="btn btn-sm rounded-pill" style="background:#25d366;color:#fff;border:none;"
                       target="_blank" rel="noopener" aria-label="Partager sur WhatsApp"
                       href="https://wa.me/?text={{ (article.titre ~ ' ' ~ app.request.uri)|url_encode }}">
                        <i class="bi bi-whatsapp"></i>
                    </a>
                    <button type="button" class="btn btn-sm rounded-pill"
                            style="background:var(--mabb-blue,#0d1b2a);color:#fff;border:none;"
                            aria-label="Copier le lien"
                            onclick="navigator.clipboard.writeText('{{ app.request.uri|e('js') }}');this.innerHTML='&lt;i class=\'bi bi-check-lg\'&gt;&lt;/i&gt; Lien copié';">
                        <i class="bi bi-link-45deg"></i> Copier le lien
                    </button>
                </div>

                <hr class="my-5">

                <div class="d-flex justify-content-between align-items-center">
                    <a href="{{ path('vitrine_news') }}" class="btn rounded-pill fw-semibold"
                       style="background:#fc702a;color:#fff;border:none">
                        <i class="bi bi-arrow-left me-1"></i>Toutes les actualités
                    </a>
                    {% if is_granted('ROLE_SUPER_ADMIN') %}
                        <a href="{{ path('admin_articles_edit', {id: article.id}) }}"
                           class="btn rounded-pill fw-semibold"
                           style="background:var(--mabb-blue);color:#fff;border:none">
                            <i class="bi bi-pencil me-1"></i>Modifier cet article
                        </a>
                    {% endif %}
                </div>

            </div>
        </div>
    </div>
</section>

{% endblock %}
