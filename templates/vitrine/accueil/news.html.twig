{% extends 'vitrine/base.html.twig' %}
{% block title %}Actualités — MABB Amiens{% endblock %}
{% block meta_description %}Toutes les actualités de la MABB : résultats, événements, tournois et vie du club.{% endblock %}

{% block body %}

<div class="page-header">
    <div class="container text-center">
        <h1>Actualités</h1>
        <p style="color:rgba(255,255,255,.75)">Toute l'actualité du club MABB</p>
    </div>
</div>

<section class="section section-gray">
    <div class="container">

        {% if articles|length == 0 %}
            <div class="text-center py-5">
                <div style="font-size:3rem">📰</div>
                <h3 class="mt-3" style="color:#063a55">Aucune actualité publiée</h3>
                <p class="text-muted">Revenez bientôt !</p>
            </div>
        {% else %}
        <div class="row g-4">
            {% for article in articles %}
            <div class="col-md-6 col-lg-4">
                <div class="card card-mabb h-100">
                    {% if article.imagePath %}
                        <img src="{{ asset('uploads/articles/' ~ article.imagePath) }}"
                             alt="{{ article.titre }}"
                             style="height:180px;object-fit:cover;width:100%">
                    {% else %}
                        <div style="height:120px;background:linear-gradient(135deg,#063a55,#0b4fa3);display:flex;align-items:center;justify-content:center">
                            <i class="bi bi-newspaper text-white" style="font-size:2.5rem;opacity:.4"></i>
                        </div>
                    {% endif %}
                    <div class="card-body p-4 d-flex flex-column">
                        <small class="text-muted mb-2">
                            <i class="bi bi-calendar3 me-1"></i>
                            {{ article.publishedAt ? article.publishedAt|date('d/m/Y') : '' }}
                        </small>
                        <a href="{{ path('vitrine_news_article', {slug: article.slug}) }}"
                           class="text-decoration-none">
                            <h5 class="fw-bold mb-2" style="color:#fff">{{ article.titre }}</h5>
                        </a>
                        <p class="text-muted flex-grow-1">{{ article.contenu|striptags|slice(0, 140) }}...</p>
                        <a href="{{ path('vitrine_news_article', {slug: article.slug}) }}"
                           class="btn btn-sm rounded-pill mt-2 fw-semibold"
                           style="background:#0b4fa3;color:#fff;border:none">
                            Lire l'article <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>

        {# Pagination #}
        {% if totalPages > 1 %}
        <div class="d-flex justify-content-center gap-2 mt-5">
            {% if page > 1 %}
                <a href="{{ path('vitrine_news', {page: page - 1}) }}"
                   class="btn btn-outline-secondary rounded-pill px-4">← Précédent</a>
            {% endif %}
            <span class="btn btn-mabb rounded-pill px-4 disabled">{{ page }} / {{ totalPages }}</span>
            {% if page < totalPages %}
                <a href="{{ path('vitrine_news', {page: page + 1}) }}"
                   class="btn btn-outline-secondary rounded-pill px-4">Suivant →</a>
            {% endif %}
        </div>
        {% endif %}
        {% endif %}

    </div>
</section>

{% endblock %}
