{% extends 'vitrine/base.html.twig' %}

{% block title %}Nos Équipes — MABB Amiens
{% endblock %}
{% block meta_description %}Les équipes de la MABB : U11, U13, U15, U18, Seniors et 3x3. Résultats, catégories et encadrement.
{% endblock %}

{% block body %}

<div class="page-header">
	<div class="container">
		<h1>Nos Équipes</h1>
		<nav aria-label="breadcrumb">
			<ol class="breadcrumb justify-content-center">
				<li class="breadcrumb-item">
					<a href="{{ path('vitrine_accueil') }}" style="color:#fff">Accueil</a>
				</li>
				<li class="breadcrumb-item active" style="color:#ff8c00;font-weight:600">
					<i class="bi bi-people-fill me-1"></i>Équipes
				</li>
				<li class="breadcrumb-item">
					<a href="{{ path('vitrine_victoires') }}" style="color:#fff">Nos Victoires</a>
				</li>
			</ol>
		</nav>
	</div>
</div>

<section class="section">
	<div class="container">
		<div class="text-center mb-5">
			<h2 class="section-title text-white">Saison
				<span>2025-2026</span>
			</h2>
			<p class="section-subtitle text-white-force ">Du Mini Basket aux Seniors, la MABB forme à tous les niveaux</p>
		</div>

		{# TODO: Quand les entités Team seront créées, cette liste sera dynamique #}
		<div class="row g-4">
			{% set equipes = [
                {cat: 'Micro Basket', ages: '3-5 ans', niveau: 'Éveil', lieu: 'Étouvie', color: '#e74c3c', icon: 'bi-balloon', desc: 'Découverte ludique, éveil psychomoteur. Matériel adapté.'},
                {cat: 'U7 / U9', ages: '5-8 ans', niveau: 'Mini Basket', lieu: '3 sites', color: '#f39c12', icon: 'bi-stars', desc: 'Apprentissage des fondamentaux. Étouvie, Nord, Est.'},
                {cat: 'U11 Féminine', ages: '9-10 ans', niveau: 'Départemental', lieu: 'Étouvie', color: '#e67e22', icon: 'bi-dribbble', desc: 'Championnes départementales invaincues. 2 équipes engagées.'},
                {cat: 'U13 Féminine', ages: '11-12 ans', niveau: 'Régional / Pré-Nat', lieu: 'Étouvie', color: '#3498db', icon: 'bi-lightning', desc: '2 équipes : régionale (R2B) et départementale. Objectif Pré-Nationale.'},
                {cat: 'U15 Féminine', ages: '13-14 ans', niveau: 'Régional', lieu: 'Étouvie', color: '#2980b9', icon: 'bi-lightning-fill', desc: '2 équipes en régionale et départementale. Vivier d\'excellence.'},
                {cat: 'U18 Féminine', ages: '15-17 ans', niveau: 'Inter-Départemental', lieu: 'Étouvie', color: '#8e44ad', icon: 'bi-fire', desc: 'Pré-Nationale la saison passée. Quadruple championnes Coupe de la Somme.'},
                {cat: 'Senior Féminine', ages: '18+ ans', niveau: 'Pré-Régional', lieu: 'Étouvie', color: '#0b4fa3', icon: 'bi-trophy', desc: 'Objectif : stabiliser en régional solide. Noyau de joueuses formées au club.'},
                {cat: 'Basket 3x3', ages: '11-25+ ans', niveau: 'Ligue MABB / FFBB', lieu: 'Divers', color: '#27ae60', icon: 'bi-dribbble', desc: 'Ligue officielle MABB (10 tournois classés). 25+ tournois QPV par an.'},
                {cat: 'Basket Loisir Mixte', ages: 'Tout âge — Mixte', niveau: 'Loisir', lieu: 'Étouvie', color: '#1c88b6', icon: 'bi-people-fill', desc: 'Pratique conviviale et non-compétitive ouverte à tous. Ambiance détendue pour jouer au basket en loisir sur Amiens Métropole.'},
            ] %}

            {% for eq in equipes %}
            <div class="col-md-6 col-lg-4">
                <div class="card card-mabb h-100">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div style="width:50px;height:50px;border-radius:12px;background:{{ eq.color }}15;display:flex;align-items:center;justify-content:center">
                                <i class="bi {{ eq.icon }}" style="font-size:1.4rem;color:{{ eq.color }}"></i>
                            </div>
                            <div>
                                <h5 class="mb-0 fw-bold">{{ eq.cat }}</h5>
                                <small class="text-muted">{{ eq.ages }}</small>
                            </div>
                        </div>
                        <p class="text-muted mb-3">{{ eq.desc }}</p>
                        {% if eq.cat == 'U18 Féminine' %}
                        <a href="{{ path('vitrine_projet_sport_etude') }}"
                           class="d-flex align-items-center gap-2 p-2 rounded-3 text-decoration-none mt-3"
                           style="background:rgba(11,79,163,.06);border:1px solid rgba(11,79,163,.2)">
                            <i class="bi bi-mortarboard-fill" style="color:#0b4fa3"></i>
                            <small style="color:#0b4fa3;font-weight:600">
                                Projet Sport-Études — Cité Scolaire d'Amiens →
                            </small>
                        </a>
                        {% endif %}
                        <div class="d-flex justify-content-between">
                            <span class="badge bg-light text-dark"><i class="bi bi-bar-chart me-1"></i>{{ eq.niveau }}</span>
                            <span class="badge bg-light text-dark"><i class="bi bi-geo-alt me-1"></i>{{ eq.lieu }}</span>
                        </div>
                        {% if eq.cat == 'Basket 3x3' %}
                        <a href="{{ path('vitrine_equipes_3x3') }}"
                           class="btn btn-sm btn-mabb rounded-pill mt-2 w-100">
                            <i class="bi bi-trophy-fill me-1"></i>Voir l'équipe 3x3 →
                        </a>
                        {% endif %}
                    </div>
                </div>
            </div>
            {% endfor %}
            
        </div>

        {# Lien Scorenco #}
        <div class="text-center mt-5">
            <p class="text-muted mb-2 text-white-force">Résultats et classements en temps réel :</p>
            <a href="https://scorenco.com/basket/clubs/amiens-metropole-basket-ball-2p8p" class="btn btn-outline-mabb text-white-force" target="_blank">
                <i class="bi bi-bar-chart-line me-2"></i>Voir sur Scorenco
            </a>
        </div>
    </div>
</section>

{# ENCADREMENT #}
<section class="section section-gray">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="section-title">Encadrement <span>technique</span></h2>
            <p class="section-subtitle">Des éducateurs formés et passionnés</p>
        </div>
        <div class="row g-4 mt-3">
            {% set coachs = [
                {nom: 'COULPIED Ugo', titre: 'Responsable sportif', diplome: 'Diplômé d\'État', emoji: '🏀'},
                {nom: 'DUFOSSE Romy', titre: 'Responsable école du mini basket', diplome: 'Diplômé d\'État', emoji: '⭐'},
                {nom: 'HARTHATI Ben Moussa', titre: 'Directeur de la structure — Coach U13 région', diplome: 'Diplômé DEJEPS', emoji: '🎯'},
                {nom: 'NDEMA MOUSSA Clavel', titre: 'Coach Senior & U15 — Cadre technique Somme U13', diplome: 'DETB (en formation)', emoji: '🏆'},
            ] %}
            {% for coach in coachs %}
            <div class="col-md-6 col-lg-3">
                <div class="card card-mabb text-center p-4 h-100">
                    <div style="font-size:2rem;margin-bottom:8px">{{ coach.emoji }}</div>
                    <h5 class="fw-bold mb-1">{{ coach.nom }}</h5>
                    <p class="text-mabb-orange fw-semibold small mb-1">{{ coach.titre }}</p>
                    <span class="badge bg-light text-muted small">{{ coach.diplome }}</span>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

{# SERVICE CIVIQUE #}
<section class="section" style="background:linear-gradient(135deg,#063a55,#0b4fa3)">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold" style="color:#fff">Service <span style="color:var(--mabb-orange)">Civique</span></h2>
            <p style="color:rgba(255,255,255,.75)">Nos volontaires en mission d'intérêt général</p>
        </div>
        {% set volontaires = [
            {nom: 'DAOUDI Annah', mission: 'Animation sportive et soutien éducatif'},
            {nom: 'GUELFAT Asma', mission: 'Animation sportive et soutien éducatif'},
            {nom: 'YAHIAOUI Ilies', mission: 'Animation sportive et soutien éducatif'},
            {nom: 'BADIBALOWA KISUMBEL Albert', mission: 'Animation sportive et soutien éducatif'},
            {nom: 'PARFAIT Solofotiana Emeric', mission: 'Animation sportive et soutien éducatif'},
            {nom: 'KOUDJIL Abderrahmane', mission: 'Animation sportive et soutien éducatif'},
            {nom: 'ATSHABO Elissa', mission: 'Photographe — valorisation des événements MABB'},
        ] %}
        <div class="row g-4 justify-content-center">
            {% for v in volontaires %}
            <div class="col-md-4 col-lg-3">
                <div class="card border-0 text-center p-4 h-100" style="background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15)!important">
                    <div style="font-size:2.5rem;margin-bottom:12px">🤝</div>
                    <h5 class="text-white fw-bold" style="font-size:.95rem">{{ v.nom }}</h5>
                    <p style="color:rgba(255,255,255,.7)" class="small mt-2 mb-0">{{ v.mission }}</p>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

{% endblock %}
