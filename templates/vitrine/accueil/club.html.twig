{% extends 'vitrine/base.html.twig' %}

{% block title %}Le Club — MABB Amiens Métropole Basket Ball
{% endblock %}
{% block meta_description %}Découvrez la MABB : histoire, valeurs, bureau dirigeant, labels FFBB et projet éducatif du club de basket féminin d'Amiens.
{% endblock %}

{% block body %}

{# HEADER #}
<div class="page-header">
	<div class="container">
		<h1>Le Club</h1>
		<nav aria-label="breadcrumb">
			<ol class="breadcrumb">
				<li class="breadcrumb-item">
					<a href="{{ path('vitrine_accueil') }}">Accueil</a>
				</li>
				<li class="breadcrumb-item active">Le Club</li>
				<li class="breadcrumb-item">
					<a href="{{ path('vitrine_employes') }}">Employés</a>
				</li>
			</ol>
		</nav>
	</div>
</div>

{# HISTOIRE #}
<section class="section">
	<div class="container">
		<div class="row align-items-center g-5">
			<div class="col-lg-7">
				{# [CMS V2 06/07/2026] Section histoire éditable dans /admin/contenus #}
				<h2 class="section-title text-white">{{ cms('club.histoire.titre_avant', 'Plus de') }}
					<span>{{ cms('club.histoire.titre_accent', '23 ans') }}</span>
					{{ cms('club.histoire.titre_apres', "d'engagement") }}</h2>
				<p class="text-white-force">
					{# [V2.4i] Nouveau nom (depuis 2025). ⚠️ Si la clé CMS est déjà enregistrée
					   en prod avec l'ancien nom, corriger aussi dans Admin → Contenus. #}
					{{ cms('club.histoire.paragraphe1', "L'Amiens Métropole Basket Ball (MABB) est une association sportive loi 1901 dédiée au basket-ball féminin. Implantée sur le territoire d'Amiens Métropole, elle accueille chaque année plus de 400 licenciées, du Micro Basket (dès 3 ans) jusqu'aux équipes Seniors.", 'long') }}
				</p>
				<p class="text-white-force">
					{{ cms('club.histoire.paragraphe2', "Le club se distingue par la qualité de son encadrement technique et sportif. La MABB a formé et continue de former d'excellentes joueuses, dont certaines ont été sélectionnées en équipes de France jeunes. Le projet du club s'articule autour de trois piliers : l'école, le terrain et la performance.", 'long') }}
				</p>
				<p class="text-white-force">
					{{ cms('club.histoire.paragraphe3', "Classée en première place parmi les 330 clubs de basket de la région Hauts-de-France, la MABB est une référence incontournable du basket féminin et de l'accès au sport pour tous.", 'long') }}
				</p>
				<a href="{{ path('vitrine_pre_inscription') }}" class="btn btn-lg mt-2"
				   style="background:#e07a1f; color:#fff; font-weight:700; border-radius:30px; padding:12px 32px; box-shadow:0 6px 18px rgba(224,122,31,.35);">
					🏀 Inscrire mon enfant
				</a>
			</div>
			<div
				class="col-lg-5">
					<img src="{{ asset(cms_img('club.histoire.photo', 'images/teamsU13HDF2025.jpg')) }}" alt="Équipe U13 MABB — HDF 2025" class="img-fluid rounded-4 w-100" style="object-fit:cover;max-height:400px;">
			</div>
		</div>
	</div>
</section>

{# VALEURS #}
<section class="section section-gray">
	<div class="container">
		<div class="text-center mb-5">
			<h2 class="section-title">Nos
				<span>valeurs</span>
			</h2>
		</div>
		<div class="row g-4">
			{% set valeurs = [
                {icon: 'bi-heart-fill', title: 'Inclusion', desc: 'Permettre au plus grand nombre de jeunes filles de pratiquer le basket, quels que soient leur quartier ou leur situation.', color: '#e74c3c'},
                {icon: 'bi-mortarboard-fill', title: 'Éducation', desc: 'Le sport comme vecteur d\'éducation et d\'éveil à la citoyenneté. Aide aux devoirs, accompagnement scolaire.', color: '#3498db'},
                {icon: 'bi-trophy-fill', title: 'Excellence', desc: 'Former des joueuses de haut niveau tout en maintenant un encadrement bienveillant et exigeant.', color: '#f39c12'},
                {icon: 'bi-people-fill', title: 'Solidarité', desc: 'Actions dans les quartiers prioritaires, stages gratuits, déplacements culturels et partenariats scolaires.', color: '#2ecc71'},
            ] %}
			{% for v in valeurs %}
				<div class="col-md-6 col-lg-3">
					<div class="card card-mabb text-center h-100 p-4"{% if v.title == 'Éducation' %} id="aide-au-devoir"{% endif %}>
						<i class="bi {{ v.icon }}" style="font-size:2.5rem;color:{{ v.color }}"></i>
						<h5 class="fw-bold mt-3">{{ v.title }}</h5>
						<p class="text-muted small">{{ v.desc }}</p>
						{% if v.title == 'Éducation' %}
						<a href="https://le-savoir-pour-tous.pass-education.fr/inscription?slug=mabb-amiens-metropole-basket-ball&token=b8db9981-d307-4e79-a539-ac30aafd2041"
						   target="_blank" rel="noopener"
						   class="btn btn-mabb btn-sm mt-3 w-100">
							<i class="bi bi-book-half me-1"></i>Aide au devoir
						</a>
						{% endif %}
					</div>
				</div>
			{% endfor %}
			<div class="col-md-6 col-lg-3">
				<a href="{{ path('vitrine_cite_educative') }}" class="text-decoration-none">
					<div class="card card-mabb text-center h-100 p-4"
					     style="border:2px solid var(--mabb-orange);transition:transform .2s"
					     onmouseover="this.style.transform='translateY(-5px)'"
					     onmouseout="this.style.transform='none'">
						<i class="bi bi-building-fill-check text-mabb-orange" style="font-size:2.5rem"></i>
						<h5 class="fw-bold mt-3">Cité Éducative</h5>
						<p class="text-muted small">Partenaire de la Cité Éducative d'Amiens — actions avec les établissements scolaires du territoire.</p>
						<span class="text-mabb-orange fw-semibold small">Découvrir →</span>
					</div>
				</a>
			</div>
		</div>
	</div>
</section>

{# BUREAU #}
<section class="section">
	<div class="container">
		<div class="text-center mb-5">
			<h2 class="section-title text-white"><span>Organigramme</span> MABB</h2>
			<p class="section-subtitle text-white-force">L'équipe qui fait vivre le club au quotidien</p>
		</div>
		<div
			class="row g-4 justify-content-center">
			{# Organigramme MABB — mis à jour 2026-06 #}
			{% set bureau = [
                {nom: 'Willy', role: 'Président / Directeur Général', emoji: '🏀'},
                {nom: 'Moussa', role: 'Coordinateur', emoji: '🏀'},
                {nom: 'Romy', role: 'Responsable Social', emoji: '🤝'},
                {nom: 'Ugo', role: 'Responsable Sportif', emoji: '🏀'},
                {nom: 'Clavel', role: 'Communication & Développement Numérique', emoji: '💻'},
                {nom: 'Larissa', role: 'BPJEPS', emoji: '🏀'},
                {nom: 'Leny', role: 'BPJEPS', emoji: '🏀'},
                {nom: 'Tony', role: 'Alternance Communication', emoji: '📱'},
                {nom: 'Services civiques · Stagiaires · Bénévoles', role: 'Soutien quotidien', emoji: '👥'},
            ] %}
			{% for m in bureau %}
				<div class="col-6 col-md-4">
					<div class="card card-mabb text-center p-4 h-100">
						<div class="mx-auto mb-3" style="width:80px;height:80px;border-radius:50%;background:var(--mabb-gray);display:flex;align-items:center;justify-content:center;font-size:2rem">{{ m.emoji }}</div>
						<h6 class="fw-bold mb-1">{{ m.nom }}</h6>
						<small class="text-mabb-orange fw-semibold">{{ m.role }}</small>
					</div>
				</div>
			{% endfor %}
		</div>

		{# CTA vers la page dédiée Employés — découverte de l'équipe pro complète #}
		<div class="text-center mt-5">
			<a href="{{ path('vitrine_employes') }}" class="btn rounded-pill px-4 py-2 fw-semibold"
			   style="background:var(--mabb-orange);color:#fff;border:2px solid var(--mabb-orange);transition:all .2s;"
			   onmouseover="this.style.background='#fff';this.style.color='var(--mabb-orange)';"
			   onmouseout="this.style.background='var(--mabb-orange)';this.style.color='#fff';">
				<i class="bi bi-people-fill me-2"></i>Découvrir tous nos employés
				<i class="bi bi-arrow-right ms-2"></i>
			</a>
		</div>
	</div>
</section>

{# LABELS #}
<section class="section section-gray">
	<div class="container">
		<div class="text-center mb-5">
			<h2 class="section-title">Nos
				<span>labels</span>
				FFBB</h2>
			<p class="section-subtitle">Reconnus par la Fédération Française de Basket-Ball</p>
		</div>
		<div class="row g-4 justify-content-center">
			{% set labels = [
                {title: 'Club Formateur', stars: 3, desc: 'Excellence dans la formation des jeunes joueuses, de l\'école de mini-basket à la performance.'},
                {title: 'Citoyenneté', stars: 3, desc: 'Engagement citoyen reconnu : actions QPV, partenariats scolaires, inclusion sociale.'},
                {title: 'École Française de Mini Basket', stars: 3, desc: 'Qualité de l\'accueil et de l\'enseignement du basket pour les enfants de 3 à 10 ans.'},
            ] %}
            {% for l in labels %}
            <div class="col-md-4">
                <div class="card card-mabb text-center h-100 p-4">
                    <div class="mb-2">
                        {% for i in 1..l.stars %}<i class="bi bi-star-fill text-warning" style="font-size:1.3rem"></i>{% endfor %}
                    </div>
                    <h5 class="fw-bold">{{ l.title }}</h5>
                    <p class="text-muted small mb-0">{{ l.desc }}</p>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

{% endblock %}
