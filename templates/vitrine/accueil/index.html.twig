{% extends 'vitrine/base.html.twig' %}

{% block title %}MABB — Amiens Métropole Basket Ball | Club de basket féminin
{% endblock %}
{% block meta_description %}Club de basket-ball exclusivement féminin à Amiens. Triple label FFBB 3 étoiles. Formation, compétition, 3x3 et inclusion par le sport.
{% endblock %}

{% block body %}

	{# ===== HERO ===== #}
	<section class="hero-accueil">
		<div class="hero-accueil-bg"></div>
		<div class="container position-relative">
			<div class="row align-items-center g-5">
				<div class="col-lg-6">
					<span class="badge-label mb-3">
						<i class="bi bi-star-fill"></i>
						Triple label FFBB 3 étoiles</span>
					<h1 class="display-4 fw-bold mb-3 hero-title">
						Amiens Métropole<br>
						<span class="text-mabb-orange">Basket Ball</span>
					</h1>
					<p class="lead mb-4 hero-desc">
						Club de basket-ball exclusivement féminin implanté sur le territoire
																		d'Amiens Métropole. De l'initiation à la performance, nous formons
																		les championnes de demain.
					</p>
					<div class="d-flex flex-wrap gap-3">
						<a href="{{ path('vitrine_compte_se_connecter') }}" class="btn btn-mabb btn-lg">
							<i class="bi bi-person-plus me-2"></i>Rejoindre le club
						</a>
						<a href="{{ path('vitrine_club') }}" class="btn btn-outline-light btn-lg rounded-pill">
							<i class="bi bi-info-circle me-2"></i>Découvrir
						</a>
						<a href="https://le-savoir-pour-tous.pass-education.fr/inscription?slug=mabb-amiens-metropole-basket-ball&token=b8db9981-d307-4e79-a539-ac30aafd2041" target="_blank" class="btn btn-lg rounded-pill btn-aide-devoir">
							<i class="bi bi-book-half me-2"></i>Aide au devoir
						</a>
						<a href="{{ path('vitrine_nos_reseaux') }}"
						   class="btn btn-lg rounded-pill fw-semibold"
						   style="background:rgba(255,255,255,.15);color:#fff;border:1px solid rgba(255,255,255,.4);backdrop-filter:blur(4px)">
							<i class="bi bi-share me-2"></i>Nos réseaux
						</a>
					</div>
				</div>
				<div class="col-lg-6 text-center">
					<div class="p-3 bg-white rounded-4 shadow-lg d-inline-block hero-photo-wrap">
						<img src="{{ asset('images/manar.jpg') }}" alt="Joueuse MABB" class="img-fluid rounded-3 hero-photo">
					</div>
				</div>
			</div>
		</div>
	</section>

	{# ===== CHIFFRES CLÉS ===== #}
	<section class="section-chiffres">
		<div class="container">
			<div class="row g-3 justify-content-center">
				{% set chiffres = [
                {icon: 'bi-people-fill', number: '400+', label: 'Licenciées'},
                {icon: 'bi-trophy-fill', number: '3', label: 'Labels FFBB 3★'},
                {icon: 'bi-building', number: '7', label: 'Quartiers'},
                {icon: 'bi-calendar-heart', number: '23+', label: 'Ans d\'engagement'},
            ] %}
            {% for c in chiffres %}
            <div class="col-6 col-md-3">
                <div class="card card-mabb text-center p-4">
                    <i class="bi {{ c.icon }} text-mabb-orange chiffre-icon"></i>
                    <div class="display-6 fw-bold mt-2 chiffre-number">{{ c.number }}</div>
                    <div class="text-muted small">{{ c.label }}</div>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

{# ===== QUI SOMMES-NOUS ===== #}
<section class="section">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <h2 class="section-title text-white">Un club engagé pour <span>le basket féminin</span></h2>
                <p class="text-white-force">
                    La MABB porte un projet sportif, éducatif et citoyen structuré. Nous accueillons
                    les jeunes filles de 3 à 25+ ans dans un cadre bienveillant et exigeant.
                    Notre mission dépasse le terrain : nous faisons du basketball un levier
                    d'émancipation et de rayonnement du sport féminin.
                </p>
                <p class="text-white-force">
                    Le club mène toute l'année des actions d'intérêt général dans les établissements
                    scolaires et les quartiers prioritaires d'Amiens : école de mini-basket,
                    aide aux devoirs, stages gratuits Génération Basket, tournois 3x3.
                </p>
                <div class="d-flex flex-wrap gap-2 mt-3">
                    <span class="badge px-3 py-2 rounded-pill fw-bold badge-label-outline"><i class="bi bi-check-circle me-1"></i> Club Formateur <span class="badge-star">★★★</span></span>
                    <span class="badge px-3 py-2 rounded-pill fw-bold badge-label-outline"><i class="bi bi-check-circle me-1"></i> Citoyenneté <span class="badge-star">★★★</span></span>
                    <span class="badge px-3 py-2 rounded-pill fw-bold badge-label-outline"><i class="bi bi-check-circle me-1"></i> Mini Basket <span class="badge-star">★★★</span></span>
                </div>
            </div>
            <div class="col-lg-6">
                <img src="{{ asset('images/teamsU1.jpg') }}" alt="Équipe MABB" class="img-fluid rounded-4 w-100" style="object-fit:cover;max-height:420px;">
            </div>
        </div>
    </div>
</section>

{# ===== NOS SECTIONS ===== #}
<section class="section section-gray">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="section-title">Du <span>Micro Basket</span> à la <span>Performance</span></h2>
            <p class="section-subtitle">Un parcours complet de 3 à 25+ ans</p>
        </div>
        <div class="row g-4">
            {% set sections = [
                {icon: 'bi-balloon', title: 'Micro Basket', ages: '3-5 ans', desc: 'Éveil psychomoteur et découverte ludique du basket pour les tout-petits. Matériel adapté en taille et en couleur.', color: '#e74c3c'},
                {icon: 'bi-stars', title: 'Mini Basket', ages: '6-10 ans', desc: 'Apprentissage en s\'amusant avec ballons adaptés (taille 3 et 5) et paniers ajustables. 3 sites : Étouvie, Nord, Est.', color: '#f39c12'},
                {icon: 'bi-lightning', title: 'Compétition', ages: 'U11 à Senior', desc: 'Équipes engagées dans tous les championnats : départemental, régional, pré-national. Formation d\'excellence.', color: '#0b4fa3'},
                {icon: 'bi-dribbble', title: 'Basket 3x3', ages: '11-25+ ans', desc: 'Ligue MABB officielle FFBB, tournois homologués dans les quartiers, format libre et créatif.', color: '#2ecc71'},
                {icon: 'bi-mortarboard', title: 'Section Sportive', ages: 'Collège', desc: 'Academy César Franck 100% féminine. Horaires aménagés, 4 entraînements/semaine, double projet scolaire-sportif.', color: '#9b59b6'},
                {icon: 'bi-heart', title: 'Actions Citoyennes', ages: 'Toute l\'année', desc: 'Centres Génération Basket gratuits, aide aux devoirs, interventions scolaires, tournois QPV.', color: '#1abc9c'},
            ] %}
				{% for s in sections %}
					<div class="col-md-6 col-lg-4">
						<div class="card card-mabb h-100">
							<div class="card-body p-4">
								<div class="d-flex align-items-center gap-3 mb-3">
									<div style="width:50px;height:50px;border-radius:12px;background:{{ s.color }}15;display:flex;align-items:center;justify-content:center">
										<i class="bi {{ s.icon }}" style="font-size:1.5rem;color:{{ s.color }}"></i>
									</div>
									<div>
										<h5 class="mb-0 fw-bold">{{ s.title }}</h5>
										<small class="text-muted">{{ s.ages }}</small>
									</div>
								</div>
								<p class="text-muted mb-0">{{ s.desc }}</p>
							</div>
						</div>
					</div>
				{% endfor %}
			</div>
		</div>
	</section>

	{# ===== DERNIÈRES ACTUS (placeholder — sera dynamique avec le CMS) ===== #}
	<section class="section">
		<div class="container">
			<div class="d-flex justify-content-between align-items-center mb-4">
				<h2 class="section-title mb-0">Dernières
					<span>actualités</span>
				</h2>
				<a href="{{ path('vitrine_news') }}"
				   class="btn rounded-pill fw-semibold"
				   style="background:#ff8c00;color:#fff;border:none">Voir tout
					<i class="bi bi-arrow-right ms-1"></i>
				</a>
			</div>
			<div class="row g-4">
				{% if dernieres_actus|length > 0 %}
					{% for actu in dernieres_actus %}
						<div class="col-md-4">
							<div class="card card-mabb h-100">
								{% if actu.imagePath %}
									<img src="{{ asset('uploads/articles/' ~ actu.imagePath) }}" alt="{{ actu.titre }}" style="height:180px;object-fit:cover;width:100%">
								{% endif %}
								<div class="card-body p-4">
									<small class="text-muted">
										<i class="bi bi-calendar3 me-1"></i>
										{{ actu.publishedAt ? actu.publishedAt|date('d/m/Y') : '' }}
									</small>
									<h5 class="fw-bold mt-2 mb-2">{{ actu.titre }}</h5>
									<p class="text-muted">{{ actu.contenu|striptags|slice(0, 120) }}...</p>
									<a href="{{ path('vitrine_news_article', {slug: actu.slug}) }}" class="btn btn-sm rounded-pill mt-2 fw-semibold" style="background:#0b4fa3;color:#fff;border:none">
										Lire la suite
										<i class="bi bi-arrow-right"></i>
									</a>
								</div>
							</div>
						</div>
					{% endfor %}
				{% else %}
					<div class="col-12 text-center py-4">
						<p class="text-muted">Aucune actualité pour le moment.</p>
					</div>
				{% endif %}
			</div>
		</div>
	</section>

	{# ===== CTA INSCRIPTION : ===== #}
	<section class="section-cta-inscription">
		<div class="container">
			<h2 class="display-5 fw-bold mb-3">Rejoins la
				<span class="text-mabb-orange">MABB</span>
			</h2>
			<p class="lead mb-4 cta-desc">
				De 3 à 25+ ans, il y a une place pour toi. Inscriptions ouvertes toute l'année.
			</p>
			<div class="d-flex flex-wrap gap-3 justify-content-center">
				<a href="{{ path('vitrine_compte_s_inscrire') }}" class="btn btn-mabb btn-lg">
					<i class="bi bi-person-plus me-2"></i>S'inscrire</a>
				<a href="mailto:contact@mabb.fr" class="btn btn-outline-light btn-lg rounded-pill">
					<i class="bi bi-envelope me-2"></i>contact@mabb.fr</a>
			</div>
		</div>
	</section>

{% endblock %}
