{% extends 'vitrine/base.html.twig' %}
{% block title %}Mon Compte — MABB{% endblock %}
{% block body %}
<div class="page-header">
    <div class="container text-center">
        <div class="mb-3">
            {% if app.user.photoPath %}
                <img src="{{ asset('uploads/avatars/' ~ app.user.photoPath) }}" alt="Photo"
                     class="compte-avatar">
            {% else %}
                <div class="compte-avatar-placeholder">👤</div>
            {% endif %}
        </div>
        <h1 class="text-white fw-bold mb-1">{{ app.user.prenom }} {{ app.user.nom }}</h1>
        <p class="compte-email">{{ app.user.email }}</p>
        <div class="d-flex flex-wrap gap-1 justify-content-center mt-2">
            {% for role in app.user.rolesMembre %}
                <span class="badge-role-membre">
                    {{ role|capitalize }}
                </span>
            {% endfor %}
        </div>
    </div>
</div>
<section class="section section-gray">
    <div class="container">
        {% for label, messages in app.flashes %}
            {% for msg in messages %}
                <div class="alert alert-{{ label == 'success' ? 'success' : 'danger' }} rounded-3 mb-4">{{ msg }}</div>
            {% endfor %}
        {% endfor %}
        <div class="row g-4 justify-content-center">
            <div class="col-lg-5">
                <div class="card card-mabb p-4">
                    <h2 class="section-title mb-4" style="font-size:1.3rem"><i class="bi bi-person-circle me-2 text-mabb-blue"></i>Mon profil</h2>
                    <form method="post" action="{{ path('vitrine_compte_update_profil') }}" enctype="multipart/form-data">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('update_profil') }}">
                        <div class="mb-3">
                            <label class="form-label fw-semibold small">Photo de profil</label>
                            <input type="file" name="photo" accept="image/*" class="form-control form-control-sm">
                            <div class="form-text">JPG/PNG max 2MB. Utilisée aussi comme photo de card Membres.</div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold small">Bio <span class="text-muted">(visible sur ta card)</span></label>
                            <textarea name="bio" class="form-control" rows="3" maxlength="200" placeholder="Présente-toi en quelques mots...">{{ app.user.bio }}</textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold small">Rôles <span class="text-muted">(plusieurs possibles)</span></label>
                            <div class="p-3 rounded-3" style="background:#f8f9fa;border:1px solid #dee2e6">
                                {# Bénévole toujours présent — non modifiable #}
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="checkbox" checked disabled style="opacity:.5">
                                    <label class="form-check-label text-muted">
                                        Bénévole <span class="badge bg-secondary ms-1" style="font-size:.7rem">par défaut</span>
                                    </label>
                                </div>
                                {% for role, label in {
                                    'coach': 'Coach',
                                    'staff': 'Staff technique',
                                    'dirigeant': 'Dirigeant',
                                    'service-civique': 'Service Civique',
                                    'joueur': 'Joueuse',
                                    'parent': 'Parent'
                                } %}
                                <div class="form-check mb-1">
                                    <input class="form-check-input" type="checkbox"
                                           name="rolesMembre[]" value="{{ role }}"
                                           id="role_{{ role }}"
                                           {{ app.user.hasRoleMembre(role) ? 'checked' }}>
                                    <label class="form-check-label" for="role_{{ role }}">{{ label }}</label>
                                </div>
                                {% endfor %}
                            </div>
                            <div class="form-text">Bénévole est toujours actif. Tes rôles supplémentaires apparaissent sur ta card.</div>
                        </div>
                        <div class="mb-4">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="isPublic" name="isPublic" {{ app.user.isPublic ? 'checked' }}>
                                <label class="form-check-label" for="isPublic">
                                    <strong>Profil public</strong> — apparaître dans la page Membres
                                </label>
                            </div>
                            <div class="form-text">Ta photo + prénom + rôle + bio visibles par tous les visiteurs.</div>
                        </div>
                        <button type="submit" class="btn btn-mabb w-100">
                            <i class="bi bi-check-lg me-1"></i>Enregistrer
                        </button>
                    </form>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card card-mabb p-4 mb-4">
                    <h2 class="section-title mb-3" style="font-size:1.3rem"><i class="bi bi-grid me-2 text-mabb-blue"></i>Mes espaces</h2>
                    {# [V2.4j] Écosystème : UN seul compte partout — cards avec STATUT réel #}
                    <p style="font-size:.74rem; color:#64748b; margin-top:-8px;">
                        Un seul compte pour tout : mêmes identifiants ici, sur Manager et sur PIRB.
                    </p>

                    {# ===== MABB Manager — card selon le statut d'appartenance au club ===== #}
                    {% if statut_mabb == 'active' %}
                        <a href="https://manager.mabb.fr" target="_blank" rel="noopener"
                           class="d-flex align-items-center gap-3 p-3 mb-2 text-decoration-none rounded"
                           style="border:2px solid var(--mabb-blue); background:#eff6ff; transition:transform .15s"
                           onmouseover="this.style.transform='translateY(-2px)'"
                           onmouseout="this.style.transform='none'">
                            <div style="width:42px;height:42px;border-radius:10px;background:var(--mabb-blue);display:flex;align-items:center;justify-content:center;flex-shrink:0">
                                <i class="bi bi-gear-fill" style="color:#fff;font-size:1.1rem"></i>
                            </div>
                            <div style="flex:1;min-width:0">
                                <div style="font-weight:700;color:var(--mabb-dark);font-size:.92rem">
                                    MABB Manager
                                    <span style="background:#dcfce7;color:#166534;font-size:.6rem;font-weight:700;padding:1px 6px;border-radius:8px;margin-left:4px">✅ Membre{{ role_mabb ? ' · ' ~ role_mabb|lower : '' }}</span>
                                </div>
                                <div style="font-size:.72rem;color:#64748b">Ton espace club — équipes, rencontres, missions</div>
                            </div>
                            <i class="bi bi-box-arrow-up-right" style="color:var(--mabb-blue)"></i>
                        </a>
                    {% elseif statut_mabb == 'pending' %}
                        <div class="d-flex align-items-center gap-3 p-3 mb-2 rounded"
                             style="border:2px dashed #f59e0b; background:#fffbeb;">
                            <div style="width:42px;height:42px;border-radius:10px;background:#f59e0b;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                                <i class="bi bi-hourglass-split" style="color:#fff;font-size:1.1rem"></i>
                            </div>
                            <div style="flex:1;min-width:0">
                                <div style="font-weight:700;color:var(--mabb-dark);font-size:.92rem">MABB Manager
                                    <span style="background:#fef3c7;color:#92400e;font-size:.6rem;font-weight:700;padding:1px 6px;border-radius:8px;margin-left:4px">⏳ En attente</span>
                                </div>
                                <div style="font-size:.72rem;color:#64748b">Ta demande d'accès au club est chez les dirigeants — rien d'autre à faire.</div>
                            </div>
                        </div>
                    {% else %}
                        <form method="post" action="{{ path('vitrine_compte_rejoindre_club') }}"
                              class="d-flex align-items-center gap-3 p-3 mb-2 rounded"
                              style="border:2px dashed var(--mabb-blue); background:#eff6ff;">
                            <input type="hidden" name="_token" value="{{ csrf_token('rejoindre_club') }}">
                            <div style="width:42px;height:42px;border-radius:10px;background:var(--mabb-blue);display:flex;align-items:center;justify-content:center;flex-shrink:0">
                                <i class="bi bi-gear-fill" style="color:#fff;font-size:1.1rem"></i>
                            </div>
                            <div style="flex:1;min-width:0">
                                <div style="font-weight:700;color:var(--mabb-dark);font-size:.92rem">MABB Manager</div>
                                <div style="font-size:.72rem;color:#64748b">Rejoins l'espace club en 1 clic (validé par un dirigeant)</div>
                            </div>
                            <button type="submit" class="btn btn-sm btn-mabb rounded-pill" style="white-space:nowrap;">Rejoindre</button>
                        </form>
                    {% endif %}

                    {# ===== PIRB — card selon la fiche joueuse liée ===== #}
                    {% if joueuse %}
                        <a href="https://pirb.mabb.fr" target="_blank" rel="noopener"
                           class="d-flex align-items-center gap-3 p-3 mb-2 text-decoration-none rounded"
                           style="border:2px solid var(--mabb-orange); background:#fff7ed; transition:transform .15s"
                           onmouseover="this.style.transform='translateY(-2px)'"
                           onmouseout="this.style.transform='none'">
                            <div style="width:42px;height:42px;border-radius:10px;background:var(--mabb-orange);display:flex;align-items:center;justify-content:center;flex-shrink:0">
                                <i class="bi bi-person-badge-fill" style="color:#fff;font-size:1.1rem"></i>
                            </div>
                            <div style="flex:1;min-width:0">
                                <div style="font-weight:700;color:var(--mabb-dark);font-size:.92rem">
                                    PIRB
                                    <span style="background:#dcfce7;color:#166534;font-size:.6rem;font-weight:700;padding:1px 6px;border-radius:8px;margin-left:4px">✅ Ta fiche : {{ joueuse.prenom }}</span>
                                </div>
                                <div style="font-size:.72rem;color:#64748b">Ton espace joueuse — stats, shot chart, bilan</div>
                            </div>
                            <i class="bi bi-box-arrow-up-right" style="color:var(--mabb-orange)"></i>
                        </a>
                    {% else %}
                        <div class="d-flex align-items-center gap-3 p-3 mb-2 rounded"
                             style="border:2px solid #e2e8f0; background:#f8fafc; opacity:.85;">
                            <div style="width:42px;height:42px;border-radius:10px;background:#94a3b8;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                                <i class="bi bi-person-badge-fill" style="color:#fff;font-size:1.1rem"></i>
                            </div>
                            <div style="flex:1;min-width:0">
                                <div style="font-weight:700;color:var(--mabb-dark);font-size:.92rem">PIRB <span style="font-size:.62rem; color:#64748b; font-weight:400;">(joueuses)</span></div>
                                <div style="font-size:.72rem;color:#64748b">Réservé aux joueuses licenciées — demande au staff de lier ta fiche.</div>
                            </div>
                        </div>
                    {% endif %}

                    <div class="d-flex flex-column gap-2 mt-3">
                        <a href="{{ path('vitrine_membres') }}" class="btn btn-sm btn-outline-secondary rounded-pill">
                            <i class="bi bi-people me-1"></i>Voir la page Membres
                        </a>
                        <a href="{{ path('vitrine_accueil') }}" class="btn btn-sm btn-outline-secondary rounded-pill">
                            <i class="bi bi-house me-1"></i>Retour à l'accueil
                        </a>
                    </div>
                </div>
                <div class="card card-mabb p-4">
                    <a href="{{ path('vitrine_logout') }}" class="btn btn-danger w-100 rounded-pill fw-semibold"
                       onclick="return confirm('Se déconnecter ?')">
                        <i class="bi bi-box-arrow-right me-1"></i>Se déconnecter
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
