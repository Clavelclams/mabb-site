{# templates/vitrine/compte/se_connecter.html.twig #}
{% extends 'vitrine/base.html.twig' %}

{% block title %}Connexion — MABB{% endblock %}

{% block body %}
<section class="auth-section">
    <div class="auth-container">
        <h1>Connexion</h1>

        {# Affiche les flash messages (ex: compte créé avec succès) #}
        {% for message in app.flashes('success') %}
            <div class="alert alert-success">{{ message }}</div>
        {% endfor %}

        {# Affiche l'erreur d'authentification si identifiants mauvais #}
        {% if error %}
            <div class="alert alert-error">
                {{ error.messageKey | trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        {#
            IMPORTANT : l'action pointe sur la MÊME route (check_path = login_path dans security.yaml).
            Symfony intercepte le POST automatiquement via le firewall.
            Les noms des champs doivent correspondre à :
            - username_parameter: _email  (défini dans security.yaml)
            - password_parameter: _password
        #}
        <form method="post" action="{{ path('vitrine_compte_se_connecter') }}">

            <div class="form-group">
                <label for="email">Adresse email</label>
                <input
                    type="email"
                    id="email"
                    name="_email"
                    value="{{ last_username }}"
                    required
                    autocomplete="email"
                    autofocus
                >
            </div>

            <div class="form-group">
                <label for="password">Mot de passe</label>
                <input
                    type="password"
                    id="password"
                    name="_password"
                    required
                    autocomplete="current-password"
                >
            </div>

            <div class="form-group form-check">
                <input type="checkbox" id="remember_me" name="_remember_me" value="on">
                <label for="remember_me">Se souvenir de moi</label>
            </div>

            {# Token CSRF généré automatiquement par Symfony — NE PAS ENLEVER #}
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button type="submit" class="btn btn-primary">Se connecter</button>

        </form>

        <p class="auth-link">
            Pas encore de compte ?
            <a href="{{ path('vitrine_compte_s_inscrire') }}">Créer un compte</a>
        </p>
    </div>
</section>
{% endblock %}
