{% extends 'vitrine/base.html.twig' %}
{% block title %}Clavel — Responsable Numérique MABB{% endblock %}
{% block body %}
<div class="page-header">
    <div class="container text-center">
        <span class="badge-label mb-3">🚧 Site en construction — Projet CDA</span>
        <h1>Clavel Ndema Moussa</h1>
        <p style="color:rgba(255,255,255,.75);font-size:1.05rem">Responsable Numérique — Amiens Métropole Basket Ball</p>
    </div>
</div>
<section class="section section-gray">
    <div class="container">
        <div class="row g-5 align-items-center">
            <div class="col-lg-6">
                <h2 class="section-title">Mon rôle à la MABB</h2>
                <p class="text-muted fs-5 mb-3">Responsable numérique bénévole, je mène la <strong>transformation digitale</strong> du club dans le cadre de ma formation CDA, avec l'accord du président <strong>Willy Dufossé</strong>.</p>
                <p class="text-muted">Ces projets constituent mon portfolio professionnel et démontrent une approche complète : conception, développement et déploiement d'applications réelles.</p>
                <p class="text-muted"><strong class="text-mabb-orange">VENA</strong> — mon projet entrepreneurial qui accompagne les associations sportives dans leur transformation numérique. La MABB est le premier projet concret.</p>
            </div>
            <div class="col-lg-6">
                <div class="card card-mabb p-4" style="background:linear-gradient(135deg,#063a55,#0b4fa3)">
                    <h3 class="text-white fw-bold mb-4">Les projets MABB</h3>
                    <div class="row g-3">
                        {% for projet in [
                            {icon:'🌐', name:'Site Vitrine', tech:'Symfony 7 · Twig · Bootstrap'},
                            {icon:'📱', name:'App Manager', tech:'React Native · Node.js · MySQL'},
                            {icon:'🏀', name:'PIRB', tech:'Stats · Gamification · Vidéo'},
                        ] %}
                        <div class="col-12">
                            <div style="background:rgba(255,255,255,.08);border-radius:10px;padding:12px 16px;display:flex;align-items:center;gap:12px">
                                <span style="font-size:1.6rem">{{ projet.icon }}</span>
                                <div>
                                    <div style="color:#fff;font-weight:600">{{ projet.name }}</div>
                                    <div style="color:rgba(255,255,255,.5);font-size:.8rem">{{ projet.tech }}</div>
                                </div>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
