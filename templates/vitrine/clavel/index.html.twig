{% extends 'vitrine/base.html.twig' %}
{% block title %}Clavel — Responsable Numérique MABB{% endblock %}
{% block body %}

<div class="page-header">
    <div class="container text-center">
        <span class="badge-label mb-3">🚧 Site en construction — Projet CDA</span>
        <h1>Clavel Ndema Moussa</h1>
        <p style="color:rgba(255,255,255,.75);font-size:1.05rem">Responsable Numérique — Amiens Métropole Basket Ball</p>
    </div>
</div>

<section class="section section-gray">
    <div class="container">
        <div class="row g-5 align-items-center">

            {# ===== Colonne gauche : présentation ===== #}
            <div class="col-lg-6">
                <h2 class="section-title">Mon rôle à la MABB</h2>
                <p class="text-muted fs-5 mb-3">Responsable numérique bénévole, je mène la <strong>transformation digitale</strong> du club dans le cadre de ma formation CDA, avec l'accord du président <strong>Willy Dufossé</strong>.</p>
                <p class="text-muted">Ces projets constituent mon portfolio professionnel et démontrent une approche complète : conception, développement et déploiement d'applications réelles.</p>
                <p class="text-muted"><strong class="text-mabb-orange">VENA</strong> — mon projet entrepreneurial qui accompagne les associations sportives dans leur transformation numérique. La MABB est le premier projet concret.</p>
            </div>

            {# ===== Colonne droite : card slider 2 vues (MABB / Velito) ===== #}
            <div class="col-lg-6">
                <div class="card card-mabb p-4" style="background:linear-gradient(135deg,var(--mabb-dark),var(--mabb-blue))">
                    {# Titre dynamique selon la vue active #}
                    <h3 class="text-white fw-bold mb-4" id="projet-titre">Les projets MABB</h3>

                    {# Zone de contenu — la liste des 3 projets de la vue active #}
                    <div class="row g-3" id="projet-liste"></div>

                    {# Footer navigation slider — même pattern que la card 3x3 #}
                    <div class="d-flex justify-content-between align-items-center mt-4 pt-3 gap-2" style="border-top:1px solid rgba(255,255,255,.15)">
                        <button type="button" id="projet-prev" class="btn btn-sm rounded-pill" style="background:rgba(255,255,255,.1);color:#fff;border:1px solid rgba(255,255,255,.3)">
                            <i class="bi bi-arrow-left me-1"></i>Précédent
                        </button>
                        <span id="projet-position" style="color:rgba(255,255,255,.7);font-size:.85rem;font-weight:600">1 / 2</span>
                        <button type="button" id="projet-next" class="btn btn-sm rounded-pill" style="background:#fc702a;color:#fff;border:1px solid #fc702a">
                            Suivant<i class="bi bi-arrow-right ms-1"></i>
                        </button>
                    </div>
                </div>

                <script>
                (function(){
                    // 2 vues : 0 = projets MABB, 1 = projets Velito
                    var vues = [
                        {
                            titre: "Les projets MABB",
                            projets: [
                                {icon:'🌐', name:'Site Vitrine', tech:'Symfony 7 · Twig · Bootstrap', url:'https://mabb.fr', external:true, statut:'En ligne'},
                                {icon:'📱', name:'App Manager', tech:'Symfony 7 · Doctrine · MariaDB', url:'https://manager.mabb.fr', external:true, statut:'En ligne'},
                                {icon:'🏀', name:'PIRB', tech:'Stats · Gamification · Vidéo', url:'{{ path('vitrine_pirb_construction') }}', external:false, statut:'Bientôt'}
                            ]
                        },
                        {
                            titre: "Mes autres projets — écosystème Velito",
                            projets: [
                                {logo:'{{ asset('images/projets/vea-logo.svg') }}', name:'VEA', tech:'Velito Esport Amiens — Asso loi 1901, inclusion par l\'esport', url:'https://vea.velito.fr', external:true, statut:'En ligne'},
                                {logo:'{{ asset('images/projets/vena-logo.svg') }}', name:'VENA', tech:'SASU — Sites & apps métier pour associations', url:'https://velito.fr', external:true, statut:'En ligne'},
                                {logo:'{{ asset('images/projets/interactive-logo.svg') }}', name:'Interactive', tech:'Jeu interactif web — motion, 3D, R&D front-end', url:'https://interactive.velito.fr', external:true, statut:'En ligne'}
                            ]
                        }
                    ];
                    var idx = 0;

                    function render(){
                        var vue = vues[idx];
                        document.getElementById("projet-titre").textContent = vue.titre;
                        document.getElementById("projet-position").textContent = (idx+1) + " / " + vues.length;

                        var html = vue.projets.map(function(p){
                            // Visuel de gauche : soit emoji (MABB), soit logo image (Velito)
                            var visuel = p.logo
                                ? '<img src="' + p.logo + '" alt="' + p.name + '" style="height:32px;width:32px;object-fit:contain;flex-shrink:0">'
                                : '<span style="font-size:1.6rem;flex-shrink:0">' + p.icon + '</span>';

                            var badgeStatut = p.statut === 'En ligne'
                                ? '<span style="background:#16a34a;color:#fff;font-size:.6rem;font-weight:700;padding:1px 6px;border-radius:8px;margin-left:4px">✅ ' + p.statut + '</span>'
                                : '<span style="background:#f59e0b;color:#fff;font-size:.6rem;font-weight:700;padding:1px 6px;border-radius:8px;margin-left:4px">🚧 ' + p.statut + '</span>';

                            var iconRight = p.external
                                ? '<i class="bi bi-box-arrow-up-right" style="color:rgba(255,255,255,.6)"></i>'
                                : '<i class="bi bi-chevron-right" style="color:rgba(255,255,255,.6)"></i>';

                            var openInBlank = p.external ? ' target="_blank" rel="noopener"' : '';

                            return '<div class="col-12">' +
                                '<a href="' + p.url + '"' + openInBlank + ' style="text-decoration:none;display:block">' +
                                    '<div class="projet-row" style="background:rgba(255,255,255,.08);border-radius:10px;padding:12px 16px;display:flex;align-items:center;gap:12px;transition:background .15s;cursor:pointer">' +
                                        visuel +
                                        '<div style="flex:1;min-width:0">' +
                                            '<div style="color:#fff;font-weight:600">' + p.name + badgeStatut + '</div>' +
                                            '<div style="color:rgba(255,255,255,.5);font-size:.8rem">' + p.tech + '</div>' +
                                        '</div>' +
                                        iconRight +
                                    '</div>' +
                                '</a>' +
                            '</div>';
                        }).join('');

                        document.getElementById("projet-liste").innerHTML = html;

                        // Hover effect sur chaque ligne (vanilla, comme l'ancien onmouseover)
                        document.querySelectorAll('#projet-liste .projet-row').forEach(function(row){
                            row.addEventListener('mouseenter', function(){ this.style.background = 'rgba(255,255,255,.16)'; });
                            row.addEventListener('mouseleave', function(){ this.style.background = 'rgba(255,255,255,.08)'; });
                        });
                    }

                    document.getElementById("projet-prev").addEventListener("click", function(){
                        idx = (idx - 1 + vues.length) % vues.length;
                        render();
                    });
                    document.getElementById("projet-next").addEventListener("click", function(){
                        idx = (idx + 1) % vues.length;
                        render();
                    });
                    render();
                })();
                </script>
            </div>
        </div>
    </div>
</section>
{% endblock %}
