{# Bandeau cookies RGPD — informatif. Le site n'utilise que des cookies
   nécessaires à son fonctionnement (session), pas de traceur publicitaire :
   un acquittement simple suffit (CNIL). Choix mémorisé en localStorage. #}
<div id="cookieBanner" class="cookie-banner" role="dialog" aria-live="polite"
     aria-label="Information cookies" style="display:none;">
    <div class="cookie-inner">
        <span>🍪 Ce site utilise uniquement des cookies nécessaires à son bon fonctionnement.
            En poursuivant ta navigation, tu acceptes notre
            <a href="{{ path('vitrine_confidentialite') }}">politique de confidentialité</a>.</span>
        <button type="button" id="cookieAccept" class="cookie-btn">J'ai compris</button>
    </div>
</div>
<style>
    .cookie-banner{position:fixed;left:0;right:0;bottom:0;z-index:1080;background:var(--mabb-blue,#0d1b2a);color:#fff;padding:14px 16px;box-shadow:0 -2px 12px rgba(0,0,0,.25);}
    .cookie-inner{max-width:1100px;margin:0 auto;display:flex;gap:14px;align-items:center;justify-content:center;flex-wrap:wrap;font-size:.9rem;}
    .cookie-inner a{color:var(--mabb-orange,#fc702a);text-decoration:underline;}
    .cookie-btn{background:#fc702a;color:#fff;border:none;border-radius:999px;padding:8px 22px;font-weight:600;cursor:pointer;white-space:nowrap;}
</style>
<script>
    (function () {
        try {
            var banner = document.getElementById('cookieBanner');
            if (banner && !localStorage.getItem('mabb_cookies_ok')) {
                banner.style.display = 'block';
            }
            var btn = document.getElementById('cookieAccept');
            if (btn) {
                btn.addEventListener('click', function () {
                    try { localStorage.setItem('mabb_cookies_ok', '1'); } catch (e) {}
                    if (banner) { banner.style.display = 'none'; }
                });
            }
        } catch (e) { /* localStorage indispo (navigation privée) : on n'affiche rien plutôt que de planter */ }
    })();
</script>
