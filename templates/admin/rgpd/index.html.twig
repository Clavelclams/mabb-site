{% extends 'admin/base.html.twig' %}

{% block title %}Demandes RGPD — Admin MABB{% endblock %}

{% block body %}

<div class="page-header">
    <h1><i class="bi bi-shield-check"></i> Demandes RGPD</h1>
    <div style="color:#64748b; font-size:.88rem;">
        {{ pending|length }} en attente · {{ recent|length }} récentes
    </div>
</div>

{% for label, messages in app.flashes(['success', 'warning', 'error']) %}
    {% for message in messages %}
        <div class="alert alert-{{ label == 'error' ? 'danger' : label }}" style="font-size:.88rem;">{{ message }}</div>
    {% endfor %}
{% endfor %}

{# === En attente === #}
<div class="card-mabb">
    <div class="card-header"><i class="bi bi-hourglass-split"></i> Demandes en attente</div>
    <div class="card-body">
        {% if pending is empty %}
            <p style="text-align:center; color:#94a3b8; padding:30px 0;">Aucune demande en attente ✓</p>
        {% else %}
            {% for req in pending %}
                <div style="border:1px solid #fcd34d; background:#fef3c7; border-radius:10px; padding:16px; margin-bottom:14px;">
                    <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:16px;">
                        <div style="flex:1;">
                            <div style="font-weight:800; color:#92400e;">
                                {% if req.type == 'effacement' %}
                                    🗑️ Effacement
                                {% else %}
                                    📥 Export
                                {% endif %}
                                — {{ req.user.prenom }} {{ req.user.nom }}
                            </div>
                            <div style="color:#78350f; font-size:.82rem; margin-top:4px;">
                                <i class="bi bi-envelope"></i> {{ req.user.email }} ·
                                Demande du {{ req.requestedAt|date('d/m/Y H:i') }}
                                ({{ req.requestedAt|date('U')|date_modify('+30 days')|date('d/m/Y') }} = deadline RGPD)
                            </div>
                            {% if req.motifUser %}
                                <div style="margin-top:10px; padding:10px 12px; background:#fff; border-radius:8px; font-size:.85rem; color:#475569;">
                                    <strong>Motif du user :</strong> {{ req.motifUser }}
                                </div>
                            {% endif %}
                        </div>
                        <div style="display:flex; flex-direction:column; gap:6px; min-width:170px;">
                            <form method="POST" action="{{ path('admin_rgpd_valider', {id: req.id}) }}"
                                  onsubmit="return confirm('VALIDER cette demande ?\n\nEffacement = IRRÉVERSIBLE.\nL\'user sera anonymisé : nom, email, téléphone, photo effacés.\nHistorique club (présences, scores) conservé sous forme pseudonymisée.');">
                                <input type="hidden" name="_token" value="{{ csrf_token('rgpd_valider_' ~ req.id) }}">
                                <button type="submit" class="btn-mabb-primary btn-sm" style="background:#dc2626; border-color:#dc2626;">
                                    <i class="bi bi-check-lg"></i> Valider + Anonymiser
                                </button>
                            </form>
                            <a href="{{ path('admin_rgpd_export', {userId: req.user.id}) }}"
                               class="btn-mabb-ghost btn-sm" style="font-size:.78rem;">
                                <i class="bi bi-download"></i> Exporter ses données
                            </a>
                            <details>
                                <summary style="cursor:pointer; font-size:.78rem; color:#78350f;">Refuser</summary>
                                <form method="POST" action="{{ path('admin_rgpd_refuser', {id: req.id}) }}" style="margin-top:8px;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('rgpd_refuser_' ~ req.id) }}">
                                    <input type="text" name="motif_admin" placeholder="Motif (obligatoire)" required
                                           style="width:100%; padding:6px 8px; font-size:.78rem; border:1px solid #d97706; border-radius:6px;">
                                    <button type="submit" class="btn-mabb-ghost btn-sm" style="margin-top:4px; font-size:.78rem; color:#991b1b;">
                                        Refuser
                                    </button>
                                </form>
                            </details>
                        </div>
                    </div>
                </div>
            {% endfor %}
        {% endif %}
    </div>
</div>

{# === Historique récent === #}
{% if recent|length > 0 %}
<div class="card-mabb" style="margin-top:16px;">
    <div class="card-header"><i class="bi bi-clock-history"></i> Historique récent</div>
    <div class="card-body" style="padding:0;">
        <table class="table-mabb" style="width:100%; font-size:.85rem;">
            <thead>
                <tr style="background:#f8fafc;">
                    <th>Date</th>
                    <th>Type</th>
                    <th>User</th>
                    <th>Statut</th>
                    <th>Traitée par</th>
                </tr>
            </thead>
            <tbody>
                {% for req in recent %}
                    <tr style="border-top:1px solid #e2e8f0;">
                        <td>{{ req.requestedAt|date('d/m/Y') }}</td>
                        <td>{{ req.type }}</td>
                        <td>{{ req.user.email|default('—') }}</td>
                        <td>
                            {% set color = req.statut == 'effectuee' ? '#065f46;background:#d1fae5'
                                         : req.statut == 'refusee' ? '#991b1b;background:#fee2e2'
                                         : req.statut == 'validee' ? '#1e3a8a;background:#dbeafe'
                                         : '#78350f;background:#fef3c7' %}
                            <span style="padding:2px 10px; border-radius:10px; font-size:.72rem; font-weight:700; color:{{ color }};">{{ req.statut }}</span>
                        </td>
                        <td>{{ req.traiteePar ? req.traiteePar.prenom ~ ' ' ~ req.traiteePar.nom : '—' }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}

{% endblock %}
