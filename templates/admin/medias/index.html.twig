{% extends 'vitrine/base.html.twig' %}

{% block title %}Galerie — Admin MABB{% endblock %}

{% block body %}
<div class="page-header">
    <div class="container">
        <h1>Galerie photos</h1>
        <p style="color:rgba(255,255,255,.75)">{{ medias|length }} photo(s) — upload multiple possible</p>
    </div>
</div>

<section class="section section-gray">
    <div class="container">

        {% for label, messages in app.flashes %}
            {% for msg in messages %}
                <div class="alert alert-{{ label == 'success' ? 'success' : 'danger' }} rounded-3 mb-3">{{ msg }}</div>
            {% endfor %}
        {% endfor %}

        {# Formulaire upload #}
        <div class="card card-mabb p-4 mb-5">
            <h5 class="fw-bold mb-3">
                <i class="bi bi-cloud-upload me-2" style="color:#0b4fa3"></i>Uploader des photos
            </h5>
            <form method="post" action="{{ path('admin_medias_upload') }}" enctype="multipart/form-data">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('media_upload') }}">
                <div class="row g-3">
                    <div class="col-md-8">
                        <input type="file" name="photos[]" accept="image/*"
                               multiple class="form-control" required>
                        <div class="form-text">JPG, PNG, WebP — plusieurs fichiers possibles (Ctrl+clic)</div>
                    </div>
                    <div class="col-md-4">
                        <input type="text" name="legende" class="form-control"
                               placeholder="Légende (optionnel)">
                    </div>
                </div>
                <button type="submit" class="btn btn-mabb mt-3">
                    <i class="bi bi-cloud-upload me-1"></i>Uploader
                </button>
            </form>
        </div>

        {# Grille photos #}
        {% if medias|length == 0 %}
            <div class="text-center py-5">
                <div style="font-size:3rem">📷</div>
                <h3 class="mt-3" style="color:#063a55">Aucune photo</h3>
                <p class="text-muted">Uploadez vos premières photos ci-dessus.</p>
            </div>
        {% else %}
            <div class="row g-3">
                {% for media in medias %}
                <div class="col-6 col-md-4 col-lg-3">
                    <div class="card card-mabb overflow-hidden h-100">
                        <img src="{{ asset('uploads/galerie/' ~ media.path) }}"
                             alt="{{ media.legende ?? media.nom }}"
                             loading="lazy"
                             style="height:180px;object-fit:cover;width:100%">
                        <div class="p-2 d-flex justify-content-between align-items-center gap-2">
                            <small class="text-muted text-truncate" style="max-width:120px"
                                   title="{{ media.legende ?? media.nom }}">
                                {{ media.legende ?? media.nom }}
                            </small>
                            <form method="post"
                                  action="{{ path('admin_medias_delete', {id: media.id}) }}"
                                  onsubmit="return confirm('Supprimer cette photo ?')">
                                <input type="hidden" name="_csrf_token"
                                       value="{{ csrf_token('delete_media_' ~ media.id) }}">
                                <button type="submit"
                                        class="btn btn-sm btn-outline-danger rounded-pill flex-shrink-0">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        {% endif %}

        <div class="d-flex gap-2 mt-4 flex-wrap">
            <a href="{{ path('admin_articles_list') }}"
               class="btn btn-outline-secondary rounded-pill">
                <i class="bi bi-newspaper me-1"></i>Articles
            </a>
            <a href="{{ path('vitrine_galerie') }}"
               class="btn btn-outline-secondary rounded-pill" target="_blank">
                <i class="bi bi-eye me-1"></i>Voir la galerie
            </a>
            <a href="{{ path('vitrine_accueil') }}"
               class="btn btn-outline-secondary rounded-pill">
                <i class="bi bi-arrow-left me-1"></i>Retour au site
            </a>
        </div>

    </div>
</section>
{% endblock %}
