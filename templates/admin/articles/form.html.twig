{% extends 'vitrine/base.html.twig' %}
{% block title %}{{ article ? 'Modifier' : 'Nouvel' }} article — Admin MABB{% endblock %}

{% block body %}
<div class="page-header">
    <div class="container">
        <h1>{{ article ? 'Modifier l\'article' : 'Nouvel article' }}</h1>
    </div>
</div>

<section class="section section-gray">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card card-mabb p-4">

                    {% if errors is defined and errors|length > 0 %}
                        <div class="alert alert-danger rounded-3 mb-4">
                            {% for error in errors %}<div>{{ error }}</div>{% endfor %}
                        </div>
                    {% endif %}

                    <form method="post"
                          action="{{ article ? path('admin_articles_edit', {id: article.id}) : path('admin_articles_new') }}"
                          enctype="multipart/form-data">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('article_form') }}">

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Titre <span class="text-danger">*</span></label>
                            <input type="text" name="titre" class="form-control form-control-lg"
                                   value="{{ article ? article.titre : '' }}" required
                                   placeholder="Titre de l'article">
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Contenu <span class="text-danger">*</span></label>
                            <textarea name="contenu" id="contenu" class="form-control" rows="12"
                                      placeholder="Rédigez votre article ici...">{{ article ? article.contenu : '' }}</textarea>
                            <div class="form-text">
                                <i class="bi bi-info-circle me-1"></i>
                                Éditeur visuel — utilisez les boutons de la barre pour mettre en forme.
                                Les liens, images et listes sont supportés.
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Image principale</label>
                            {% if article and article.imagePath %}
                                <div class="mb-2">
                                    <img src="{{ asset('uploads/articles/' ~ article.imagePath) }}"
                                         style="max-height:120px;border-radius:8px" alt="Image actuelle">
                                    <div class="form-text">Image actuelle — uploader une nouvelle image pour la remplacer</div>
                                </div>
                            {% endif %}
                            <input type="file" name="image" accept="image/*" class="form-control">
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Statut</label>
                            <select name="statut" class="form-select">
                                <option value="brouillon" {{ (article and article.statut == 'brouillon') or not article ? 'selected' : '' }}>
                                    📝 Brouillon
                                </option>
                                <option value="publie" {{ article and article.statut == 'publie' ? 'selected' : '' }}>
                                    ✅ Publié
                                </option>
                                <option value="archive" {{ article and article.statut == 'archive' ? 'selected' : '' }}>
                                    📦 Archivé
                                </option>
                            </select>
                            <div class="form-text">Passer en "Publié" rend l'article visible sur le site.</div>
                        </div>

                        <div class="d-flex gap-3">
                            <button type="submit" class="btn btn-mabb px-4">
                                <i class="bi bi-check-lg me-1"></i>
                                {{ article ? 'Enregistrer' : 'Créer l\'article' }}
                            </button>
                            <a href="{{ path('admin_articles_list') }}"
                               class="btn btn-outline-secondary rounded-pill">Annuler</a>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}

{% block extra_js %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/easymde@2.18.0/dist/easymde.min.css">
<script src="https://cdn.jsdelivr.net/npm/easymde@2.18.0/dist/easymde.min.js"></script>
<script>
    const easyMDE = new EasyMDE({
        element: document.getElementById('contenu'),
        spellChecker: false,
        placeholder: 'Rédigez votre article ici...\n\nAstuce : sélectionnez du texte pour voir les options de mise en forme.',
        toolbar: [
            'bold', 'italic', 'heading', '|',
            'quote', 'unordered-list', 'ordered-list', '|',
            'link', 'image', '|',
            'preview', 'side-by-side', '|',
            'guide'
        ],
        status: false,
        autosave: {
            enabled: true,
            uniqueId: 'article-editor',
            delay: 3000,
        },
    });
</script>
{% endblock %}
