{% extends 'vitrine/base.html.twig' %}
{% block title %}Admin — Gestion des rôles{% endblock %}
{% block body %}
<div class="page-header">
    <div class="container text-center">
        <h1>🛡 Gestion des rôles</h1>
        <p style="color:rgba(255,255,255,.75)">Accès super admin uniquement — {{ utilisateurs|length }} utilisateur(s)</p>
    </div>
</div>
<section class="section section-gray">
    <div class="container">
        {% for label, messages in app.flashes %}
            {% for msg in messages %}
                <div class="alert alert-{{ label == 'success' ? 'success' : 'danger' }} rounded-3 mb-4">{{ msg }}</div>
            {% endfor %}
        {% endfor %}

        <div class="card card-mabb">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead style="background:#f8f9fa">
                        <tr>
                            <th class="px-4 py-3">Utilisateur</th>
                            <th class="py-3">Email</th>
                            <th class="py-3">Rôles vitrine</th>
                            <th class="py-3">Profil public</th>
                            <th class="py-3">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for user in utilisateurs %}
                        <tr>
                            <td class="px-4 py-3 fw-semibold">{{ user.prenom }} {{ user.nom }}</td>
                            <td class="py-3 text-muted small">{{ user.email }}</td>
                            <td class="py-3">
                                {% for role in user.rolesMembre %}
                                    <span class="badge rounded-pill me-1"
                                          style="background:{% if role == 'benevole' %}#6c757d{% else %}var(--mabb-orange){% endif %}">
                                        {{ role }}
                                    </span>
                                {% endfor %}
                            </td>
                            <td class="py-3">
                                {% if user.isPublic %}
                                    <span class="badge bg-success">Oui</span>
                                {% else %}
                                    <span class="badge bg-secondary">Non</span>
                                {% endif %}
                            </td>
                            <td class="py-3">
                                <a href="{{ path('admin_utilisateur_roles', {id: user.id}) }}"
                                   class="btn btn-sm btn-outline-secondary rounded-pill">
                                    <i class="bi bi-pencil me-1"></i>Rôles
                                </a>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        <div class="mt-4">
            <a href="{{ path('vitrine_accueil') }}" class="btn btn-outline-secondary rounded-pill">
                <i class="bi bi-arrow-left me-1"></i>Retour accueil
            </a>
        </div>
    </div>
</section>
{% endblock %}
