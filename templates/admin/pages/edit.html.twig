{% extends 'vitrine/base.html.twig' %}

{% block title %}Modifier {{ page.pageNom }} — Admin MABB{% endblock %}

{% block body %}
<div class="page-header">
    <div class="container">
        <h1>Modifier : {{ page.pageNom }}</h1>
        <p style="color:rgba(255,255,255,.75)">Page : /{{ page.pageSlug }}</p>
    </div>
</div>

<section class="section section-gray">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-9">

                {% for label, messages in app.flashes %}
                    {% for msg in messages %}
                        <div class="alert alert-{{ label == 'success' ? 'success' : 'danger' }} rounded-3 mb-3">{{ msg }}</div>
                    {% endfor %}
                {% endfor %}

                <div class="card card-mabb p-4">
                    <form method="post"
                          action="{{ path('admin_pages_edit', {id: page.id}) }}"
                          enctype="multipart/form-data">
                        <input type="hidden" name="_csrf_token"
                               value="{{ csrf_token('page_edit_' ~ page.id) }}">

                        {# Nom (lecture seule) #}
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Nom de la page</label>
                            <input type="text" class="form-control" value="{{ page.pageNom }}" disabled>
                            <div class="form-text text-muted">Le nom de la page n'est pas modifiable ici.</div>
                        </div>

                        {# Sous-titre #}
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Sous-titre de la page</label>
                            <input type="text" name="sousTitre" class="form-control"
                                   value="{{ page.sousTitre }}"
                                   placeholder="Ex: La MABB et la Cité Scolaire...">
                        </div>

                        {# Image de couverture #}
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Image de couverture (header)</label>
                            {% if page.imagePath %}
                                <div class="mb-2 d-flex align-items-center gap-3">
                                    <img src="{{ asset('uploads/pages/' ~ page.imagePath) }}"
                                         style="max-height:80px;border-radius:8px;border:2px solid #dee2e6" alt="Image actuelle">
                                    <span class="text-muted small">Image actuelle — uploader une nouvelle pour remplacer</span>
                                </div>
                            {% endif %}
                            <input type="file" name="image" accept="image/*" class="form-control">
                            <div class="form-text">JPG ou PNG recommandé — affichée en arrière-plan du header de la page.</div>
                        </div>

                        {# Couleur du texte header #}
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Couleur du texte du header</label>
                            <div class="d-flex gap-2 flex-wrap" id="palette-couleurs">
                                {% set couleurs = [
                                    {hex: '#ffffff', label: 'Blanc'},
                                    {hex: '#063a55', label: 'Bleu foncé'},
                                    {hex: '#0b4fa3', label: 'Bleu MABB'},
                                    {hex: '#ff8c00', label: 'Orange MABB'},
                                    {hex: '#1c88b6', label: 'Bleu clair'},
                                    {hex: '#222222', label: 'Noir'},
                                ] %}
                                {% for c in couleurs %}
                                    <label class="couleur-swatch d-flex align-items-center gap-2 px-3 py-2 rounded-pill"
                                           style="border:2px solid {{ c.hex == (page.couleurTexte ?? '#ffffff') ? c.hex : '#dee2e6' }};background:{{ c.hex == (page.couleurTexte ?? '#ffffff') ? c.hex ~ '22' : '#f8f9fa' }};cursor:pointer;transition:all .15s">
                                        <input type="radio" name="couleurTexte" value="{{ c.hex }}"
                                               {{ c.hex == (page.couleurTexte ?? '#ffffff') ? 'checked' : '' }}
                                               style="display:none" class="radio-couleur">
                                        <span style="width:18px;height:18px;border-radius:50%;background:{{ c.hex }};border:2px solid #ccc;display:inline-block;flex-shrink:0"></span>
                                        <span class="small fw-semibold" style="color:#444">{{ c.label }}</span>
                                    </label>
                                {% endfor %}
                            </div>
                            <div class="form-text">Choisir la couleur du titre et sous-titre affichés sur le header de la page.</div>
                        </div>

                        {# Contenu principal (Quill) #}
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Contenu principal</label>
                            <div id="quill-page">{{ page.contenu|raw }}</div>
                            <textarea name="contenu" id="pageContenu" style="display:none">{{ page.contenu }}</textarea>
                            <div class="form-text">
                                <i class="bi bi-info-circle me-1"></i>
                                Éditeur Quill — mise en forme, couleurs, liens et images.
                            </div>
                        </div>

                        <div class="d-flex gap-3">
                            <button type="submit" class="btn btn-mabb px-4">
                                <i class="bi bi-check-lg me-1"></i>Enregistrer
                            </button>
                            <a href="{{ path('admin_pages_list') }}"
                               class="btn btn-outline-secondary rounded-pill">Annuler</a>
                        </div>
                    </form>
                </div>

            </div>
        </div>
    </div>
</section>
{% endblock %}

{% block extra_js %}
{# Interaction visuelle palette couleurs #}
<style>
.couleur-swatch:has(input:checked) {
    border-color: #0b4fa3 !important;
    background: rgba(11,79,163,.1) !important;
    box-shadow: 0 0 0 2px rgba(11,79,163,.25);
}
.couleur-swatch:hover { opacity: .85; }
</style>
<script>
document.querySelectorAll('.radio-couleur').forEach(function(radio) {
    radio.addEventListener('change', function() {
        document.querySelectorAll('.couleur-swatch').forEach(function(label) {
            label.style.borderColor = '#dee2e6';
            label.style.background  = '#f8f9fa';
            label.style.boxShadow   = '';
        });
        var parent = radio.closest('.couleur-swatch');
        parent.style.borderColor = '#0b4fa3';
        parent.style.background  = 'rgba(11,79,163,.1)';
        parent.style.boxShadow   = '0 0 0 2px rgba(11,79,163,.25)';
    });
});
</script>

{# Quill CDN #}
<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
<script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
<style>
    #quill-page { height: 300px; background: #fff; font-size: 15px; }
    #quill-page .ql-toolbar.ql-snow { border-radius: 6px 6px 0 0; background: #f8f9fa; }
    #quill-page .ql-container.ql-snow { border-radius: 0 0 6px 6px; }
</style>
<script>
var quill = new Quill('#quill-page', {
    theme: 'snow',
    modules: {
        toolbar: [
            [{ 'header': [1, 2, 3, false] }],
            ['bold', 'italic', 'underline'],
            [{ 'color': ['#ffffff','#063a55','#ff8c00','#6c757d','#1a1a2e','#0b4fa3','#343a40'] }],
            [{ 'align': [] }],
            [{ 'list': 'ordered'}, { 'list': 'bullet' }],
            ['link', 'image'],
            ['clean']
        ]
    },
    placeholder: 'Contenu de la page...'
});
var existing = document.getElementById('pageContenu').value;
if (existing) {
    quill.root.innerHTML = existing;
}
document.querySelector('form').addEventListener('submit', function() {
    document.getElementById('pageContenu').value = quill.root.innerHTML;
});
</script>
{% endblock %}
