{# templates/admin/login.html.twig #}
{# Formulaire de connexion de l'espace /admin — firewall "vitrine_admin" #}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Administration — MABB</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #0b1f3a 0%, #063a55 50%, #0b4fa3 100%);
            font-family: 'Segoe UI', sans-serif;
        }
        .login-card {
            background: #fff;
            border-radius: 16px;
            padding: 44px 40px;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 20px 60px rgba(0,0,0,.35);
        }
        .login-badge {
            display: inline-block;
            background: #fef3e2;
            color: #d97706;
            border: 1px solid #fcd34d;
            border-radius: 20px;
            font-size: .75rem;
            font-weight: 700;
            padding: 4px 12px;
            margin-bottom: 16px;
            text-transform: uppercase;
            letter-spacing: .5px;
        }
        .login-card h1 { font-size: 1.6rem; font-weight: 800; color: #0b1f3a; }
        .login-card .subtitle { font-size: .85rem; color: #64748b; margin-bottom: 28px; }
        .form-control {
            background: #f8fafc;
            border: 1.5px solid #e2e8f0;
            border-radius: 10px;
            padding: 11px 14px;
            font-size: .93rem;
        }
        .form-control:focus {
            border-color: #0b4fa3;
            box-shadow: 0 0 0 3px rgba(11,79,163,.12);
            background: #fff;
        }
        .form-label { font-size: .83rem; font-weight: 600; color: #1e293b; }
        .btn-login {
            width: 100%;
            padding: 12px;
            background: #0b4fa3;
            border: none;
            border-radius: 10px;
            color: #fff;
            font-weight: 700;
            font-size: .95rem;
            transition: background .2s;
            margin-top: 6px;
        }
        .btn-login:hover { background: #063a55; color: #fff; }
        .alert-err {
            background: #fef2f2;
            border: 1px solid #fecaca;
            border-radius: 8px;
            color: #dc2626;
            padding: 10px 14px;
            font-size: .85rem;
            margin-bottom: 18px;
        }
        .back-link { font-size: .8rem; color: #94a3b8; text-align: center; margin-top: 18px; }
        .back-link a { color: #0b4fa3; text-decoration: none; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="login-badge">⚙️ Administration</div>

        <h1>Espace Admin</h1>
        <p class="subtitle">Accès réservé aux super administrateurs MABB</p>

        {# Affichage de l'erreur de connexion (identifiants incorrects, compte inactif...) #}
        {% if error %}
            <div class="alert-err">
                <i class="bi bi-exclamation-triangle me-1"></i>
                {{ error.messageKey | trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        {#
            CSRF Token obligatoire — protège contre les attaques CSRF (Cross-Site Request Forgery).
            Sans ce token, un site malveillant pourrait soumettre le formulaire à ta place.
            Symfony vérifie ce token automatiquement lors du traitement du POST.
        #}
        <form method="post" action="{{ path('admin_login') }}">

            <div class="mb-3">
                <label class="form-label" for="email">Email</label>
                <input
                    type="email"
                    id="email"
                    name="_email"
                    class="form-control"
                    value="{{ last_username }}"
                    autocomplete="email"
                    autofocus
                    required
                    placeholder="admin@mabb.fr"
                >
            </div>

            <div class="mb-3">
                <label class="form-label" for="password">Mot de passe</label>
                <input
                    type="password"
                    id="password"
                    name="_password"
                    class="form-control"
                    autocomplete="current-password"
                    required
                    placeholder="••••••••"
                >
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button type="submit" class="btn btn-login">
                <i class="bi bi-shield-lock me-2"></i>Se connecter
            </button>

        </form>

        <p class="back-link">
            <a href="{{ path('vitrine_accueil') }}">← Retour au site</a>
        </p>
    </div>
</body>
</html>
