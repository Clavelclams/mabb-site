{% extends 'manager/base.html.twig' %}

{# [V2.4h] Pré-inscriptions déposées via la vitrine (mabb.fr/pre-inscription).
   Conversion en un clic : dossier licence + contact parent + fiche joueuse.
   L'anti-doublon est VISIBLE : « fiche existante détectée » avant conversion. #}

{% block title %}Pré-inscriptions{% endblock %}

{% block body %}
    <div class="page-header">
        <div>
            <h1><i class="bi bi-inbox"></i> Pré-inscriptions</h1>
            <p class="subtitle">{{ nb_nouvelles }} nouvelle{{ nb_nouvelles > 1 ? 's' : '' }} demande{{ nb_nouvelles > 1 ? 's' : '' }} — formulaire public : mabb.fr/pre-inscription</p>
        </div>
        <a href="{{ path('manager_secretariat_licences') }}" class="btn-mabb-ghost"><i class="bi bi-journal-bookmark"></i> Classeur</a>
    </div>

    {# Filtre statut #}
    <div style="display:flex; gap:6px; margin-bottom:14px;">
        {% for code, label in {'NOUVELLE': 'Nouvelles', 'CONVERTIE': 'Converties', 'REFUSEE': 'Refusées'} %}
            <a href="{{ path('manager_secretariat_pre_inscriptions', {statut: code}) }}"
               class="{{ statut == code ? 'btn-mabb-orange' : 'btn-mabb-ghost' }}" style="font-size:.8rem;">{{ label }}</a>
        {% endfor %}
    </div>

    {% if liste is empty %}
        <div class="card-mabb"><div class="card-body" style="text-align:center; color:var(--mabb-muted); padding:40px;">
            <i class="bi bi-inbox" style="font-size:2rem;"></i>
            <p style="margin:10px 0 0;">Aucune pré-inscription {{ statut == 'NOUVELLE' ? 'en attente' : (statut|lower) }}.</p>
        </div></div>
    {% endif %}

    {% for pre in liste %}
        <div class="card-mabb" style="margin-bottom:12px;">
            <div class="card-body" style="display:flex; gap:16px; flex-wrap:wrap;">
                <div style="flex:1; min-width:260px;">
                    <div style="font-weight:700; font-size:1rem;">
                        {{ pre.nomComplet }}
                        {% if pre.dateNaissance %}<small style="color:var(--mabb-muted); font-weight:400;"> · née le {{ pre.dateNaissance|date('d/m/Y') }}</small>{% endif %}
                    </div>
                    <div style="font-size:.8rem; color:var(--mabb-muted); margin-top:4px;">
                        Déposée le {{ pre.createdAt|date('d/m/Y à H\\hi') }} · saison {{ pre.saison }}
                        {% if pre.categorie %} · catégorie souhaitée : {{ pre.categorie }}{% endif %}
                        {% if pre.secteurSouhaite %} · secteur souhaité : <strong>{{ pre.secteurSouhaite }}</strong>{% endif %}
                        {% if pre.telephoneJoueuse %} · <i class="bi bi-telephone"></i> {{ pre.telephoneJoueuse }}{% endif %}
                    </div>
                    {% if pre.parentNom %}
                        <div style="font-size:.82rem; margin-top:6px; padding:8px 10px; background:#f8fafc; border:1px solid var(--mabb-border); border-radius:8px;">
                            <i class="bi bi-person-hearts"></i> <strong>{{ pre.parentNom }}</strong>
                            {% if pre.parentTelephone %} · {{ pre.parentTelephone }}{% endif %}
                            {% if pre.parentEmail %} · {{ pre.parentEmail }}{% endif %}
                            {% if pre.parentAdresse %}<br><small style="color:var(--mabb-muted);">{{ pre.parentAdresse }}{% if pre.parentCodePostal %}, {{ pre.parentCodePostal }}{% endif %}</small>{% endif %}
                        </div>
                    {% endif %}

                    {% if pre.isNouvelle %}
                        {% set fiche = fiches_detectees[pre.id] ?? null %}
                        {% if fiche %}
                            <div style="font-size:.78rem; margin-top:6px; color:#16a34a;">
                                <i class="bi bi-patch-check-fill"></i> Fiche existante détectée :
                                <a href="{{ path('manager_joueur_show', {id: fiche.id}) }}">{{ fiche.prenom }} {{ fiche.nom }}</a>
                                — la conversion s'y rattachera (pas de doublon).
                            </div>
                        {% else %}
                            <div style="font-size:.78rem; margin-top:6px; color:#a16207;">
                                <i class="bi bi-person-plus"></i> Aucune fiche joueuse trouvée — coche « créer la fiche » pour l'ajouter.
                            </div>
                        {% endif %}
                    {% elseif pre.traiteLe %}
                        <div style="font-size:.76rem; margin-top:6px; color:var(--mabb-muted);">
                            Traitée le {{ pre.traiteLe|date('d/m/Y') }}{% if pre.traitePar %} par {{ pre.traitePar.prenom }}{% endif %}
                            {% if pre.noteTraitement %} — {{ pre.noteTraitement }}{% endif %}
                        </div>
                    {% endif %}
                </div>

                {% if pre.isNouvelle %}
                <div style="min-width:260px; display:flex; flex-direction:column; gap:8px;">
                    <form method="post" action="{{ path('manager_secretariat_pre_inscription_convertir', {id: pre.id}) }}"
                          style="display:flex; flex-direction:column; gap:6px; border:1px solid var(--mabb-border); border-radius:10px; padding:10px;">
                        <input type="hidden" name="_token" value="{{ csrf_token('pre_convertir_' ~ pre.id) }}">
                        <select name="secteur" class="form-select" style="font-size:.78rem;">
                            <option value="">Secteur : {{ pre.secteurSouhaite ?? 'À placer' }}</option>
                            {% for s in secteurs %}<option value="{{ s.nom }}">{{ s.nom }}</option>{% endfor %}
                        </select>
                        <div style="display:flex; gap:6px;">
                            <input type="text" name="categorie" class="form-control" style="font-size:.78rem;" placeholder="Catégorie ({{ pre.categorie ?? '?' }})">
                            <input type="text" name="tarif" class="form-control" style="font-size:.78rem; max-width:90px;" placeholder="Tarif">
                        </div>
                        {% set fiche = fiches_detectees[pre.id] ?? null %}
                        <label style="font-size:.76rem; display:flex; gap:6px; align-items:center; {{ fiche ? 'opacity:.5;' : '' }}">
                            <input type="checkbox" name="creer_fiche" value="1" {{ fiche ? '' : 'checked' }} {{ fiche ? 'disabled' : '' }}>
                            Créer la fiche joueuse {{ fiche ? '(inutile : fiche trouvée)' : '' }}
                        </label>
                        <button type="submit" class="btn-mabb-orange" style="font-size:.8rem;"><i class="bi bi-check2-circle"></i> Convertir en dossier</button>
                    </form>
                    <form method="post" action="{{ path('manager_secretariat_pre_inscription_refuser', {id: pre.id}) }}"
                          style="display:flex; gap:6px;" onsubmit="return confirm('Refuser la demande de {{ pre.nomComplet }} ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('pre_refuser_' ~ pre.id) }}">
                        <input type="text" name="note" class="form-control" style="font-size:.76rem;" placeholder="Raison (optionnel)">
                        <button type="submit" class="btn-mabb-ghost" style="font-size:.76rem; color:var(--mabb-red);">Refuser</button>
                    </form>
                </div>
                {% endif %}
            </div>
        </div>
    {% endfor %}
{% endblock %}
