{# B1 — Étape 1 : formulaire demande de reset password (Manager). #}
{# Réutilise le design du login Manager (gradient bleu + carte blanche). #}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mot de passe oublié — MABB Manager</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body {
            min-height: 100vh; display: flex; align-items: center; justify-content: center;
            background: linear-gradient(135deg, #063a55 0%, #0b4fa3 60%, #1c88b6 100%);
            font-family: 'Segoe UI', sans-serif;
        }
        .login-card {
            background: #fff; border-radius: 16px; padding: 44px 40px;
            width: 100%; max-width: 420px;
            box-shadow: 0 20px 60px rgba(0,0,0,.3);
        }
        .login-badge {
            display: inline-block; background: #fef3c7; color: #92400e;
            border: 1px solid #fcd34d; border-radius: 20px;
            font-size: .75rem; font-weight: 700; padding: 4px 12px;
            margin-bottom: 16px; text-transform: uppercase; letter-spacing: .5px;
        }
        .login-card h1 { font-size: 1.5rem; font-weight: 800; color: #0b1f3a; margin-bottom: 8px; }
        .login-card .subtitle { font-size: .88rem; color: #64748b; margin-bottom: 28px; line-height: 1.5; }
        .form-control {
            background: #f8fafc; border: 1.5px solid #e2e8f0; border-radius: 10px;
            padding: 11px 14px; font-size: .93rem;
        }
        .form-control:focus { border-color: #1d4ed8; background: #fff; box-shadow: 0 0 0 3px rgba(29,78,216,.15); }
        .btn-primary-mabb {
            background: linear-gradient(135deg, #1d4ed8, #2563eb); border: none; color: #fff;
            font-weight: 700; padding: 12px; border-radius: 10px; width: 100%;
            font-size: .95rem; margin-top: 8px;
        }
        .btn-primary-mabb:hover { transform: translateY(-1px); box-shadow: 0 8px 20px rgba(29,78,216,.35); }
        .back-link { display: block; text-align: center; margin-top: 18px; color: #64748b; text-decoration: none; font-size: .88rem; }
        .back-link:hover { color: #1d4ed8; }
        .flash-warning, .flash-error {
            padding: 12px 14px; border-radius: 10px; margin-bottom: 16px; font-size: .88rem;
        }
        .flash-warning { background: #fef3c7; border-left: 4px solid #f59e0b; color: #92400e; }
        .flash-error { background: #fee2e2; border-left: 4px solid #ef4444; color: #991b1b; }
    </style>
</head>
<body>
    <div class="login-card">
        <span class="login-badge"><i class="bi bi-key"></i> Réinitialisation</span>
        <h1>Mot de passe oublié</h1>
        <p class="subtitle">
            Entre l'email de ton compte MABB Manager. Si un compte existe avec cette adresse,
            on t'enverra un lien pour choisir un nouveau mot de passe (valide 1 heure).
        </p>

        {% for label, messages in app.flashes(['warning', 'error']) %}
            {% for message in messages %}
                <div class="flash-{{ label }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
            <div class="mb-3">
                {{ form_label(form.email, null, {'label_attr': {'class': 'form-label fw-semibold small text-secondary'}}) }}
                {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.email) }}
            </div>

            <button type="submit" class="btn-primary-mabb">
                <i class="bi bi-envelope-arrow-up"></i> Envoyer le lien de réinitialisation
            </button>
        {{ form_end(form) }}

        <a href="{{ path('manager_login') }}" class="back-link">
            <i class="bi bi-arrow-left"></i> Retour à la connexion
        </a>
    </div>
</body>
</html>
