{# B1 — Étape 2 : formulaire de nouveau password. #}
{# Affiché après clic sur le lien dans le mail (token valide). #}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nouveau mot de passe — MABB Manager</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body {
            min-height: 100vh; display: flex; align-items: center; justify-content: center;
            background: linear-gradient(135deg, #063a55 0%, #0b4fa3 60%, #1c88b6 100%);
            font-family: 'Segoe UI', sans-serif;
        }
        .login-card {
            background: #fff; border-radius: 16px; padding: 44px 40px;
            width: 100%; max-width: 440px; box-shadow: 0 20px 60px rgba(0,0,0,.3);
        }
        .login-badge {
            display: inline-block; background: #d1fae5; color: #065f46;
            border: 1px solid #6ee7b7; border-radius: 20px;
            font-size: .75rem; font-weight: 700; padding: 4px 12px;
            margin-bottom: 16px; text-transform: uppercase; letter-spacing: .5px;
        }
        .login-card h1 { font-size: 1.5rem; font-weight: 800; color: #0b1f3a; margin-bottom: 8px; }
        .login-card .subtitle { font-size: .88rem; color: #64748b; margin-bottom: 28px; }
        .form-control {
            background: #f8fafc; border: 1.5px solid #e2e8f0; border-radius: 10px;
            padding: 11px 14px; font-size: .93rem;
        }
        .form-control:focus { border-color: #10b981; background: #fff; box-shadow: 0 0 0 3px rgba(16,185,129,.15); }
        .btn-primary-mabb {
            background: linear-gradient(135deg, #059669, #10b981); border: none; color: #fff;
            font-weight: 700; padding: 12px; border-radius: 10px; width: 100%;
            font-size: .95rem; margin-top: 8px;
        }
        .btn-primary-mabb:hover { transform: translateY(-1px); box-shadow: 0 8px 20px rgba(16,185,129,.35); }
        .invalid-feedback, .form-error {
            display: block; color: #991b1b; font-size: .8rem; margin-top: 4px;
        }
        ul.form-error li { color: #991b1b; font-size: .8rem; }
        .pwd-hint {
            background: #f0f9ff; border: 1px solid #bae6fd; color: #075985;
            padding: 10px 12px; border-radius: 8px; font-size: .8rem; margin-bottom: 18px;
        }
    </style>
</head>
<body>
    <div class="login-card">
        <span class="login-badge"><i class="bi bi-shield-check"></i> Nouveau mot de passe</span>
        <h1>Choisis ton nouveau mot de passe</h1>
        <p class="subtitle">
            Choisis un mot de passe d'au moins 8 caractères, varié (majuscules, chiffres, symboles).
        </p>

        <div class="pwd-hint">
            <i class="bi bi-info-circle"></i> <strong>Astuce</strong> : utilise une phrase secrète,
            par exemple <em>"basket25!Amiens"</em> — long, varié, mémorisable.
        </div>

        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
            <div class="mb-3">
                {{ form_label(form.plainPassword.first, null, {'label_attr': {'class': 'form-label fw-semibold small text-secondary'}}) }}
                {{ form_widget(form.plainPassword.first, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.plainPassword.first) }}
            </div>

            <div class="mb-3">
                {{ form_label(form.plainPassword.second, null, {'label_attr': {'class': 'form-label fw-semibold small text-secondary'}}) }}
                {{ form_widget(form.plainPassword.second, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.plainPassword.second) }}
            </div>

            {{ form_errors(form) }}

            <button type="submit" class="btn-primary-mabb">
                <i class="bi bi-check-circle"></i> Enregistrer le nouveau mot de passe
            </button>
        {{ form_end(form) }}
    </div>
</body>
</html>
