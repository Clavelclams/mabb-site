{% extends 'manager/base.html.twig' %}

{% block title %}{{ evenement.titre }}{% endblock %}

{% block body %}
    <div class="page-header">
        <div>
            <h1>
                <i class="bi bi-calendar-event"></i> {{ evenement.titre }}
                {% if evenement.statut == 'brouillon' %}
                    <span style="background:#fef3c7; color:#92400e; padding:4px 10px; border-radius:10px; font-size:.7rem; font-weight:700; vertical-align:middle;">
                        <i class="bi bi-eye-slash"></i> BROUILLON
                    </span>
                {% elseif evenement.statut == 'annule' %}
                    <span style="background:#fee2e2; color:#b91c1c; padding:4px 10px; border-radius:10px; font-size:.7rem; font-weight:700; vertical-align:middle;">
                        <i class="bi bi-x-circle"></i> ANNULÉ
                    </span>
                {% endif %}
            </h1>
            <p class="subtitle">
                <span style="background:var(--mabb-blue); color:#fff; padding:2px 10px; border-radius:8px; font-size:.7rem; font-weight:700;">
                    {{ evenement.typeLibelle|upper }}
                </span>
                · {{ evenement.date|date('l d/m/Y \\à H:i') }}
                {% if evenement.dateFin %} → {{ evenement.dateFin|date('d/m H:i') }}{% endif %}
            </p>
        </div>
        <div style="display:flex; gap:8px;">
            <a href="{{ path('manager_evenement_index') }}" class="btn-mabb-ghost">
                <i class="bi bi-arrow-left"></i> Retour
            </a>
            {% if is_staff %}
                <a href="{{ path('manager_evenement_edit', {id: evenement.id}) }}" class="btn-mabb-ghost">
                    <i class="bi bi-pencil"></i> Modifier
                </a>
            {% endif %}
        </div>
    </div>

    <div class="row g-3">
        <div class="col-lg-7">
            {# Détails événement #}
            <div class="card-mabb">
                <div class="card-header"><i class="bi bi-info-circle"></i> Détails</div>
                <div class="card-body">
                    {% if evenement.description %}
                        <p style="margin-bottom:16px; white-space:pre-line;">{{ evenement.description }}</p>
                    {% endif %}
                    <dl style="display:grid; grid-template-columns: auto 1fr; gap:8px 16px; margin:0;">
                        {% if evenement.lieu %}
                            <dt style="font-weight:700;"><i class="bi bi-geo-alt"></i> Lieu</dt>
                            <dd style="margin:0;">{{ evenement.lieu }}</dd>
                        {% endif %}
                        <dt style="font-weight:700;"><i class="bi bi-people"></i> Ouvert à</dt>
                        <dd style="margin:0;">{{ evenement.ouvertALibelle }}</dd>
                        {% if evenement.inscriptionsMax %}
                            <dt style="font-weight:700;"><i class="bi bi-person-add"></i> Places</dt>
                            <dd style="margin:0;">{{ evenement.participations|length }} / {{ evenement.inscriptionsMax }}</dd>
                        {% endif %}
                        {% if evenement.createur %}
                            <dt style="font-weight:700;"><i class="bi bi-pencil"></i> Créé par</dt>
                            <dd style="margin:0;">{{ evenement.createur.prenom }} {{ evenement.createur.nom }}</dd>
                        {% endif %}
                    </dl>
                </div>
            </div>

            {# Actions staff (publier / annuler) #}
            {% if is_staff %}
                <div class="card-mabb" style="margin-top:16px;">
                    <div class="card-header"><i class="bi bi-tools"></i> Actions staff</div>
                    <div class="card-body" style="display:flex; gap:8px; flex-wrap:wrap;">
                        {% if evenement.statut == 'brouillon' %}
                            <form method="post" action="{{ path('manager_evenement_publier', {id: evenement.id}) }}" style="display:inline;">
                                <input type="hidden" name="_token" value="{{ csrf_token('publier_' ~ evenement.id) }}">
                                <button type="submit" class="btn-mabb-primary">
                                    <i class="bi bi-check-circle"></i> Publier
                                </button>
                            </form>
                        {% endif %}
                        {% if evenement.statut != 'annule' %}
                            <form method="post" action="{{ path('manager_evenement_annuler', {id: evenement.id}) }}" style="display:inline;"
                                  onsubmit="return confirm('Annuler définitivement cet événement ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('annuler_' ~ evenement.id) }}">
                                <button type="submit" class="btn-mabb-ghost" style="color:var(--mabb-red); border-color:var(--mabb-red);">
                                    <i class="bi bi-x-circle"></i> Annuler l'événement
                                </button>
                            </form>
                        {% endif %}
                    </div>
                </div>
            {% endif %}
        </div>

        <div class="col-lg-5">
            {# Bouton participer / désinscrire (côté user) #}
            {% if evenement.statut == 'publie' and not evenement.passe %}
                <div class="card-mabb" style="margin-bottom:16px;">
                    <div class="card-body" style="text-align:center;">
                        {% if ma_participation %}
                            <p style="margin-bottom:12px;">
                                ✅ Tu participes à cet événement.
                                <br><small style="color:var(--mabb-muted);">Statut : <strong>{{ ma_participation.statut }}</strong></small>
                            </p>
                            <form method="post" action="{{ path('manager_evenement_desinscrire', {id: evenement.id}) }}"
                                  onsubmit="return confirm('Te désinscrire de cet événement ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('desinscrire_' ~ evenement.id) }}">
                                <button type="submit" class="btn-mabb-ghost btn-sm">
                                    <i class="bi bi-x-circle"></i> Me désinscrire
                                </button>
                            </form>
                        {% else %}
                            {% if evenement.complet %}
                                <p style="color:var(--mabb-orange); margin:0;">
                                    <i class="bi bi-exclamation-triangle"></i> Événement complet
                                </p>
                            {% else %}
                                <p style="margin-bottom:12px;">Tu veux participer ?</p>
                                <form method="post" action="{{ path('manager_evenement_participer', {id: evenement.id}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('participer_' ~ evenement.id) }}">
                                    <button type="submit" class="btn-mabb-orange">
                                        <i class="bi bi-hand-thumbs-up-fill"></i> Je participe
                                    </button>
                                </form>
                            {% endif %}
                        {% endif %}
                    </div>
                </div>
            {% endif %}

            {# Liste participants #}
            <div class="card-mabb">
                <div class="card-header">
                    <i class="bi bi-people-fill"></i> Participants ({{ participations|length }})
                </div>
                <div class="card-body">
                    {% if participations|length == 0 %}
                        <p style="color:var(--mabb-muted); font-style:italic; margin:0;">Aucun participant pour l'instant.</p>
                    {% else %}
                        {% for p in participations %}
                            <div style="display:flex; align-items:center; gap:10px; padding:8px 0; border-bottom:1px solid var(--mabb-border);">
                                <div style="width:32px; height:32px; border-radius:50%; background:var(--mabb-blue); color:#fff; display:flex; align-items:center; justify-content:center; font-weight:700;">
                                    {{ p.user.prenom|first|upper }}{{ p.user.nom|first|upper }}
                                </div>
                                <div style="flex:1;">
                                    <div style="font-weight:600; font-size:.9rem;">{{ p.user.prenom }} {{ p.user.nom }}</div>
                                    <div style="font-size:.72rem; color:var(--mabb-muted);">
                                        {% if p.statut == 'inscrit' %}
                                            <i class="bi bi-clock"></i> Inscrit
                                        {% elseif p.statut == 'present' %}
                                            <span style="color:#16a34a;"><i class="bi bi-check-circle-fill"></i> Présent</span>
                                        {% elseif p.statut == 'absent' %}
                                            <span style="color:var(--mabb-red);"><i class="bi bi-x-circle"></i> Absent</span>
                                        {% elseif p.statut == 'excuse' %}
                                            <span style="color:#a16207;"><i class="bi bi-info-circle"></i> Excusé</span>
                                        {% endif %}
                                    </div>
                                </div>
                                {% if is_staff and evenement.passe %}
                                    {# Form rapide pour marquer présent / absent / excuse #}
                                    <form method="post" action="{{ path('manager_evenement_marquer_present', {id: evenement.id, userId: p.user.id}) }}" style="display:flex; gap:4px;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('presence_evenement_' ~ evenement.id) }}">
                                        <select name="statut" class="form-select" style="font-size:.75rem; padding:2px 6px; height:auto;" onchange="this.form.submit()">
                                            <option value="inscrit" {{ p.statut == 'inscrit' ? 'selected' : '' }}>Inscrit</option>
                                            <option value="present" {{ p.statut == 'present' ? 'selected' : '' }}>Présent</option>
                                            <option value="absent"  {{ p.statut == 'absent' ? 'selected' : '' }}>Absent</option>
                                            <option value="excuse"  {{ p.statut == 'excuse' ? 'selected' : '' }}>Excusé</option>
                                        </select>
                                    </form>
                                {% endif %}
                            </div>
                        {% endfor %}
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    {# ============ SORTIES : inscriptions (staff, type sortie) ============ #}
    {% if is_staff and evenement.type == 'sortie' %}
    <div class="card-mabb" style="margin-top:16px;">
        <div class="card-header"><i class="bi bi-clipboard-check"></i> Inscriptions à la sortie</div>
        <div class="card-body">

            {# Dashboard agrégats #}
            <div style="display:flex; flex-wrap:wrap; gap:12px; margin-bottom:16px;">
                <div style="flex:1; min-width:110px; background:#eff6ff; border-radius:10px; padding:10px 12px;">
                    <div style="font-size:1.4rem; font-weight:800; color:var(--mabb-blue);">{{ agregats.nb }}{% if evenement.inscriptionsMax %} / {{ evenement.inscriptionsMax }}{% endif %}</div>
                    <div style="font-size:.72rem; color:var(--mabb-muted);">inscrit·e·s</div>
                </div>
                {% if evenement.autorisationRequise %}
                <div style="flex:1; min-width:110px; background:#f0fdf4; border-radius:10px; padding:10px 12px;">
                    <div style="font-size:1.4rem; font-weight:800; color:#16a34a;">{{ agregats.autorisations_recues }}</div>
                    <div style="font-size:.72rem; color:var(--mabb-muted);">autorisations reçues{% if agregats.autorisations_manquantes %} · {{ agregats.autorisations_manquantes }} manquante·s{% endif %}</div>
                </div>
                {% endif %}
                {% if evenement.estPayant %}
                <div style="flex:1; min-width:110px; background:#fefce8; border-radius:10px; padding:10px 12px;">
                    <div style="font-size:1.4rem; font-weight:800; color:#a16207;">{{ agregats.total_encaisse|number_format(2, ',', ' ') }} €</div>
                    <div style="font-size:.72rem; color:var(--mabb-muted);">{{ agregats.payes }} payé·s · {{ agregats.a_payer }} à payer</div>
                </div>
                {% endif %}
                {% if evenement.passe %}
                <div style="flex:1; min-width:110px; background:#f5f3ff; border-radius:10px; padding:10px 12px;">
                    <div style="font-size:1.4rem; font-weight:800; color:#7c3aed;">{{ agregats.presents }}</div>
                    <div style="font-size:.72rem; color:var(--mabb-muted);">présent·e·s</div>
                </div>
                {% endif %}
            </div>

            {# Formulaire d'ajout #}
            <form method="post" action="{{ path('manager_evenement_inscription_add', {id: evenement.id}) }}"
                  style="background:#f8fafc; border:1px solid var(--mabb-border); border-radius:10px; padding:12px; margin-bottom:16px;">
                <input type="hidden" name="_token" value="{{ csrf_token('inscription_add_' ~ evenement.id) }}">
                <div style="display:flex; flex-wrap:wrap; gap:10px; align-items:flex-end;">
                    <div style="flex:2; min-width:200px;">
                        <label class="form-label" style="font-size:.78rem;">Joueuse licenciée</label>
                        <select name="joueur_id" class="form-select">
                            <option value="0">{% if evenement.ouvertA == 'tous' %}— ou saisie libre ci-dessous —{% else %}— choisir une joueuse —{% endif %}</option>
                            {% for j in joueurs_club %}
                                <option value="{{ j.id }}">{{ j.prenom }} {{ j.nom }}{% if j.equipe %} ({{ j.equipe.nom }}){% endif %}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <button type="submit" class="btn-mabb-primary"><i class="bi bi-plus-lg"></i> Inscrire</button>
                </div>
                {% if evenement.ouvertA == 'tous' %}
                    <div style="display:flex; flex-wrap:wrap; gap:10px; margin-top:10px;">
                        <input type="text" name="prenom" class="form-control" placeholder="Prénom (non licencié)" style="flex:1; min-width:120px;">
                        <input type="text" name="nom" class="form-control" placeholder="Nom" style="flex:1; min-width:120px;">
                        <input type="date" name="date_naissance" class="form-control" style="flex:1; min-width:120px;" title="Date de naissance">
                        <input type="text" name="responsable_legal" class="form-control" placeholder="Responsable légal (si mineur)" style="flex:1; min-width:160px;">
                        <input type="tel" name="telephone_contact" class="form-control" placeholder="Téléphone contact" style="flex:1; min-width:140px;">
                    </div>
                    <p style="font-size:.72rem; color:var(--mabb-muted); margin:6px 0 0;">Renseigne une joueuse licenciée OU la saisie libre (non licenciée).</p>
                {% endif %}
            </form>

            {# Tableau des inscrit·e·s #}
            {% if inscriptions|length == 0 %}
                <p style="color:var(--mabb-muted); font-style:italic; margin:0;">Personne d'inscrit pour l'instant.</p>
            {% else %}
                <div style="overflow-x:auto;">
                <table style="width:100%; border-collapse:collapse; font-size:.82rem;">
                    <thead>
                        <tr style="text-align:left; border-bottom:2px solid var(--mabb-border);">
                            <th style="padding:6px;">Participant·e</th>
                            {% if evenement.autorisationRequise %}<th style="padding:6px;">Autorisation</th>{% endif %}
                            {% if evenement.estPayant %}<th style="padding:6px;">Paiement</th>{% endif %}
                            <th style="padding:6px;">Présence</th>
                            <th style="padding:6px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for i in inscriptions %}
                        <tr style="border-bottom:1px solid var(--mabb-border);">
                            <td style="padding:6px;">
                                <strong>{{ i.nomAffichage }}</strong>
                                <div style="font-size:.7rem; color:var(--mabb-muted);">
                                    {% if i.joueur %}<i class="bi bi-patch-check"></i> licenciée{% if i.joueur.equipe %} · {{ i.joueur.equipe.nom }}{% endif %}
                                    {% else %}saisie libre{% if i.isMineur %} · <span style="color:var(--mabb-red);">mineure</span>{% endif %}{% endif %}
                                </div>
                            </td>
                            {% if evenement.autorisationRequise %}
                            <td style="padding:6px;">
                                <form method="post" action="{{ path('manager_evenement_inscription_autorisation', {id: evenement.id, iid: i.id}) }}" style="display:inline;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('inscription_autorisation_' ~ i.id) }}">
                                    <button type="submit" style="border:none; background:none; cursor:pointer; font-size:.78rem;" title="Basculer reçue / en attente">
                                        {% if i.autorisationStatut == 'RECUE' %}<span style="color:#16a34a;"><i class="bi bi-check-circle-fill"></i> Reçue</span>
                                        {% else %}<span style="color:#a16207;"><i class="bi bi-clock"></i> En attente</span>{% endif %}
                                    </button>
                                </form>
                                {# Décharge signée (Lot D v2) : dépôt / consultation / retrait #}
                                <div style="margin-top:3px; display:flex; align-items:center; gap:6px; flex-wrap:wrap;">
                                    {% if i.autorisationFichier %}
                                        <a href="{{ path('manager_evenement_inscription_decharge_voir', {id: evenement.id, iid: i.id}) }}"
                                           target="_blank" style="font-size:.72rem; text-decoration:none; color:var(--mabb-blue);"
                                           title="Voir la décharge signée">
                                            <i class="bi bi-file-earmark-check"></i> décharge
                                        </a>
                                        <form method="post" action="{{ path('manager_evenement_inscription_decharge_supprimer', {id: evenement.id, iid: i.id}) }}"
                                              style="display:inline;" onsubmit="return confirm('Supprimer la décharge de {{ i.nomAffichage }} ?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('inscription_decharge_supprimer_' ~ i.id) }}">
                                            <button type="submit" style="border:none; background:none; cursor:pointer; color:var(--mabb-red); font-size:.72rem; padding:0;"
                                                    title="Supprimer la décharge"><i class="bi bi-x-circle"></i></button>
                                        </form>
                                    {% else %}
                                        <form method="post" action="{{ path('manager_evenement_inscription_decharge_upload', {id: evenement.id, iid: i.id}) }}"
                                              enctype="multipart/form-data" style="display:flex; align-items:center; gap:4px;">
                                            <input type="hidden" name="_token" value="{{ csrf_token('inscription_decharge_' ~ i.id) }}">
                                            <label style="font-size:.7rem; color:var(--mabb-muted); cursor:pointer; margin:0;" title="Déposer la décharge signée (PDF ou photo, 10 Mo max)">
                                                <i class="bi bi-paperclip"></i>
                                                <input type="file" name="decharge" accept="application/pdf,image/jpeg,image/png,image/webp"
                                                       style="display:none;" onchange="this.form.submit()">
                                                joindre
                                            </label>
                                        </form>
                                    {% endif %}
                                </div>
                            </td>
                            {% endif %}
                            {% if evenement.estPayant %}
                            <td style="padding:6px;">
                                <form method="post" action="{{ path('manager_evenement_inscription_paiement', {id: evenement.id, iid: i.id}) }}" style="display:flex; flex-wrap:wrap; gap:4px; align-items:center;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('inscription_paiement_' ~ i.id) }}">
                                    <select name="paiement_statut" class="form-select" style="font-size:.72rem; padding:2px 4px; height:auto; width:auto;">
                                        {% for s in ['A_PAYER','PAYE','EXONERE','REMBOURSE'] %}
                                            <option value="{{ s }}" {{ i.paiementStatut == s ? 'selected' : '' }}>{{ s|lower }}</option>
                                        {% endfor %}
                                    </select>
                                    <input type="text" name="montant_paye" value="{{ i.montantPaye }}" placeholder="€" style="width:52px; font-size:.72rem; padding:2px 4px;" class="form-control">
                                    <select name="moyen_paiement" class="form-select" style="font-size:.72rem; padding:2px 4px; height:auto; width:auto;">
                                        <option value="">moyen</option>
                                        {% for m in ['ESPECE','CHEQUE','VIREMENT','AUTRE'] %}
                                            <option value="{{ m }}" {{ i.moyenPaiement == m ? 'selected' : '' }}>{{ m|lower }}</option>
                                        {% endfor %}
                                    </select>
                                    <button type="submit" class="btn-mabb-ghost btn-sm" style="font-size:.7rem; padding:2px 6px;" title="Enregistrer"><i class="bi bi-save"></i></button>
                                </form>
                            </td>
                            {% endif %}
                            <td style="padding:6px;">
                                <form method="post" action="{{ path('manager_evenement_inscription_presence', {id: evenement.id, iid: i.id}) }}" style="display:inline;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('inscription_presence_' ~ i.id) }}">
                                    <select name="presence" class="form-select" style="font-size:.72rem; padding:2px 4px; height:auto; width:auto;" onchange="this.form.submit()">
                                        {% for p in ['INSCRIT','PRESENT','ABSENT'] %}
                                            <option value="{{ p }}" {{ i.presence == p ? 'selected' : '' }}>{{ p|lower }}</option>
                                        {% endfor %}
                                    </select>
                                </form>
                            </td>
                            <td style="padding:6px; text-align:right;">
                                <form method="post" action="{{ path('manager_evenement_inscription_supprimer', {id: evenement.id, iid: i.id}) }}" style="display:inline;"
                                      onsubmit="return confirm('Retirer {{ i.nomAffichage }} ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('inscription_supprimer_' ~ i.id) }}">
                                    <button type="submit" style="border:none; background:none; cursor:pointer; color:var(--mabb-red);" title="Retirer"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
                </div>
            {% endif %}
        </div>
    </div>
    {% endif %}
{% endblock %}
