{# templates/manager/inscription.html.twig #}
{# Création de compte — manager.mabb.fr — multi-club V1 (MABB seul actif) #}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inscription — Manager MABB</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #063a55 0%, #0b4fa3 60%, #1c88b6 100%);
            font-family: 'Segoe UI', sans-serif;
            padding: 30px 16px;
        }
        .signup-card {
            background: #fff;
            border-radius: 16px;
            padding: 36px 36px 32px;
            width: 100%;
            max-width: 640px;
            box-shadow: 0 20px 60px rgba(0,0,0,.3);
        }
        .signup-badge {
            display: inline-block;
            background: #fff7ed;
            color: #c2410c;
            border: 1px solid #fed7aa;
            border-radius: 20px;
            font-size: .75rem;
            font-weight: 700;
            padding: 4px 12px;
            margin-bottom: 16px;
            text-transform: uppercase;
            letter-spacing: .5px;
        }
        .signup-card h1 { font-size: 1.6rem; font-weight: 800; color: #0b1f3a; margin-bottom: 4px; }
        .signup-card .subtitle { font-size: .9rem; color: #64748b; margin-bottom: 28px; }

        /* Grille de cards clubs */
        .clubs-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 12px;
            margin-bottom: 24px;
        }
        @media (max-width: 520px) {
            .clubs-grid { grid-template-columns: 1fr; }
        }
        .club-card {
            border: 2px solid #e2e8f0;
            border-radius: 12px;
            padding: 18px 16px;
            cursor: pointer;
            transition: all .15s;
            background: #fff;
            position: relative;
            text-align: center;
        }
        .club-card:hover {
            border-color: #1c88b6;
            background: #f0f9ff;
            transform: translateY(-2px);
        }
        .club-card input[type=radio] {
            position: absolute;
            top: 10px;
            right: 10px;
        }
        .club-card.selected {
            border-color: #fc702a;
            background: linear-gradient(135deg, #fff7ed, #ffedd5);
        }
        .club-card.disabled {
            opacity: .35;
            cursor: not-allowed;
            pointer-events: none;
            background: #f8fafc;
        }
        .club-card .club-logo {
            font-size: 2rem;
            margin-bottom: 8px;
        }
        .club-card .club-name {
            font-weight: 700;
            color: #0b1f3a;
            font-size: .95rem;
            margin-bottom: 2px;
            line-height: 1.2;
        }
        /* Initiale du nom du club mise en valeur (cohérent avec branding MABB) */
        .club-card .club-name .initiale {
            color: #fc702a;
            font-weight: 800;
        }
        .club-card .club-acronym {
            color: #fc702a;
            font-size: .72rem;
            font-weight: 800;
            letter-spacing: 1px;
            margin-bottom: 4px;
        }
        .club-card .club-meta {
            font-size: .72rem;
            color: #64748b;
        }
        .club-card .badge-v2 {
            position: absolute;
            top: 10px;
            right: 10px;
            background: #fef3c7;
            color: #92400e;
            font-size: .65rem;
            font-weight: 700;
            padding: 3px 8px;
            border-radius: 8px;
            letter-spacing: .3px;
        }

        .section-label {
            font-size: .75rem;
            font-weight: 700;
            color: #64748b;
            text-transform: uppercase;
            letter-spacing: .5px;
            margin-bottom: 10px;
        }

        .form-control {
            background: #f8fafc;
            border: 1.5px solid #e2e8f0;
            border-radius: 10px;
            padding: 11px 14px;
            font-size: .93rem;
        }
        .form-control:focus {
            border-color: #1c88b6;
            box-shadow: 0 0 0 3px rgba(28,136,182,.12);
            background: #fff;
        }
        .form-label { font-size: .83rem; font-weight: 600; color: #1e293b; }
        .btn-signup {
            width: 100%;
            padding: 12px;
            background: linear-gradient(90deg, #fc702a, #ea580c);
            border: none;
            border-radius: 10px;
            color: #fff;
            font-weight: 700;
            font-size: .95rem;
            margin-top: 6px;
            transition: opacity .2s;
        }
        .btn-signup:hover { opacity: .9; color: #fff; }
        .alert-err {
            background: #fef2f2;
            border: 1px solid #fecaca;
            border-radius: 8px;
            color: #dc2626;
            padding: 10px 14px;
            font-size: .85rem;
            margin-bottom: 18px;
        }
        .alert-err ul { margin: 4px 0 0; padding-left: 18px; }
        .back-link { font-size: .8rem; color: #94a3b8; text-align: center; margin-top: 18px; }
        .back-link a { color: #0b4fa3; text-decoration: none; }
        .multi-tenant-info {
            background: #eff6ff;
            border-left: 4px solid #1d4ed8;
            border-radius: 8px;
            padding: 12px 14px;
            font-size: .82rem;
            color: #1e3a8a;
            margin-bottom: 22px;
        }
        .multi-tenant-info strong { color: #1d4ed8; }
    </style>
</head>
<body>
    <div class="signup-card">
        <div class="signup-badge">🏀 Inscription Manager</div>
        <h1>Rejoindre un club</h1>
        <p class="subtitle">Crée ton compte sur la plateforme MABB Manager.</p>

        <div class="multi-tenant-info">
            <i class="bi bi-info-circle"></i>
            <strong>MABB Manager</strong> est une plateforme <strong>multi-clubs</strong>.
            En version 1, seul le club <strong>Métropole Amiénoise Basketball</strong> est actif.
            La création de nouveaux clubs viendra en V2 — chaque président d'asso pourra provisionner le sien.
        </div>

        {% if errors|length > 0 %}
            <div class="alert-err">
                <i class="bi bi-exclamation-triangle me-1"></i>
                <strong>Quelques points à corriger :</strong>
                <ul>
                    {% for err in errors %}<li>{{ err }}</li>{% endfor %}
                </ul>
            </div>
        {% endif %}

        <form method="post" action="{{ path('manager_inscription') }}">

            {# ============ Choix du club ============ #}
            <div class="section-label">1 · Choisis ton club</div>
            <div class="clubs-grid">
                {% for c in clubs_actifs %}
                    {# Calcule l'acronyme du nom (premières lettres significatives).
                       Ex: "Métropole Amiénoise Basketball" → "MAB"
                       On retire les mots vides courts comme "de", "du", "la"... #}
                    {% set mots = c.nom|split(' ')|filter(m => m|length > 1 and m|lower not in ['de','du','la','le','les','d','l']) %}
                    {% set acronyme = '' %}
                    {% for m in mots %}{% set acronyme = acronyme ~ (m|slice(0,1)|upper) %}{% endfor %}

                    <label class="club-card" onclick="this.parentElement.querySelectorAll('.club-card').forEach(e => e.classList.remove('selected')); this.classList.add('selected');">
                        <input type="radio" name="club_id" value="{{ c.id }}" {{ loop.first ? 'checked' : '' }} required>
                        <div class="club-logo">🏀</div>
                        <div class="club-name">
                            {# Affiche chaque mot avec sa première lettre en orange (initiale capturée par l'acronyme) #}
                            {% for m in c.nom|split(' ') %}
                                {% if m|length > 1 and m|lower not in ['de','du','la','le','les','d','l'] %}
                                    <span class="initiale">{{ m|slice(0,1) }}</span>{{ m|slice(1) }}
                                {% else %}
                                    {{ m }}
                                {% endif %}{{ not loop.last ? ' ' : '' }}
                            {% endfor %}
                        </div>
                        {% if acronyme|length >= 2 %}
                            <div class="club-acronym">({{ acronyme }})</div>
                        {% endif %}
                        <div class="club-meta">{{ c.ville ?: 'Club basket' }}</div>
                    </label>
                {% endfor %}

                {# Carte "Créer mon club" désactivée — vision V2 visible #}
                <div class="club-card disabled" title="Création de club disponible en V2">
                    <span class="badge-v2">V2</span>
                    <div class="club-logo">➕</div>
                    <div class="club-name">Créer mon club</div>
                    <div class="club-meta">Bientôt disponible</div>
                </div>
            </div>

            {# ============ Rôle demandé ============ #}
            <div class="section-label">2 · Quel sera ton rôle dans le club ?</div>
            <div class="mb-3" style="margin-top:8px;">
                <select name="role_demande" id="role_demande" class="form-control" required>
                    <option value="BENEVOLE" selected>👋 Bénévole — j'aide quand je peux</option>
                    <option value="JOUEUR">🏀 Joueur / Joueuse — je viens jouer</option>
                    <option value="PARENT">👨‍👩‍👧 Parent — mon enfant joue</option>
                    <option value="COACH">📋 Coach — j'encadre une équipe</option>
                    <option value="STAFF">🛠️ Staff — j'aide à l'organisation</option>
                    <option value="DIRIGEANT">🎩 Dirigeant — bureau / asso loi 1901</option>
                </select>
                <small style="font-size:.78rem; color:#64748b; display:block; margin-top:6px;">
                    Le dirigeant validera ton rôle. Tu n'auras les permissions correspondantes qu'après validation.
                </small>
            </div>

            {# ============ Profil ============ #}
            <div class="section-label">3 · Tes informations</div>
            <div class="row g-2 mb-3">
                <div class="col-6">
                    <label class="form-label" for="prenom">Prénom</label>
                    <input type="text" id="prenom" name="prenom" class="form-control" required autofocus
                           value="{{ app.request.request.get('prenom') }}">
                </div>
                <div class="col-6">
                    <label class="form-label" for="nom">Nom</label>
                    <input type="text" id="nom" name="nom" class="form-control" required
                           value="{{ app.request.request.get('nom') }}">
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label" for="email">Email</label>
                <input type="email" id="email" name="email" class="form-control" required
                       value="{{ app.request.request.get('email') }}"
                       placeholder="ton.email@exemple.fr">
            </div>

            {# Champs optionnels mais qui servent au match auto avec une fiche existante #}
            <div class="row g-2 mb-3">
                <div class="col-7">
                    <label class="form-label" for="licence">Numéro de licence FFBB <small style="color:#94a3b8;">(si joueur)</small></label>
                    <input type="text" id="licence" name="licence" class="form-control"
                           value="{{ app.request.request.get('licence') }}"
                           placeholder="Ex: BC123456 ou VT987654" maxlength="20">
                </div>
                <div class="col-5">
                    <label class="form-label" for="telephone">Téléphone <small style="color:#94a3b8;">(optionnel)</small></label>
                    <input type="tel" id="telephone" name="telephone" class="form-control"
                           value="{{ app.request.request.get('telephone') }}"
                           placeholder="06 12 34 56 78" maxlength="20">
                </div>
            </div>
            <div style="background:#eff6ff; border-left:3px solid #1d4ed8; padding:10px 14px; border-radius:6px; margin-bottom:18px; font-size:.78rem; color:#1e3a8a;">
                <i class="bi bi-magic"></i>
                <strong>Astuce :</strong> si ton coach a déjà saisi tes infos dans le club
                (licence FFBB, email ou téléphone), ton compte sera <strong>validé immédiatement</strong>
                et tu retrouveras toute ta gamification (XP, badges) accumulée.
                Sinon ta demande sera en attente de validation par un dirigeant.
            </div>
            <div class="row g-2 mb-3">
                <div class="col-6">
                    <label class="form-label" for="password">Mot de passe</label>
                    <input type="password" id="password" name="password" class="form-control" required minlength="8"
                           placeholder="8 caractères min.">
                </div>
                <div class="col-6">
                    <label class="form-label" for="password_confirm">Confirme</label>
                    <input type="password" id="password_confirm" name="password_confirm" class="form-control" required minlength="8">
                </div>
            </div>

            <div class="mb-3 form-check">
                <input type="checkbox" id="rgpd_consent" name="rgpd_consent" value="1" class="form-check-input" required>
                <label for="rgpd_consent" class="form-check-label" style="font-size:.82rem;">
                    J'accepte la <a href="https://mabb.fr/politique-confidentialite" target="_blank">politique de confidentialité</a>
                    et le traitement de mes données conformément au RGPD.
                </label>
            </div>

            <button type="submit" class="btn-signup">
                <i class="bi bi-person-plus me-2"></i>Créer mon compte
            </button>
        </form>

        <p class="back-link" style="margin-top:24px;">
            Déjà inscrit ? <a href="{{ path('manager_login') }}">Connecte-toi</a>
            &nbsp;·&nbsp;
            <a href="https://mabb.fr">← Site MABB</a>
        </p>
    </div>

    <script>
        // Pré-sélectionne visuellement la première card (MABB)
        document.addEventListener('DOMContentLoaded', () => {
            const firstClub = document.querySelector('.clubs-grid .club-card:not(.disabled)');
            if (firstClub) firstClub.classList.add('selected');
        });
    </script>
</body>
</html>
