{# Panneau super-admin cross-club — page AUTONOME (n'étend pas le layout Manager
   pour ne pas dépendre d'un club actif : un super-admin n'a pas de club à lui). #}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Super-admin — Tous les clubs</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <style>
        * { box-sizing: border-box; }
        body { margin: 0; font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif; background: #0d1b2a; color: #e9edf2; }
        .wrap { max-width: 900px; margin: 0 auto; padding: 28px 16px 60px; }
        h1 { font-size: 1.5rem; margin: 0 0 4px; }
        .sub { color: #9db2c6; margin: 0 0 24px; font-size: .92rem; }
        .flash { border-radius: 10px; padding: 12px 14px; margin-bottom: 16px; font-size: .92rem; }
        .flash-success { background: rgba(46,160,93,.18); border: 1px solid #2ea05d; }
        .flash-error { background: rgba(176,65,62,.18); border: 1px solid #b0413e; }
        .club { background: #16273a; border: 1px solid #24405c; border-radius: 12px; padding: 16px; margin-bottom: 12px;
                display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
        .club-main { flex: 1 1 240px; min-width: 0; }
        .club-nom { font-weight: 700; font-size: 1.05rem; }
        .club-meta { color: #9db2c6; font-size: .82rem; margin-top: 2px; }
        .badge-actif { background: #fc702a; color: #fff; border-radius: 999px; padding: 2px 10px; font-size: .72rem; font-weight: 700; }
        .btn { border: none; border-radius: 999px; padding: 9px 18px; font-weight: 600; cursor: pointer; font-size: .9rem; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; }
        .btn-entrer { background: #fc702a; color: #fff; }
        .btn-ghost { background: transparent; color: #9db2c6; border: 1px solid #24405c; }
        .empty { color: #9db2c6; text-align: center; padding: 40px 0; }
        form { margin: 0; }
    </style>
</head>
<body>
<div class="wrap">
    <h1><i class="bi bi-shield-lock"></i> Console super-admin</h1>
    <p class="sub">Tous les clubs de la plateforme. « Entrer » te place en mode support dans le club choisi
        (tu vois et gères tout, comme un dirigeant), sans en être membre.</p>

    {% for msg in app.flashes('success') %}<div class="flash flash-success"><i class="bi bi-check-circle"></i> {{ msg }}</div>{% endfor %}
    {% for msg in app.flashes('error') %}<div class="flash flash-error"><i class="bi bi-exclamation-triangle"></i> {{ msg }}</div>{% endfor %}

    {% if clubs is empty %}
        <div class="empty"><i class="bi bi-building"></i> Aucun club sur la plateforme.</div>
    {% else %}
        {% for club in clubs %}
            <div class="club">
                <div class="club-main">
                    <div class="club-nom">
                        {{ club.nom }}
                        {% if club_actif and club_actif.id == club.id %}<span class="badge-actif">actif</span>{% endif %}
                        {% if not club.isActive %}<span style="color:#b0413e;font-size:.75rem;">(inactif)</span>{% endif %}
                    </div>
                    <div class="club-meta">
                        {{ club.ville ?: '—' }}{% if club.codePostal %} · {{ club.codePostal }}{% endif %}
                        · {{ club.userClubRoles|length }} membre(s) · <code>{{ club.slug }}</code>
                    </div>
                </div>
                <form method="post" action="{{ path('manager_super_admin_entrer', {id: club.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('super_admin_entrer_' ~ club.id) }}">
                    <button type="submit" class="btn btn-entrer"><i class="bi bi-box-arrow-in-right"></i> Entrer</button>
                </form>
            </div>
        {% endfor %}
    {% endif %}

    <div style="margin-top:22px;">
        <a href="{{ path('manager_dashboard') }}" class="btn btn-ghost"><i class="bi bi-arrow-left"></i> Retour au tableau de bord</a>
    </div>
</div>
</body>
</html>
