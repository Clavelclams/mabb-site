{% extends 'manager/base.html.twig' %}

{% block title %}Stats LIVE — {{ rencontre.equipe.nom }} vs {{ rencontre.adversaire }}{% endblock %}

{#
    ============================================================
    STATS LIVE — saisie temps réel pendant le match
    ============================================================
    Layout tablette paysage :
       ┌──────────┬──────────────────┬─────────────┐
       │ JOUEUSES │  DEMI-TERRAIN    │  ACTIONS    │
       │   col-2  │       SVG        │  catégories │
       │          │  cliquable       │             │
       ├──────────┴──────────────────┴─────────────┤
       │       HISTORIQUE (10 dernières actions)    │
       └────────────────────────────────────────────┘

    WORKFLOW :
       1. Clic JOUEUSE → elle devient ACTIVE (border bleu)
       2. Pour un TIR : clic SUR LE TERRAIN → marker temporaire, options "réussi/raté"
          → clic option → POST création ActionMatch + MAJ compteurs
       3. Pour une autre action : clic JOUEUSE + clic BOUTON catégorie
          → POST création + MAJ
       4. Chaque action ajoutée → apparait en haut de l'historique
       5. Bouton Annuler sur chaque action récente → DELETE

    JS pur vanilla, pas de framework. Tout dans ce fichier pour rester simple.

    [V2.3 05/07/2026] MODE INTERNE À DEUX ÉQUIPES :
       Si rencontre.isInterneDeuxEquipes(), la colonne JOUEUSES est coupée
       en deux verticalement (Équipe A à gauche / Équipe B à droite) et les
       deux scores du header sont calculés depuis les actions (A vs B).
       Le reste du moteur (terrain, actions, historique, sessions) est
       strictement identique — même markup .joueuse-item, même JS.
#}

{# [V2.3] Carte joueuse — factorisation pour les colonnes A et B.
   Markup identique aux cartes classiques : les sélecteurs JS existants
   (data-joueur-id, data-joueur-pts, data-badge-joueur…) restent valides. #}
{% macro carte_joueuse(j, comptages, est_sur_terrain, cote='nous') %}
    {% set pts = ((comptages.tir_2pt_int_reussi ?? 0) + (comptages.tir_2pt_ext_reussi ?? 0)) * 2
               + (comptages.tir_3pt_reussi ?? 0) * 3
               + (comptages.lancer_reussi ?? 0) %}
    <div class="joueuse-item {{ est_sur_terrain ? 'sur-terrain' : '' }}"
         data-joueur-id="{{ j.id }}"
         data-pts="{{ pts }}"
         data-cote="{{ cote }}"
         data-sur-terrain="{{ est_sur_terrain ? '1' : '0' }}">
        <span class="badge-terrain {{ est_sur_terrain ? 'on' : '' }}" data-badge-joueur="{{ j.id }}">
            <span class="dot"></span>
            <span class="badge-label">{{ est_sur_terrain ? 'ON' : 'OFF' }}</span>
        </span>
        <div class="joueuse-avatar">
            {% if j.numeroMaillot is not null %}{{ j.numeroMaillot }}{% else %}{{ j.prenom|first|upper }}{% endif %}
        </div>
        <div class="joueuse-info">
            <div class="joueuse-name">{{ j.prenom }} {{ j.nom }}</div>
            <div class="joueuse-stats">
                <span class="pts" data-joueur-pts="{{ j.id }}">{{ pts }}</span> pts
                · <span class="temps-jeu" data-temps-jeu="{{ j.id }}">00:00</span>
            </div>
        </div>
    </div>
{% endmacro %}

{# Un demi-terrain offensif FFBB (panier en haut). Réutilisé en 1 ou 2 exemplaires
   (match normal = 1 ; match 2 équipes = 1 par équipe, teinté à sa couleur). #}
{% macro demi_terrain(suffixe, cote, bg, titre) %}
    <div class="court-col" data-cote="{{ cote }}" style="flex:1; min-width:0;">
        {% if titre %}<div class="court-col-title">{{ titre }}</div>{% endif %}
        <div class="court-svg-wrap" id="courtWrap{{ suffixe }}" data-cote="{{ cote }}" style="background:{{ bg }};">
            <svg class="court-svg" id="courtSvg{{ suffixe }}" data-cote="{{ cote }}" viewBox="0 0 1500 1400" preserveAspectRatio="xMidYMid meet">
                <line x1="0" y1="0" x2="1500" y2="0" class="court-line"/>
                <line x1="0" y1="0" x2="0" y2="1400" class="court-line"/>
                <line x1="1500" y1="0" x2="1500" y2="1400" class="court-line"/>
                <line x1="0" y1="1400" x2="1500" y2="1400" class="court-line"/>
                <rect x="505" y="0" width="490" height="580" class="court-paint court-line"/>
                <circle cx="750" cy="580" r="180" class="court-line"/>
                <path d="M 625,130 A 125,125 0 0 0 875,130" class="court-line"/>
                <line x1="90" y1="0" x2="90" y2="299" class="court-line"/>
                <line x1="1410" y1="0" x2="1410" y2="299" class="court-line"/>
                <path d="M 90,299 A 675,675 0 0 0 1410,299" class="court-line"/>
                <line x1="660" y1="100" x2="840" y2="100" class="court-line" style="stroke-width:6;"/>
                <circle cx="750" cy="130" r="22" fill="none" stroke="#fff" stroke-width="4"/>
                <g id="shotMarkers{{ suffixe }}" class="shot-markers"></g>
                <circle id="pendingTir{{ suffixe }}" class="pending-tir-marker" cx="-100" cy="-100" style="display:none;"/>
            </svg>
        </div>
    </div>
{% endmacro %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* ===== Layout principal — fix viewport pour tablette ===== */
        body { background: #0f172a; color: #e2e8f0; }
        .stats-live-wrapper {
            display: grid;
            grid-template-rows: auto 1fr auto;
            min-height: calc(100vh - 60px);
            gap: 8px;
            padding: 8px;
        }

        /* ===== Header : score live + QT + chrono ===== */
        .stats-header {
            display: grid;
            grid-template-columns: 1fr auto 1fr;
            gap: 12px;
            padding: 10px 14px;
            background: linear-gradient(135deg, #1e293b, #334155);
            border-radius: 10px;
            align-items: center;
        }
        .score-block { text-align: center; }
        .score-team {
            font-size: 0.85rem;
            color: #94a3b8;
            font-weight: 600;
        }
        .score-value {
            font-size: 2.2rem;
            font-weight: 900;
            color: #fbbf24;
            line-height: 1;
            margin: 2px 0;
        }
        .qt-block {
            text-align: center;
            background: #f97316;
            border-radius: 10px;
            padding: 8px 18px;
            min-width: 160px;
        }
        .qt-label {
            font-size: 0.7rem;
            color: #fff;
            opacity: 0.85;
            font-weight: 700;
            letter-spacing: 0.04em;
        }
        .qt-buttons {
            display: flex;
            gap: 4px;
            justify-content: center;
            margin-top: 4px;
        }
        .qt-btn {
            background: rgba(255,255,255,.15);
            border: 1px solid rgba(255,255,255,.3);
            color: #fff;
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 0.78rem;
            font-weight: 700;
            cursor: pointer;
            transition: background .15s;
        }
        .qt-btn.active {
            background: #fff;
            color: #ea580c;
            box-shadow: 0 0 0 2px #fff;
        }
        .qt-btn:hover { background: rgba(255,255,255,.3); }

        /* ===== Chrono V2.1a ===== */
        .chrono-block {
            border-radius: 14px;
            padding: 12px 18px;
            text-align: center;
            box-shadow: 0 4px 16px rgba(234,88,12,.3);
        }
        .chrono-period {
            font-size: 0.85rem;
            font-weight: 800;
            color: #fff;
            letter-spacing: 0.05em;
            margin-bottom: 4px;
        }
        .chrono-period span:first-child {
            font-size: 1.05rem;
        }
        .chrono-display {
            font-family: 'Courier New', Consolas, monospace;
            font-size: 2.6rem;
            font-weight: 900;
            color: #fff;
            line-height: 1;
            letter-spacing: 0.06em;
            text-shadow: 0 2px 6px rgba(0,0,0,.25);
            transition: color .15s;
        }
        .chrono-display.running {
            color: #fef9c3; /* jaune clair quand le chrono tourne */
        }
        .chrono-display.warning {
            color: #fecaca; /* rouge si < 1 min */
            animation: chronoBlink 1s ease-in-out infinite;
        }
        @keyframes chronoBlink {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.55; }
        }
        .chrono-controls {
            display: flex;
            gap: 6px;
            justify-content: center;
            margin-top: 8px;
            flex-wrap: wrap;
        }
        .chrono-btn {
            background: rgba(255,255,255,.18);
            border: 1px solid rgba(255,255,255,.35);
            color: #fff;
            padding: 6px 12px;
            border-radius: 8px;
            font-size: 0.85rem;
            font-weight: 700;
            cursor: pointer;
            transition: all .12s;
            min-width: 42px;
        }
        .chrono-btn:hover { background: rgba(255,255,255,.32); }
        .chrono-btn-main {
            background: #fff;
            color: #ea580c;
            font-size: 1.05rem;
            padding: 6px 18px;
        }
        .chrono-btn-main:hover { background: #fef3c7; }
        .chrono-btn-main.is-running { background: #fbbf24; color: #78350f; }
        .chrono-btn-adjust {
            font-family: monospace;
            font-size: 0.82rem;
        }
        .chrono-btn-danger:hover {
            background: rgba(239,68,68,.45);
            border-color: rgba(239,68,68,.6);
        }

        /* ===== Mode Débutant V2.1g ===== */
        .mode-toggle {
            display: flex;
            gap: 4px;
            background: rgba(255,255,255,.08);
            padding: 4px;
            border-radius: 8px;
        }
        .mode-toggle-btn {
            padding: 6px 14px;
            border: none;
            border-radius: 6px;
            background: transparent;
            color: #cbd5e1;
            font-weight: 700;
            font-size: 0.82rem;
            cursor: pointer;
            transition: all .15s;
        }
        .mode-toggle-btn.active {
            background: #fbbf24;
            color: #78350f;
        }
        .mode-toggle-btn:hover:not(.active) {
            background: rgba(255,255,255,.12);
            color: #fff;
        }

        /* V2.1l — DIFFÉRENCE Expert vs Débutant :
             - Expert   : 3 colonnes — sidebar | TERRAIN cliquable | actions groupées
             - Débutant : 2 colonnes — sidebar (avec carte adversaire) | actions groupées
                          (terrain inutile car workflow = click joueuse → modal)
           L'historique footer reste visible dans les 2 modes. */
        .stats-live-wrapper.mode-debutant .court-zone {
            display: none !important;
        }
        .stats-live-wrapper.mode-debutant .shoot-options,
        .stats-live-wrapper.mode-debutant #btnComposerCinq {
            display: none !important;
        }
        /* V2.1m — Carte adversaire masquée partout (doublon avec actions panel) */
        .joueuse-adversaire { display: none !important; }
        /* V2.1g.2 — Modal action (mode Débutant) */
        .action-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
            margin-bottom: 16px;
        }
        .action-btn {
            background: #334155;
            border: 2px solid transparent;
            color: #fff;
            padding: 14px 8px;
            border-radius: 10px;
            font-weight: 700;
            font-size: 0.85rem;
            cursor: pointer;
            transition: all .12s;
            text-align: center;
        }
        .action-btn:hover { background: #475569; }
        .action-btn-success { background: #16a34a; }
        .action-btn-success:hover { background: #15803d; }
        .action-btn-danger { background: #dc2626; }
        .action-btn-danger:hover { background: #b91c1c; }
        .action-btn-warning { background: #d97706; }
        .action-btn-warning:hover { background: #b45309; }
        .action-btn-info { background: #2563eb; }
        .action-btn-info:hover { background: #1d4ed8; }
        .action-btn-purple { background: #7c3aed; }
        .action-btn-purple:hover { background: #6d28d9; }
        .action-btn .icon { font-size: 1.4rem; display: block; margin-bottom: 2px; }
        .action-btn .lbl { font-size: 0.72rem; opacity: .9; }
        /* Carte spéciale ADVERSAIRE en haut sidebar */
        .joueuse-adversaire {
            background: linear-gradient(135deg, #7f1d1d, #b91c1c);
            color: #fff;
            padding: 12px;
            border-radius: 10px;
            margin-bottom: 10px;
            cursor: pointer;
            text-align: center;
            font-weight: 800;
            border: 2px solid transparent;
            transition: all .12s;
        }
        .joueuse-adversaire:hover { background: linear-gradient(135deg, #b91c1c, #dc2626); }
        .joueuse-adversaire .lbl { font-size: 0.7rem; opacity: .9; font-weight: 500; }
        /* Cache la carte adversaire en mode expert (on l'affiche que débutant) */
        .stats-live-wrapper:not(.mode-debutant) .joueuse-adversaire { display: none; }

        /* ===== Boutons score adverse V2.1e ===== */
        .adverse-btn {
            background: rgba(239,68,68,.2);
            border: 1px solid rgba(239,68,68,.4);
            color: #fecaca;
            padding: 4px 10px;
            border-radius: 6px;
            font-weight: 700;
            font-size: 0.78rem;
            cursor: pointer;
            transition: all .12s;
            min-width: 36px;
        }
        .adverse-btn:hover {
            background: #ef4444;
            color: #fff;
            border-color: #fecaca;
        }
        .adverse-btn-undo {
            background: rgba(148,163,184,.2);
            border-color: rgba(148,163,184,.4);
            color: #cbd5e1;
        }
        .adverse-btn-undo:hover { background: #64748b; }

        /* ===== Badge ON/OFF terrain V2.1b ===== */
        .joueuse-item {
            position: relative;
        }
        .badge-terrain {
            position: absolute;
            top: 6px;
            right: 6px;
            display: inline-flex;
            align-items: center;
            gap: 3px;
            padding: 4px 9px; /* +un peu pour faciliter le tap */
            border-radius: 10px;
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 0.04em;
            background: #475569;
            color: #cbd5e1;
            text-transform: uppercase;
            cursor: pointer;
            transition: all .15s;
            z-index: 2;
            user-select: none;
        }
        .badge-terrain:hover {
            transform: scale(1.08);
            background: #64748b;
        }
        .badge-terrain.on:hover {
            background: #15803d;
        }
        .badge-terrain.on {
            background: #16a34a;
            color: #fff;
            box-shadow: 0 0 0 2px rgba(22,163,74,.35);
        }
        .badge-terrain .dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: currentColor;
        }
        .joueuse-item.sur-terrain {
            border-left: 4px solid #16a34a;
            background: linear-gradient(90deg, rgba(22,163,74,.12) 0%, transparent 60%);
        }
        .temps-jeu {
            font-family: 'Courier New', monospace;
            font-size: 0.72rem;
            color: #94a3b8;
            font-weight: 600;
            letter-spacing: 0.02em;
        }
        .joueuse-item.sur-terrain .temps-jeu {
            color: #22c55e;
        }

        /* ===== Modal Composer 5 ===== */
        .modal-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(15,23,42,.85);
            z-index: 1000;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .modal-overlay.show {
            display: flex;
        }
        .modal-box {
            background: #1e293b;
            border-radius: 16px;
            padding: 24px;
            width: 100%;
            max-width: 540px;
            max-height: 88vh;
            overflow-y: auto;
            box-shadow: 0 12px 48px rgba(0,0,0,.5);
        }
        .modal-title {
            font-size: 1.25rem;
            font-weight: 800;
            color: #fff;
            margin: 0 0 6px;
        }
        .modal-subtitle {
            color: #94a3b8;
            font-size: 0.88rem;
            margin: 0 0 18px;
        }
        .modal-counter {
            background: #0f172a;
            border: 2px solid #ea580c;
            border-radius: 10px;
            padding: 8px 14px;
            text-align: center;
            font-weight: 800;
            color: #fbbf24;
            font-size: 1rem;
            margin-bottom: 14px;
        }
        .modal-counter.complete {
            border-color: #16a34a;
            color: #4ade80;
        }
        .modal-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
            gap: 8px;
            margin-bottom: 18px;
        }
        .modal-joueuse-btn {
            background: #334155;
            border: 2px solid transparent;
            color: #fff;
            padding: 10px 12px;
            border-radius: 10px;
            font-weight: 600;
            font-size: 0.85rem;
            cursor: pointer;
            text-align: left;
            transition: all .15s;
        }
        .modal-joueuse-btn:hover { background: #475569; }
        .modal-joueuse-btn.selected {
            background: #16a34a;
            border-color: #4ade80;
            box-shadow: 0 0 0 2px rgba(22,163,74,.3);
        }
        .modal-actions {
            display: flex;
            gap: 10px;
            justify-content: flex-end;
        }
        .modal-btn {
            padding: 10px 18px;
            border-radius: 8px;
            border: none;
            font-weight: 700;
            cursor: pointer;
            font-size: 0.92rem;
        }
        .modal-btn-cancel { background: #475569; color: #fff; }
        .modal-btn-validate { background: #ea580c; color: #fff; }
        .modal-btn-validate:disabled {
            background: #64748b;
            cursor: not-allowed;
        }

        /* ===== Grid 3 colonnes ===== */
        .stats-grid {
            display: grid;
            grid-template-columns: 240px 1fr 280px;
            gap: 8px;
            min-height: 500px;
        }
        @media (max-width: 1100px) {
            .stats-grid { grid-template-columns: 200px 1fr 240px; }
        }
        @media (max-width: 900px) {
            .stats-grid { grid-template-columns: 1fr; grid-template-rows: auto auto auto; }
        }

        /* ===== Sidebar joueuses ===== */
        .joueuses-list {
            background: #1e293b;
            border-radius: 10px;
            padding: 6px;
            overflow-y: auto;
            max-height: calc(100vh - 200px);
        }
        .joueuse-item {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 8px 10px;
            border-radius: 8px;
            cursor: pointer;
            margin-bottom: 4px;
            border: 2px solid transparent;
            transition: all .15s;
            user-select: none;
        }
        .joueuse-item:hover { background: rgba(59,130,246,.15); }
        .joueuse-item.active {
            background: rgba(59,130,246,.25);
            border-color: #3b82f6;
        }
        .joueuse-avatar {
            width: 36px; height: 36px;
            border-radius: 50%;
            background: linear-gradient(135deg, #3b82f6, #1e40af);
            color: #fff;
            display: flex; align-items: center; justify-content: center;
            font-weight: 800; font-size: 0.82rem;
            flex-shrink: 0;
        }
        .joueuse-info { flex: 1; min-width: 0; }
        .joueuse-name {
            font-weight: 700;
            font-size: 0.88rem;
            color: #f1f5f9;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .joueuse-stats {
            font-size: 0.7rem;
            color: #94a3b8;
            margin-top: 1px;
        }
        .joueuse-stats .pts {
            color: #fbbf24;
            font-weight: 700;
        }

        /* ===== Centre : terrain SVG ===== */
        .court-zone {
            background: #1e293b;
            border-radius: 10px;
            padding: 10px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }
        .court-svg-wrap {
            width: 100%;
            max-width: 600px;
            cursor: crosshair;
            position: relative;
        }
        .court-svg-wrap.disabled { cursor: not-allowed; opacity: .55; }
        /* Deux demi-terrains (match 2 équipes) : titre + surbrillance de l'équipe active */
        .court-col-title { text-align:center; font-size:.72rem; font-weight:700; text-transform:uppercase; letter-spacing:.04em; padding:3px 0 4px; opacity:.9; color:#fff; }
        .court-svg-wrap { border-radius:8px; transition:opacity .15s ease, outline-color .15s ease; }
        .court-svg-wrap.court-actif { outline:2px solid rgba(255,255,255,.6); }
        .court-svg-wrap.court-inactif { opacity:.4; }
        .court-svg {
            background: #c2410c;
            border-radius: 4px;
        }
        .court-line { stroke: #fff; stroke-width: 4; fill: none; }
        .court-paint { fill: rgba(255,255,255,.15); }
        .court-hint {
            color: #94a3b8;
            text-align: center;
            font-size: 0.8rem;
            margin-top: 8px;
        }
        .pending-tir-marker {
            fill: #fbbf24;
            stroke: #fff;
            stroke-width: 3;
            r: 12;
            animation: pulse 1s infinite;
        }
        @keyframes pulse {
            0%,100% { opacity: 1; }
            50% { opacity: 0.5; }
        }

        /* ===== Panneau actions ===== */
        .actions-panel {
            background: #1e293b;
            border-radius: 10px;
        }
        .actions-group { margin-bottom: 4px; }
        .actions-group-title {
            font-size: 0.7rem;
            color: #94a3b8;
            font-weight: 700;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            margin-bottom: 4px;
            padding-left: 4px;
        }
        .action-btn {
            display: block;
            width: 100%;
            padding: 10px 12px;
            background: #334155;
            color: #f1f5f9;
            border: 1px solid #475569;
            border-radius: 8px;
            font-weight: 700;
            font-size: 0.85rem;
            cursor: pointer;
            margin-bottom: 4px;
            text-align: left;
            transition: all .12s;
            user-select: none;
        }
        .action-btn:hover { background: #475569; transform: translateX(2px); }
        .action-btn:disabled {
            opacity: 0.4;
            cursor: not-allowed;
            transform: none;
        }
        .action-btn.action-shot { background: #16a34a; border-color: #15803d; }
        .action-btn.action-shot:hover { background: #15803d; }
        .action-btn.action-shot-miss { background: #dc2626; border-color: #991b1b; }
        .action-btn.action-shot-miss:hover { background: #991b1b; }
        .action-btn.action-positive { background: #2563eb; border-color: #1d4ed8; }
        .action-btn.action-positive:hover { background: #1d4ed8; }
        .action-btn.action-negative { background: #b45309; border-color: #92400e; }
        .action-btn.action-negative:hover { background: #92400e; }

        /* ===== Mode tir : cache les actions non-tir ===== */
        .stats-live-wrapper.mode-tir .actions-group:not(.shoot-options) { display: none; }
        .stats-live-wrapper:not(.mode-tir) .shoot-options { display: none; }

        /* ===== Historique footer ===== */
        .history-bar {
            background: #1e293b;
            border-radius: 10px;
            padding: 8px 12px;
            display: flex;
            flex-direction: column;
            gap: 4px;
            min-height: 80px;
        }
        .history-bar-title {
            font-size: 0.7rem;
            color: #94a3b8;
            font-weight: 700;
            letter-spacing: 0.05em;
            margin-bottom: 2px;
        }
        .history-items {
            display: flex;
            gap: 6px;
            overflow-x: auto;
            padding-bottom: 4px;
        }
        .history-item {
            background: #334155;
            color: #e2e8f0;
            padding: 6px 10px;
            border-radius: 6px;
            font-size: 0.75rem;
            white-space: nowrap;
            display: flex;
            align-items: center;
            gap: 6px;
            flex-shrink: 0;
        }
        .history-item .undo-btn {
            background: transparent;
            border: 0;
            color: #ef4444;
            cursor: pointer;
            padding: 0;
            font-weight: 800;
        }
        .history-item .undo-btn:hover { color: #fca5a5; }

        /* ===== Toast feedback ===== */
        #toast {
            position: fixed;
            bottom: 24px;
            right: 24px;
            padding: 12px 18px;
            border-radius: 8px;
            color: #fff;
            font-weight: 700;
            transform: translateY(120%);
            transition: transform .25s ease;
            z-index: 9999;
        }
        #toast.show { transform: translateY(0); }
        #toast.error { background: #dc2626; }

        /* ═══════════════════════════════════════════════════════════════
           V2.1j — TOP BAR FIDÈLE MAQUETTE
           Layout 5 colonnes : [☰] [ÉQUIPE/score] [TIMER/chrono] [ADV/score] [Session]
           Hamburger inline (pas fixed). Drawer latéral nav méta.
           ═══════════════════════════════════════════════════════════════ */

        .stats-header {
            grid-template-columns: auto 1fr auto 1fr auto !important;
            gap: 12px !important;
        }

        /* Hamburger inline (remplace le fixed top-right de la V2.1i Phase 1) */
        .header-hamburger {
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            gap: 5px;
            width: 44px;
            height: 44px;
            background: rgba(255,255,255,.08);
            border: 1px solid rgba(255,255,255,.14);
            border-radius: 10px;
            cursor: pointer;
            padding: 0;
            transition: background .15s;
        }
        .header-hamburger:hover { background: rgba(255,255,255,.16); }
        .header-hamburger .hamb-bar {
            width: 20px;
            height: 2.5px;
            background: #f1f5f9;
            border-radius: 2px;
            transition: transform .25s, opacity .25s;
        }
        body.drawer-open .header-hamburger .hamb-bar:nth-child(1) { transform: translateY(7px) rotate(45deg); }
        body.drawer-open .header-hamburger .hamb-bar:nth-child(2) { opacity: 0; }
        body.drawer-open .header-hamburger .hamb-bar:nth-child(3) { transform: translateY(-8px) rotate(-45deg); }

        /* Distinction visuelle des score-blocks selon équipe */
        .score-block-mabb .score-value { color: #3b82f6; }
        .score-block-adv  .score-value { color: #ef4444; }
        .score-block .score-team {
            font-size: 0.78rem;
            color: #cbd5e1;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            font-weight: 700;
        }

        /* TIMER label dans le chrono-period */
        .chrono-period {
            display: flex;
            gap: 6px;
            align-items: baseline;
            justify-content: center;
        }
        .chrono-period > span:first-child {
            color: #94a3b8;
            font-size: 0.7rem;
            letter-spacing: 0.08em;
            font-weight: 700;
        }
        .chrono-period .chrono-period-q {
            color: #fbbf24;
            font-weight: 800;
            font-size: 0.85rem;
        }

        /* Session info à droite (pas d'icone) */
        .session-info {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            justify-content: center;
            text-align: right;
            min-width: 110px;
        }
        .session-label {
            font-size: 0.7rem;
            color: #94a3b8;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            font-weight: 700;
        }
        .session-value {
            font-size: 0.92rem;
            color: #f1f5f9;
            font-weight: 700;
            max-width: 140px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        /* ═══ Nav drawer latéral (slide depuis la gauche) ═══ */
        .nav-drawer {
            position: fixed;
            top: 0;
            left: 0;
            bottom: 0;
            width: min(320px, 85vw);
            background: #0b1220;
            z-index: 310;
            transform: translateX(-100%);
            transition: transform .3s cubic-bezier(.4,0,.2,1);
            display: flex;
            flex-direction: column;
            box-shadow: 8px 0 32px rgba(0,0,0,.5);
            padding-top: max(0px, env(safe-area-inset-top));
            padding-bottom: max(0px, env(safe-area-inset-bottom));
        }
        body.drawer-open .nav-drawer { transform: translateX(0); }
        .nav-drawer-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 18px 18px 12px;
            border-bottom: 1px solid rgba(255,255,255,.08);
            color: #f1f5f9;
            font-size: 1.05rem;
        }
        .nav-drawer-close {
            background: transparent;
            border: none;
            color: #94a3b8;
            font-size: 1.6rem;
            cursor: pointer;
            line-height: 1;
            padding: 4px 8px;
        }
        .nav-drawer-close:hover { color: #fff; }
        .nav-drawer-body {
            flex: 1;
            overflow-y: auto;
            padding: 8px 0;
            display: flex;
            flex-direction: column;
        }
        .nav-drawer-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 14px 18px;
            color: #cbd5e1;
            text-decoration: none;
            background: transparent;
            border: none;
            text-align: left;
            font-size: 0.92rem;
            cursor: pointer;
            transition: background .12s;
            width: 100%;
            font-family: inherit;
        }
        .nav-drawer-item:hover { background: rgba(255,255,255,.06); color: #fff; }
        .nav-drawer-item .nav-icon {
            font-size: 1.2rem;
            min-width: 24px;
            text-align: center;
        }
        .nav-drawer-item.nav-item-danger { color: #fca5a5; }
        .nav-drawer-item.nav-item-danger:hover { background: rgba(239,68,68,.12); color: #fecaca; }
        .nav-drawer-divider {
            height: 1px;
            background: rgba(255,255,255,.08);
            margin: 8px 18px;
        }
        .nav-drawer-footer {
            padding: 12px 18px;
            border-top: 1px solid rgba(255,255,255,.08);
            color: #94a3b8;
            font-size: 0.78rem;
            line-height: 1.5;
        }
        .nav-drawer-footer strong { color: #fbbf24; }

        /* Anciens éléments V2.1i devenus inutiles (mini-bar + hamburger fixed) */
        .stats-mini-bar,
        .btn-hamburger { display: none !important; }

        /* V2.1m — Compaction top bar : on cache les controls chrono inline
           (déplacés dans le drawer). Affichage = TIMER + chrono seulement. */
        .stats-header .chrono-controls,
        .stats-header .adverse-controls,
        .stats-header #btnEffectifMatch,
        .stats-header #btnComposerCinq { display: none !important; }

        /* V2.1m — App layout 100vh, ultra-compact pour tout faire rentrer */
        html, body {
            margin: 0 !important;
            padding: 0 !important;
            height: 100vh !important;
            overflow: hidden !important;
        }
        body > .topbar { display: none !important; }
        main.container-app {
            padding: 0 !important;
            margin: 0 !important;
            max-width: 100% !important;
            height: 100vh !important;
            overflow: hidden !important;
        }
        /* V2.1n — Boutons − / + autour du score adverse, style pro pill 3D */
        .adv-score-row {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 5px;
        }
        .adv-tiny-btn {
            width: 14px;
            height: 14px;
            border-radius: 50%;
            border: none;
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            font-weight: 900;
            font-size: 0.6rem;
            line-height: 1;
            cursor: pointer;
            padding: 0;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            user-select: none;
            -webkit-tap-highlight-color: transparent;
            transition: transform .12s ease, box-shadow .15s ease, background .15s ease;
            position: relative;
            overflow: hidden;
        }
        /* − rouge sombre (subtractif, plus discret) */
        .adv-tiny-btn[data-delta="-1"] {
            background: linear-gradient(180deg, #7f1d1d 0%, #5a0e0e 100%);
            color: #fecaca;
            box-shadow:
                0 1px 0 rgba(255,255,255,.15) inset,
                0 -1px 0 rgba(0,0,0,.35) inset,
                0 2px 4px rgba(0,0,0,.4);
        }
        .adv-tiny-btn[data-delta="-1"]:hover {
            background: linear-gradient(180deg, #991b1b 0%, #7f1d1d 100%);
            color: #fff;
        }
        /* + rouge vif (additif, dominant) */
        .adv-tiny-btn[data-delta="1"] {
            background: linear-gradient(180deg, #ef4444 0%, #b91c1c 100%);
            color: #fff;
            box-shadow:
                0 1px 0 rgba(255,255,255,.25) inset,
                0 -1px 0 rgba(0,0,0,.3) inset,
                0 2px 6px rgba(239,68,68,.45);
        }
        .adv-tiny-btn[data-delta="1"]:hover {
            background: linear-gradient(180deg, #f87171 0%, #dc2626 100%);
            box-shadow:
                0 1px 0 rgba(255,255,255,.3) inset,
                0 -1px 0 rgba(0,0,0,.3) inset,
                0 3px 10px rgba(239,68,68,.6);
            transform: translateY(-1px);
        }
        /* Effet enfoncé au tap (les 2) */
        .adv-tiny-btn:active {
            transform: translateY(1px) scale(0.95);
            box-shadow:
                0 1px 0 rgba(255,255,255,.1) inset,
                0 -1px 0 rgba(0,0,0,.4) inset,
                0 1px 2px rgba(0,0,0,.3);
        }
        /* Focus accessibilité */
        .adv-tiny-btn:focus-visible {
            outline: 2px solid #fca5a5;
            outline-offset: 2px;
        }
        /* Anneau pulsant quand on tap (feedback haptique visuel) */
        .adv-tiny-btn::after {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: 50%;
            box-shadow: 0 0 0 0 rgba(239,68,68,.5);
            transition: box-shadow .35s ease;
            pointer-events: none;
        }
        .adv-tiny-btn:active::after {
            box-shadow: 0 0 0 8px rgba(239,68,68,0);
            transition: box-shadow 0s;
        }

        /* V2.1n — Override box-sizing global (demandé par tests inspecteur) */
        .stats-live-wrapper,
        .stats-live-wrapper *,
        .stats-live-wrapper *::before,
        .stats-live-wrapper *::after { box-sizing: content-box; }

        /* V2.1n — Masque la Symfony Web Dev Toolbar sur cette page Stats Live.
           Plus de conflit avec le footer historique. En prod pas de toolbar de
           toute façon, en dev elle reste sur les AUTRES pages Manager. */
        [id^="sfwdt"],
        .sf-toolbar,
        .sf-minitoolbar,
        [class^="sf-toolbar"],
        [class*=" sf-toolbar"] { display: none !important; }
        /* Force la couleur grise du "/ nbPeriodes" pour qu'il ne devienne pas rouge */
        .stats-header .chrono-period > span:last-child { color: #64748b !important; }

        /* V2.1n — Modal action guidée mode débutant : compaction pour tenir
           dans le viewport sans scroll interne. Cible : modal-box ≤ 90vh,
           contenu condensé, boutons d'action 2 lignes max. */
        .modal-overlay {
            padding: 8px !important;
            align-items: center !important;
        }
        .modal-box {
            padding: 14px !important;
            max-width: 460px !important;
            max-height: 92vh !important;
            border-radius: 12px !important;
        }
        .modal-title {
            font-size: 1.05rem !important;
            margin: 0 0 3px 0 !important;
            line-height: 1.2;
        }
        .modal-subtitle {
            font-size: 0.75rem !important;
            margin: 0 0 10px 0 !important;
            line-height: 1.2;
        }
        .modal-counter {
            padding: 5px 10px !important;
            font-size: 0.78rem !important;
            margin-bottom: 8px !important;
        }
        /* Grille d'actions (Tir réussi, Tir raté, Passe D, Rebond DEF, etc.) */
        .modal-box .action-grid {
            grid-template-columns: repeat(3, 1fr) !important;
            gap: 6px !important;
            margin-bottom: 10px !important;
        }
        .modal-box .action-btn {
            padding: 10px 4px !important;
            font-size: 0.78rem !important;
            border-radius: 8px !important;
            min-height: 0;
        }
        .modal-box .action-btn .icon {
            font-size: 1.3rem !important;
            margin-bottom: 1px !important;
        }
        .modal-box .action-btn .lbl {
            font-size: 0.68rem !important;
            display: block;
        }
        /* Grille de choix joueuse (modal-joueuse-btn) */
        .modal-grid {
            grid-template-columns: repeat(3, 1fr) !important;
            gap: 6px !important;
            margin-bottom: 8px !important;
        }
        .modal-joueuse-btn {
            padding: 8px 6px !important;
            font-size: 0.78rem !important;
            min-height: 0;
        }
        .modal-joueuse-btn strong {
            font-size: 0.82rem;
        }
        /* Boutons d'actions du modal (annuler / valider) */
        .modal-actions {
            margin-top: 8px !important;
            gap: 6px !important;
        }
        .modal-btn {
            padding: 8px 14px !important;
            font-size: 0.85rem !important;
            border-radius: 8px !important;
        }

        /* Petit écran (≤ 500px) — modal full screen bottom-sheet */
        @media (max-height: 500px) {
            .modal-overlay {
                align-items: flex-end !important;
                padding: 0 !important;
            }
            .modal-box {
                max-width: 100% !important;
                max-height: 100vh !important;
                border-radius: 14px 14px 0 0 !important;
                width: 100%;
                padding: 10px !important;
            }
            .modal-title { font-size: 0.95rem !important; }
            .modal-subtitle { font-size: 0.7rem !important; margin-bottom: 6px !important; }
            .modal-box .action-btn { padding: 8px 4px !important; }
            .modal-box .action-btn .icon { font-size: 1.1rem !important; }
            .modal-box .action-btn .lbl { font-size: 0.62rem !important; }
        }
        .stats-live-wrapper {
            display: flex !important;
            flex-direction: column;
            height: 100%;
            min-height: 0 !important;
            padding: 0 !important;
            gap: 2px !important;
            overflow: hidden;
            background: #0f172a;
        }

        /* HEADER ultra-mince (cible ~38px) — z-index élevé pour rester au-dessus du terrain */
        .stats-header {
            flex-shrink: 0;
            padding: 0 !important;
            min-height: 0;
            z-index: 50;
            position: relative;
            border-radius: 0 !important;
        }
        .stats-header .score-team,
        .stats-header .session-label {
            font-size: 0.5rem !important;
            line-height: 1;
            margin: 0;
        }
        .stats-header .score-value {
            font-size: 1.1rem !important;
            line-height: 1;
            margin: 0;
        }
        .stats-header .chrono-display {
            font-size: 1.1rem !important;
            padding: 0 4px !important;
            line-height: 1;
            margin: 0;
        }
        .stats-header .chrono-period {
            font-size: 0.5rem !important;
            margin: 0;
            gap: 3px !important;
        }
        .stats-header .chrono-period .chrono-period-q {
            font-size: 0.62rem !important;
        }
        .stats-header .session-value {
            font-size: 0.66rem !important;
            line-height: 1.1;
        }
        .stats-header .header-hamburger {
            width: 26px;
            height: 26px;
            gap: 3px;
        }
        .stats-header .header-hamburger .hamb-bar {
            width: 14px;
            height: 2px;
        }

        /* Court zone : SVG doit rester dans sa colonne, pas déborder */
        .court-zone {
            min-width: 0;
            min-height: 0;
            overflow: hidden;
            position: relative;
        }
        .court-zone svg {
            width: 100%;
            height: 100%;
            display: block;
        }

        /* TOGGLE compact (cible ~34px) */
        #modeToggleWrapper {
            flex-shrink: 0;
            padding: 2px 0 !important;
        }
        #modeToggleWrapper .mode-toggle-btn {
            padding: 4px 14px !important;
            font-size: 0.75rem !important;
        }

        /* GRID prend tout le reste */
        .stats-grid {
            flex: 1;
            min-height: 0;
            overflow: hidden;
        }

        /* FOOTER ultra-compact (cible ~28px, collé en bas) */
        .history-bar {
            flex-shrink: 0;
            max-height: 28px !important;
            min-height: 0;
            overflow: hidden;
            padding: 3px 8px !important;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .history-bar .history-bar-title {
            font-size: 0.6rem !important;
            margin: 0 !important;
            flex-shrink: 0;
            color: #94a3b8;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }
        .history-items {
            display: flex;
            gap: 6px;
            overflow-x: auto;
            overflow-y: hidden;
            white-space: nowrap;
            flex: 1;
        }
        .history-items .history-item {
            font-size: 0.65rem;
            flex-shrink: 0;
            padding: 1px 6px;
        }

        /* COL 1 sidebar joueuses compacte */
        .joueuses-list {
            min-height: 0;
            overflow-y: auto;
            padding: 4px !important;
        }
        .joueuses-list .joueuse-item {
            padding: 4px 6px !important;
            margin-bottom: 3px !important;
            gap: 6px;
        }
        .joueuses-list .joueuse-avatar {
            width: 28px !important;
            height: 28px !important;
            font-size: 0.7rem !important;
        }
        .joueuses-list .joueuse-name {
            font-size: 0.76rem !important;
        }
        .joueuses-list .joueuse-stats {
            font-size: 0.62rem !important;
        }

        /* COL 3 actions panel compacte */
        .actions-panel {
            min-height: 0;
            overflow-y: auto;
            padding: 4px !important;
        }
        .actions-panel .actions-group {
            margin-bottom: 4px;
        }
        .actions-panel .actions-group-title {
            font-size: 0.62rem !important;
            margin-bottom: 3px !important;
            padding: 0 4px;
        }
        .actions-panel .action-btn {
            padding: 6px 8px !important;
            font-size: 0.74rem !important;
            margin-bottom: 3px;
            min-height: 0;
        }
        .actions-panel .action-btn .icon { display: none; }
        .actions-panel .action-btn .lbl { font-size: 0.74rem; }
        /* Sidebar joueuses + actions panel : scroll INTERNE seulement si déborde */
        .joueuses-list {
            min-height: 0;
            overflow-y: auto;
        }
        .actions-panel {
            min-height: 0;
            overflow-y: auto;
        }

        /* Styles drawer chrono controls */
        .nav-drawer-section-title {
            padding: 8px 18px 4px;
            font-size: 0.7rem;
            color: #94a3b8;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            font-weight: 700;
        }
        .nav-drawer-chrono {
            padding: 8px 18px 12px;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        .chrono-control-btn {
            background: rgba(255,255,255,.08);
            border: 1px solid rgba(255,255,255,.14);
            color: #f1f5f9;
            padding: 10px 12px;
            border-radius: 8px;
            font-weight: 700;
            font-size: 0.85rem;
            cursor: pointer;
            font-family: inherit;
        }
        .chrono-control-btn:hover { background: rgba(255,255,255,.18); }
        .chrono-control-main {
            background: #fbbf24;
            color: #78350f;
            border-color: transparent;
        }
        .chrono-control-main:hover { background: #f59e0b; }
        .chrono-control-danger { background: rgba(239,68,68,.2); border-color: rgba(239,68,68,.4); color: #fecaca; }
        .chrono-control-row {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 6px;
        }

        /* V2.1l — Toggle Expert/Débutant en pill centrée, AU-DESSUS du terrain */
        #modeToggleWrapper {
            display: flex;
            justify-content: center;
            padding: 8px 0 4px;
            position: relative;
            z-index: 5;
        }
        #modeToggleWrapper .mode-toggle {
            background: rgba(15,23,42,.85);
            border-radius: 999px;
            display: inline-flex;
            gap: 0;
            box-shadow: 0 4px 12px rgba(0,0,0,.3);
        }
        #modeToggleWrapper .mode-toggle-btn {
            border-radius: 999px;
            padding: 8px 18px;
            font-size: 0.85rem;
            font-weight: 700;
            white-space: nowrap;
            background: transparent;
            border: none;
            color: #cbd5e1;
            cursor: pointer;
            transition: all .15s;
        }
        #modeToggleWrapper .mode-toggle-btn.active {
            background: #fbbf24;
            color: #78350f;
        }

        /* V2.1l — Top bar STICKY en mobile, ne disparaît plus au scroll */
        @media (max-width: 1023px) {
            .stats-header {
                position: sticky;
                top: 0;
                z-index: 50;
                /* Le wrapper a déjà un padding, on s'assure que le sticky tient au top */
                margin-top: 0;
            }
            /* Les boutons score adverse inline (+1 +2 +3 -1) sortent de la top bar
               (déplacés dans le score-block adverse cliquable / drawer) */
            .stats-header .adverse-controls { display: none !important; }
            /* Hamburger inline reste visible et bien aligné en top-left */
            .stats-header .header-hamburger { order: -1; }
        }

        /* V2.1k — Force la maquette 3 colonnes à partir de 700px (iPhone XR
           paysage 896px inclus). Override les blocs ≤ 1199px et ≤ 899px qui
           voulaient compacter ou empiler. Sur < 700px on garde l'empilement
           (1 colonne unique avec scroll vertical). */
        @media (min-width: 700px) {
            /* Expert = 3 colonnes (sidebar | terrain | actions) */
            .stats-live-wrapper:not(.mode-debutant) .stats-grid {
                grid-template-columns: minmax(180px, 220px) 1fr minmax(200px, 260px) !important;
                grid-template-rows: 1fr !important;
                gap: 8px !important;
            }
            /* Débutant = 2 colonnes équilibrées (sidebar | actions), terrain caché */
            .stats-live-wrapper.mode-debutant .stats-grid {
                grid-template-columns: 1fr 1fr !important;
                grid-template-rows: 1fr !important;
                gap: 12px !important;
            }
            .stats-grid {
                /* fallback générique */
                grid-template-columns: minmax(180px, 220px) 1fr minmax(200px, 260px);
                grid-template-rows: 1fr !important;
                gap: 8px !important;
            }
            /* La sidebar joueuses (EFFECTIF) reste haute mais scroll interne si déborde */
            .joueuses-list {
                max-height: none !important;
                height: 100% !important;
                overflow-y: auto;
                display: block !important; /* override les grid 2 cols des breakpoints mobile */
            }
            .joueuses-list .joueuse-item { margin-bottom: 6px; }
            /* V2.1m — Carte adversaire restée masquée partout */
            /* Court zone toujours visible */
            .court-zone { display: block !important; }
            /* History bar toujours visible en bas */
            .history-bar { display: block !important; }
            /* Actions panel toujours visible */
            .actions-panel { display: flex !important; flex-direction: column; gap: 12px; }
        }

        /* Desktop large (≥ 1280px) : on respire un peu */
        @media (min-width: 1280px) {
            .stats-header {
                padding: 14px 22px !important;
                gap: 20px !important;
            }
            .header-hamburger { width: 48px; height: 48px; }
            .score-block .score-value { font-size: 2.4rem; }
            .chrono-display { font-size: 2.2rem; padding: 5px 18px; }
            .session-info { min-width: 140px; }
            .session-value { font-size: 1rem; }
        }

        /* Tablette compacte (700-1023px) : ajustements pour que le 5 colonnes
           tienne quand même en portrait iPad. Empile la session en mode compact. */
        @media (max-width: 1023px) and (min-width: 700px) {
            .stats-header {
                padding: 10px 12px !important;
                gap: 8px !important;
            }
            .session-info { min-width: 90px; }
            .session-value { font-size: 0.82rem; max-width: 100px; }
            .score-block .score-value { font-size: 1.9rem; }
            .chrono-display { font-size: 1.8rem; }
        }

        /* ═══════════════════════════════════════════════════════════════
           V2.1i Phase 1 — Hamburger + drawer header
           ≤ 1023px : header inline masqué, accessible via tap hamburger
           ═══════════════════════════════════════════════════════════════ */

        /* Hamburger fixed top-right — caché par défaut, visible ≤ 1023px */
        .btn-hamburger {
            display: none;
            position: fixed;
            top: max(10px, env(safe-area-inset-top));
            right: max(10px, env(safe-area-inset-right));
            z-index: 300;
            width: 44px;
            height: 44px;
            background: rgba(15,23,42,.92);
            border: 1px solid rgba(255,255,255,.18);
            border-radius: 12px;
            cursor: pointer;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            gap: 5px;
            padding: 0;
            box-shadow: 0 4px 12px rgba(0,0,0,.4);
            backdrop-filter: blur(6px);
            -webkit-backdrop-filter: blur(6px);
            transition: transform .15s;
        }
        .btn-hamburger:active { transform: scale(0.94); }
        .btn-hamburger .hamb-bar {
            width: 22px;
            height: 2.5px;
            background: #f1f5f9;
            border-radius: 2px;
            transition: transform .25s, opacity .25s;
        }
        /* Animation hamburger → X quand drawer ouvert */
        body.drawer-open .btn-hamburger .hamb-bar:nth-child(1) {
            transform: translateY(8px) rotate(45deg);
        }
        body.drawer-open .btn-hamburger .hamb-bar:nth-child(2) {
            opacity: 0;
        }
        body.drawer-open .btn-hamburger .hamb-bar:nth-child(3) {
            transform: translateY(-7px) rotate(-45deg);
        }

        /* Overlay sombre derrière le drawer */
        .drawer-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.55);
            z-index: 250;
            opacity: 0;
            transition: opacity .25s;
        }
        body.drawer-open .drawer-overlay {
            display: block;
            opacity: 1;
        }

        /* Mini bandeau toujours visible ≤ 1023px — score MABB | chrono Q | score ADV */
        .stats-mini-bar {
            display: none;
            position: fixed;
            top: max(10px, env(safe-area-inset-top));
            left: max(10px, env(safe-area-inset-left));
            right: 64px; /* laisse la place au hamburger (44px + 10px + 10px gap) */
            z-index: 280;
            background: rgba(15,23,42,.92);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            border: 1px solid rgba(255,255,255,.12);
            border-radius: 12px;
            padding: 6px 10px;
            box-shadow: 0 4px 12px rgba(0,0,0,.4);
            cursor: pointer;
            user-select: none;
            justify-content: space-between;
            align-items: center;
            gap: 8px;
            min-height: 44px;
            transition: transform .15s;
        }
        .stats-mini-bar:active { transform: scale(0.98); }
        .stats-mini-bar .mini-score {
            display: flex;
            flex-direction: column;
            align-items: center;
            line-height: 1;
            min-width: 42px;
        }
        .stats-mini-bar .mini-score small {
            font-size: 0.6rem;
            color: #94a3b8;
            font-weight: 600;
            letter-spacing: 0.04em;
        }
        .stats-mini-bar .mini-score-mabb strong { color: #fbbf24; font-size: 1.25rem; }
        .stats-mini-bar .mini-score-adv strong { color: #ef4444; font-size: 1.25rem; }
        .stats-mini-bar .mini-chrono-block {
            display: flex;
            flex-direction: column;
            align-items: center;
            line-height: 1;
            flex: 1;
        }
        .stats-mini-bar .mini-period {
            font-size: 0.62rem;
            color: #94a3b8;
            font-weight: 700;
            letter-spacing: 0.05em;
        }
        .stats-mini-bar .mini-chrono {
            font-family: 'Courier New', monospace;
            font-size: 1.05rem;
            color: #f1f5f9;
            font-weight: 800;
        }
        .stats-mini-bar.chrono-running .mini-chrono { color: #22c55e; }
        .stats-mini-bar.chrono-warning .mini-chrono { color: #fbbf24; animation: blink 1s infinite; }
        @keyframes blink { 50% { opacity: 0.45; } }

        @media (max-width: 1023px) {
            /* V2.1j — Header reste INLINE (pas fixed). On ne masque plus rien.
               Le hamburger est inline dans la top bar (cf .header-hamburger). */

            /* V2.1l — Toggle Expert/Débutant centré AU-DESSUS du terrain (maquette).
               Plus de pill flottante : il est dans le flow normal entre la top bar et le terrain. */

            /* V2.1n — Plus de padding-bottom (la pill flottante n'existe plus).
               Le wrapper utilise toute la hauteur dispo. */
            .stats-live-wrapper {
                padding-bottom: 0 !important;
            }
            /* En drawer ouvert, on cache le mini-bar (le vrai header le remplace) */
            body.drawer-open .stats-mini-bar {
                opacity: 0;
                pointer-events: none;
            }
        }

        /* ═══════════════════════════════════════════════════════════════
           V2.1h — RESPONSIVE COMPLET Stats Live
           Stratégie mobile-first override :
             ≤ 1199px : tablette paysage / petit desktop — sidebar + récap réduits
             ≤  899px : tablette portrait — passe en 1 colonne, modal plus compact
             ≤  699px : mobile paysage — sidebar grid 2 cols, boutons agrandis
             ≤  499px : mobile portrait — FORCE mode débutant (JS),
                        masque toggle Expert, top bar empilée, modal full-screen
           ═══════════════════════════════════════════════════════════════ */

        @media (max-width: 1199px) {
            .stats-grid { grid-template-columns: 200px 1fr 240px; }
            .stats-header { padding: 8px 10px; gap: 8px; }
            .score-value { font-size: 2rem; }
            .joueuses-list { max-height: calc(100vh - 240px); }
        }

        @media (max-width: 899px) {
            .stats-live-wrapper { padding: 6px; gap: 6px; min-height: calc(100vh - 50px); }
            .stats-grid { grid-template-columns: 1fr; grid-template-rows: auto auto auto; gap: 6px; }

            /* Header : score + chrono + score sur 1 ligne, mais compact */
            .stats-header {
                grid-template-columns: 1fr auto 1fr;
                padding: 8px 10px;
                gap: 6px;
            }
            .score-team { font-size: 0.7rem; }
            .score-value { font-size: 1.7rem; line-height: 1; }
            .chrono-display { font-size: 1.6rem; padding: 3px 10px; }
            .chrono-period { font-size: 0.75rem; }
            .qt-label { font-size: 0.7rem; }
            .qt-btn { padding: 4px 8px; font-size: 0.78rem; min-width: 30px; }
            .chrono-controls { gap: 4px; flex-wrap: wrap; justify-content: center; }
            .chrono-btn { padding: 4px 8px; font-size: 0.75rem; }
            .chrono-btn-main { padding: 5px 12px; font-size: 0.85rem; }

            /* Sidebar prend toute la largeur, hauteur limitée scrollable */
            .joueuses-list { max-height: 50vh; }

            /* Mode débutant : action-grid 3 → 2 cols pour des boutons plus gros */
            .action-grid { grid-template-columns: repeat(2, 1fr); gap: 8px; }
            .action-btn { padding: 16px 8px; font-size: 0.95rem; }
            .action-btn .icon { font-size: 1.6rem; }
            .action-btn .lbl { font-size: 0.78rem; }

            /* Modal plus compact */
            .modal-overlay { padding: 10px; }
            .modal-box { padding: 18px; max-height: 92vh; }
            .modal-title { font-size: 1.1rem; }
            .modal-grid { grid-template-columns: repeat(2, 1fr); gap: 8px; }
            .modal-joueuse-btn { padding: 12px 8px; font-size: 0.9rem; }

            /* Boutons score adverse plus grands au tap */
            .adverse-btn { padding: 10px 14px; font-size: 0.95rem; min-width: 48px; }
        }

        @media (max-width: 699px) {
            /* Mobile paysage : tap targets 44px+ partout (WCAG), sidebar 2 cols */
            .stats-header {
                grid-template-columns: 1fr;
                grid-template-rows: auto auto auto;
                row-gap: 6px;
            }
            .stats-header .score-block { display: flex; align-items: baseline; justify-content: center; gap: 10px; }
            .stats-header .score-block .score-value { font-size: 1.4rem; }
            .stats-header .score-block .score-team { font-size: 0.78rem; }
            .chrono-display { font-size: 1.4rem; }

            /* V2.1i — La pill flottante (#modeToggleWrapper) garde les labels
               visibles, on n'applique plus le mode icônes-only ici. */

            /* Sidebar joueuses : grid 2 colonnes pour économiser de la verticale */
            .joueuses-list {
                display: grid;
                grid-template-columns: repeat(2, 1fr);
                gap: 6px;
                max-height: 45vh;
                padding: 6px;
            }
            .joueuse-item {
                margin-bottom: 0;
                padding: 8px;
                position: relative;
            }
            .joueuse-name { font-size: 0.82rem; }
            .joueuse-avatar { width: 32px; height: 32px; font-size: 0.78rem; }

            /* Badge ON/OFF plus tactile, repositionné */
            .badge-terrain {
                top: 4px;
                right: 4px;
                padding: 5px 10px;
                font-size: 0.65rem;
                min-height: 24px;
            }

            /* Actions garder 2 cols mais boutons jumbo */
            .action-btn { padding: 18px 6px; }
            .action-btn .icon { font-size: 1.8rem; }

            /* Modal joueuse 1 colonne lisible */
            .modal-grid { grid-template-columns: 1fr; }
            .modal-joueuse-btn { padding: 14px; font-size: 1rem; text-align: left; }

            /* Carte ADVERSAIRE plus visible */
            .joueuse-adversaire { padding: 14px; font-size: 1rem; }

            /* Score adverse : layout horizontal compact */
            .adverse-btn { padding: 12px 10px; font-size: 1rem; }
        }

        @media (max-width: 499px) {
            /* Mobile portrait — FORCE mode débutant (JS) + hide toggle Expert */
            .stats-live-wrapper { padding: 4px; }

            /* Toggle Expert masqué (le JS rajoute disabled, on confirme visuellement) */
            #modeExpertBtn {
                opacity: 0.35;
                pointer-events: none;
                cursor: not-allowed;
            }
            #modeExpertBtn::after {
                content: ' 📱';
                font-size: 0.8rem;
            }

            /* Top bar : empilage maximal */
            .stats-header { padding: 6px 8px; }
            .stats-header .score-block {
                gap: 6px;
                font-size: 0.85rem;
            }
            .score-value { font-size: 1.3rem !important; }
            .chrono-display { font-size: 1.2rem; padding: 2px 8px; }

            /* Sidebar joueuses : reste en 2 cols mais cards plus compactes */
            .joueuses-list { max-height: 42vh; gap: 4px; padding: 4px; }
            .joueuse-item { padding: 6px 8px; gap: 6px; }
            .joueuse-name { font-size: 0.78rem; }
            .joueuse-stats { font-size: 0.65rem; }
            .joueuse-avatar { width: 28px; height: 28px; font-size: 0.7rem; }

            /* Mode débutant : action-grid garde 2 cols pour gros tap targets */
            .action-grid { gap: 6px; }
            .action-btn { padding: 14px 4px; }
            .action-btn .icon { font-size: 1.6rem; }
            .action-btn .lbl { font-size: 0.72rem; }

            /* Modal full-screen sur smartphone portrait */
            .modal-overlay { padding: 0; align-items: flex-end; }
            .modal-box {
                max-width: 100%;
                max-height: 95vh;
                border-radius: 16px 16px 0 0;
                padding: 16px;
                width: 100%;
            }
            .modal-title { font-size: 1rem; }
            .modal-subtitle { font-size: 0.78rem; margin-bottom: 10px; }
            .modal-counter { padding: 6px 10px; font-size: 0.85rem; }

            /* Bandeau session : compacté */
            #bandeauSession {
                padding: 6px 8px !important;
                font-size: 0.75rem !important;
            }

            /* Boutons score adverse en grille 2 cols compacte */
            .adverse-buttons { gap: 4px !important; }
            .adverse-btn { padding: 10px 6px; font-size: 0.85rem; }
        }

        /* Safe-area iOS (notch + barre Home) */
        @supports (padding: env(safe-area-inset-bottom)) {
            .stats-live-wrapper {
                padding-bottom: max(8px, env(safe-area-inset-bottom));
                padding-left: max(8px, env(safe-area-inset-left));
                padding-right: max(8px, env(safe-area-inset-right));
            }
            .modal-box {
                padding-bottom: max(16px, env(safe-area-inset-bottom));
            }
        }

        /* ═══════════════════════════════════════════════════════════════
           V2.1h — MODE APP MOBILE (≤ 699px)
           Layout 100dvh fixed, pas de scroll body, bottom nav fixe,
           sheets bottom pour les actions secondaires.
           ═══════════════════════════════════════════════════════════════ */

        /* Bottom nav cachée par défaut (desktop / tablette paysage) */
        /* V2.1k — bottom-nav supprimée (remplacée par drawer nav méta + layout 3 colonnes maquette) */
        .stats-bottom-nav { display: none !important; }

        @media (max-width: 699px) {
            /* V2.1k — On retire le mode app fullscreen (position:fixed, navbar cachée).
               L'écran Stats Live mobile garde la navbar Manager + scroll naturel. */

            /* V2.1k — En mobile portrait, on PERMET le scroll vertical naturel.
               Stack : top bar / sidebar effectif / terrain / actions / historique.
               Plus de position:fixed qui empêchait de voir le bas de la page. */
            .stats-live-wrapper {
                position: static;
                height: auto;
                min-height: 100dvh;
                display: grid;
                grid-template-columns: 1fr;
                grid-template-rows: auto auto auto auto;
                padding: 8px !important;
                gap: 8px;
                overflow: visible;
            }

            /* Top : header sticky, compact, non scrollable */
            .stats-header {
                flex-shrink: 0;
                border-radius: 0;
                padding: 8px 10px !important;
                grid-template-columns: 1fr auto 1fr;
                grid-template-rows: none;
                row-gap: 0;
                column-gap: 8px;
            }
            .stats-header .score-block {
                display: flex !important;
                align-items: baseline;
                justify-content: center;
                gap: 6px;
                flex-direction: column;
            }
            .score-team { font-size: 0.65rem !important; line-height: 1; }
            .score-value { font-size: 1.4rem !important; line-height: 1; }
            .stats-header .score-block small { display: none; } /* MABB inutile, déjà dans score-team */
            .chrono-display { font-size: 1.3rem; padding: 2px 8px; }
            .chrono-period { font-size: 0.7rem; }
            .qt-label { font-size: 0.65rem; }
            .qt-buttons { gap: 2px; }
            .qt-btn { padding: 3px 6px; font-size: 0.7rem; min-width: 26px; }
            .chrono-controls { gap: 3px; margin-top: 4px; flex-wrap: wrap; }
            .chrono-btn { padding: 3px 6px; font-size: 0.7rem; }

            /* Effectif + Composer 5 inline déjà existants → on les masque
               (remplacés par les boutons du bottom nav) */
            .stats-header #btnEffectifMatch,
            .stats-header #btnComposerCinq { display: none !important; }
            /* Idem boutons score adverse inline (remplacés par sheet Adv.) */
            .stats-header .adverse-controls { display: none !important; }

            /* V2.1i — Le toggle reste visible en pill flottante (voir #modeToggleWrapper
               dans le bloc 1023px). On NE le masque PAS ici. */

            /* Stats grid : prend tout l'espace dispo, scroll interne sur la sidebar */
            .stats-grid {
                flex: 1;
                min-height: 0;
                grid-template-columns: 1fr !important;
                grid-template-rows: 1fr !important;
                gap: 0;
                overflow: hidden;
            }

            /* Liste joueuses occupe l'écran central, scroll INTERNE seulement */
            .joueuses-list {
                max-height: none !important;
                height: 100% !important;
                overflow-y: auto;
                -webkit-overflow-scrolling: touch;
                border-radius: 0;
                padding: 8px;
                /* On garde la grid 2 cols du breakpoint précédent en paysage,
                   on passe à 1 col seulement en portrait étroit */
            }

            /* V2.1k — Historique visible aussi en mobile portrait (scroll vertical) */
            .history-bar { display: block !important; }

            /* ───── Bottom nav app ───── */
            .stats-bottom-nav {
                display: flex;
                flex-shrink: 0;
                background: #0f172a;
                border-top: 1px solid #1e293b;
                padding: 6px 4px;
                padding-bottom: max(6px, env(safe-area-inset-bottom));
                gap: 4px;
                z-index: 100;
            }
            .stats-nav-btn {
                flex: 1;
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: 2px;
                background: transparent;
                border: none;
                color: #cbd5e1;
                padding: 8px 4px;
                border-radius: 10px;
                cursor: pointer;
                min-height: 52px;
                transition: background .15s;
            }
            .stats-nav-btn:active,
            .stats-nav-btn:hover {
                background: rgba(255,255,255,.08);
                color: #fff;
            }
            .stats-nav-btn .nav-icon {
                font-size: 1.4rem;
                line-height: 1;
            }
            .stats-nav-btn .nav-label {
                font-size: 0.68rem;
                font-weight: 600;
                letter-spacing: 0.02em;
            }

            /* Sheets bottom : slide depuis le bas */
            .modal-box-sheet {
                max-width: 100% !important;
                max-height: 80vh !important;
                border-radius: 18px 18px 0 0 !important;
                margin-bottom: 0;
                width: 100%;
            }
            .modal-overlay { align-items: flex-end !important; padding: 0 !important; }
        }

        /* Mobile portrait étroit < 500px : sidebar 1 col, encore plus compact */
        @media (max-width: 499px) {
            .joueuses-list {
                grid-template-columns: 1fr !important;
                display: flex !important;
                flex-direction: column;
            }
            .joueuse-item { padding: 10px 12px; }
            .stats-nav-btn .nav-label { font-size: 0.62rem; }
            .stats-nav-btn .nav-icon { font-size: 1.3rem; }
        }

        /* ================================================================
           [V2.3 05/07/2026] MATCH INTERNE À DEUX ÉQUIPES — sidebar A/B
           La div "liste des joueuses" est coupée en deux VERTICALEMENT :
           Équipe A à gauche (bleu), Équipe B à droite (rouge).
           Les .joueuse-item gardent exactement le même markup → tout le JS
           existant (sélection, compteurs, ON/OFF terrain) fonctionne tel quel.
        ================================================================ */
        .ab-split {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 6px;
            align-items: start;
        }
        .ab-col { display: flex; flex-direction: column; gap: 6px; min-width: 0; }
        .ab-col-header {
            position: sticky; top: 0; z-index: 2;
            font-size: .72rem; font-weight: 800; text-transform: uppercase;
            letter-spacing: .05em; padding: 6px 8px; border-radius: 8px;
            text-align: center; backdrop-filter: blur(4px);
        }
        .ab-col-a .ab-col-header { color: #3b82f6; background: rgba(59,130,246,.12); border: 1px solid rgba(59,130,246,.35); }
        .ab-col-b .ab-col-header { color: #ef4444; background: rgba(239,68,68,.12); border: 1px solid rgba(239,68,68,.35); }
        .ab-col-a .joueuse-item { border-left: 3px solid #3b82f6; }
        .ab-col-b .joueuse-item { border-left: 3px solid #ef4444; }
        /* Cartes plus compactes : 2 colonnes dans un espace prévu pour 1 */
        .ab-split .joueuse-item { padding: 8px 8px; }
        .ab-split .joueuse-avatar { width: 26px; height: 26px; font-size: .72rem; }
        .ab-split .joueuse-name { font-size: .78rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        /* Mobile portrait : on garde les 2 colonnes côte à côte (exigence
           fonctionnelle : statter A et B en même temps), on compacte encore */
        @media (max-width: 499px) {
            .ab-split { grid-template-columns: 1fr 1fr !important; }
            .ab-split .joueuse-name { font-size: .7rem; }
        }
    </style>
{% endblock %}

{% block body %}

    {# V2.1k — Bandeau session supprimé (info "Session : Prénom" déjà dans la top bar à droite, statut dans le drawer footer) #}

    {# V2.1j — Overlay seul (le hamburger est désormais inline dans la top bar) #}
    <div id="drawerOverlay" class="drawer-overlay" aria-hidden="true"></div>

    {# V2.1j — Drawer latéral nav méta (quitter, retour, clôturer match…) #}
    <aside id="navDrawer" class="nav-drawer" aria-hidden="true">
        <div class="nav-drawer-header">
            <strong>Stats Live</strong>
            <button type="button" id="btnCloseDrawer" class="nav-drawer-close" aria-label="Fermer">×</button>
        </div>
        <nav class="nav-drawer-body">
            <a href="{{ path('manager_rencontre_show', {id: rencontre.id}) }}" class="nav-drawer-item">
                <span class="nav-icon">↩️</span>
                <span>Quitter — retour à la rencontre</span>
            </a>
            <a href="{{ path('manager_dashboard') }}" class="nav-drawer-item">
                <span class="nav-icon">🏠</span>
                <span>Manager — accueil</span>
            </a>
            <a href="{{ path('manager_rencontre_sessions', {id: rencontre.id}) }}" class="nav-drawer-item">
                <span class="nav-icon">🗂️</span>
                <span>Voir les sessions de saisie</span>
            </a>
            <div class="nav-drawer-divider"></div>

            {# V2.1m — Contrôles chrono déplacés ici pour libérer la top bar #}
            <div class="nav-drawer-section-title">CHRONO</div>
            <div class="nav-drawer-chrono">
                <button type="button" id="navBtnStartPause" class="chrono-control-btn chrono-control-main">
                    <span id="navBtnStartPauseIcon">▶</span> Démarrer / Pause
                </button>
                <div class="chrono-control-row">
                    <button type="button" id="navBtnMinus1" class="chrono-control-btn">−1s</button>
                    <button type="button" id="navBtnPlus1" class="chrono-control-btn">+1s</button>
                    <button type="button" id="navBtnNextPeriod" class="chrono-control-btn">Période →</button>
                    <button type="button" id="navBtnResetChrono" class="chrono-control-btn chrono-control-danger">Reset</button>
                </div>
            </div>
            <div class="nav-drawer-divider"></div>
            <button type="button" class="nav-drawer-item" id="navBtnComposerCinq">
                <span class="nav-icon">👥</span>
                <span>Composer le 5</span>
            </button>
            <button type="button" class="nav-drawer-item" id="navBtnEffectif">
                <span class="nav-icon">📋</span>
                <span>Effectif du match</span>
            </button>
            <button type="button" class="nav-drawer-item nav-item-danger" id="navBtnCloturer">
                <span class="nav-icon">🏁</span>
                <span>Clôturer le match</span>
            </button>
        </nav>
        {% if session_courante %}
        <div class="nav-drawer-footer">
            Session : <strong>{{ session_courante.nom }}</strong><br>
            <small>Statut : {{ session_courante.statutLabel }}</small>
        </div>
        {% endif %}
    </aside>

    {# ===== HEADER : score live + QT en cours ===== #}
    {# V2.1g — Wrapper porte la classe "mode-debutant" ou non, contrôlée par le toggle.
       V2.1g.5 — Mode DÉBUTANT par défaut (plus accessible aux bénévoles formation). #}
    <div class="stats-live-wrapper mode-debutant" id="liveWrapper">
        {# V2.1j — Top bar fidèle maquette : [☰] [ÉQUIPE/score] [TIMER/chrono] [ADV/score] [Session]
           Hamburger inline (ouvre nav méta), score MABB+ÉQUIPE, TIMER+chrono+Q, ADV+score, "Session: …".
           Les controls chrono (start/pause/+/-/next/reset) restent inline mais condensés. #}
        <div class="stats-header">
            {# Hamburger inline (remplace l'ancien fixed top-right) #}
            <button type="button" id="btnHamburger" class="header-hamburger" aria-label="Ouvrir le menu" aria-expanded="false">
                <span class="hamb-bar"></span>
                <span class="hamb-bar"></span>
                <span class="hamb-bar"></span>
            </button>

            <div class="score-block score-block-mabb">
                {# [V2.3] Mode interne A/B : le bloc gauche devient le score de l'Équipe A #}
                <div class="score-team">{{ mode_interne_ab ? rencontre.equipeANom : rencontre.equipe.nom }}</div>
                <div class="score-value" id="scoreMabb">0</div>
            </div>

            {# ===== CHRONO + PÉRIODE (V2.1a) ===== #}
            <div class="chrono-block" id="chronoBlock">
                <div class="chrono-period">
                    <span>TIMER</span>
                    <span class="chrono-period-q" id="periodLabel">Q1</span>
                    <span style="color:#64748b; font-size:.7rem;">/ {{ rencontre.nbPeriodes }}</span>
                </div>
                <div class="chrono-display" id="chronoDisplay">
                    {{ '%02d'|format(rencontre.dureePeriodeMinutes) }}:00
                </div>
                <div class="chrono-controls">
                    <button type="button" class="chrono-btn chrono-btn-adjust" id="btnMinus1" title="-1 seconde">−1s</button>
                    <button type="button" class="chrono-btn chrono-btn-main" id="btnStartPause" title="Démarrer / Pauser">
                        <span id="btnStartPauseIcon">▶</span>
                    </button>
                    <button type="button" class="chrono-btn chrono-btn-adjust" id="btnPlus1" title="+1 seconde">+1s</button>
                    <button type="button" class="chrono-btn chrono-btn-secondary" id="btnNextPeriod" title="Période suivante">→</button>
                    <button type="button" class="chrono-btn chrono-btn-danger" id="btnResetChrono" title="Réinitialiser la période">⟲</button>
                </div>
                {# Boutons Composer 5 / Effectif déplacés dans le drawer (V2.1j).
                   On garde des IDs cachés pour que le code JS existant continue
                   de fonctionner via les boutons du drawer qui les déclenchent. #}
                <button type="button" id="btnEffectifMatch" hidden></button>
                <button type="button" id="btnComposerCinq" hidden></button>
            </div>

            <div class="score-block score-block-adv">
                {# [V2.3] Mode interne A/B : le bloc droit devient le score de l'Équipe B,
                   CALCULÉ depuis les actions saisies (comme le score A) — les boutons
                   manuels −/+ n'ont plus de sens et sont masqués. #}
                <div class="score-team">{{ mode_interne_ab ? rencontre.equipeBNom : rencontre.adversaire }}</div>
                {% if mode_interne_ab %}
                    <div class="score-value" id="scoreAdverseDisplay" style="color:#ef4444;">0</div>
                {% else %}
                {# V2.1n — Boutons − / + autour du score pour ajustement rapide #}
                <div class="adv-score-row">
                    <button type="button" class="adverse-btn adv-tiny-btn" data-delta="-1" title="−1 point">−</button>
                    <div class="score-value" id="scoreAdverseDisplay" style="color:#ef4444;">{{ rencontre.scoreAdverse ?? 0 }}</div>
                    <button type="button" class="adverse-btn adv-tiny-btn" data-delta="1" title="+1 point">+</button>
                </div>
                {# Boutons score adverse déplacés dans le drawer / pill, on cache inline #}
                <div class="adverse-controls" style="display:flex; gap:4px; justify-content:center; margin-top:4px;">
                    <button type="button" class="adverse-btn" data-delta="1" title="+1 point">+1</button>
                    <button type="button" class="adverse-btn" data-delta="2" title="+2 points (panier)">+2</button>
                    <button type="button" class="adverse-btn" data-delta="3" title="+3 points (à 3 pts)">+3</button>
                    <button type="button" class="adverse-btn adverse-btn-undo" data-delta="-1" title="Corriger (-1)">−1</button>
                </div>
                {% endif %}
            </div>

            {# V2.1j — Info session courante à droite (pas d'icone, juste texte) #}
            <div class="session-info">
                <div class="session-label">Session</div>
                <div class="session-value">
                    {% if session_courante and session_courante.createdBy %}
                        {{ session_courante.createdBy.prenom }}
                        {% if session_courante.createdBy.nom %}{{ session_courante.createdBy.nom|first|upper }}.{% endif %}
                    {% else %}
                        —
                    {% endif %}
                </div>
            </div>
        </div>

        {# V2.1l — Toggle Expert/Débutant centré, au-dessus du terrain comme maquette #}
        <div id="modeToggleWrapper">
            <div class="mode-toggle">
                <button type="button" class="mode-toggle-btn" id="modeExpertBtn" data-mode="expert">⚡ Expert</button>
                <button type="button" class="mode-toggle-btn active" id="modeDebutantBtn" data-mode="debutant">👶 Débutant</button>
            </div>
        </div>

        {# ===== GRID 3 COLONNES ===== #}
        <div class="stats-grid">

            {# ===== COLONNE 1 : LISTE DES JOUEUSES ===== #}
            <div class="joueuses-list" id="joueusesList">
            {% if mode_interne_ab %}
                {# ============================================================
                   [V2.3] MATCH INTERNE — liste coupée en 2 verticalement.
                   Équipe A à gauche, Équipe B à droite. Pas de carte
                   "adversaire" : les deux équipes sont du club, chaque
                   action est saisie nominativement sur une joueuse.
                ============================================================ #}
                <div class="ab-split">
                    <div class="ab-col ab-col-a" id="colEquipeA">
                        <div class="ab-col-header">{{ rencontre.equipeANom }}</div>
                        {% for j in joueuses_equipe_a %}
                            {{ _self.carte_joueuse(j, comptages_par_joueur[j.id] ?? {}, j.id in ids_sur_terrain, 'a') }}
                        {% else %}
                            <p style="color:#94a3b8; padding:8px; font-size:.8rem;">Aucune joueuse.</p>
                        {% endfor %}
                    </div>
                    <div class="ab-col ab-col-b" id="colEquipeB">
                        <div class="ab-col-header">{{ rencontre.equipeBNom }}</div>
                        {% for j in joueuses_equipe_b %}
                            {{ _self.carte_joueuse(j, comptages_par_joueur[j.id] ?? {}, j.id in ids_sur_terrain, 'b') }}
                        {% else %}
                            <p style="color:#94a3b8; padding:8px; font-size:.8rem;">Aucune joueuse.</p>
                        {% endfor %}
                    </div>
                </div>
                <a href="{{ path('manager_rencontre_composition_interne', {id: rencontre.id}) }}"
                   style="display:block; text-align:center; font-size:.75rem; color:#94a3b8; margin-top:8px;">
                    ✏️ Modifier la composition A/B
                </a>
            {% else %}
                {# V2.1g.2 — Carte ADVERSAIRE (visible en mode Débutant uniquement) #}
                <div class="joueuse-adversaire" id="cardAdversaire" data-adversaire="1">
                    <i class="bi bi-shield-shaded"></i>
                    {{ rencontre.adversaire }}
                    <div class="lbl">Saisir une action adverse</div>
                </div>
                {% if joueuses is empty %}
                    <p style="color:#94a3b8; padding:12px; font-size:0.85rem;">
                        Aucune joueuse active dans cette équipe.<br>
                        <a href="{{ path('manager_joueur_new', {equipe_id: rencontre.equipe.id}) }}" style="color:#3b82f6;">Ajouter une joueuse</a>
                    </p>
                {% else %}
                    {% for j in joueuses %}
                        {% set comptages = comptages_par_joueur[j.id] ?? {} %}
                        {# Calcul points côté serveur pour 1er render — JS prend le relais après #}
                        {% set pts = ((comptages.tir_2pt_int_reussi ?? 0) + (comptages.tir_2pt_ext_reussi ?? 0)) * 2
                                   + (comptages.tir_3pt_reussi ?? 0) * 3
                                   + (comptages.lancer_reussi ?? 0) %}
                        {% set est_sur_terrain = j.id in ids_sur_terrain %}
                        <div class="joueuse-item {{ est_sur_terrain ? 'sur-terrain' : '' }}"
                             data-joueur-id="{{ j.id }}"
                             data-pts="{{ pts }}"
                             data-cote="nous"
                             data-sur-terrain="{{ est_sur_terrain ? '1' : '0' }}">
                            <span class="badge-terrain {{ est_sur_terrain ? 'on' : '' }}" data-badge-joueur="{{ j.id }}">
                                <span class="dot"></span>
                                <span class="badge-label">{{ est_sur_terrain ? 'ON' : 'OFF' }}</span>
                            </span>
                            <div class="joueuse-avatar">
                                {% if j.numeroMaillot is not null %}{{ j.numeroMaillot }}{% else %}{{ j.prenom|first|upper }}{% endif %}
                            </div>
                            <div class="joueuse-info">
                                <div class="joueuse-name">{{ j.prenom }} {{ j.nom }}</div>
                                <div class="joueuse-stats">
                                    <span class="pts" data-joueur-pts="{{ j.id }}">{{ pts }}</span> pts
                                    · <span class="temps-jeu" data-temps-jeu="{{ j.id }}">00:00</span>
                                </div>
                            </div>
                        </div>
                    {% endfor %}

                    {# [V2.2] Joueuses éphémères de NOTRE équipe pour cette rencontre #}
                    {% if joueuses_ephemeres_notres is defined and joueuses_ephemeres_notres|length > 0 %}
                        <div style="margin:8px 0 4px; padding:4px 0; border-top:1px solid rgba(255,255,255,.08); font-size:.72rem; font-weight:700; color:#ea580c; text-transform:uppercase; letter-spacing:.05em;">
                            ⚡ Éphémères
                        </div>
                        {% for j in joueuses_ephemeres_notres %}
                            {% set comptages = comptages_par_joueur[j.id] ?? {} %}
                            {% set pts = ((comptages.tir_2pt_int_reussi ?? 0) + (comptages.tir_2pt_ext_reussi ?? 0)) * 2
                                       + (comptages.tir_3pt_reussi ?? 0) * 3
                                       + (comptages.lancer_reussi ?? 0) %}
                            {% set est_sur_terrain = j.id in ids_sur_terrain %}
                            <div class="joueuse-item {{ est_sur_terrain ? 'sur-terrain' : '' }}"
                                 data-joueur-id="{{ j.id }}"
                                 data-pts="{{ pts }}"
                                 data-cote="nous"
                                 data-sur-terrain="{{ est_sur_terrain ? '1' : '0' }}"
                                 style="border-left: 3px solid {{ j.couleurMaillot ?? '#ea580c' }};">
                                <span class="badge-terrain {{ est_sur_terrain ? 'on' : '' }}" data-badge-joueur="{{ j.id }}">
                                    <span class="dot"></span>
                                    <span class="badge-label">{{ est_sur_terrain ? 'ON' : 'OFF' }}</span>
                                </span>
                                <div class="joueuse-avatar"
                                     style="background:{{ j.couleurMaillot ?? '#ea580c' }}; font-size:.7rem;">
                                    {% if j.numeroMaillot is not null %}{{ j.numeroMaillot }}{% else %}{{ j.prenom|first|upper }}{% endif %}
                                </div>
                                <div class="joueuse-info">
                                    <div class="joueuse-name" style="display:flex; align-items:center; gap:4px;">
                                        {{ j.prenom }} {{ j.nom }}
                                        <span style="font-size:.65rem; background:rgba(234,88,12,.2); color:#ea580c; padding:0 4px; border-radius:3px;">essai</span>
                                    </div>
                                    <div class="joueuse-stats">
                                        <span class="pts" data-joueur-pts="{{ j.id }}">{{ pts }}</span> pts
                                        · <span class="temps-jeu" data-temps-jeu="{{ j.id }}">00:00</span>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    {% endif %}

                    {# [V2.2] Joueuses éphémères de L'ÉQUIPE ADVERSE #}
                    {% if joueuses_ephemeres_adverses is defined and joueuses_ephemeres_adverses|length > 0 %}
                        <div style="margin:8px 0 4px; padding:4px 0; border-top:1px solid rgba(255,255,255,.08); font-size:.72rem; font-weight:700; color:#ef4444; text-transform:uppercase; letter-spacing:.05em;">
                            🆚 {{ joueuses_ephemeres_adverses[0].equipeEphemere ?? rencontre.adversaire }}
                        </div>
                        {% for j in joueuses_ephemeres_adverses %}
                            {% set comptages = comptages_par_joueur[j.id] ?? {} %}
                            {% set pts = ((comptages.tir_2pt_int_reussi ?? 0) + (comptages.tir_2pt_ext_reussi ?? 0)) * 2
                                       + (comptages.tir_3pt_reussi ?? 0) * 3
                                       + (comptages.lancer_reussi ?? 0) %}
                            {% set est_sur_terrain = j.id in ids_sur_terrain %}
                            <div class="joueuse-item {{ est_sur_terrain ? 'sur-terrain' : '' }}"
                                 data-joueur-id="{{ j.id }}"
                                 data-pts="{{ pts }}"
                                 data-cote="adverse"
                                 data-sur-terrain="{{ est_sur_terrain ? '1' : '0' }}"
                                 style="border-left: 3px solid {{ j.couleurMaillot ?? '#ef4444' }}; opacity:.9;">
                                <span class="badge-terrain {{ est_sur_terrain ? 'on' : '' }}" data-badge-joueur="{{ j.id }}">
                                    <span class="dot"></span>
                                    <span class="badge-label">{{ est_sur_terrain ? 'ON' : 'OFF' }}</span>
                                </span>
                                <div class="joueuse-avatar"
                                     style="background:{{ j.couleurMaillot ?? '#ef4444' }}; font-size:.7rem;">
                                    {% if j.numeroMaillot is not null %}{{ j.numeroMaillot }}{% else %}{{ j.prenom|first|upper }}{% endif %}
                                </div>
                                <div class="joueuse-info">
                                    <div class="joueuse-name" style="display:flex; align-items:center; gap:4px;">
                                        {{ j.prenom }} {{ j.nom }}
                                        <span style="font-size:.65rem; background:rgba(239,68,68,.2); color:#ef4444; padding:0 4px; border-radius:3px;">adv</span>
                                    </div>
                                    <div class="joueuse-stats">
                                        <span class="pts" data-joueur-pts="{{ j.id }}">{{ pts }}</span> pts
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    {% endif %}

                {% endif %}
            {% endif %}{# fin mode_interne_ab #}
            </div>

            {# ===== COLONNE 2 : TERRAIN SVG ===== #}
            <div class="court-zone">
                {% set deux_terrains = mode_interne_ab or (joueuses_ephemeres_adverses is defined and joueuses_ephemeres_adverses|length > 0) %}
                {% if deux_terrains %}
                    {% set coteA = mode_interne_ab ? 'a' : 'nous' %}
                    {% set coteB = mode_interne_ab ? 'b' : 'adverse' %}
                    <div style="display:flex; gap:10px; align-items:flex-start;">
                        {{ _self.demi_terrain('', coteA, 'rgba(59,130,246,.14)', mode_interne_ab ? rencontre.equipeANom : 'Notre équipe') }}
                        {{ _self.demi_terrain('Adverse', coteB, 'rgba(239,68,68,.14)', mode_interne_ab ? rencontre.equipeBNom : rencontre.adversaire) }}
                    </div>
                {% else %}
                    {{ _self.demi_terrain('', 'nous', 'transparent', '') }}
                {% endif %}
                <div class="court-hint" id="courtHint">
                    <i class="bi bi-info-circle"></i>
                    Sélectionne une joueuse, puis clique sur SON demi-terrain (surligné) pour saisir un tir.
                </div>
            </div>

            {# ===== COLONNE 3 : ACTIONS ===== #}
            <div class="actions-panel" id="actionsPanel">

                {# === Boutons APRES clic sur terrain (mode tir) === #}
                <div class="actions-group shoot-options">
                    <div class="actions-group-title">Tir saisi sur le terrain</div>
                    <button type="button" class="action-btn action-shot" data-action="shot_reussi">
                        <i class="bi bi-check-circle-fill"></i> RÉUSSI <small id="shotZoneLabel" style="display:block;opacity:.85;font-weight:500;">—</small>
                    </button>
                    <button type="button" class="action-btn action-shot-miss" data-action="shot_rate">
                        <i class="bi bi-x-circle-fill"></i> RATÉ
                    </button>
                    <button type="button" class="action-btn" data-action="cancel_shot" style="background:#475569;">
                        <i class="bi bi-arrow-counterclockwise"></i> Annuler tir
                    </button>
                </div>

                {# === Lancers francs === #}
                <div class="actions-group">
                    <div class="actions-group-title">Lancers francs</div>
                    <button type="button" class="action-btn action-shot" data-type="lancer_reussi">
                        <i class="bi bi-check-lg"></i> LF Réussi (+1)
                    </button>
                    <button type="button" class="action-btn action-shot-miss" data-type="lancer_rate">
                        <i class="bi bi-x-lg"></i> LF Raté
                    </button>
                </div>

                {# === Défense / passes === #}
                <div class="actions-group">
                    <div class="actions-group-title">Défense + passes</div>
                    <button type="button" class="action-btn action-positive" data-type="rebond_defensif">
                        <i class="bi bi-arrow-down-circle"></i> Rebond DEF
                    </button>
                    <button type="button" class="action-btn action-positive" data-type="rebond_offensif">
                        <i class="bi bi-arrow-up-circle"></i> Rebond OFF
                    </button>
                    <button type="button" class="action-btn action-positive" data-type="passe_decisive">
                        <i class="bi bi-arrow-right-circle"></i> Passe décisive
                    </button>
                    <button type="button" class="action-btn action-positive" data-type="interception">
                        <i class="bi bi-shield-fill"></i> Interception
                    </button>
                    <button type="button" class="action-btn action-positive" data-type="contre">
                        <i class="bi bi-hand-thumbs-up-fill"></i> Contre
                    </button>
                    <button type="button" class="action-btn action-positive" data-type="faute_provoquee">
                        <i class="bi bi-emoji-sunglasses"></i> Faute provoquée
                    </button>
                </div>

                {# === Erreurs === #}
                <div class="actions-group">
                    <div class="actions-group-title">Erreurs</div>
                    <button type="button" class="action-btn action-negative" data-type="perte_balle">
                        <i class="bi bi-x-octagon"></i> Perte de balle
                    </button>
                    <button type="button" class="action-btn action-negative" data-type="faute_commise">
                        <i class="bi bi-exclamation-triangle"></i> Faute commise
                    </button>
                    <button type="button" class="action-btn action-negative" data-type="contre_subi">
                        <i class="bi bi-hand-thumbs-down"></i> Contre subi
                    </button>
                </div>

            </div>
        </div>

        {# ===== HISTORIQUE FOOTER ===== #}
        <div class="history-bar">
            <div class="history-bar-title">
                <i class="bi bi-clock-history"></i> HISTORIQUE — dernières actions (cliquer ⨯ pour annuler)
            </div>
            <div class="history-items" id="historyItems">
                {% for action in historique %}
                    <div class="history-item" data-action-id="{{ action.id }}">
                        <strong>{{ action.joueur.prenom|first|upper }}{{ action.joueur.nom|first|upper }}</strong>
                        <span style="color:#fbbf24;">{{ action.type }}</span>
                        <small style="color:#94a3b8;">{{ action.quartTemps }} {{ action.minute }}'{{ action.secondes }}"</small>
                        <button class="undo-btn" title="Annuler">✕</button>
                    </div>
                {% endfor %}
                {% if historique is empty %}
                    <small style="color:#94a3b8; font-style:italic;">Aucune action saisie pour le moment.</small>
                {% endif %}
            </div>
        </div>
    </div>

    {# ===== V2.1h — BOTTOM NAV mobile (mode app) =====
       Visible uniquement sous 700px. Donne accès aux actions secondaires
       sans avoir à scroller la page. Les 3 tabs ouvrent un sheet bottom. #}
    <nav class="stats-bottom-nav" id="statsBottomNav" aria-label="Actions mobile">
        <button type="button" class="stats-nav-btn" data-sheet="effectif" aria-label="Effectif du match">
            <span class="nav-icon">📋</span>
            <span class="nav-label">Effectif</span>
        </button>
        {# [V2.3] Pas de score adverse manuel en mode interne A/B (calculé) #}
        {% if not mode_interne_ab %}
        <button type="button" class="stats-nav-btn" data-sheet="adversaire" aria-label="Score adversaire">
            <span class="nav-icon">🔴</span>
            <span class="nav-label">Score adv.</span>
        </button>
        {% endif %}
        <button type="button" class="stats-nav-btn" data-sheet="plus" aria-label="Plus d'actions">
            <span class="nav-icon">⋯</span>
            <span class="nav-label">Plus</span>
        </button>
    </nav>

    {# Sheet Score adversaire (déclenché par bottom nav) #}
    <div class="modal-overlay" id="sheetAdversaire">
        <div class="modal-box modal-box-sheet">
            <h2 class="modal-title">Score adversaire</h2>
            <p class="modal-subtitle">Tape sur les boutons pour ajuster le score live</p>
            <div style="display:grid; grid-template-columns:repeat(2,1fr); gap:10px; margin:14px 0;">
                <button type="button" class="adverse-btn sheet-adv-btn" data-delta="1" style="padding:18px; font-size:1.3rem;">+1</button>
                <button type="button" class="adverse-btn sheet-adv-btn" data-delta="2" style="padding:18px; font-size:1.3rem;">+2 (panier)</button>
                <button type="button" class="adverse-btn sheet-adv-btn" data-delta="3" style="padding:18px; font-size:1.3rem;">+3 (3pts)</button>
                <button type="button" class="adverse-btn adverse-btn-undo sheet-adv-btn" data-delta="-1" style="padding:18px; font-size:1.3rem;">−1</button>
            </div>
            <div style="text-align:center; color:#94a3b8; margin:8px 0; font-size:.85rem;">
                Score actuel : <strong style="color:#ef4444; font-size:1.2rem;" id="sheetAdvScoreLive">0</strong>
            </div>
            <div class="modal-actions">
                <button type="button" class="modal-btn modal-btn-cancel" data-close-sheet="adversaire">Fermer</button>
            </div>
        </div>
    </div>

    {# Sheet Plus (actions secondaires) #}
    <div class="modal-overlay" id="sheetPlus">
        <div class="modal-box modal-box-sheet">
            <h2 class="modal-title">Plus d'actions</h2>
            <div style="display:flex; flex-direction:column; gap:10px; margin:14px 0;">
                <a href="{{ path('manager_rencontre_sessions', {id: rencontre.id}) }}"
                   class="modal-btn modal-btn-cancel" style="text-align:left; padding:14px; text-decoration:none;">
                    🗂️ Voir les sessions de saisie
                </a>
                <a href="{{ path('manager_rencontre_show', {id: rencontre.id}) }}"
                   class="modal-btn modal-btn-cancel" style="text-align:left; padding:14px; text-decoration:none;">
                    📅 Retour à la rencontre
                </a>
                <button type="button" class="modal-btn modal-btn-cancel"
                        id="sheetPlusCinq" style="text-align:left; padding:14px;">
                    👥 Composer le 5
                </button>
            </div>
            <div class="modal-actions">
                <button type="button" class="modal-btn modal-btn-cancel" data-close-sheet="plus">Fermer</button>
            </div>
        </div>
    </div>

    {# Toast feedback en bas à droite #}
    <div id="toast"></div>

    {# ===== MODAL ACTION GUIDÉE V2.1g.2 (mode Débutant) =====
       Workflow : click joueuse → choisir type d'action → sous-workflows selon type.
       Le modal peut afficher plusieurs "écrans" en séquence (étapes). #}
    <div class="modal-overlay" id="modalAction">
        <div class="modal-box">
            <h2 class="modal-title" id="modalActionTitle">Que veux-tu saisir ?</h2>
            <p class="modal-subtitle" id="modalActionSubtitle"></p>
            <div id="modalActionBody"></div>
            <div class="modal-actions">
                <button type="button" class="modal-btn modal-btn-cancel" id="modalActionCancel">Annuler</button>
            </div>
        </div>
    </div>

    {# ===== MODAL "Effectif du match" V2.1f =====
       Logique INVERSÉE pour l'intuitivité :
       - Joueuse cochée (vert) = ELLE JOUE
       - Joueuse décochée (gris) = ABSENTE (blessée/examen)
       Par défaut toutes cochées. L'user décoche celles qui n'y sont pas. #}
    <div class="modal-overlay" id="modalEffectif">
        <div class="modal-box">
            <h2 class="modal-title">📋 Effectif du match</h2>
            <p class="modal-subtitle">
                Coche les joueuses qui jouent aujourd'hui. Décoche celles qui sont
                absentes (blessées, examens). Par défaut, toutes sont cochées.
            </p>
            <div class="modal-counter" id="modalEffectifCounter">— qui jouent</div>
            <div class="modal-grid" id="modalEffectifGrid">
                {# Boutons générés à l'ouverture #}
            </div>
            <div class="modal-actions">
                <button type="button" class="modal-btn modal-btn-cancel" id="modalEffectifCancel">Annuler</button>
                <button type="button" class="modal-btn modal-btn-validate" id="modalEffectifValidate" style="background:#ea580c;">Enregistrer l'effectif</button>
            </div>
        </div>
    </div>

    {# ===== MODAL "Composer le 5" V2.1b ===== #}
    <div class="modal-overlay" id="modalCinq">
        <div class="modal-box">
            <h2 class="modal-title">👥 Composer le 5 sur le terrain</h2>
            <p class="modal-subtitle">
                Sélectionne EXACTEMENT 5 joueuses. Les autres seront sur le banc et pourront entrer plus tard.
            </p>
            <div class="modal-counter" id="modalCinqCounter">0 / 5 sélectionnées</div>
            <div class="modal-grid" id="modalCinqGrid">
                {# Boutons générés à l'ouverture (voir openModalCinq) #}
            </div>
            <div class="modal-actions">
                <button type="button" class="modal-btn modal-btn-cancel" id="modalCinqCancel">Annuler</button>
                <button type="button" class="modal-btn modal-btn-validate" id="modalCinqValidate" disabled>Valider le 5</button>
            </div>
        </div>
    </div>

{% endblock %}


{% block javascripts %}
    {{ parent() }}
    <script>
    (function(){
        // ====================================================================
        // CONFIGURATION — données injectées depuis Twig
        // ====================================================================
        const RENCONTRE_ID = {{ rencontre.id }};
        const CSRF_TOKEN = '{{ csrf_token('stats_live_' ~ rencontre.id) }}';
        // [V2.3] Match interne à deux équipes : bascule le calcul des scores
        // du header en mode "somme par colonne A/B" (voir updateScoreEquipe).
        const MODE_INTERNE_AB = {{ mode_interne_ab ? 'true' : 'false' }};
        const URL_ACTION_CREATE = '{{ path('manager_rencontre_stats_live_action_create', {id: rencontre.id}) }}';
        const URL_ACTION_DELETE_BASE = '{{ path('manager_rencontre_stats_live_action_delete', {id: rencontre.id, actionId: 0}) }}'.replace(/\/0$/, '/');

        // Format match V2.1a — venant de l'entité Rencontre
        const NB_PERIODES = {{ rencontre.nbPeriodes }};
        const DUREE_PERIODE_MIN = {{ rencontre.dureePeriodeMinutes }};
        const STORAGE_KEY = 'mabb_chrono_' + RENCONTRE_ID;

        // ====================================================================
        // ÉTAT LOCAL
        // ====================================================================
        let state = {
            joueurActif: null,       // id de la joueuse sélectionnée
            tirX: null,              // position X normalisée 0-1 du tir en cours
            tirY: null,              // position Y normalisée 0-1 du tir en cours
            tirZone: null,           // zone détectée (3pt / 2pt int / 2pt ext)
            quartTemps: 'QT1',       // libellé compat (sera dérivé du chrono)
            minute: 0,               // minute du match (déduite du chrono)
            secondes: 0,             // seconde du match
        };

        // ====================================================================
        // CHRONO (V2.1a)
        // ====================================================================
        // Le chrono est INDÉPENDANT de state : il a son propre objet pour
        // pouvoir survivre à un refresh tablette via localStorage.
        let chrono = {
            periode: 1,                              // 1 à NB_PERIODES (ou +1 si prolongation)
            tempsRestantSec: DUREE_PERIODE_MIN * 60, // décompte en secondes
            running: false,                          // true = timer actif
            lastTick: null,                          // timestamp du dernier tick (pour drift correction)
            intervalId: null,                        // id du setInterval
        };

        // Restaure depuis localStorage si on a déjà commencé ce match
        function restoreChrono() {
            try {
                const raw = localStorage.getItem(STORAGE_KEY);
                if (!raw) return;
                const saved = JSON.parse(raw);
                if (typeof saved.periode === 'number') chrono.periode = saved.periode;
                if (typeof saved.tempsRestantSec === 'number') chrono.tempsRestantSec = saved.tempsRestantSec;
                // On NE restore PAS running (sécurité : si tablette plantée, on redémarre en pause)
            } catch (e) { /* corrupt storage : on ignore */ }
        }

        function persistChrono() {
            try {
                localStorage.setItem(STORAGE_KEY, JSON.stringify({
                    periode: chrono.periode,
                    tempsRestantSec: chrono.tempsRestantSec,
                }));
            } catch (e) {}
        }

        function formatChrono(secondesTotal) {
            if (secondesTotal < 0) secondesTotal = 0;
            const m = Math.floor(secondesTotal / 60);
            const s = secondesTotal % 60;
            return String(m).padStart(2, '0') + ':' + String(s).padStart(2, '0');
        }

        function updateChronoDisplay() {
            const display = document.getElementById('chronoDisplay');
            const periodLabel = document.getElementById('periodLabel');

            display.textContent = formatChrono(chrono.tempsRestantSec);

            // Style selon état
            display.classList.toggle('running', chrono.running);
            display.classList.toggle('warning', chrono.tempsRestantSec < 60 && chrono.tempsRestantSec > 0);

            // Libellé période (Q1/Q2... pour quart-temps, M1/M2 pour mi-temps)
            const prefix = NB_PERIODES === 4 ? 'Q' : 'M';
            periodLabel.textContent = prefix + chrono.periode;

            // Met à jour state.quartTemps pour compat avec saveAction()
            state.quartTemps = (NB_PERIODES === 4 ? 'QT' : 'MT') + chrono.periode;
            // state.minute / secondes = temps ÉCOULÉ dans la période (utile pour ActionMatch)
            const ecoule = (DUREE_PERIODE_MIN * 60) - chrono.tempsRestantSec;
            state.minute = Math.floor(ecoule / 60);
            state.secondes = ecoule % 60;
        }

        function tick() {
            if (!chrono.running) return;
            const now = Date.now();
            const elapsed = chrono.lastTick ? Math.floor((now - chrono.lastTick) / 1000) : 1;
            chrono.lastTick = now;
            chrono.tempsRestantSec -= elapsed;

            if (chrono.tempsRestantSec <= 0) {
                chrono.tempsRestantSec = 0;
                pauseChrono();
                toast('Fin de la période !');
            }
            updateChronoDisplay();
            persistChrono();
        }

        function startChrono() {
            if (chrono.tempsRestantSec <= 0) {
                toast('Période terminée. Clique → pour la suivante.', true);
                return;
            }
            chrono.running = true;
            chrono.lastTick = Date.now();
            chrono.intervalId = setInterval(tick, 1000);
            document.getElementById('btnStartPauseIcon').textContent = '⏸';
            document.getElementById('btnStartPause').classList.add('is-running');
            updateChronoDisplay();
        }

        function pauseChrono() {
            chrono.running = false;
            if (chrono.intervalId) {
                clearInterval(chrono.intervalId);
                chrono.intervalId = null;
            }
            document.getElementById('btnStartPauseIcon').textContent = '▶';
            document.getElementById('btnStartPause').classList.remove('is-running');
            updateChronoDisplay();
        }

        function resetPeriode() {
            if (!confirm('Réinitialiser la période ' + chrono.periode + ' à ' + DUREE_PERIODE_MIN + ':00 ?')) return;
            pauseChrono();
            chrono.tempsRestantSec = DUREE_PERIODE_MIN * 60;
            updateChronoDisplay();
            persistChrono();
        }

        function periodeNext() {
            const nextNum = chrono.periode + 1;
            const total = NB_PERIODES;
            let msg;
            if (nextNum <= total) {
                msg = 'Passer à la période ' + nextNum + ' / ' + total + ' ?';
            } else {
                // Au-delà du nb prévu = prolongation
                msg = 'Période ' + chrono.periode + ' terminée. Démarrer une PROLONGATION (' + DUREE_PERIODE_MIN + ' min) ?';
            }
            if (!confirm(msg)) return;
            pauseChrono();
            chrono.periode = nextNum;
            chrono.tempsRestantSec = DUREE_PERIODE_MIN * 60;
            updateChronoDisplay();
            persistChrono();
        }

        function ajusterChrono(deltaSec) {
            chrono.tempsRestantSec = Math.max(0, chrono.tempsRestantSec + deltaSec);
            updateChronoDisplay();
            persistChrono();
        }

        // === Init chrono au chargement ===
        restoreChrono();
        updateChronoDisplay();
        document.getElementById('btnStartPause').addEventListener('click', () => {
            chrono.running ? pauseChrono() : startChrono();
        });
        document.getElementById('btnResetChrono').addEventListener('click', resetPeriode);
        document.getElementById('btnNextPeriod').addEventListener('click', periodeNext);
        document.getElementById('btnMinus1').addEventListener('click', () => ajusterChrono(-1));
        document.getElementById('btnPlus1').addEventListener('click', () => ajusterChrono(+1));

        // ====================================================================
        // V2.1b — Présence sur le terrain (5 + changements + temps de jeu)
        // ====================================================================
        // URLs API exposées via Twig pour rester centralisé
        const URL_ENTRER = '{{ path('manager_rencontre_stats_live_entrer', {id: rencontre.id}) }}';
        const URL_SORTIR = '{{ path('manager_rencontre_stats_live_sortir', {id: rencontre.id}) }}';

        /**
         * Temps absolu en secondes depuis Q1 0:00.
         * Le serveur a besoin de ça pour calculer le temps de jeu réel.
         * Calcul : (période_passées) * durée_période + temps_écoulé_dans_période_courante.
         */
        function getTempsAbsolu() {
            const periodesPassees = chrono.periode - 1;
            const ecouleDansPeriode = (DUREE_PERIODE_MIN * 60) - chrono.tempsRestantSec;
            return periodesPassees * DUREE_PERIODE_MIN * 60 + ecouleDansPeriode;
        }

        /**
         * État local des joueuses sur le terrain (Set d'IDs).
         * Initialisé depuis ce que le serveur a envoyé (ids_sur_terrain).
         * Pour chaque ID, on stocke aussi le temps d'entrée (secondes absolues)
         * pour calculer le temps de jeu LIVE sans appel serveur.
         */
        const surTerrain = new Map(); // joueurId → secondesEntree
        {% for jid in ids_sur_terrain %}
            // Au reload de la page, on ne connaît PAS le temps d'entrée précis
            // (le serveur le sait mais on ne le récupère pas dans la payload).
            // Approximation : on considère qu'elle est entrée à l'instant courant.
            // L'historique BDD reste précis, c'est juste l'affichage LIVE qui peut
            // être sous-estimé après un reload.
            surTerrain.set({{ jid }}, getTempsAbsolu());
        {% endfor %}

        /**
         * Met à jour visuellement le badge ON/OFF + classe sur-terrain.
         */
        function updateBadge(joueurId, estSurTerrain) {
            const item = document.querySelector('.joueuse-item[data-joueur-id="' + joueurId + '"]');
            if (!item) return;
            item.dataset.surTerrain = estSurTerrain ? '1' : '0';
            item.classList.toggle('sur-terrain', estSurTerrain);
            const badge = item.querySelector('.badge-terrain');
            if (badge) {
                badge.classList.toggle('on', estSurTerrain);
                badge.querySelector('.badge-label').textContent = estSurTerrain ? 'ON' : 'OFF';
            }
        }

        /**
         * Format MM:SS pour l'affichage temps de jeu.
         */
        function formatTempsJeu(s) {
            const m = Math.floor(s / 60);
            const sec = s % 60;
            return String(m).padStart(2, '0') + ':' + String(sec).padStart(2, '0');
        }

        /**
         * Met à jour les compteurs de temps de jeu live pour TOUTES les joueuses
         * sur le terrain. Appelé chaque seconde si le chrono tourne.
         */
        function refreshTempsJeu() {
            const now = getTempsAbsolu();
            surTerrain.forEach((tEntree, jid) => {
                const dureeSec = Math.max(0, now - tEntree);
                const el = document.querySelector('[data-temps-jeu="' + jid + '"]');
                if (el) el.textContent = formatTempsJeu(dureeSec);
            });
        }

        /**
         * Appelle l'API /entrer pour faire entrer une joueuse + met à jour l'UI.
         */
        async function entrerJoueuse(joueurId) {
            try {
                const tempsAbsolu = getTempsAbsolu();
                const res = await fetch(URL_ENTRER, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF_TOKEN },
                    body: JSON.stringify({ joueurId: joueurId, tempsAbsolu: tempsAbsolu }),
                });
                const data = await res.json();
                if (!res.ok || !data.success) {
                    toast(data.error || 'Entrée refusée', true);
                    return false;
                }
                surTerrain.set(joueurId, tempsAbsolu);
                updateBadge(joueurId, true);
                return true;
            } catch (e) {
                toast('Erreur réseau (entrée)', true);
                return false;
            }
        }

        /**
         * Appelle l'API /sortir pour faire sortir une joueuse + met à jour l'UI.
         */
        async function sortirJoueuse(joueurId) {
            try {
                const tempsAbsolu = getTempsAbsolu();
                const res = await fetch(URL_SORTIR, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF_TOKEN },
                    body: JSON.stringify({ joueurId: joueurId, tempsAbsolu: tempsAbsolu }),
                });
                const data = await res.json();
                if (!res.ok || !data.success) {
                    toast(data.error || 'Sortie refusée', true);
                    return false;
                }
                surTerrain.delete(joueurId);
                updateBadge(joueurId, false);
                return true;
            } catch (e) {
                toast('Erreur réseau (sortie)', true);
                return false;
            }
        }

        // === Modal "Composer le 5" ===
        const modal = document.getElementById('modalCinq');
        const modalGrid = document.getElementById('modalCinqGrid');
        const modalCounter = document.getElementById('modalCinqCounter');
        const modalValidate = document.getElementById('modalCinqValidate');

        let modalSelection = new Set();
        // [V2.4e 06/07/2026] Mode interne A/B : côté de chaque joueuse
        // (déduit du DOM à l'ouverture) pour imposer 5 par ÉQUIPE et non
        // 5 au total — un match interne aligne 2×5 joueuses.
        let modalCotes = {};

        function coteDe(jid) { return modalCotes[jid] ?? null; }
        function compteCote(cote) {
            let n = 0;
            modalSelection.forEach(id => { if (coteDe(id) === cote) n++; });
            return n;
        }

        function openModalCinq() {
            // Régénère la grille à chaque ouverture (joueuses + sélection = celles actuellement sur terrain)
            modalSelection = new Set(surTerrain.keys());
            modalCotes = {};
            modalGrid.innerHTML = '';
            const titre = document.querySelector('#modalCinq .modal-title');
            if (titre) titre.textContent = MODE_INTERNE_AB ? 'Composer les deux 5 (A et B)' : 'Composer le 5 de départ';
            document.querySelectorAll('.joueuse-item').forEach(item => {
                const jid = parseInt(item.dataset.joueurId, 10);
                const nom = item.querySelector('.joueuse-name').textContent.trim();
                const num = item.querySelector('.joueuse-avatar').textContent.trim();
                // Côté A/B via la colonne parente (mode interne uniquement)
                const cote = item.closest('.ab-col-a') ? 'A' : (item.closest('.ab-col-b') ? 'B' : null);
                modalCotes[jid] = cote;
                const btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'modal-joueuse-btn' + (modalSelection.has(jid) ? ' selected' : '');
                btn.dataset.joueurId = jid;
                const chip = cote
                    ? '<span style="font-size:.65rem; font-weight:800; padding:1px 6px; border-radius:6px; margin-right:4px; background:' +
                      (cote === 'A' ? 'rgba(59,130,246,.25); color:#3b82f6' : 'rgba(239,68,68,.25); color:#ef4444') + ';">' + cote + '</span>'
                    : '';
                btn.innerHTML = chip + '<strong>#' + num + '</strong> · ' + nom;
                btn.addEventListener('click', () => {
                    if (modalSelection.has(jid)) {
                        modalSelection.delete(jid);
                        btn.classList.remove('selected');
                    } else {
                        if (MODE_INTERNE_AB && cote) {
                            if (compteCote(cote) >= 5) {
                                toast('Maximum 5 joueuses sur le terrain pour l\'équipe ' + cote + '.', true);
                                return;
                            }
                        } else if (modalSelection.size >= 5) {
                            toast('Maximum 5 joueuses sur le terrain.', true);
                            return;
                        }
                        modalSelection.add(jid);
                        btn.classList.add('selected');
                    }
                    refreshModalCounter();
                });
                modalGrid.appendChild(btn);
            });
            refreshModalCounter();
            modal.classList.add('show');
        }

        function refreshModalCounter() {
            if (MODE_INTERNE_AB) {
                const nA = compteCote('A'), nB = compteCote('B');
                modalCounter.textContent = 'Équipe A : ' + nA + '/5 · Équipe B : ' + nB + '/5';
                const complet = (nA === 5 && nB === 5);
                modalCounter.classList.toggle('complete', complet);
                // On autorise la validation dès qu'aucune équipe ne dépasse 5
                // et qu'au moins une joueuse est sélectionnée (une équipe peut
                // avoir moins de 5 joueuses en interne — le coach décide).
                modalValidate.disabled = (modalSelection.size === 0 || nA > 5 || nB > 5);
                return;
            }
            const n = modalSelection.size;
            modalCounter.textContent = n + ' / 5 sélectionnées';
            modalCounter.classList.toggle('complete', n === 5);
            modalValidate.disabled = (n !== 5);
        }

        function closeModalCinq() { modal.classList.remove('show'); }

        /**
         * Valide la sélection : diff avec la composition actuelle
         * → entrées (nouvelles) + sorties (retirées).
         */
        async function validerCompositionCinq() {
            const actuelles = new Set(surTerrain.keys());
            const choisies = modalSelection;

            const aSortir = [...actuelles].filter(j => !choisies.has(j));
            const aEntrer = [...choisies].filter(j => !actuelles.has(j));

            // Sorties d'abord (libère du temps de jeu), puis entrées
            for (const jid of aSortir) await sortirJoueuse(jid);
            for (const jid of aEntrer) await entrerJoueuse(jid);

            closeModalCinq();
            toast('5 sur le terrain : ' + choisies.size + ' joueuses');
        }

        document.getElementById('btnComposerCinq').addEventListener('click', openModalCinq);
        document.getElementById('modalCinqCancel').addEventListener('click', closeModalCinq);
        document.getElementById('modalCinqValidate').addEventListener('click', validerCompositionCinq);
        // Click sur overlay (hors box) ferme le modal
        modal.addEventListener('click', (e) => { if (e.target === modal) closeModalCinq(); });

        // === Tick auto pour rafraîchir le temps de jeu live ===
        // Indépendant du chrono : tourne dès qu'au moins 1 joueuse est sur le terrain
        // ET que le chrono tourne. Sinon, valeurs figées.
        setInterval(() => {
            if (chrono.running && surTerrain.size > 0) refreshTempsJeu();
        }, 1000);

        // 1er render des temps de jeu à 00:00
        refreshTempsJeu();

        // ====================================================================
        // V2.1e — Score adverse live
        // ====================================================================
        const URL_SCORE_ADVERSE = '{{ path('manager_rencontre_stats_live_score_adverse', {id: rencontre.id}) }}';
        const scoreAdverseDisplay = document.getElementById('scoreAdverseDisplay');

        async function updateScoreAdverse(delta) {
            try {
                const res = await fetch(URL_SCORE_ADVERSE, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF_TOKEN },
                    body: JSON.stringify({ delta: delta }),
                });
                const data = await res.json();
                if (!res.ok || !data.success) {
                    toast(data.error || 'Échec mise à jour score adverse', true);
                    return;
                }
                scoreAdverseDisplay.textContent = data.scoreAdverse;
                // Petit flash visuel pour confirmer
                scoreAdverseDisplay.style.transform = 'scale(1.15)';
                setTimeout(() => { scoreAdverseDisplay.style.transform = ''; }, 200);
                toast((delta > 0 ? '+' : '') + delta + ' adverse → ' + data.scoreAdverse);
            } catch (e) {
                toast('Erreur réseau (score adverse)', true);
            }
        }

        document.querySelectorAll('.adverse-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const delta = parseInt(btn.dataset.delta, 10);
                updateScoreAdverse(delta);
            });
        });

        // ====================================================================
        // V2.1f — Modal Effectif du match
        // ====================================================================
        const URL_EFFECTIF = '{{ path('manager_rencontre_stats_live_effectif', {id: rencontre.id}) }}';

        // Liste COMPLÈTE de l'effectif équipe (utile car la sidebar n'a que les présentes)
        // Format injecté : [{id, prenom, nom, num}, ...]
        const EFFECTIF_COMPLET = [
            {% for j in joueuses_toutes %}
                { id: {{ j.id }}, prenom: {{ j.prenom|json_encode|raw }}, nom: {{ j.nom|json_encode|raw }}, num: {{ j.numeroMaillot ?? 'null' }} }{% if not loop.last %},{% endif %}
            {% endfor %}
        ];
        // IDs actuellement marquées NON convoquées (sur le banc des absentes)
        let nonConvoqueesActuelles = new Set([{{ ids_non_convoquees|join(', ') }}]);

        const modalEffectif = document.getElementById('modalEffectif');
        const modalEffectifGrid = document.getElementById('modalEffectifGrid');
        const modalEffectifCounter = document.getElementById('modalEffectifCounter');
        // INVERSION V2.1f : la sélection représente maintenant les JOUEUSES QUI JOUENT
        // (UX intuitive : "je coche les présentes" est plus naturel que "je coche les absentes")
        let modalEffectifJouent = new Set();

        function openModalEffectif() {
            // [V2.4e 06/07/2026] Mode interne A/B : l'effectif du match EST la
            // composition A/B (le modal classique liste l'équipe de la rencontre,
            // hors sujet pour un match interne multi-catégorie) → on envoie vers
            // la page de composition, qui est l'outil adapté.
            if (MODE_INTERNE_AB) {
                window.location.href = '{{ path('manager_rencontre_composition_interne', {id: rencontre.id}) }}';
                return;
            }
            // Par défaut TOUTES les joueuses jouent SAUF celles dans nonConvoqueesActuelles
            modalEffectifJouent = new Set(
                EFFECTIF_COMPLET
                    .map(j => j.id)
                    .filter(id => !nonConvoqueesActuelles.has(id))
            );
            modalEffectifGrid.innerHTML = '';
            EFFECTIF_COMPLET.forEach(j => {
                const btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'modal-joueuse-btn' + (modalEffectifJouent.has(j.id) ? ' selected' : '');
                btn.dataset.joueurId = j.id;
                btn.innerHTML = '<strong>' + (j.num !== null ? '#' + j.num : '·') + '</strong> ' + j.prenom + ' ' + j.nom;
                btn.addEventListener('click', () => {
                    if (modalEffectifJouent.has(j.id)) {
                        modalEffectifJouent.delete(j.id);
                        btn.classList.remove('selected');
                    } else {
                        modalEffectifJouent.add(j.id);
                        btn.classList.add('selected');
                    }
                    refreshEffectifCounter();
                });
                modalEffectifGrid.appendChild(btn);
            });
            refreshEffectifCounter();
            modalEffectif.classList.add('show');
        }

        function refreshEffectifCounter() {
            const nbJouent = modalEffectifJouent.size;
            const total = EFFECTIF_COMPLET.length;
            const nbAbsentes = total - nbJouent;
            modalEffectifCounter.textContent = nbAbsentes === 0
                ? '✓ Toutes les ' + total + ' joueuses jouent'
                : nbJouent + ' jouent · ' + nbAbsentes + ' absente' + (nbAbsentes > 1 ? 's' : '');
            modalEffectifCounter.classList.toggle('complete', nbAbsentes === 0);
        }

        function closeModalEffectif() { modalEffectif.classList.remove('show'); }

        async function validerEffectif() {
            // Calcule les NON convoquées = EFFECTIF_COMPLET MINUS celles qui jouent
            const idsNonConvoquees = EFFECTIF_COMPLET
                .map(j => j.id)
                .filter(id => !modalEffectifJouent.has(id));
            try {
                const res = await fetch(URL_EFFECTIF, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF_TOKEN },
                    body: JSON.stringify({ joueursNonConvoques: idsNonConvoquees }),
                });
                const data = await res.json();
                if (!res.ok || !data.success) {
                    toast(data.error || 'Échec mise à jour effectif', true);
                    return;
                }
                nonConvoqueesActuelles = new Set(data.joueursNonConvoques);
                closeModalEffectif();
                toast('Effectif enregistré — rechargement…');
                // Rechargement auto pour appliquer le filtre sidebar côté serveur
                setTimeout(() => location.reload(), 600);
            } catch (e) {
                toast('Erreur réseau (effectif)', true);
            }
        }

        document.getElementById('btnEffectifMatch').addEventListener('click', openModalEffectif);
        document.getElementById('modalEffectifCancel').addEventListener('click', closeModalEffectif);
        document.getElementById('modalEffectifValidate').addEventListener('click', validerEffectif);
        modalEffectif.addEventListener('click', (e) => { if (e.target === modalEffectif) closeModalEffectif(); });

        // ====================================================================
        // V2.1g — Mode Expert / Mode Débutant
        // ====================================================================
        const MODE_STORAGE_KEY = 'mabb_mode_' + RENCONTRE_ID;
        const wrapper = document.getElementById('liveWrapper');
        const btnExpert = document.getElementById('modeExpertBtn');
        const btnDebutant = document.getElementById('modeDebutantBtn');

        function appliquerMode(mode) {
            if (mode === 'debutant') {
                wrapper.classList.add('mode-debutant');
                btnDebutant.classList.add('active');
                btnExpert.classList.remove('active');
            } else {
                wrapper.classList.remove('mode-debutant');
                btnExpert.classList.add('active');
                btnDebutant.classList.remove('active');
            }
            try { localStorage.setItem(MODE_STORAGE_KEY, mode); } catch(e) {}
        }

        // V2.1g.5 — Mode Débutant par défaut (HTML déjà en mode-debutant).
        // Restore depuis localStorage seulement si l'user a explicitement choisi
        // Expert lors d'une session précédente. Sinon on reste en Débutant.
        try {
            const modeSauve = localStorage.getItem(MODE_STORAGE_KEY);
            if (modeSauve === 'expert') appliquerMode('expert');
        } catch(e) {}

        btnExpert.addEventListener('click', () => appliquerMode('expert'));
        btnDebutant.addEventListener('click', () => appliquerMode('debutant'));

        // V2.1h — Sous 500px (mobile portrait), on FORCE le mode débutant.
        // Le terrain SVG est inutilisable sur un écran si étroit ; le toggle
        // Expert est masqué visuellement par CSS (opacity + pointer-events:none)
        // et désactivé fonctionnellement ici. Si le user retourne en paysage
        // (>= 500px), on lui rend la main : on restore le mode préféré du
        // localStorage. matchMedia + listener = pas besoin de reload.
        const mqlSmartphone = window.matchMedia('(max-width: 499px)');
        function appliquerContrainteEcran(e) {
            if (e.matches) {
                // Trop petit → force débutant (sans toucher au localStorage,
                // pour préserver le choix du user quand il reviendra en paysage)
                if (!wrapper.classList.contains('mode-debutant')) {
                    wrapper.classList.add('mode-debutant');
                    btnDebutant.classList.add('active');
                    btnExpert.classList.remove('active');
                }
                btnExpert.setAttribute('disabled', '');
                btnExpert.title = 'Mode Expert indisponible en portrait smartphone — tourne ton écran ou utilise une tablette.';
            } else {
                // Retour à un écran assez large → on respecte le choix sauvegardé
                btnExpert.removeAttribute('disabled');
                btnExpert.title = '';
                try {
                    const modeSauve = localStorage.getItem(MODE_STORAGE_KEY);
                    if (modeSauve === 'expert') appliquerMode('expert');
                } catch(e) {}
            }
        }
        // Run au chargement + à chaque rotation d'écran / resize
        appliquerContrainteEcran(mqlSmartphone);
        mqlSmartphone.addEventListener('change', appliquerContrainteEcran);

        // ====================================================================
        // V2.1g.2 — Workflow guidé Mode Débutant
        // ====================================================================
        // En mode Débutant :
        //   - Click joueuse → ouvre modal "Que veux-tu saisir ?"
        //   - Selon le type → sous-workflows (assist, rebond, zone interception…)
        //   - Click carte "Adversaire" → modal actions adverses (tir raté → rebond pour nous)
        //
        // Le modal réutilise la structure du modalAction (titre + body + cancel).
        // On change le contenu HTML du body selon l'étape.

        const modalAction = document.getElementById('modalAction');
        const modalActionTitle = document.getElementById('modalActionTitle');
        const modalActionSubtitle = document.getElementById('modalActionSubtitle');
        const modalActionBody = document.getElementById('modalActionBody');
        document.getElementById('modalActionCancel').addEventListener('click', () => modalAction.classList.remove('show'));
        modalAction.addEventListener('click', (e) => { if (e.target === modalAction) modalAction.classList.remove('show'); });

        function openModalAction(titre, sousTitre, bodyHtml) {
            modalActionTitle.textContent = titre;
            modalActionSubtitle.textContent = sousTitre || '';
            modalActionBody.innerHTML = bodyHtml;
            modalAction.classList.add('show');
        }
        function closeModalAction() { modalAction.classList.remove('show'); }

        // ─── Étape 1 : choix du type d'action pour UNE joueuse ───
        function workflowJoueuse(joueurId, joueurNom) {
            const btn = (type, color, icon, label) =>
                `<button class="action-btn ${color}" data-type="${type}"><span class="icon">${icon}</span><span class="lbl">${label}</span></button>`;
            const html = `
                <div class="action-grid">
                    ${btn('tir_2pt_int_reussi', 'action-btn-success', '🏀', 'Panier 2pts')}
                    ${btn('tir_3pt_reussi', 'action-btn-success', '🎯', 'Panier 3pts')}
                    ${btn('lancer_reussi', 'action-btn-success', '🤲', 'LF réussi')}
                    ${btn('tir_2pt_int_rate', 'action-btn-danger', '❌', 'Tir 2pts raté')}
                    ${btn('tir_3pt_rate', 'action-btn-danger', '❌', 'Tir 3pts raté')}
                    ${btn('lancer_rate', 'action-btn-danger', '❌', 'LF raté')}
                    ${btn('rebond_offensif', 'action-btn-warning', '🔄', 'Rebond Off')}
                    ${btn('rebond_defensif', 'action-btn-warning', '🛡️', 'Rebond Déf')}
                    ${btn('interception', 'action-btn-info', '✋', 'Interception')}
                    ${btn('passe_decisive', 'action-btn-purple', '🎁', 'Passe D')}
                    ${btn('faute_commise', 'action-btn-danger', '⚠️', 'Faute')}
                    ${btn('perte_balle', 'action-btn-danger', '💥', 'Perte balle')}
                </div>
            `;
            openModalAction(joueurNom, 'Choisis le type d\'action', html);
            modalActionBody.querySelectorAll('.action-btn').forEach(b => {
                b.addEventListener('click', () => handleActionChoisie(joueurId, joueurNom, b.dataset.type));
            });
        }

        // ─── Étape 2 : selon le type, ouvre un sous-workflow ou enregistre direct ───
        async function handleActionChoisie(joueurId, joueurNom, type) {
            state.joueurActif = joueurId;

            // Tir RÉUSSI → demande "avec assist ?"
            if (['tir_2pt_int_reussi', 'tir_2pt_ext_reussi', 'tir_3pt_reussi'].includes(type)) {
                workflowAssist(joueurId, joueurNom, type);
                return;
            }

            // Tir RATÉ → demande "qui a eu le rebond ?"
            if (['tir_2pt_int_rate', 'tir_2pt_ext_rate', 'tir_3pt_rate', 'lancer_rate'].includes(type)) {
                // On enregistre d'abord le tir raté
                await saveAction(type, { positionX: 0.5, positionY: 0.5 });
                workflowRebondApresTirRate(joueurNom);
                return;
            }

            // Interception → demande zone avant ou arrière (= info dans toast)
            if (type === 'interception') {
                workflowZoneInterception(joueurId, joueurNom);
                return;
            }

            // Passe D → demande qui a marqué
            if (type === 'passe_decisive') {
                workflowPasseDecisive(joueurId, joueurNom);
                return;
            }

            // Action simple → enregistré direct
            const needsPosition = ['tir_2pt_int_reussi', 'tir_3pt_reussi', 'lancer_reussi'].includes(type);
            await saveAction(type, needsPosition ? { positionX: 0.5, positionY: 0.5 } : {});
            closeModalAction();
        }

        // ─── Sous-workflow : tir réussi avec assist ? ───
        function workflowAssist(joueurId, joueurNom, typeTir) {
            const html = `
                <div class="action-grid" style="grid-template-columns:1fr 1fr;">
                    <button class="action-btn action-btn-purple" data-choice="oui"><span class="icon">🎁</span><span class="lbl">OUI, avec passe D</span></button>
                    <button class="action-btn" data-choice="non"><span class="icon">⛹️</span><span class="lbl">NON, seule</span></button>
                </div>
            `;
            openModalAction(joueurNom + ' a marqué !', 'Avec une passe décisive ?', html);
            modalActionBody.querySelectorAll('.action-btn').forEach(b => {
                b.addEventListener('click', async () => {
                    if (b.dataset.choice === 'non') {
                        await saveAction(typeTir, { positionX: 0.5, positionY: 0.5 });
                        closeModalAction();
                    } else {
                        // Demande qui a fait la passe
                        showJoueurChoice('Qui a fait la passe ?', joueurId, async (passeurId) => {
                            await saveAction(typeTir, { positionX: 0.5, positionY: 0.5, assistJoueurId: passeurId });
                            closeModalAction();
                        });
                    }
                });
            });
        }

        // ─── Sous-workflow : rebond après tir raté ───
        function workflowRebondApresTirRate(tireuse) {
            const html = `
                <div class="action-grid" style="grid-template-columns:1fr 1fr;">
                    <button class="action-btn action-btn-warning" data-choice="nous"><span class="icon">🛡️</span><span class="lbl">Notre équipe</span></button>
                    <button class="action-btn action-btn-danger" data-choice="adv"><span class="icon">🚫</span><span class="lbl">Adversaire</span></button>
                </div>
            `;
            openModalAction('Tir raté — qui a eu le rebond ?', tireuse + ' a manqué', html);
            modalActionBody.querySelectorAll('.action-btn').forEach(b => {
                b.addEventListener('click', () => {
                    if (b.dataset.choice === 'adv') {
                        // Pas d'enregistrement spécifique côté adverse pour MVP
                        toast('Rebond adverse noté');
                        closeModalAction();
                    } else {
                        showJoueurChoice('Quelle joueuse a pris le rebond ?', null, async (joueurId) => {
                            state.joueurActif = joueurId;
                            await saveAction('rebond_defensif', {});
                            closeModalAction();
                        });
                    }
                });
            });
        }

        // ─── Sous-workflow : zone interception (avant/arrière) ───
        function workflowZoneInterception(joueurId, joueurNom) {
            const html = `
                <div class="action-grid" style="grid-template-columns:1fr 1fr;">
                    <button class="action-btn action-btn-info" data-zone="avant"><span class="icon">⬆️</span><span class="lbl">Zone avant<br>(offensive)</span></button>
                    <button class="action-btn action-btn-info" data-zone="arriere"><span class="icon">⬇️</span><span class="lbl">Zone arrière<br>(défensive)</span></button>
                </div>
            `;
            openModalAction('Interception de ' + joueurNom, 'Dans quelle zone ?', html);
            modalActionBody.querySelectorAll('.action-btn').forEach(b => {
                b.addEventListener('click', async () => {
                    // Position approximée : avant = haut terrain (Y=0.2), arrière = bas (Y=0.8)
                    const posY = b.dataset.zone === 'avant' ? 0.2 : 0.8;
                    state.joueurActif = joueurId;
                    await saveAction('interception', { positionX: 0.5, positionY: posY });
                    toast('Interception ' + b.dataset.zone);
                    closeModalAction();
                });
            });
        }

        // ─── Sous-workflow : passe décisive (qui a marqué après ?) ───
        function workflowPasseDecisive(passeurId, passeurNom) {
            showJoueurChoice('Qui a marqué grâce à ' + passeurNom + ' ?', passeurId, async (marqueurId) => {
                // On crée le tir réussi pour le marqueur + assist pour le passeur
                state.joueurActif = marqueurId;
                await saveAction('tir_2pt_int_reussi', { positionX: 0.5, positionY: 0.5, assistJoueurId: passeurId });
                closeModalAction();
            });
        }

        // ─── Sous-workflow : adversaire (tir raté → rebond pour nous) ───
        function workflowAdversaire() {
            const html = `
                <div class="action-grid" style="grid-template-columns:1fr 1fr;">
                    <button class="action-btn action-btn-danger" data-act="tir_rate"><span class="icon">❌</span><span class="lbl">Tir raté adverse</span></button>
                    <button class="action-btn action-btn-success" data-act="tir_reussi"><span class="icon">🏀</span><span class="lbl">Tir réussi adverse</span></button>
                </div>
            `;
            openModalAction('Action adversaire', 'Que vient-il de faire ?', html);
            modalActionBody.querySelectorAll('.action-btn').forEach(b => {
                b.addEventListener('click', async () => {
                    if (b.dataset.act === 'tir_reussi') {
                        // Le score adverse augmente — on demande le nombre de points
                        const htmlPts = `
                            <div class="action-grid" style="grid-template-columns:repeat(3,1fr);">
                                <button class="action-btn" data-pts="1"><span class="icon">1️⃣</span><span class="lbl">+1 pt</span></button>
                                <button class="action-btn" data-pts="2"><span class="icon">2️⃣</span><span class="lbl">+2 pts</span></button>
                                <button class="action-btn" data-pts="3"><span class="icon">3️⃣</span><span class="lbl">+3 pts</span></button>
                            </div>
                        `;
                        openModalAction('Combien de points ?', 'Score adverse à ajouter', htmlPts);
                        modalActionBody.querySelectorAll('.action-btn').forEach(bp => {
                            bp.addEventListener('click', async () => {
                                const delta = parseInt(bp.dataset.pts, 10);
                                await updateScoreAdverse(delta);
                                closeModalAction();
                            });
                        });
                    } else {
                        // Tir raté adverse → on demande qui prend le rebond défensif
                        closeModalAction();
                        showJoueurChoice('Qui a pris le rebond défensif ?', null, async (rebondeurId) => {
                            state.joueurActif = rebondeurId;
                            await saveAction('rebond_defensif');
                            closeModalAction();
                        });
                    }
                });
            });
        }

        // ====================================================================
        // V2.1i — MODE APP MOBILE (bottom nav + sheets)
        // ====================================================================
        // Activé sous 700px : ajoute body.stats-live-app-mode, masque la navbar
        // Manager, lock le scroll body, et branche les 3 tabs du bottom nav.
        const mqlAppMode = window.matchMedia('(max-width: 699px)');

        function syncAppModeClass(mql) {
            if (mql.matches) {
                document.body.classList.add('stats-live-app-mode');
            } else {
                document.body.classList.remove('stats-live-app-mode');
                // En sortant du mode app, ferme tous les sheets éventuellement ouverts
                document.querySelectorAll('.modal-overlay.show').forEach(m => {
                    if (m.id === 'sheetAdversaire' || m.id === 'sheetPlus') {
                        m.classList.remove('show');
                    }
                });
            }
        }
        syncAppModeClass(mqlAppMode);
        mqlAppMode.addEventListener('change', syncAppModeClass);

        // ─── Bottom nav : ouvre la sheet correspondante ───
        const sheetAdv = document.getElementById('sheetAdversaire');
        const sheetPlus = document.getElementById('sheetPlus');
        const sheetAdvScoreLive = document.getElementById('sheetAdvScoreLive');

        function openSheet(name) {
            if (name === 'effectif') {
                // Réutilise le modal effectif existant (déjà géré par btnEffectifMatch)
                document.getElementById('btnEffectifMatch')?.click();
            } else if (name === 'adversaire') {
                // Sync le score affiché dans la sheet
                if (sheetAdvScoreLive) {
                    sheetAdvScoreLive.textContent = document.getElementById('scoreAdverseDisplay')?.textContent || '0';
                }
                sheetAdv.classList.add('show');
            } else if (name === 'plus') {
                sheetPlus.classList.add('show');
            }
        }
        function closeSheet(name) {
            if (name === 'adversaire') sheetAdv.classList.remove('show');
            if (name === 'plus') sheetPlus.classList.remove('show');
        }

        document.querySelectorAll('.stats-nav-btn').forEach(btn => {
            btn.addEventListener('click', () => openSheet(btn.dataset.sheet));
        });
        document.querySelectorAll('[data-close-sheet]').forEach(btn => {
            btn.addEventListener('click', () => closeSheet(btn.dataset.closeSheet));
        });

        // Click hors de la box → ferme la sheet (UX bottom-sheet standard)
        sheetAdv?.addEventListener('click', (e) => { if (e.target === sheetAdv) closeSheet('adversaire'); });
        sheetPlus?.addEventListener('click', (e) => { if (e.target === sheetPlus) closeSheet('plus'); });

        // Boutons score adverse INSIDE la sheet → réutilisent la même API
        sheetAdv?.querySelectorAll('.sheet-adv-btn').forEach(btn => {
            btn.addEventListener('click', async () => {
                const delta = parseInt(btn.dataset.delta, 10);
                await updateScoreAdverse(delta);
                // Refresh le score affiché dans la sheet sans la fermer
                if (sheetAdvScoreLive) {
                    sheetAdvScoreLive.textContent = document.getElementById('scoreAdverseDisplay')?.textContent || '0';
                }
            });
        });

        // Sheet "Plus" → Composer 5 délégué au modal existant
        document.getElementById('sheetPlusCinq')?.addEventListener('click', () => {
            closeSheet('plus');
            document.getElementById('btnComposerCinq')?.click();
        });

        // ====================================================================
        // V2.1i Phase 1 — Hamburger + drawer header
        // ====================================================================
        const btnHamburger = document.getElementById('btnHamburger');
        const drawerOverlay = document.getElementById('drawerOverlay');

        function toggleDrawer(force) {
            const isOpen = document.body.classList.contains('drawer-open');
            const shouldOpen = (force === undefined) ? !isOpen : force;
            if (shouldOpen) {
                document.body.classList.add('drawer-open');
                btnHamburger?.setAttribute('aria-expanded', 'true');
                drawerOverlay?.setAttribute('aria-hidden', 'false');
            } else {
                document.body.classList.remove('drawer-open');
                btnHamburger?.setAttribute('aria-expanded', 'false');
                drawerOverlay?.setAttribute('aria-hidden', 'true');
            }
        }

        btnHamburger?.addEventListener('click', () => toggleDrawer());
        drawerOverlay?.addEventListener('click', () => toggleDrawer(false));
        document.getElementById('btnCloseDrawer')?.addEventListener('click', () => toggleDrawer(false));

        // V2.1j — Branche les boutons du drawer sur les actions correspondantes
        // (les boutons d'origine sont maintenant cachés avec [hidden], on les
        // déclenche par .click() pour réutiliser leur handler existant).
        document.getElementById('navBtnComposerCinq')?.addEventListener('click', () => {
            toggleDrawer(false);
            document.getElementById('btnComposerCinq')?.click();
        });
        document.getElementById('navBtnEffectif')?.addEventListener('click', () => {
            toggleDrawer(false);
            document.getElementById('btnEffectifMatch')?.click();
        });
        // V2.1m — Boutons chrono du drawer → déclenchent les boutons cachés originaux
        document.getElementById('navBtnStartPause')?.addEventListener('click', () => {
            document.getElementById('btnStartPause')?.click();
            // Sync l'icône play/pause du drawer
            const icon = document.getElementById('btnStartPauseIcon')?.textContent || '▶';
            const navIcon = document.getElementById('navBtnStartPauseIcon');
            if (navIcon) navIcon.textContent = icon;
        });
        document.getElementById('navBtnMinus1')?.addEventListener('click', () => document.getElementById('btnMinus1')?.click());
        document.getElementById('navBtnPlus1')?.addEventListener('click', () => document.getElementById('btnPlus1')?.click());
        document.getElementById('navBtnNextPeriod')?.addEventListener('click', () => document.getElementById('btnNextPeriod')?.click());
        document.getElementById('navBtnResetChrono')?.addEventListener('click', () => document.getElementById('btnResetChrono')?.click());

        document.getElementById('navBtnCloturer')?.addEventListener('click', async () => {
            if (!confirm('Clôturer le match ? La session courante sera marquée TERMINÉE. Un staff pourra ensuite la promouvoir officielle.')) return;
            const sessionId = {{ session_courante ? session_courante.id : 'null' }};
            if (!sessionId) {
                toast('Aucune session en cours à clôturer.', true);
                return;
            }
            try {
                const fd = new FormData();
                fd.append('_token', '{{ csrf_token('marquer_complete') }}');
                const r = await fetch(`/sessions/${sessionId}/marquer-complete`, { method: 'POST', body: fd });
                if (!r.ok) throw new Error('HTTP ' + r.status);
                toast('Match clôturé ✓');
                setTimeout(() => location.href = '{{ path('manager_rencontre_show', {id: rencontre.id}) }}', 1200);
            } catch (e) {
                toast('Erreur lors de la clôture : ' + e.message, true);
            }
        });

        // Échap = ferme le drawer
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && document.body.classList.contains('drawer-open')) {
                toggleDrawer(false);
            }
        });

        // Si l'écran repasse > 1023px (rotation tablette), force fermer le drawer
        // (le header redevient inline, le drawer n'a plus de sens)
        const mqlDrawerActive = window.matchMedia('(max-width: 1023px)');
        mqlDrawerActive.addEventListener('change', (e) => {
            if (!e.matches) toggleDrawer(false);
        });

        // ─── Helper : modal de sélection d'une joueuse ───
        // V2.1g.3 — On ne propose QUE les joueuses sur le terrain (le 5).
        // Logique : seules celles qui jouent peuvent faire une action en cours.
        // Si tu fais la passe à un fantôme du banc, c'est une erreur de saisie.
        //
        // excludeId : id à exclure (la joueuse qui a fait l'action principale).
        function showJoueurChoice(titre, excludeId, callback) {
            const items = document.querySelectorAll('.joueuse-item');
            let html = '<div class="modal-grid">';
            let nbAffichees = 0;
            items.forEach(item => {
                const jid = parseInt(item.dataset.joueurId, 10);
                if (jid === excludeId) return;
                // Filtre : seulement les joueuses ACTUELLEMENT sur le terrain
                if (!surTerrain.has(jid)) return;
                const nom = item.querySelector('.joueuse-name').textContent.trim();
                const num = item.querySelector('.joueuse-avatar').textContent.trim();
                html += `<button class="modal-joueuse-btn" data-jid="${jid}"><strong>#${num}</strong> ${nom}</button>`;
                nbAffichees++;
            });
            html += '</div>';

            // Cas dégradé : aucune joueuse éligible (pas de 5 composé, ou les 5 sont l'exclude)
            if (nbAffichees === 0) {
                html = `
                    <div style="padding:16px; background:#7f1d1d; border-radius:10px; color:#fef2f2; text-align:center;">
                        <strong>⚠️ Aucune joueuse disponible sur le terrain</strong>
                        <div style="font-size:.82rem; margin-top:6px; opacity:.85;">
                            Compose ton 5 via le bouton "👥 Composer le 5" en mode Expert, puis reviens.
                        </div>
                    </div>
                `;
            }

            openModalAction(titre, nbAffichees > 0 ? 'Sur le terrain uniquement' : '', html);
            modalActionBody.querySelectorAll('.modal-joueuse-btn').forEach(b => {
                b.addEventListener('click', () => callback(parseInt(b.dataset.jid, 10)));
            });
        }

        // ─── Bind : click joueuse en mode débutant → ouvre workflow ───
        // V2.1g.6 — On skip si le click vient du badge ON/OFF (qui a son propre handler).
        document.querySelectorAll('.joueuse-item').forEach(item => {
            item.addEventListener('click', (e) => {
                // Si l'utilisateur a cliqué sur le badge ou un de ses enfants → laisser le badge gérer
                if (e.target.closest('.badge-terrain')) return;
                if (!wrapper.classList.contains('mode-debutant')) return; // mode expert → comportement normal
                e.stopImmediatePropagation();
                const jid = parseInt(item.dataset.joueurId, 10);
                const nom = item.querySelector('.joueuse-name').textContent.trim();
                workflowJoueuse(jid, nom);
            }, true); // useCapture: true pour intercepter AVANT le handler de sélection
        });

        // ─── Bind : click adversaire ───
        // [V2.3] Garde null : la carte adversaire n'existe pas en mode
        // interne A/B (les deux équipes sont du club, pas d'adversaire).
        const cardAdv = document.getElementById('cardAdversaire');
        if (cardAdv) {
            cardAdv.addEventListener('click', () => {
                if (!wrapper.classList.contains('mode-debutant')) return;
                workflowAdversaire();
            });
        }

        // ─── V2.1g.7 — Click badge ON/OFF : event delegation au document ───
        // Bind sur DOCUMENT en useCapture : s'exécute en TOUT PREMIER dans la
        // chaîne capture (avant tout handler local sur .joueuse-item, .stats-grid,
        // etc.). Approche plus robuste que de bind individuellement sur chaque
        // badge avec useCapture, car le check closest() gère tous les cas
        // (click sur le badge, sur .dot ou sur .badge-label enfant).
        document.addEventListener('click', async (e) => {
            const badge = e.target.closest('.badge-terrain');
            if (!badge) return; // pas un click sur un badge → on laisse passer

            // Bloque TOUS les autres handlers (workflowJoueuse + selectionnerJoueuse)
            e.stopPropagation();
            e.stopImmediatePropagation();
            e.preventDefault();

            const joueurId = parseInt(badge.dataset.badgeJoueur, 10);
            if (!joueurId) return;

            const estSurTerrain = surTerrain.has(joueurId);
            if (estSurTerrain) {
                await sortirJoueuse(joueurId);
            } else {
                // Limite 5 PAR ÉQUIPE (et non 5 au total) : on compte les joueuses
                // déjà sur le terrain qui partagent le même côté (data-cote) que
                // celle qu'on veut faire entrer → 5 chez nous + 5 adverses possibles.
                const carteCourante = badge.closest('.joueuse-item');
                const coteCourant   = carteCourante?.dataset.cote || 'nous';
                let dejaSurCeCote = 0;
                surTerrain.forEach((_v, id) => {
                    const c = document.querySelector('.joueuse-item[data-joueur-id="' + id + '"]')?.dataset.cote || 'nous';
                    if (c === coteCourant) dejaSurCeCote++;
                });
                if (dejaSurCeCote >= 5) {
                    toast('Maximum 5 pour cette équipe. Sors-en une d\'abord.', true);
                    return;
                }
                await entrerJoueuse(joueurId);
            }
        }, true); // useCapture: true → first to fire de toute la chaîne

        // ====================================================================
        // HELPERS
        // ====================================================================
        function toast(msg, isError) {
            const t = document.getElementById('toast');
            t.textContent = msg;
            t.className = isError ? 'show error' : 'show';
            setTimeout(() => t.className = '', 2500);
        }

        function setMode(modeTir) {
            const wrapper = document.getElementById('liveWrapper');
            if (modeTir) wrapper.classList.add('mode-tir');
            else wrapper.classList.remove('mode-tir');
        }

        function clearPendingTir() {
            state.tirX = null;
            state.tirY = null;
            state.tirZone = null;
            state.tirCote = null;
            document.querySelectorAll('.pending-tir-marker').forEach(m => { m.style.display = 'none'; });
            setMode(false);
        }

        // Détecte la zone d'un tir à partir des coords X/Y normalisées (0-1)
        // Aligné avec ShotChartCalculator côté PHP
        function detectZone(x, y) {
            // 3pts : panier à (0.5, ~0.09) ; ligne 3pts ~0.45 du Y
            const dx = x - 0.5;
            const dy = y - 0.093;
            const dist = Math.sqrt(dx*dx + dy*dy);

            // Si distance > 0.42 du panier OU dans les coins (Y < 0.2 et X aux extrêmes)
            const dansCoinGauche = (y < 0.215 && x < 0.06);
            const dansCoinDroit = (y < 0.215 && x > 0.94);
            const auDelaArc3pts = dist > 0.42;

            if (dansCoinGauche || dansCoinDroit || auDelaArc3pts) {
                return { type3pts: true, label: '3 PTS' };
            }
            // 2pts : intérieur si dans la raquette, sinon extérieur
            const dansRaquette = (x >= 0.336 && x <= 0.664 && y < 0.45);
            if (dansRaquette || dist < 0.18) {
                return { type3pts: false, interieur: true, label: '2 PTS INT' };
            }
            return { type3pts: false, interieur: false, label: '2 PTS EXT' };
        }

        // ====================================================================
        // RENDU
        // ====================================================================
        function updateJoueurPts(joueurId, comptages) {
            const span = document.querySelector(`[data-joueur-pts="${joueurId}"]`);
            if (!span) return;
            const pts = ((comptages.tir_2pt_int_reussi || 0) + (comptages.tir_2pt_ext_reussi || 0)) * 2
                      + (comptages.tir_3pt_reussi || 0) * 3
                      + (comptages.lancer_reussi || 0);
            span.textContent = pts;
        }

        function updateScoreEquipe() {
            // [V2.3] Mode interne A/B : chaque score du header = somme des
            // points des joueuses de SA colonne. Le score B n'est plus le
            // "score adverse" saisi manuellement — il est calculé comme le A.
            if (MODE_INTERNE_AB) {
                let totalA = 0, totalB = 0;
                document.querySelectorAll('#colEquipeA [data-joueur-pts]').forEach(el => {
                    totalA += parseInt(el.textContent, 10) || 0;
                });
                document.querySelectorAll('#colEquipeB [data-joueur-pts]').forEach(el => {
                    totalB += parseInt(el.textContent, 10) || 0;
                });
                document.getElementById('scoreMabb').textContent = totalA;
                const advDisplay = document.getElementById('scoreAdverseDisplay');
                if (advDisplay) advDisplay.textContent = totalB;
                return;
            }
            // Somme des pts de toutes les joueuses (depuis le DOM)
            let total = 0;
            document.querySelectorAll('[data-joueur-pts]').forEach(el => {
                total += parseInt(el.textContent, 10) || 0;
            });
            document.getElementById('scoreMabb').textContent = total;
        }

        function addToHistory(actionId, joueurInitiales, type, qt, minute, secondes) {
            const items = document.getElementById('historyItems');
            const empty = items.querySelector('small');
            if (empty) empty.remove();
            const item = document.createElement('div');
            item.className = 'history-item';
            item.dataset.actionId = actionId;
            item.innerHTML = `
                <strong>${joueurInitiales}</strong>
                <span style="color:#fbbf24;">${type}</span>
                <small style="color:#94a3b8;">${qt} ${minute}'${secondes}"</small>
                <button class="undo-btn" title="Annuler">✕</button>
            `;
            items.insertBefore(item, items.firstChild);

            // Garde max 15 items dans l'historique visible
            const all = items.querySelectorAll('.history-item');
            if (all.length > 15) all[all.length - 1].remove();
        }

        // ====================================================================
        // AJAX — création d'action
        // ====================================================================
        async function saveAction(type, options) {
            options = options || {};
            if (!state.joueurActif) {
                toast('Sélectionne une joueuse d\'abord', true);
                return;
            }

            const payload = {
                joueurId: state.joueurActif,
                type: type,
                quartTemps: state.quartTemps,
                minute: state.minute,
                secondes: state.secondes,
                positionX: options.positionX !== undefined ? options.positionX : state.tirX,
                positionY: options.positionY !== undefined ? options.positionY : state.tirY,
            };

            try {
                const res = await fetch(URL_ACTION_CREATE, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-Token': CSRF_TOKEN,
                    },
                    body: JSON.stringify(payload),
                });
                const data = await res.json();
                if (!res.ok || !data.success) {
                    toast(data.error || 'Erreur', true);
                    return;
                }

                // === Met à jour les compteurs joueuse ===
                updateJoueurPts(state.joueurActif, data.comptages);
                updateScoreEquipe();

                // === Ajoute à l'historique ===
                const joueurEl = document.querySelector(`[data-joueur-id="${state.joueurActif}"]`);
                const initiales = joueurEl ? joueurEl.querySelector('.joueuse-avatar').textContent.trim() : '?';
                addToHistory(data.actionId, initiales, type, state.quartTemps, state.minute, state.secondes);

                // === Si c'était un tir, on dessine le marker permanent ===
                if (payload.positionX !== null && payload.positionY !== null) {
                    drawShotMarker(payload.positionX, payload.positionY, type.endsWith('_reussi'));
                }

                // === Reset mode tir + désélection joueuse ===
                // Désélection auto après chaque action : évite d'attribuer
                // par erreur la prochaine action à la joueuse précédente.
                // (validé par user le 2026-06-07)
                if (typeof window.deselectionnerJoueuse === 'function') {
                    window.deselectionnerJoueuse();
                } else {
                    clearPendingTir();
                }
                toast('Action enregistrée');

            } catch (e) {
                toast('Erreur réseau : ' + e.message, true);
            }
        }

        // ====================================================================
        // AJAX — suppression d'action (undo)
        // ====================================================================
        async function deleteAction(actionId) {
            try {
                const res = await fetch(URL_ACTION_DELETE_BASE + actionId, {
                    method: 'DELETE',
                    headers: { 'X-CSRF-Token': CSRF_TOKEN },
                });
                const data = await res.json();
                if (!res.ok || !data.success) {
                    toast(data.error || 'Erreur', true);
                    return;
                }
                // Retire l'item de l'historique
                const item = document.querySelector(`[data-action-id="${actionId}"]`);
                if (item) item.remove();
                // MAJ compteurs si on a retrouvé le joueur
                if (data.joueurId) {
                    updateJoueurPts(data.joueurId, data.comptages);
                    updateScoreEquipe();
                }
                toast('Action annulée');
            } catch (e) {
                toast('Erreur réseau : ' + e.message, true);
            }
        }

        // ====================================================================
        // DESSIN MARKERS DE TIR (permanent)
        // ====================================================================
        function drawShotMarker(x, y, reussi) {
            // Dessine dans le demi-terrain de l'équipe du tir (state.tirCote), sinon le principal.
            const cote = state.tirCote || 'nous';
            const group = document.querySelector('.court-svg[data-cote="' + cote + '"] .shot-markers')
                       || document.getElementById('shotMarkers');
            if (!group) return;
            const cx = x * 1500;
            const cy = y * 1400;

            // Crée un cercle SVG vert si réussi, rouge si raté
            const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
            circle.setAttribute('cx', cx);
            circle.setAttribute('cy', cy);
            circle.setAttribute('r', '14');
            circle.setAttribute('fill', reussi ? '#16a34a' : '#dc2626');
            circle.setAttribute('stroke', '#fff');
            circle.setAttribute('stroke-width', '2');
            group.appendChild(circle);
        }

        // ====================================================================
        // ÉVÉNEMENTS UI
        // ====================================================================

        // --- Sélection joueuse ---
        // Comportement TOGGLE : un clic sur la joueuse déjà sélectionnée la
        // désélectionne. Évite d'avoir à cliquer sur une autre joueuse pour
        // "annuler" sa sélection si on s'est trompé.
        // V2.1g.6 — On skip si le click vient du badge ON/OFF.
        document.querySelectorAll('.joueuse-item').forEach(el => {
            el.addEventListener('click', (e) => {
                if (e.target.closest('.badge-terrain')) return;
                const idClique = parseInt(el.dataset.joueurId, 10);
                const dejaSelectionnee = state.joueurActif === idClique;

                if (dejaSelectionnee) {
                    deselectionnerJoueuse();
                } else {
                    selectionnerJoueuse(el, idClique);
                }
            });
        });

        /**
         * Sélectionne une joueuse — visuellement + en state.
         * Toujours appelée à la place d'une logique éparpillée pour rester DRY.
         */
        function selectionnerJoueuse(el, joueurId) {
            // Reset visuel des autres
            document.querySelectorAll('.joueuse-item').forEach(e => e.classList.remove('active'));
            el.classList.add('active');
            state.joueurActif = joueurId;
            // Surligne le demi-terrain de l'équipe de la joueuse, grise l'autre.
            const cote = el.dataset.cote || 'nous';
            document.querySelectorAll('.court-svg-wrap').forEach(w => {
                const actif = (w.dataset.cote || 'nous') === cote;
                w.classList.toggle('court-actif', actif);
                w.classList.toggle('court-inactif', !actif);
            });
            clearPendingTir(); // toujours repartir d'un état tir vierge
        }

        /**
         * Désélectionne la joueuse active — reset visuel + state.
         * Appelée :
         *   1. Quand on re-clique sur la joueuse déjà sélectionnée (toggle)
         *   2. (Optionnel — voir constante) Après chaque action saisie pour
         *      éviter d'attribuer la suivante par erreur à la même joueuse.
         */
        function deselectionnerJoueuse() {
            document.querySelectorAll('.joueuse-item').forEach(e => e.classList.remove('active'));
            document.querySelectorAll('.court-svg-wrap').forEach(w => w.classList.remove('court-actif', 'court-inactif'));
            state.joueurActif = null;
            clearPendingTir();
        }

        // Expose au scope outer pour appel depuis saveAction si DESELECT_APRES_ACTION = true
        window.deselectionnerJoueuse = deselectionnerJoueuse;

        // --- Clic sur le terrain ---
        document.querySelectorAll('.court-svg').forEach(courtEl => {
          courtEl.addEventListener('click', (e) => {
            if (!state.joueurActif) {
                toast('Sélectionne une joueuse d\'abord', true);
                return;
            }

            const svg = e.currentTarget;
            // Le tir doit être saisi sur le demi-terrain de l'ÉQUIPE de la joueuse.
            const courtCote  = svg.dataset.cote || 'nous';
            const joueurCote = document.querySelector('.joueuse-item[data-joueur-id="' + state.joueurActif + '"]')?.dataset.cote || 'nous';
            if (courtCote !== joueurCote) {
                toast('Clique sur le demi-terrain de l\'équipe de cette joueuse.', true);
                return;
            }

            // Coordonnées clic en pixel SVG (basées sur le viewBox)
            const pt = svg.createSVGPoint();
            pt.x = e.clientX;
            pt.y = e.clientY;
            const ctm = svg.getScreenCTM();
            if (!ctm) return;
            const svgPoint = pt.matrixTransform(ctm.inverse());
            // Normalisation 0-1
            const x = Math.max(0, Math.min(1, svgPoint.x / 1500));
            const y = Math.max(0, Math.min(1, svgPoint.y / 1400));

            // Reset (masque les pending des 2 terrains) puis pose le nouvel état
            clearPendingTir();
            state.tirX = x;
            state.tirY = y;
            state.tirZone = detectZone(x, y);
            state.tirCote = courtCote;

            // Affiche le marker pending sur CE demi-terrain
            const marker = svg.querySelector('.pending-tir-marker');
            if (marker) {
                marker.setAttribute('cx', x * 1500);
                marker.setAttribute('cy', y * 1400);
                marker.style.display = 'block';
            }

            // Affiche les options réussi/raté en mode tir
            setMode(true);
            document.getElementById('shotZoneLabel').textContent = state.tirZone.label;
          });
        });

        // --- Boutons actions (panneau droit) ---
        document.querySelectorAll('.action-btn[data-type]').forEach(btn => {
            btn.addEventListener('click', () => {
                const type = btn.dataset.type;
                saveAction(type);
            });
        });

        // --- Boutons shoot réussi/raté/annuler ---
        document.querySelectorAll('.action-btn[data-action]').forEach(btn => {
            btn.addEventListener('click', () => {
                const action = btn.dataset.action;
                if (action === 'cancel_shot') {
                    clearPendingTir();
                    return;
                }
                if (state.tirX === null) {
                    toast('Aucun tir positionné', true);
                    return;
                }
                const reussi = (action === 'shot_reussi');
                const zone = state.tirZone;
                let type;
                if (zone.type3pts) type = reussi ? 'tir_3pt_reussi' : 'tir_3pt_rate';
                else if (zone.interieur) type = reussi ? 'tir_2pt_int_reussi' : 'tir_2pt_int_rate';
                else type = reussi ? 'tir_2pt_ext_reussi' : 'tir_2pt_ext_rate';

                saveAction(type);
            });
        });

        // --- Quart-temps : DÉPRÉCIÉ V2.1a ---
        // La sélection manuelle est remplacée par le chrono qui gère
        // automatiquement la période courante via le bouton "→". Le bloc
        // qt-block du template a été remplacé par chrono-block. On garde
        // ce commentaire pour rappel : state.quartTemps est mis à jour par
        // updateChronoDisplay() chaque tick.

        // --- Annulation actions (délégation pour les items ajoutés dynamiquement) ---
        document.getElementById('historyItems').addEventListener('click', (e) => {
            const undo = e.target.closest('.undo-btn');
            if (!undo) return;
            const item = undo.closest('.history-item');
            if (!item) return;
            const actionId = parseInt(item.dataset.actionId, 10);
            if (!actionId) return;
            if (!confirm('Annuler cette action ?')) return;
            deleteAction(actionId);
        });

        // === Init : draw markers des tirs existants depuis le DOM (si re-chargement) ===
        // (TODO : exposer les tirs existants depuis Twig pour re-render au mount)

    })();
    </script>
{% endblock %}
