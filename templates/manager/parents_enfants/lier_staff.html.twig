{% extends 'manager/base.html.twig' %}
{% block title %}Lier un parent à {{ joueur.prenom }} {{ joueur.nom }}{% endblock %}

{% block body %}

    <div class="page-header">
        <div>
            <h1><i class="bi bi-link-45deg"></i> Lier un parent à {{ joueur.prenom }} {{ joueur.nom }}</h1>
            <p class="subtitle">Le lien créé est validé automatiquement (initiative staff).</p>
        </div>
        <a href="{{ path('manager_parents_enfants_index') }}" class="btn-mabb-ghost">
            <i class="bi bi-arrow-left"></i> Retour
        </a>
    </div>

    {% for label, messages in app.flashes(['success', 'warning', 'error', 'info']) %}
        {% for message in messages %}
            <div class="card-mabb" style="padding:12px 16px; margin-bottom:14px; border-left:4px solid {{ label == 'success' ? '#16a34a' : (label == 'warning' ? '#d97706' : (label == 'info' ? '#1d4ed8' : '#ef4444')) }};">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    {# Recherche #}
    <form method="GET" action="{{ path('manager_parents_enfants_lier_staff', {joueurId: joueur.id}) }}" class="card-mabb" style="padding:16px;">
        <label style="font-size:.85rem; color:var(--mabb-muted); display:block; margin-bottom:6px;">
            Rechercher le parent par email, nom ou prénom
        </label>
        <div style="display:flex; gap:8px;">
            <input type="text" name="q" value="{{ recherche }}" autofocus
                   placeholder="Tape un email, nom ou prénom..."
                   style="flex:1; padding:10px 14px; border:1px solid #e2e8f0; border-radius:8px; font-size:.92rem;">
            <button type="submit" class="btn-mabb-primary">
                <i class="bi bi-search"></i> Rechercher
            </button>
        </div>
    </form>

    {# Résultats #}
    {% if recherche and candidats is empty %}
        <div class="card-mabb" style="padding:24px; text-align:center;">
            <p style="margin:0; color:var(--mabb-muted);">
                Aucun user trouvé pour "<strong>{{ recherche }}</strong>". <br>
                <small>Si le parent n'a pas encore de compte, utilise <a href="#">l'invitation par mail</a> (B30c).</small>
            </p>
        </div>
    {% endif %}

    {% if candidats is not empty %}
        <div class="card-mabb">
            <div class="card-header"><i class="bi bi-people"></i> {{ candidats|length }} résultat(s)</div>
            <div class="card-body" style="padding:0;">
                {% for c in candidats %}
                    <form method="POST" action="{{ path('manager_parents_enfants_lier_staff', {joueurId: joueur.id}) }}"
                          style="display:flex; align-items:center; gap:14px; padding:12px 16px; border-bottom:1px solid #e2e8f0;"
                          onsubmit="return confirm('Lier {{ c.prenom }} {{ c.nom }} comme parent de {{ joueur.prenom }} {{ joueur.nom }} ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('lier_parent_staff_' ~ joueur.id) }}">
                        <input type="hidden" name="user_parent_id" value="{{ c.id }}">

                        <div style="width:40px; height:40px; border-radius:50%; background:linear-gradient(135deg, var(--mabb-blue), var(--mabb-dark)); color:#fff; display:flex; align-items:center; justify-content:center; font-weight:800;">
                            {{ c.prenom|first|upper }}{{ c.nom|first|upper }}
                        </div>
                        <div style="flex:1;">
                            <div style="font-weight:700;">{{ c.prenom }} {{ c.nom }}</div>
                            <div style="color:var(--mabb-muted); font-size:.82rem;">{{ c.email }}</div>
                        </div>
                        <button type="submit" class="btn-mabb-primary btn-sm">
                            <i class="bi bi-link"></i> Lier
                        </button>
                    </form>
                {% endfor %}
            </div>
        </div>
    {% endif %}

{% endblock %}
