{#
   Page Staff Manager — Coachs, Dirigeants, Trésorerie, Staff du club.
   Affiche les sections par rôle, card par personne.
   Style aligné sur la page Équipes.
#}
{% extends 'manager/base.html.twig' %}

{% block title %}Staff du club — {{ club.nom }}{% endblock %}

{% block body %}

    <div class="page-header">
        <div>
            <h1><i class="bi bi-shield-fill-check"></i> Staff du club</h1>
            <div style="color:var(--mabb-muted); font-size:.92rem;">
                {{ total }} membre{{ total > 1 ? 's' : '' }} encadrant{{ total > 1 ? 's' : '' }} actif{{ total > 1 ? 's' : '' }} pour <strong>{{ club.nom }}</strong>
            </div>
        </div>
        {% if is_granted('CLUB_STAFF', club) %}
            <a href="{{ path('manager_staff_comptes_en_attente') }}" class="btn-mabb-ghost" style="position:relative;">
                <i class="bi bi-person-exclamation"></i> Comptes sans fiche
            </a>
        {% endif %}
    </div>

    {% if total == 0 %}
        <div class="card-mabb" style="text-align:center; padding:40px 20px;">
            <i class="bi bi-shield-fill-x" style="font-size:3rem; color:var(--mabb-muted); margin-bottom:10px;"></i>
            <h3 style="margin:0 0 8px 0;">Aucun staff actif</h3>
            <p style="color:var(--mabb-muted); margin:0;">
                Personne n'a encore de rôle Coach, Dirigeant, Trésorier ou Staff sur ce club.
                {% if is_granted('CLUB_ADMIN', club) %}
                    <br><a href="{{ path('manager_utilisateurs_index') }}">Va attribuer des rôles →</a>
                {% endif %}
            </p>
        </div>
    {% endif %}

    {% for role_code, ucrs in groupes %}
        {% if ucrs|length > 0 %}
            <div class="card-mabb" style="margin-bottom:16px;">
                <div class="card-header" style="display:flex; align-items:center; justify-content:space-between;">
                    <span style="display:flex; align-items:center; gap:10px;">
                        <i class="bi {{ icones[role_code] }}" style="color:{{ couleurs[role_code] }}; font-size:1.3rem;"></i>
                        <strong>{{ libelles[role_code] }}</strong>
                        <span style="background:rgba(0,0,0,.05); padding:2px 10px; border-radius:999px; font-size:.78rem; font-weight:700; color:var(--mabb-muted);">
                            {{ ucrs|length }}
                        </span>
                    </span>
                    {% if is_granted('CLUB_ADMIN', club) %}
                        <a href="{{ path('manager_utilisateurs_index') }}"
                           style="color:var(--mabb-muted); font-size:.78rem; text-decoration:none;"
                           title="Gérer les rôles du club">
                            <i class="bi bi-gear"></i> Gérer les rôles
                        </a>
                    {% endif %}
                </div>
                <div class="card-body">
                    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(240px, 1fr)); gap:12px;">
                        {% for ucr in ucrs %}
                            {% set u = ucr.user %}
                            {% if u %}
                                <a href="{{ path('manager_staff_show', {userId: u.id}) }}" style="text-decoration:none; color:inherit;">
                                <div style="display:flex; align-items:center; gap:12px; padding:12px;
                                            background:#f8fafc; border:1px solid #e5e7eb; border-radius:10px;
                                            transition:all .15s; cursor:pointer;"
                                     onmouseover="this.style.borderColor='{{ couleurs[role_code] }}'; this.style.transform='translateY(-2px)';"
                                     onmouseout="this.style.borderColor='#e5e7eb'; this.style.transform='none';">
                                    {# Avatar : initiales colorées par rôle #}
                                    <div style="width:48px; height:48px; border-radius:50%; flex-shrink:0;
                                                background:linear-gradient(135deg, {{ couleurs[role_code] }}, var(--mabb-dark));
                                                color:#fff; display:flex; align-items:center; justify-content:center;
                                                font-weight:800; font-size:1.05rem;">
                                        {{ u.prenom|first|upper }}{{ u.nom|first|upper }}
                                    </div>
                                    <div style="flex:1; min-width:0;">
                                        <div style="font-weight:700; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                                            {{ u.prenom }} {{ u.nom }}
                                        </div>
                                        <div style="color:var(--mabb-muted); font-size:.78rem;
                                                    white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                                            <i class="bi bi-envelope"></i> {{ u.email }}
                                        </div>
                                        {% if ucr.createdAt %}
                                            <div style="color:var(--mabb-muted); font-size:.7rem; margin-top:2px;">
                                                <i class="bi bi-clock"></i> Depuis le {{ ucr.createdAt|date('d/m/Y') }}
                                            </div>
                                        {% endif %}
                                    </div>
                                </div>
                                </a>
                            {% endif %}
                        {% endfor %}
                    </div>
                </div>
            </div>
        {% endif %}
    {% endfor %}

    {# Lien utile vers la page Utilisateurs pour les dirigeants #}
    {% if is_granted('CLUB_ADMIN', club) %}
        <div style="text-align:center; padding:20px;">
            <a href="{{ path('manager_utilisateurs_index') }}" class="btn-mabb-ghost">
                <i class="bi bi-people-fill"></i> Gérer tous les rôles utilisateurs
            </a>
        </div>
    {% endif %}

{% endblock %}
