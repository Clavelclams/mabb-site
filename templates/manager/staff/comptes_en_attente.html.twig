{% extends 'manager/base.html.twig' %}
{% block title %}Comptes PIRB sans fiche joueuse{% endblock %}

{% block body %}

<div class="page-header">
    <div>
        <h1><i class="bi bi-person-exclamation"></i> Comptes PIRB sans fiche</h1>
        <p class="subtitle">
            Ces utilisateurs ont un compte sur manager.mabb.fr / pirb.mabb.fr
            mais aucune fiche joueuse n'est encore liée à leur profil.
        </p>
    </div>
    <a href="{{ path('manager_staff_index') }}" class="btn-mabb-ghost">
        <i class="bi bi-arrow-left"></i> Retour au staff
    </a>
</div>

{% if entrees is empty %}
    <div class="card-mabb" style="text-align:center; padding:40px 20px;">
        <i class="bi bi-check-circle" style="font-size:2.5rem; color:#22c55e;"></i>
        <h3 style="margin:12px 0 6px; font-size:1rem;">Tout est lié ✓</h3>
        <p style="color:var(--mabb-muted); font-size:.84rem; margin:0;">
            Chaque membre du club a une fiche joueuse associée à son compte.
        </p>
    </div>
{% else %}
    {# Explication du flux #}
    <div style="background:#eff6ff; border:1px solid #bfdbfe; border-radius:10px; padding:14px 18px; margin-bottom:20px; font-size:.85rem; color:#1e40af;">
        <strong><i class="bi bi-info-circle"></i> Comment ça fonctionne</strong><br>
        <span style="color:#3730a3;">
            Si une fiche joueuse a le <strong>même email</strong> que le compte,
            le lien se fait <strong>automatiquement au prochain login PIRB</strong> de la joueuse.
            Sinon, va sur la fiche de la joueuse concernée → section "Compte PIRB" → Lier.
        </span>
    </div>

    <div class="card-mabb">
        <div class="card-body" style="padding:0;">
            {% for entry in entrees %}
                {% set u = entry.user %}
                {% set suggestion = entry.suggestion %}
                <div style="display:grid; grid-template-columns:1fr auto; align-items:center; gap:16px; padding:14px 18px; border-bottom:1px solid var(--mabb-border);">
                    <div>
                        {# User info #}
                        <div style="font-weight:700; font-size:.92rem;">
                            {{ u.prenom }} {{ u.nom|upper }}
                        </div>
                        <div style="font-size:.78rem; color:var(--mabb-muted); margin-top:2px;">
                            {{ u.email }}
                        </div>

                        {# Suggestion auto-détectée #}
                        {% if suggestion is not null %}
                            <div style="margin-top:8px; display:inline-flex; align-items:center; gap:6px; background:#fef3c7; border:1px solid #fcd34d; border-radius:8px; padding:4px 10px; font-size:.75rem; color:#92400e;">
                                <i class="bi bi-lightbulb-fill"></i>
                                Correspond à la fiche :
                                <strong>{{ suggestion.prenom }} {{ suggestion.nom|upper }}</strong>
                                {% if suggestion.equipe %} · {{ suggestion.equipe.nom }}{% endif %}
                                — <em>même email, lien auto au prochain login</em>
                            </div>
                        {% else %}
                            <div style="margin-top:6px; font-size:.75rem; color:var(--mabb-muted);">
                                <i class="bi bi-search"></i> Aucune fiche détectée par email — lier manuellement depuis la fiche joueuse
                            </div>
                        {% endif %}
                    </div>

                    {# Actions #}
                    <div style="display:flex; gap:8px; flex-direction:column; align-items:flex-end;">
                        {% if suggestion is not null %}
                            {# Lien direct vers la fiche avec la suggestion #}
                            <a href="{{ path('manager_joueur_show', {id: suggestion.id}) }}"
                               class="btn-mabb-ghost btn-sm"
                               style="white-space:nowrap;">
                                <i class="bi bi-link-45deg"></i> Voir la fiche
                            </a>
                        {% endif %}
                        <a href="{{ path('manager_joueur_index') }}"
                           class="btn-mabb-ghost btn-sm"
                           style="white-space:nowrap; font-size:.72rem; opacity:.7;">
                            <i class="bi bi-search"></i> Chercher manuellement
                        </a>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>

    <div style="margin-top:14px; font-size:.78rem; color:var(--mabb-muted); text-align:center;">
        {{ entrees|length }} compte{{ entrees|length > 1 ? 's' : '' }} sans fiche liée
    </div>
{% endif %}

{% endblock %}
