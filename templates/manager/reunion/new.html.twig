{% extends 'manager/base.html.twig' %}

{% block title %}Nouvelle réunion{% endblock %}

{% block body %}
    <div class="page-header">
        <div>
            <h1><i class="bi bi-plus-circle"></i> Nouvelle réunion</h1>
            <p class="subtitle">Crée une réunion + convoque les membres concernés</p>
        </div>
        <a href="{{ path('manager_reunion_index') }}" class="btn-mabb-ghost">
            <i class="bi bi-arrow-left"></i> Retour aux réunions
        </a>
    </div>

    <form method="post" action="{{ path('manager_reunion_new') }}">
        <input type="hidden" name="_token" value="{{ csrf_token('new_reunion_' ~ club.id) }}">

        <div class="row g-3">
            {# === Bloc principal === #}
            <div class="col-lg-7">
                <div class="card-mabb">
                    <div class="card-header"><i class="bi bi-info-circle"></i> Informations</div>
                    <div class="card-body" style="display:flex; flex-direction:column; gap:14px;">
                        <div>
                            <label class="form-label fw-semibold">Titre *</label>
                            <input type="text" name="titre" required maxlength="200" placeholder="Ex : CA du 15 juin 2026"
                                   style="width:100%; padding:10px 14px; border:1px solid #d1d5db; border-radius:8px; font-size:.95rem;">
                        </div>
                        <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px;">
                            <div>
                                <label class="form-label fw-semibold">Type *</label>
                                <select name="type" required style="width:100%; padding:10px 14px; border:1px solid #d1d5db; border-radius:8px; font-size:.95rem;">
                                    {% for code, libelle in types %}
                                        <option value="{{ code }}">{{ libelle }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div>
                                <label class="form-label fw-semibold">Date & heure *</label>
                                <input type="datetime-local" name="date" required
                                       style="width:100%; padding:10px 14px; border:1px solid #d1d5db; border-radius:8px; font-size:.95rem;">
                            </div>
                        </div>
                        <div>
                            <label class="form-label fw-semibold">Lieu</label>
                            <input type="text" name="lieu" maxlength="200" placeholder="Ex : Salle du club, Gymnase Diagana, en ligne (Zoom)…"
                                   style="width:100%; padding:10px 14px; border:1px solid #d1d5db; border-radius:8px; font-size:.95rem;">
                        </div>
                        <div>
                            <label class="form-label fw-semibold">Ordre du jour *</label>
                            <textarea name="ordreDuJour" required rows="8" placeholder="1. Validation du PV précédent
2. Bilan financier semestriel
3. Préparation tournoi 3x3
4. Questions diverses"
                                      style="width:100%; padding:10px 14px; border:1px solid #d1d5db; border-radius:8px; font-size:.92rem; font-family:inherit;"></textarea>
                            <small class="text-muted">Un point par ligne. Sera affiché tel quel sur la fiche de la réunion.</small>
                        </div>
                    </div>
                </div>
            </div>

            {# === Convocations === #}
            <div class="col-lg-5">
                <div class="card-mabb">
                    <div class="card-header"><i class="bi bi-people"></i> Qui convoquer ?</div>
                    <div class="card-body">
                        <p class="text-muted small mb-3">
                            Coche les rôles dont les membres seront automatiquement convoqués.
                            Tu peux ajouter des users individuels après la création (V2).
                        </p>
                        <div style="display:flex; flex-direction:column; gap:8px;">
                            {% set role_color = {
                                'DIRIGEANT': '#8b5cf6',
                                'COACH':     'var(--mabb-blue)',
                                'STAFF':     '#0891b2',
                                'JOUEUR':    'var(--mabb-orange)',
                                'PARENT':    '#ec4899',
                                'BENEVOLE':  '#22c55e',
                                'EMPLOYE':   '#0d9488'
                            } %}
                            {% for role in roles_dispo %}
                                <label style="display:flex; align-items:center; gap:10px; padding:10px 14px; background:#f8fafc; border:1.5px solid #e5e7eb; border-radius:8px; cursor:pointer; transition:all .15s;"
                                       onmouseover="this.style.background='#eff6ff';this.style.borderColor='{{ role_color[role] ?? '#64748b' }}'"
                                       onmouseout="this.style.background='#f8fafc';this.style.borderColor='#e5e7eb'">
                                    <input type="checkbox" name="rolesConvoques[]" value="{{ role }}"
                                           {{ role == 'DIRIGEANT' ? 'checked' }}
                                           style="width:18px; height:18px;">
                                    <span style="font-weight:700; color:{{ role_color[role] ?? '#64748b' }};">{{ role }}</span>
                                </label>
                            {% endfor %}
                        </div>
                        <p class="small text-muted mt-3 mb-0">
                            <i class="bi bi-info-circle"></i>
                            Les convoqués verront <strong>"Nouveau PV à lire"</strong> sur leur dashboard quand le compte-rendu sera saisi.
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <div style="margin-top:20px; display:flex; gap:12px; justify-content:flex-end;">
            <a href="{{ path('manager_reunion_index') }}" class="btn-mabb-ghost">Annuler</a>
            <button type="submit" class="btn-mabb-orange">
                <i class="bi bi-check-lg"></i> Créer la réunion
            </button>
        </div>
    </form>
{% endblock %}
