{# Template email HTML envoyé à chaque convoqué.
   Style inline obligatoire pour la compatibilité Gmail / Outlook / Apple Mail
   (les classes CSS sont ignorées par certains clients mail). #}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Convocation</title>
</head>
<body style="margin:0; padding:0; background:#f3f4f6; font-family: Arial, sans-serif; color:#1f2937;">

    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#f3f4f6; padding:30px 0;">
        <tr>
            <td align="center">
                <table width="600" cellpadding="0" cellspacing="0" border="0" style="background:#fff; border-radius:12px; overflow:hidden; box-shadow:0 4px 16px rgba(0,0,0,.08);">

                    {# === HEADER orange MABB === #}
                    <tr>
                        <td style="background:linear-gradient(135deg, #fc702a, #d65d1f); padding:30px 32px; text-align:left;">
                            <h1 style="margin:0; color:#fff; font-size:22px; font-weight:700;">{{ reunion.club.nom }}</h1>
                            <p style="margin:6px 0 0; color:rgba(255,255,255,.9); font-size:14px;">Convocation officielle</p>
                        </td>
                    </tr>

                    {# === BODY === #}
                    <tr>
                        <td style="padding:32px;">
                            <p style="margin:0 0 16px; font-size:16px;">
                                Bonjour <strong>{{ user.prenom }}</strong>,
                            </p>

                            <p style="margin:0 0 20px; font-size:15px; line-height:1.6;">
                                Vous êtes convoqué·e à la <strong>{{ type_label }}</strong> ci-dessous.
                                Merci de noter cette date à votre agenda et de confirmer votre présence.
                            </p>

                            {# === Bloc info réunion === #}
                            <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#f9fafb; border-left:4px solid #fc702a; padding:16px 20px; margin:20px 0;">
                                <tr>
                                    <td style="font-size:15px; line-height:1.7;">
                                        <strong style="color:#0062a8;">{{ reunion.titre }}</strong><br>
                                        <span style="color:#6b7280;">
                                            📅 {{ reunion.date|date('l j F Y', 'Europe/Paris')|capitalize }}<br>
                                            ⏰ {{ reunion.date|date('H\\hi') }}
                                            {% if reunion.lieu %}<br>📍 {{ reunion.lieu }}{% endif %}
                                        </span>
                                    </td>
                                </tr>
                            </table>

                            <p style="margin:20px 0 16px; font-size:14px; color:#4b5563;">
                                La convocation officielle au format PDF est jointe à cet email.
                                Vous y trouverez l'ordre du jour complet et la liste des membres convoqués.
                            </p>

                            {# === Bouton CTA === #}
                            <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:24px 0;">
                                <tr>
                                    <td align="center">
                                        <a href="https://manager.mabb.fr/reunions/{{ reunion.id }}"
                                           style="display:inline-block; background:#fc702a; color:#fff; padding:14px 28px; border-radius:8px; text-decoration:none; font-weight:600; font-size:15px;">
                                            Confirmer ma présence
                                        </a>
                                    </td>
                                </tr>
                            </table>

                            <p style="margin:24px 0 0; font-size:13px; color:#6b7280; line-height:1.5;">
                                <strong>Sans réponse de votre part avant la veille de la réunion</strong>,
                                vous serez considéré·e comme « non répondant·e ».
                                Cliquez sur le bouton ci-dessus pour confirmer votre présence
                                directement depuis votre espace Manager.
                            </p>
                        </td>
                    </tr>

                    {# === FOOTER === #}
                    <tr>
                        <td style="background:#f9fafb; padding:20px 32px; border-top:1px solid #e5e7eb;">
                            <p style="margin:0; font-size:12px; color:#6b7280; line-height:1.5;">
                                Email automatique envoyé par <strong>MABB Manager</strong> — Ne pas répondre.<br>
                                Pour toute question, contactez le secrétariat du club.
                            </p>
                        </td>
                    </tr>

                </table>
            </td>
        </tr>
    </table>

</body>
</html>
