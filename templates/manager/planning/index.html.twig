{% extends 'manager/base.html.twig' %}

{% block title %}Planning du club{% endblock %}

{% block stylesheets %}
<style>
    /* ───── Grille planning hebdo ───── */
    .planning-grid {
        display: grid;
        grid-template-columns: 70px repeat(7, 1fr);
        gap: 1px;
        background: var(--mabb-border);
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid var(--mabb-border);
    }
    .planning-grid > div { background: #fff; }
    .planning-header {
        background: var(--mabb-dark) !important;
        color: white;
        padding: 10px 6px;
        text-align: center;
        font-weight: 700;
        font-size: .85rem;
        text-transform: uppercase;
        letter-spacing: .05em;
    }
    .planning-hour {
        background: #f8fafc !important;
        padding: 6px 4px;
        text-align: right;
        font-weight: 700;
        color: var(--mabb-muted);
        font-size: .8rem;
        border-right: 2px solid var(--mabb-border);
    }
    .planning-cell {
        min-height: 50px;
        padding: 4px;
        position: relative;
    }
    /* Bloc créneau coloré par catégorie */
    .planning-block {
        background: var(--bloc-color, var(--mabb-blue));
        color: white;
        padding: 6px 8px;
        border-radius: 6px;
        font-size: .75rem;
        line-height: 1.3;
        margin-bottom: 3px;
        cursor: pointer;
        text-decoration: none;
        display: block;
        transition: transform .12s, box-shadow .12s;
    }
    .planning-block:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 10px rgba(0,0,0,.15);
        color: white;
    }
    .planning-block strong { display: block; font-weight: 700; }
    .planning-block .meta { font-size: .68rem; opacity: .9; }

    /* Couleurs par catégorie (avec fallback) */
    .cat-U7, .cat-U9          { --bloc-color: #f59e0b; }
    .cat-U11                  { --bloc-color: #ec4899; }
    .cat-U13                  { --bloc-color: #06b6d4; }
    .cat-U14                  { --bloc-color: #0891b2; }
    .cat-U15                  { --bloc-color: #8b5cf6; }
    .cat-U16, .cat-U17        { --bloc-color: #6366f1; }
    .cat-U18                  { --bloc-color: #4f46e5; }
    .cat-Senior-F             { --bloc-color: #ef4444; }
    .cat-Senior-H             { --bloc-color: #dc2626; }
    .cat-Loisir-Mixte         { --bloc-color: #22c55e; }

    @media (max-width: 768px) {
        .planning-grid { font-size: .7rem; }
        .planning-block { font-size: .65rem; padding: 3px 5px; }
    }

    /* [UI 05/07/2026] Mobile : 7 jours dans 360px = illisible (≈41px/jour).
       On donne à la grille une largeur minimale utilisable et on scrolle
       horizontalement DANS la grille (la page, elle, ne bouge pas —
       body est en overflow-x:clip depuis base.html.twig). */
    @media (max-width: 767px) {
        .planning-scroll {
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
            border-radius: 12px;
        }
        .planning-grid {
            min-width: 700px;   /* ≈ 90px/jour : blocs lisibles */
        }
    }
</style>
{% endblock %}

{% block body %}
    <div class="page-header">
        <div>
            <h1><i class="bi bi-grid-3x3-gap"></i> Planning du club</h1>
            <p class="subtitle">Vue d'ensemble des créneaux hebdomadaires d'entraînement de toutes les équipes.</p>
        </div>
        {% if is_granted('CLUB_STAFF', club) %}
            <a href="{{ path('manager_planning_global_new') }}" class="btn-mabb-orange">
                <i class="bi bi-plus-lg"></i> Ajouter un créneau
            </a>
        {% endif %}
    </div>

    {# ========================================================
       Filtres : par catégorie ou par équipe
       ======================================================== #}
    <div class="card-mabb" style="margin-bottom:16px;">
        <div class="card-body" style="padding:14px 20px;">
            <form method="get" style="display:flex; gap:12px; align-items:center; flex-wrap:wrap; margin:0;">
                <label style="font-weight:600; margin:0;">Filtrer par :</label>
                <select name="categorie" class="form-select" style="max-width:200px;" onchange="this.form.submit()">
                    <option value="">— Toutes catégories —</option>
                    {% for c in categories %}
                        <option value="{{ c }}" {{ categorie_filtre == c ? 'selected' : '' }}>Catégorie {{ c }}</option>
                    {% endfor %}
                </select>
                <select name="equipe_id" class="form-select" style="max-width:280px;" onchange="this.form.submit()">
                    <option value="">— Toutes équipes —</option>
                    {% for e in equipes %}
                        <option value="{{ e.id }}" {{ equipe_filtre and equipe_filtre.id == e.id ? 'selected' : '' }}>
                            {{ e.nom }} ({{ e.categorie }})
                        </option>
                    {% endfor %}
                </select>
                {% if categorie_filtre or equipe_filtre %}
                    <a href="{{ path('manager_planning_index') }}" class="btn-mabb-ghost btn-sm">
                        <i class="bi bi-x-lg"></i> Réinitialiser
                    </a>
                {% endif %}
            </form>
        </div>
    </div>

    {# ========================================================
       Grille du planning hebdo
       ======================================================== #}
    {% set jours = {1:'Lundi', 2:'Mardi', 3:'Mercredi', 4:'Jeudi', 5:'Vendredi', 6:'Samedi', 7:'Dimanche'} %}
    {% set total_creneaux = 0 %}
    {% for j, items in plannings_par_jour %}{% set total_creneaux = total_creneaux + items|length %}{% endfor %}

    {% if total_creneaux == 0 %}
        <div class="card-mabb">
            <div class="empty-state">
                <i class="bi bi-calendar-x"></i>
                <h3>Aucun créneau récurrent</h3>
                <p>
                    Aucune équipe n'a encore défini de créneau d'entraînement{% if categorie_filtre or equipe_filtre %} pour ce filtre{% endif %}.<br>
                    Commence par ajouter un créneau pour faire vivre ton planning club.
                </p>
                {% if is_granted('CLUB_STAFF', club) %}
                    <a href="{{ path('manager_planning_global_new') }}" class="btn-mabb-orange" style="margin-top:12px;">
                        <i class="bi bi-plus-lg"></i> Ajouter mon premier créneau
                    </a>
                {% endif %}
            </div>
        </div>
    {% else %}
        {# [UI 05/07/2026] Wrapper de scroll horizontal mobile (voir CSS) #}
        <div class="planning-scroll">
        <div class="planning-grid">
            {# Header : vide + 7 jours #}
            <div class="planning-header"></div>
            {% for j, nom in jours %}
                <div class="planning-header">
                    {{ nom }}
                    {% if plannings_par_jour[j]|length > 0 %}
                        <div style="font-weight:400; font-size:.7rem; opacity:.7;">{{ plannings_par_jour[j]|length }}</div>
                    {% endif %}
                </div>
            {% endfor %}

            {# Lignes : 1 par heure de 8h à 22h #}
            {% for heure in range(8, 22) %}
                <div class="planning-hour">{{ '%02d:00'|format(heure) }}</div>
                {% for j, nom in jours %}
                    <div class="planning-cell">
                        {% for p in plannings_par_jour[j] %}
                            {% set h_planning = p.heureDebut|split(':')[0]|number_format %}
                            {% if h_planning == heure %}
                                <a href="{{ path('manager_planning_edit', {id: p.id}) }}"
                                   class="planning-block cat-{{ p.equipe.categorie|replace({' ':'-'}) }}"
                                   title="{{ p.equipe.nom }} — {{ p.lieu }}">
                                    <strong>{{ p.equipe.nom }}</strong>
                                    <div class="meta">
                                        {{ p.heureDebut }} ({{ p.dureeMinutes }}min)<br>
                                        {{ p.lieu }}
                                    </div>
                                </a>
                            {% endif %}
                        {% endfor %}
                    </div>
                {% endfor %}
            {% endfor %}
        </div>
        </div>{# fin .planning-scroll #}

        {# Légende #}
        <div style="margin-top:16px; display:flex; flex-wrap:wrap; gap:10px; align-items:center;">
            <span style="font-weight:600; color:var(--mabb-muted); font-size:.85rem;">Code couleurs :</span>
            {% set cats_vues = [] %}
            {% for j, items in plannings_par_jour %}
                {% for p in items %}
                    {% if p.equipe.categorie not in cats_vues %}
                        <span class="planning-block cat-{{ p.equipe.categorie|replace({' ':'-'}) }}" style="display:inline-block; padding:3px 12px; font-size:.75rem; margin:0;">
                            {{ p.equipe.categorie }}
                        </span>
                        {% set cats_vues = cats_vues|merge([p.equipe.categorie]) %}
                    {% endif %}
                {% endfor %}
            {% endfor %}
        </div>
    {% endif %}

    {# Note pédagogique #}
    <div class="card-mabb" style="margin-top:20px; opacity:.85;">
        <div class="card-body">
            <p style="margin:0; font-size:.85rem; color:var(--mabb-muted);">
                <i class="bi bi-info-circle"></i>
                Cette vue présente les <strong>créneaux RÉCURRENTS</strong> de la semaine type.
                Pour voir les séances générées ou les rencontres ponctuelles, va dans
                <a href="{{ path('manager_seance_index') }}">Séances</a> ou
                <a href="{{ path('manager_rencontre_index') }}">Rencontres</a>.
                Une vue calendrier mensuel mixant tout viendra dans une prochaine itération.
            </p>
        </div>
    </div>
{% endblock %}
