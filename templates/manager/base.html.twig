{# templates/manager/base.html.twig
   Layout commun à toutes les pages de manager.mabb.fr
   - Navbar haut (logo + menu modules + user)
   - Flash messages
   - Bloc contenu principal
   - Footer minimal
#}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Manager{% endblock %} — MABB</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        :root {
            --mabb-blue:   #0062a8;
            --mabb-dark:   #0e2a54;
            --mabb-light:  #1c7ec4;
            --mabb-orange: #fc702a;
            --mabb-red:    #ff3b2f;
            --mabb-bg:     #f1f5f9;
            --mabb-card:   #ffffff;
            --mabb-border: #e2e8f0;
            --mabb-text:   #0f172a;
            --mabb-muted:  #64748b;
        }

        body {
            background: var(--mabb-bg);
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            color: var(--mabb-text);
        }

        /* ───── Navbar ───── */
        .topbar {
            background: linear-gradient(90deg, var(--mabb-dark), var(--mabb-blue));
            color: #fff;
            padding: 14px 28px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 2px 8px rgba(14, 42, 84, 0.18);
        }
        .topbar .brand {
            font-weight: 800;
            font-size: 1.15rem;
            letter-spacing: .5px;
            color: #fff;
            text-decoration: none;
        }
        .topbar .nav-modules {
            display: flex;
            gap: 4px;
            list-style: none;
            padding: 0;
            /* [UI 05/07/2026] La navbar compte 11 modules : même en desktop
               1024-1300px elle peut déborder. min-width:0 + flex:1 laisse la
               rangée rétrécir, overflow-x:auto la rend scrollable au lieu de
               casser la ligne ou pousser la user-zone hors écran. */
            flex: 1 1 auto;
            min-width: 0;
            overflow-x: auto;
            overflow-y: hidden;
            scrollbar-width: thin;
            scrollbar-color: rgba(255,255,255,0.2) transparent;
            margin: 0 12px;
        }
        .topbar .nav-modules::-webkit-scrollbar { height: 4px; }
        .topbar .nav-modules::-webkit-scrollbar-thumb {
            background: rgba(255,255,255,0.2);
            border-radius: 4px;
        }
        .topbar .nav-modules a {
            color: rgba(255,255,255,0.85);
            text-decoration: none;
            font-weight: 500;
            font-size: .9rem;
            padding: 8px 14px;
            border-radius: 8px;
            transition: background .15s;
            white-space: nowrap;   /* jamais de lien sur 2 lignes */
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }
        .topbar .user-zone { flex-shrink: 0; }
        .topbar .nav-modules a:hover,
        .topbar .nav-modules a.active {
            background: rgba(255,255,255,0.12);
            color: #fff;
        }
        .topbar .user-zone {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: .9rem;
        }
        .topbar .user-zone .user-name {
            color: rgba(255,255,255,0.9);
        }

        /* ═══════════════════════════════════════════════════════════
           [UI 05/07/2026] Menu utilisateur <details> (profil + saison
           + déconnexion). Pure CSS — pas de dépendance Bootstrap JS.
           ═══════════════════════════════════════════════════════════ */
        .user-menu { position: relative; }
        .user-menu > summary {
            list-style: none;             /* enlève le triangle natif */
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: rgba(255,255,255,0.92);
            padding: 7px 12px;
            border-radius: 999px;
            border: 1px solid rgba(255,255,255,0.25);
            font-weight: 600;
            font-size: .85rem;
            transition: background .15s;
            user-select: none;
            white-space: nowrap;
        }
        .user-menu > summary::-webkit-details-marker { display: none; }
        .user-menu > summary:hover,
        .user-menu[open] > summary { background: rgba(255,255,255,0.14); }
        .user-menu > summary .chev { font-size: .7rem; transition: transform .15s; }
        .user-menu[open] > summary .chev { transform: rotate(180deg); }
        .user-menu .saison-chip {
            background: rgba(252,112,42,.9);
            color: #fff;
            font-size: .68rem;
            font-weight: 800;
            padding: 2px 8px;
            border-radius: 999px;
            letter-spacing: .02em;
        }
        .user-menu-panel {
            position: absolute;
            top: calc(100% + 8px);
            right: 0;
            min-width: 240px;
            background: #fff;
            border: 1px solid var(--mabb-border);
            border-radius: 12px;
            box-shadow: 0 12px 32px rgba(14,42,84,.22);
            z-index: 1050;
            overflow: hidden;
            padding: 6px;
        }
        .user-menu-head {
            padding: 10px 12px;
            border-bottom: 1px solid var(--mabb-border);
            margin-bottom: 4px;
            display: flex;
            flex-direction: column;
            gap: 2px;
        }
        .user-menu-head strong { color: var(--mabb-dark); font-size: .9rem; }
        .user-menu-head small { color: var(--mabb-muted); font-size: .75rem; word-break: break-all; }
        .user-menu-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 8px;
            color: var(--mabb-text);
            text-decoration: none;
            font-size: .88rem;
            font-weight: 500;
        }
        a.user-menu-item:hover { background: #f1f5f9; color: var(--mabb-dark); }
        .user-menu-logout { color: #b91c1c; }
        a.user-menu-logout:hover { background: #fef2f2; color: #991b1b; }
        .user-menu-saison {
            flex-direction: column;
            align-items: stretch;
            gap: 6px;
            cursor: default;
        }
        .user-menu-saison label {
            font-size: .72rem;
            font-weight: 700;
            color: var(--mabb-muted);
            text-transform: uppercase;
            letter-spacing: .05em;
            display: flex;
            align-items: center;
            gap: 6px;
            margin: 0;
        }
        .user-menu-saison select {
            width: 100%;
            border: 1.5px solid var(--mabb-border);
            border-radius: 8px;
            padding: 8px 10px;
            font-size: .88rem;
            cursor: pointer;
            background: #fff;
            color: var(--mabb-text);
        }
        .user-menu-saison select:focus {
            outline: none;
            border-color: var(--mabb-orange);
            box-shadow: 0 0 0 3px rgba(252,112,42,.15);
        }

        /* ───── Contenu ───── */
        main.container-app {
            max-width: 1200px;
            margin: 0 auto;
            padding: 28px 24px;
        }

        /* ───── Page header ───── */
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            flex-wrap: wrap;
            gap: 12px;
        }
        .page-header h1 {
            font-size: 1.6rem;
            font-weight: 800;
            color: var(--mabb-dark);
            margin: 0;
        }
        .page-header .subtitle {
            color: var(--mabb-muted);
            font-size: .9rem;
            margin-top: 4px;
        }

        /* ───── Cards ───── */
        .card-mabb {
            background: var(--mabb-card);
            border-radius: 12px;
            border: 1px solid var(--mabb-border);
            box-shadow: 0 1px 3px rgba(0,0,0,.04);
            overflow: hidden;
        }
        .card-mabb .card-header {
            background: #f8fafc;
            border-bottom: 1px solid var(--mabb-border);
            padding: 14px 20px;
            font-weight: 700;
            color: var(--mabb-dark);
        }
        .card-mabb .card-body { padding: 20px; }

        /* ───── Boutons MABB ───── */
        .btn-mabb-primary {
            background: var(--mabb-blue);
            color: #fff;
            border: none;
            padding: 8px 18px;
            border-radius: 8px;
            font-weight: 600;
            font-size: .9rem;
            transition: background .15s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }
        .btn-mabb-primary:hover { background: var(--mabb-dark); color: #fff; }
        .btn-mabb-orange {
            background: var(--mabb-orange);
            color: #fff;
            border: none;
            padding: 8px 18px;
            border-radius: 8px;
            font-weight: 600;
            font-size: .9rem;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }
        .btn-mabb-orange:hover { background: var(--mabb-red); color: #fff; }
        .btn-mabb-ghost {
            background: transparent;
            color: var(--mabb-blue);
            border: 1px solid var(--mabb-blue);
            padding: 7px 16px;
            border-radius: 8px;
            font-weight: 600;
            font-size: .85rem;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }
        .btn-mabb-ghost:hover { background: var(--mabb-blue); color: #fff; }

        /* ───── Badges ───── */
        .badge-categorie {
            background: #e0f2fe;
            color: var(--mabb-dark);
            font-weight: 600;
            font-size: .75rem;
            padding: 3px 10px;
            border-radius: 12px;
        }
        .badge-niveau {
            background: #fff7ed;
            color: var(--mabb-orange);
            font-weight: 600;
            font-size: .75rem;
            padding: 3px 10px;
            border-radius: 12px;
        }
        .badge-inactive {
            background: #fee2e2;
            color: #991b1b;
            font-weight: 600;
            font-size: .75rem;
            padding: 3px 10px;
            border-radius: 12px;
        }
        .badge-active {
            background: #dcfce7;
            color: #166534;
            font-weight: 600;
            font-size: .75rem;
            padding: 3px 10px;
            border-radius: 12px;
        }

        /* ───── Table ───── */
        .table-mabb { width: 100%; border-collapse: collapse; }
        .table-mabb thead th {
            background: #f8fafc;
            color: var(--mabb-dark);
            font-weight: 700;
            font-size: .8rem;
            text-transform: uppercase;
            letter-spacing: .03em;
            padding: 12px 16px;
            text-align: left;
            border-bottom: 2px solid var(--mabb-border);
        }
        .table-mabb tbody td {
            padding: 14px 16px;
            border-bottom: 1px solid #f1f5f9;
            font-size: .9rem;
        }
        .table-mabb tbody tr:hover { background: #f8fafc; }
        .table-mabb tbody tr.inactive { opacity: 0.55; }

        /* ───── Flash messages ───── */
        .flash {
            padding: 14px 20px;
            border-radius: 10px;
            margin-bottom: 16px;
            border-left: 4px solid;
            font-weight: 500;
        }
        .flash-success { background: #f0fdf4; border-color: #22c55e; color: #166534; }
        .flash-error   { background: #fef2f2; border-color: #ef4444; color: #991b1b; }
        .flash-warning { background: #fffbeb; border-color: #f59e0b; color: #92400e; }
        .flash-info    { background: #eff6ff; border-color: var(--mabb-blue); color: var(--mabb-dark); }

        /* ───── Forms : design moderne ───── */
        .form-mabb { font-family: inherit; }
        .form-mabb label {
            font-weight: 600;
            color: var(--mabb-dark);
            margin-bottom: 6px;
            font-size: .88rem;
            display: block;
        }

        /* Inputs texte unifiés */
        .form-mabb input[type="text"],
        .form-mabb input[type="email"],
        .form-mabb input[type="password"],
        .form-mabb input[type="number"],
        .form-mabb input[type="date"],
        .form-mabb input[type="datetime-local"],
        .form-mabb input[type="time"],
        .form-mabb input[type="search"],
        .form-mabb input[type="url"],
        .form-mabb input[type="tel"],
        .form-mabb textarea,
        .form-mabb select,
        .form-mabb .form-control,
        .form-mabb .form-select {
            width: 100%;
            border: 1.5px solid var(--mabb-border);
            border-radius: 10px;
            padding: 10px 14px;
            font-size: .92rem;
            font-family: inherit;
            background-color: #fff;
            color: var(--mabb-text);
            transition: border-color .15s, box-shadow .15s, background-color .15s;
            box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
        }

        .form-mabb input::placeholder,
        .form-mabb textarea::placeholder {
            color: #94a3b8;
            font-weight: 400;
        }

        /* Hover (sans focus) — bordure légèrement plus marquée */
        .form-mabb input:hover:not(:focus):not(:disabled),
        .form-mabb textarea:hover:not(:focus):not(:disabled),
        .form-mabb select:hover:not(:focus):not(:disabled) {
            border-color: #cbd5e1;
            background-color: #fafbfc;
        }

        /* Focus : ring orange MABB */
        .form-mabb input:focus,
        .form-mabb textarea:focus,
        .form-mabb select:focus,
        .form-mabb .form-control:focus,
        .form-mabb .form-select:focus {
            outline: none;
            border-color: var(--mabb-orange);
            box-shadow: 0 0 0 4px rgba(252, 112, 42, 0.15);
            background-color: #fff;
        }

        /* Select custom — chevron SVG inline, sans apparence native moche */
        .form-mabb select,
        .form-mabb .form-select {
            appearance: none;
            -webkit-appearance: none;
            -moz-appearance: none;
            background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' width='12' height='8' viewBox='0 0 12 8' fill='none'%3e%3cpath d='M1 1.5L6 6.5L11 1.5' stroke='%230e2a54' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/%3e%3c/svg%3e");
            background-repeat: no-repeat;
            background-position: right 14px center;
            padding-right: 40px;
            cursor: pointer;
        }
        .form-mabb select:focus,
        .form-mabb .form-select:focus {
            background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' width='12' height='8' viewBox='0 0 12 8' fill='none'%3e%3cpath d='M1 1.5L6 6.5L11 1.5' stroke='%23fc702a' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/%3e%3c/svg%3e");
        }
        .form-mabb select option {
            padding: 10px;
            background-color: #fff;
            color: var(--mabb-text);
        }

        /* Textarea : redimensionnement vertical seul + min-height confortable */
        .form-mabb textarea {
            resize: vertical;
            min-height: 80px;
            line-height: 1.5;
        }

        /* Inputs date / datetime-local : icône native plus moderne */
        .form-mabb input[type="date"],
        .form-mabb input[type="datetime-local"],
        .form-mabb input[type="time"] {
            font-family: inherit;
        }
        .form-mabb input[type="date"]::-webkit-calendar-picker-indicator,
        .form-mabb input[type="datetime-local"]::-webkit-calendar-picker-indicator,
        .form-mabb input[type="time"]::-webkit-calendar-picker-indicator {
            cursor: pointer;
            opacity: .6;
            transition: opacity .15s;
        }
        .form-mabb input[type="date"]::-webkit-calendar-picker-indicator:hover {
            opacity: 1;
        }

        /* Checkbox custom */
        .form-mabb input[type="checkbox"] {
            width: 18px;
            height: 18px;
            border: 1.5px solid var(--mabb-border);
            border-radius: 5px;
            cursor: pointer;
            accent-color: var(--mabb-orange);
            margin-right: 8px;
            vertical-align: middle;
        }
        .form-mabb .form-check {
            padding: 8px 0;
        }
        .form-mabb .form-check-label {
            cursor: pointer;
            font-weight: 500 !important;
            color: var(--mabb-text) !important;
        }

        /* Help text sous chaque champ */
        .form-mabb .form-text,
        .form-mabb small.form-text {
            display: block;
            color: var(--mabb-muted);
            font-size: .78rem;
            margin-top: 6px;
            font-weight: 400;
            line-height: 1.5;
        }

        /* État invalide */
        .form-mabb input.is-invalid,
        .form-mabb textarea.is-invalid,
        .form-mabb select.is-invalid {
            border-color: var(--mabb-red);
            background-color: #fef2f2;
        }
        .form-mabb input.is-invalid:focus,
        .form-mabb textarea.is-invalid:focus,
        .form-mabb select.is-invalid:focus {
            box-shadow: 0 0 0 4px rgba(255, 59, 47, 0.15);
        }
        .form-mabb .invalid-feedback {
            display: block;
            color: var(--mabb-red);
            font-size: .82rem;
            font-weight: 500;
            margin-top: 6px;
        }

        /* Disabled */
        .form-mabb input:disabled,
        .form-mabb textarea:disabled,
        .form-mabb select:disabled {
            background-color: #f1f5f9;
            color: #94a3b8;
            cursor: not-allowed;
            opacity: .7;
        }

        /* Asterisque rouge automatique sur les labels des champs requis.
           Symfony Form ajoute la classe "required" aux labels quand
           le champ est obligatoire — on l'exploite ici. */
        .form-mabb label.required::after {
            content: ' *';
            color: var(--mabb-red);
            font-weight: 800;
            margin-left: 2px;
        }
        /* Bandeau "champs obligatoires" en haut des formulaires */
        .form-mabb .form-required-info {
            font-size: .85rem;
            color: var(--mabb-muted);
            margin-bottom: 16px;
            padding: 8px 12px;
            background: #f8fafc;
            border-left: 3px solid var(--mabb-orange);
            border-radius: 4px;
        }
        .form-mabb .form-required-info strong { color: var(--mabb-red); }
        .form-mabb .form-control,
        .form-mabb .form-select {
            border: 1px solid var(--mabb-border);
            border-radius: 8px;
            padding: 8px 12px;
            font-size: .95rem;
        }
        .form-mabb .form-control:focus,
        .form-mabb .form-select:focus {
            border-color: var(--mabb-blue);
            box-shadow: 0 0 0 3px rgba(0, 98, 168, 0.12);
        }
        .form-mabb .form-text { color: var(--mabb-muted); font-size: .8rem; margin-top: 4px; }
        .form-mabb .row-form > div { margin-bottom: 16px; }

        /* ───── Empty state ───── */
        .empty-state {
            text-align: center;
            padding: 50px 24px;
            color: var(--mabb-muted);
        }
        .empty-state i { font-size: 2.5rem; color: #cbd5e1; margin-bottom: 10px; display: block; }
        .empty-state h3 { color: var(--mabb-dark); margin-bottom: 6px; font-weight: 700; font-size: 1.1rem; }
        .empty-state p { font-size: .9rem; margin-bottom: 0; }
        /* Bouton CTA dans l'empty-state — plus discret, taille raisonnable */
        .empty-state .btn-mabb-orange,
        .empty-state .btn-mabb-primary {
            padding: 8px 20px;
            font-size: .85rem;
            border-radius: 20px;
            margin-top: 16px;
            font-weight: 600;
            box-shadow: 0 2px 8px rgba(252, 112, 42, 0.25);
        }

        /* ───── Variantes "small" des boutons ───── */
        .btn-mabb-primary.btn-sm,
        .btn-mabb-orange.btn-sm,
        .btn-mabb-ghost.btn-sm {
            padding: 5px 12px;
            font-size: .78rem;
            border-radius: 6px;
        }

        /* ───── Sections de formulaire ───── */
        .form-section {
            margin-bottom: 24px;
        }
        .form-section-title {
            font-size: .78rem;
            font-weight: 700;
            color: var(--mabb-orange);
            text-transform: uppercase;
            letter-spacing: .08em;
            margin: 0 0 14px;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .form-section-title::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--mabb-border);
            margin-left: 8px;
        }

        /* ═══════════════════════════════════════════════════════
           Responsive — navbar et layout sur tablette & mobile
           Stratégie :
             - >= 1024px (desktop)    : tout en ligne, labels complets
             - 768-1023px (tablette)  : nav scrollable horizontale, labels conservés
             - 480-767px (mobile)     : nav scrollable, labels réduits
             - < 480px (smartphone)   : nav scrollable avec icônes uniquement
           ═══════════════════════════════════════════════════════ */
        @media (max-width: 1023px) {
            .topbar {
                padding: 12px 18px;
                flex-wrap: wrap;
                gap: 10px;
            }
            .topbar .brand {
                font-size: 1.05rem;
                flex-shrink: 0;
            }
            .topbar .nav-modules {
                order: 3;
                width: 100%;
                overflow-x: auto;
                overflow-y: hidden;
                margin-top: 4px;
                padding-bottom: 6px;
                /* Scrollbar discrète sur Firefox + Chrome */
                scrollbar-width: thin;
                scrollbar-color: rgba(255,255,255,0.2) transparent;
                -webkit-overflow-scrolling: touch;
            }
            .topbar .nav-modules::-webkit-scrollbar {
                height: 4px;
            }
            .topbar .nav-modules::-webkit-scrollbar-thumb {
                background: rgba(255,255,255,0.2);
                border-radius: 4px;
            }
            .topbar .nav-modules a {
                white-space: nowrap;
                flex-shrink: 0;
                font-size: .85rem;
                padding: 8px 12px;
            }
            .topbar .user-zone {
                margin-left: auto;
                font-size: .85rem;
            }
            main.container-app {
                padding: 20px 16px;
            }
            .page-header h1 {
                font-size: 1.35rem;
            }
        }

        @media (max-width: 767px) {
            .topbar {
                padding: 10px 14px;
            }
            .topbar .nav-modules a {
                font-size: .8rem;
                padding: 8px 10px;
            }
            .topbar .nav-modules a i {
                margin-right: 4px;
            }
            .page-header {
                flex-direction: column;
                align-items: flex-start;
            }
            .page-header h1 {
                font-size: 1.2rem;
            }
            /* Cards plus compactes sur mobile */
            .card-mabb .card-header,
            .card-mabb .card-body {
                padding: 14px 16px;
            }
            /* Tables horizontalement scrollables si elles débordent */
            .card-mabb {
                overflow-x: auto;
            }
        }

        @media (max-width: 479px) {
            /* Smartphone étroit : on cache le texte des liens nav, on garde
               juste les icônes. Le user reconnaît par l'icône.
               Le label reste accessible via title="..." (tooltip) — à ajouter
               sur les <a> du base.html.twig si on veut. */
            .topbar .brand {
                font-size: .95rem;
            }
            .topbar .nav-modules a {
                font-size: 0;          /* cache le texte */
                padding: 8px 10px;
            }
            .topbar .nav-modules a i {
                font-size: 1.15rem;    /* agrandit l'icône pour compenser */
                margin: 0;
            }
            .topbar .user-zone {
                font-size: .78rem;
            }
            /* [UI 05/07/2026] Smartphone : on cache le prénom dans le bouton
               du menu user, on garde avatar + chip saison + chevron */
            .user-menu .username-text {
                display: none;
            }
            .user-menu > summary {
                padding: 6px 10px;
                gap: 6px;
            }
            main.container-app {
                padding: 14px 10px;
            }
        }

        /* ═══════════════════════════════════════════════════════════════
           V2.1h — Renforts responsive transversaux Manager
           Compléments au bloc navbar existant, pour les pages avec :
             - tableaux (rencontre, joueur, séance, cotisations…)
             - groupes de boutons d'action (page-actions, table-actions)
             - modals, formulaires, page-headers
           ═══════════════════════════════════════════════════════════════ */

        /* Tablette (768-1023px) : tables un peu plus compactes */
        @media (max-width: 1023px) {
            .table-mabb thead th,
            .table-mabb tbody td {
                padding: 10px 8px;
                font-size: 0.88rem;
            }
            .page-header {
                gap: 8px;
            }
        }

        /* Mobile paysage / portrait (≤ 767px) : pas de wrap des actions, table scroll dédié */
        @media (max-width: 767px) {
            /* Le scroll horizontal est sur le PARENT direct de la table, pas la card entière.
               Évite que le card-header (titre + filtres) scrolle aussi.
               On entoure les tables par défaut avec un overflow géré sur card-body. */
            .card-mabb .card-body {
                overflow-x: auto;
                -webkit-overflow-scrolling: touch;
            }
            .card-mabb {
                overflow-x: visible; /* override la règle précédente */
            }
            .table-mabb {
                min-width: 600px;     /* force le scroll si vraiment trop large */
            }
            /* Boutons d'action min 36px (proche WCAG 44px sans casser le design) */
            .btn-mabb-primary,
            .btn-mabb-orange,
            .btn-mabb-ghost {
                min-height: 38px;
                padding-left: 14px;
                padding-right: 14px;
            }
            .btn-mabb-primary.btn-sm,
            .btn-mabb-orange.btn-sm,
            .btn-mabb-ghost.btn-sm {
                min-height: 34px;
                padding: 6px 12px;
                font-size: 0.78rem;
            }
            /* Page actions (groupe d'CTAs en haut) : passe en wrap */
            .page-header {
                flex-wrap: wrap;
            }
            .page-actions,
            .toolbar,
            .header-actions {
                display: flex;
                flex-wrap: wrap;
                gap: 6px;
                width: 100%;
            }
            /* Formulaires : labels au-dessus, inputs full width */
            .form-mabb .form-row,
            .form-mabb .row {
                flex-direction: column;
                gap: 8px;
            }
            input[type="text"],
            input[type="email"],
            input[type="password"],
            input[type="number"],
            input[type="date"],
            input[type="time"],
            input[type="datetime-local"],
            input[type="tel"],
            input[type="url"],
            input[type="search"],
            select,
            textarea {
                font-size: 16px; /* évite le zoom auto iOS sur focus */
            }
            /* Modals (Bureau, etc.) */
            .modal-dialog,
            .modal-content,
            .modal-mabb {
                max-width: 100% !important;
                margin: 8px !important;
            }
        }

        /* Smartphone étroit (< 480px) : on agrandit encore les tap targets sur les rangs */
        @media (max-width: 479px) {
            .table-mabb tbody td {
                padding: 12px 8px;
            }
            /* Tooltip si label nav caché : on lit aria-label / title (déjà géré par browser) */
        }

        /* ═══════════════════════════════════════════════════════════════
           [UI 05/07/2026] BLINDAGE RESPONSIVE GLOBAL — anti scroll horizontal
           Constat : plusieurs pages débordent en mobile car
             1. des tables .table-mabb (min-width:600px) sont posées
                DIRECTEMENT dans .card-mabb sans .card-body — or le scroll
                interne n'était géré QUE sur .card-body → la table poussait
                toute la page (long scroll horizontal).
             2. aucune barrière au niveau du document : le moindre élément
                trop large élargissait <body>.
             3. les grids inline repeat(auto-fill, minmax(280px+…)) peuvent
                déborder sur les écrans < 400px.
           Correctifs CENTRALISÉS ici (une seule source, 0 template modifié).
           ═══════════════════════════════════════════════════════════════ */

        /* 2. Barrière document : rien ne peut élargir la page.
           `clip` (et non `hidden`) : ne crée pas de contexte de scroll,
           ne casse pas position:sticky des enfants. */
        html, body {
            max-width: 100%;
            overflow-x: clip;
        }

        /* Les médias ne débordent jamais du contenu */
        main.container-app img,
        main.container-app video,
        main.container-app canvas {
            max-width: 100%;
            height: auto;
        }

        @media (max-width: 1023px) {
            /* 1. Toute card contenant DIRECTEMENT une table devient son
               propre conteneur de scroll (le reste de la page ne bouge pas).
               :has() est supporté par tous les navigateurs actuels
               (Chrome/Edge 105+, Safari 15.4+, Firefox 121+). */
            .card-mabb:has(> .table-mabb),
            .card-mabb:has(> table),
            .card-mabb:has(> .table-responsive > table) {
                overflow-x: auto;
                -webkit-overflow-scrolling: touch;
            }
            /* Idem pour les tables Bootstrap .table posées nues dans une card */
            .card-mabb > table {
                margin-bottom: 0;
            }
        }

        @media (max-width: 767px) {
            /* min-width des tables : 600px est trop agressif pour les petites
               tables 2-3 colonnes → on ne force le min-width QUE si la table
               a beaucoup de colonnes ne sert à rien en CSS pur ; à la place,
               on laisse 600px par défaut mais les tables marquées "compacte"
               peuvent s'y soustraire. */
            .table-mabb.table-compacte { min-width: 0; }
        }

        @media (max-width: 399px) {
            /* 3. Grids inline auto-fill/auto-fit avec minmax ≥ 200px :
               sur très petit écran on force UNE colonne. Sélecteur par
               substring d'attribut style — évite de retoucher ~20 templates. */
            main [style*="minmax(360px"],
            main [style*="minmax(340px"],
            main [style*="minmax(320px"],
            main [style*="minmax(300px"],
            main [style*="minmax(280px"],
            main [style*="minmax(260px"],
            main [style*="minmax(240px"],
            main [style*="minmax(220px"],
            main [style*="minmax(200px"] {
                grid-template-columns: 1fr !important;
            }
        }

        /* iPad portrait (600-820px) : les grids "larges" passent à 2 colonnes max
           via la même technique, uniquement pour les très larges (320px+) */
        @media (min-width: 600px) and (max-width: 820px) {
            main [style*="minmax(360px"],
            main [style*="minmax(340px"] {
                grid-template-columns: repeat(2, 1fr) !important;
            }
        }

        /* Grids inline à colonnes FIXES (1fr 1fr, 1fr 2fr, 2fr 1fr…) :
           jamais responsive par construction → on les empile sur mobile.
           NB : "1fr 1fr 1fr" contient "1fr 1fr" → couvert aussi (voulu). */
        @media (max-width: 600px) {
            main [style*="grid-template-columns:1fr 1fr"],
            main [style*="grid-template-columns: 1fr 1fr"],
            main [style*="grid-template-columns:1fr 2fr"],
            main [style*="grid-template-columns: 1fr 2fr"],
            main [style*="grid-template-columns:2fr 1fr"],
            main [style*="grid-template-columns: 2fr 1fr"] {
                grid-template-columns: 1fr !important;
            }
        }
        /* Grids "label fixe + valeur" (140px/170px 1fr) : empilées sur
           smartphone étroit, le label au-dessus de la valeur */
        @media (max-width: 479px) {
            main [style*="grid-template-columns:140px"],
            main [style*="grid-template-columns: 140px"],
            main [style*="grid-template-columns:170px"],
            main [style*="grid-template-columns: 170px"] {
                grid-template-columns: 1fr !important;
            }
        }
    </style>

    {% block stylesheets %}{% endblock %}
</head>
<body>

<div class="topbar">
    <a href="{{ path('manager_dashboard') }}" class="brand">🏀 MABB Manager</a>

    {# [V2.4m] Le club de la navbar est résolu ICI (fallback club_actif()) :
       les items conditionnés ne dépendent plus du fait que chaque contrôleur
       pense à passer `club` — fini la navbar amputée sur certaines pages. #}
    {% set nav_club = (club is defined and club) ? club : club_actif() %}
    <ul class="nav-modules">
        <li><a href="{{ path('manager_dashboard') }}" class="{{ app.request.attributes.get('_route') == 'manager_dashboard' ? 'active' : '' }}">
            <i class="bi bi-grid"></i> Tableau de bord
        </a></li>
        <li><a href="{{ path('manager_equipe_index') }}" class="{{ app.request.attributes.get('_route') starts with 'manager_equipe' ? 'active' : '' }}">
            <i class="bi bi-people-fill"></i> Équipes
        </a></li>
        <li><a href="{{ path('manager_joueur_index') }}" class="{{ app.request.attributes.get('_route') starts with 'manager_joueur' ? 'active' : '' }}">
            <i class="bi bi-person-badge"></i> Joueuses
        </a></li>
        <li><a href="{{ path('manager_staff_index') }}" class="{{ app.request.attributes.get('_route') starts with 'manager_staff' ? 'active' : '' }}">
            <i class="bi bi-shield-fill-check"></i> Staff
        </a></li>
        <li><a href="{{ path('manager_seance_index') }}" class="{{ app.request.attributes.get('_route') starts with 'manager_seance' ? 'active' : '' }}">
            <i class="bi bi-calendar-week"></i> Séances
        </a></li>
        <li><a href="{{ path('manager_rencontre_index') }}" class="{{ app.request.attributes.get('_route') starts with 'manager_rencontre' ? 'active' : '' }}">
            <i class="bi bi-trophy"></i> Rencontres
        </a></li>
        <li><a href="{{ path('manager_stats_live_index') }}" class="{{ app.request.attributes.get('_route') starts with 'manager_stats_live' ? 'active' : '' }}"
               style="{{ app.request.attributes.get('_route') starts with 'manager_stats_live' ? '' : '' }}">
            <i class="bi bi-lightning-charge-fill"></i> Stats Live
        </a></li>
        <li><a href="{{ path('manager_ent_index') }}" class="{{ app.request.attributes.get('_route') starts with 'manager_ent' ? 'active' : '' }}">
            <i class="bi bi-folder2-open"></i> ENT
        </a></li>
        {# [V2.4g] Secrétariat — dirigeant + rôle SECRETAIRE uniquement #}
        {% if nav_club and is_granted('CLUB_SECRETARIAT', nav_club) %}
        <li><a href="{{ path('manager_secretariat_dashboard') }}" class="{{ app.request.attributes.get('_route') starts with 'manager_secretariat' ? 'active' : '' }}">
            <i class="bi bi-journal-text"></i> Secrétariat
        </a></li>
        {% endif %}
        {# [V2.4m] Dashboard OTM : retiré de la navbar (demande Clavel) —
           accessible via sa card sur le tableau de bord, avec les autres modules. #}
        {% if nav_club and is_granted('CLUB_STAFF_ELARGI', nav_club) %}
        <li><a href="{{ path('manager_coach_dashboard') }}" class="{{ app.request.attributes.get('_route') starts with 'manager_bilan' or app.request.attributes.get('_route') == 'manager_coach_dashboard' ? 'active' : '' }}">
            <i class="bi bi-speedometer2"></i> Coach
        </a></li>
        {% endif %}
        <li><a href="{{ path('manager_evenement_index') }}" class="{{ app.request.attributes.get('_route') starts with 'manager_evenement' ? 'active' : '' }}">
            <i class="bi bi-calendar-event-fill"></i> Événements
        </a></li>
        <li><a href="{{ path('manager_classement') }}" class="{{ app.request.attributes.get('_route') starts with 'manager_classement' ? 'active' : '' }}">
            <i class="bi bi-trophy-fill"></i> Classement
        </a></li>
        {# Réunions, PDFs FFBB, Bibliothèque, Séances solo : retirés de la navbar,
           accessibles via cards sur le dashboard #}
        {# Lien Demandes — visible UNIQUEMENT aux dirigeants du club actif #}
        {% if nav_club and is_granted('CLUB_ADMIN', nav_club) %}
            <li><a href="{{ path('manager_demandes_index') }}" class="{{ app.request.attributes.get('_route') starts with 'manager_demandes' ? 'active' : '' }}">
                <i class="bi bi-hourglass-split"></i> Demandes
            </a></li>
        {% endif %}
    </ul>

    {# ═══════════════════════════════════════════════════════════════
       [UI 05/07/2026] MENU UTILISATEUR — <details> natif, ZÉRO JS requis
       (Bootstrap JS n'est pas chargé dans Manager, les dropdowns
       data-bs-* ne fonctionneraient pas).
       Le sélecteur de SAISON vit désormais ICI et non plus inline dans
       la topbar : il gonflait la user-zone et cassait le responsive
       (wrap + scroll horizontal en mobile).
       ═══════════════════════════════════════════════════════════════ #}
    <div class="user-zone">
        {% if app.user %}
            <details class="user-menu" id="userMenu">
                <summary title="Compte, saison, déconnexion">
                    <i class="bi bi-person-circle"></i>
                    <span class="username-text">{{ app.user.prenom }}</span>
                    <span class="saison-chip">{{ saison_active() }}</span>
                    <i class="bi bi-chevron-down chev"></i>
                </summary>
                <div class="user-menu-panel">
                    <div class="user-menu-head">
                        <strong>{{ app.user.prenom }} {{ app.user.nom }}</strong>
                        <small>{{ app.user.email }}</small>
                    </div>
                    <a href="{{ path('manager_profil') }}" class="user-menu-item">
                        <i class="bi bi-person"></i> Mon profil
                    </a>
                    {# [V2.4j] Pont écosystème : les membres du club de la vitrine
                       ont AUSSI leur compte mabb.fr (même login) — on le leur montre.
                       Invisible pour les clubs externes (mabb.fr n'est pas leur site). #}
                    {% set menu_club = (club is defined and club) ? club : club_actif() %}
                    {% if menu_club and menu_club.slug == club_vitrine_slug %}
                        <a href="https://mabb.fr/compte/mon-compte" class="user-menu-item" target="_blank" rel="noopener">
                            <i class="bi bi-globe"></i> Mon compte mabb.fr
                        </a>
                    {% endif %}
                    {# [V2.4k] Guide « première fois » — toujours à portée de main #}
                    <a href="{{ path('manager_bienvenue') }}" class="user-menu-item">
                        <i class="bi bi-question-circle"></i> Guide du site
                    </a>
                    <div class="user-menu-item user-menu-saison">
                        <label for="saisonSelect"><i class="bi bi-calendar3"></i> Saison</label>
                        <form method="post" action="{{ path('saison_changer') }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('saison_changer') }}">
                            <select id="saisonSelect" name="saison" onchange="this.form.submit()">
                                {% for s in saisons_disponibles() %}
                                    <option value="{{ s }}" {% if s == saison_active() %}selected{% endif %}>{{ s }}</option>
                                {% endfor %}
                            </select>
                        </form>
                    </div>
                    <a href="{{ path('manager_logout') }}" class="user-menu-item user-menu-logout">
                        <i class="bi bi-box-arrow-right"></i> Déconnexion
                    </a>
                </div>
            </details>
        {% endif %}
    </div>
</div>

<main class="container-app">
    {# Flash messages — affichés une fois puis disparaissent #}
    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="flash flash-{{ type }}">
                <i class="bi bi-{{ type == 'success' ? 'check-circle-fill' : type == 'error' ? 'x-circle-fill' : type == 'warning' ? 'exclamation-triangle-fill' : 'info-circle-fill' }}"></i>
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    {% block body %}{% endblock %}
</main>

{# ═══ [UI 05/07/2026] JS global léger — vanilla, aucune lib ═══ #}
<script>
(function () {
    // 1. Menu utilisateur <details> : fermeture au clic extérieur + Échap.
    //    (comportement natif : <details> reste ouvert sinon)
    const menu = document.getElementById('userMenu');
    if (menu) {
        document.addEventListener('click', (e) => {
            if (menu.hasAttribute('open') && !menu.contains(e.target)) {
                menu.removeAttribute('open');
            }
        });
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') menu.removeAttribute('open');
        });
    }

    // 2. Boutons de fermeture des alertes Bootstrap (.btn-close).
    //    Bootstrap JS n'est PAS chargé dans Manager : les data-bs-dismiss
    //    étaient morts. Délégation minimale : clic → on retire l'alerte.
    document.addEventListener('click', (e) => {
        const btn = e.target.closest('.btn-close, [data-bs-dismiss="alert"]');
        if (!btn) return;
        const alerte = btn.closest('.alert, .flash');
        if (alerte) alerte.remove();
    });
})();
</script>

{% block javascripts %}{% endblock %}

{# ─── Chatbot assistant flottant ─────────────────────────────────────────── #}
{% if app.user %}
    {{ include('partials/_chatbot.html.twig', {chatbotContext: 'manager'}) }}
{% endif %}

</body>
</html>
