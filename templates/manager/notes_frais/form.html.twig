{% extends 'manager/base.html.twig' %}

{% block title %}Nouvelle note de frais{% endblock %}

{% block body %}
    <div class="page-header">
        <div>
            <h1><i class="bi bi-receipt"></i> Nouvelle note de frais</h1>
            <p class="subtitle">
                <a href="{{ path('manager_mes_notes_frais') }}" style="color:var(--mabb-muted); text-decoration:none;">
                    <i class="bi bi-arrow-left"></i> Retour à mes notes
                </a>
            </p>
        </div>
    </div>

    {% if errors|length > 0 %}
        <div class="card-mabb" style="border-left:4px solid #dc2626; background:#fef2f2; margin-bottom:16px;">
            <div class="card-body" style="padding:14px 18px;">
                <strong style="color:#991b1b;"><i class="bi bi-exclamation-triangle-fill"></i> Corrige ces erreurs :</strong>
                <ul style="margin:8px 0 0; padding-left:24px; color:#7f1d1d;">
                    {% for err in errors %}
                        <li>{{ err }}</li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    {% endif %}

    {# Bandeau d'info pour l'user qui dépose #}
    <div class="card-mabb" style="border-left:4px solid #3b82f6; background:#eff6ff; margin-bottom:16px;">
        <div class="card-body" style="padding:14px 18px; display:flex; gap:12px; align-items:center;">
            <i class="bi bi-info-circle-fill" style="color:#1e40af; font-size:1.3rem; flex-shrink:0;"></i>
            <div style="color:#1e3a8a; font-size:.88rem;">
                Une note de frais doit être accompagnée d'un <strong>justificatif obligatoire</strong>
                (ticket de caisse photographié, facture PDF, etc.). Le trésorier la validera ou la rejettera.
                Une fois validée, le remboursement sera enregistré en compta automatiquement.
            </div>
        </div>
    </div>

    <form method="POST" enctype="multipart/form-data" action="{{ path('manager_note_frais_new') }}">
        <div class="card-mabb" style="margin-bottom:16px;">
            <div class="card-body" style="padding:24px;">

                {# === Montant + Date dépense === #}
                <div class="row g-3" style="margin-bottom:20px;">
                    <div class="col-md-6">
                        <label for="montant" style="display:block; font-weight:600; color:var(--mabb-dark); margin-bottom:6px;">
                            Montant remboursé (€) *
                        </label>
                        <input type="text" id="montant" name="montant" required
                               value="{{ note.montant != '0.00' ? note.montant : '' }}"
                               placeholder="ex: 27.50"
                               pattern="^\d+([.,]\d{1,2})?$"
                               style="width:100%; padding:10px 14px; border:2px solid #e5e7eb; border-radius:8px; font-size:1.1rem; font-weight:600;">
                    </div>
                    <div class="col-md-6">
                        <label for="date_depense" style="display:block; font-weight:600; color:var(--mabb-dark); margin-bottom:6px;">
                            Date de la dépense *
                        </label>
                        <input type="date" id="date_depense" name="date_depense" required
                               value="{{ note.dateDepense|date('Y-m-d') }}"
                               max="{{ 'now'|date('Y-m-d') }}"
                               style="width:100%; padding:10px 14px; border:2px solid #e5e7eb; border-radius:8px; font-size:1rem;">
                        <small style="color:var(--mabb-muted);">Date à laquelle tu as payé, pas aujourd'hui.</small>
                    </div>
                </div>

                {# === Libellé === #}
                <div style="margin-bottom:20px;">
                    <label for="libelle" style="display:block; font-weight:600; color:var(--mabb-dark); margin-bottom:6px;">
                        Pour quoi ? *
                    </label>
                    <input type="text" id="libelle" name="libelle" required
                           value="{{ note.libelle }}"
                           maxlength="255"
                           placeholder="ex: Péages déplacement match Saint-Quentin"
                           style="width:100%; padding:10px 14px; border:2px solid #e5e7eb; border-radius:8px; font-size:1rem;">
                </div>

                {# === Notes === #}
                <div style="margin-bottom:20px;">
                    <label for="notes" style="display:block; font-weight:600; color:var(--mabb-dark); margin-bottom:6px;">
                        Précisions (optionnel)
                    </label>
                    <textarea id="notes" name="notes" rows="2"
                              placeholder="Contexte, justification, équipe concernée…"
                              style="width:100%; padding:10px 14px; border:2px solid #e5e7eb; border-radius:8px; font-size:.95rem; font-family:inherit; resize:vertical;">{{ note.notes }}</textarea>
                </div>

                {# === Justificatif OBLIGATOIRE === #}
                <div>
                    <label for="justificatif" style="display:block; font-weight:600; color:var(--mabb-dark); margin-bottom:6px;">
                        Justificatif *
                        <span style="color:#dc2626; font-weight:700;">(obligatoire)</span>
                    </label>
                    <input type="file" id="justificatif" name="justificatif" required
                           accept=".pdf,.jpg,.jpeg,.png,.webp,.heic,.heif"
                           style="display:block; padding:10px; border:2px dashed #d1d5db; border-radius:8px; width:100%; background:#fafafa;">
                    <small style="color:var(--mabb-muted);">
                        PDF, JPG, PNG, WebP, HEIC. Max 5 Mo.<br>
                        <strong>Astuce :</strong> sur mobile, prends une photo nette du ticket avec une bonne lumière.
                    </small>
                </div>
            </div>
        </div>

        <div style="display:flex; gap:10px; justify-content:flex-end;">
            <a href="{{ path('manager_mes_notes_frais') }}" class="btn-mabb-secondary">Annuler</a>
            <button type="submit" class="btn-mabb-orange">
                <i class="bi bi-send"></i> Envoyer au trésorier
            </button>
        </div>
    </form>
{% endblock %}
