{# templates/manager/dashboard.html.twig — STUB Sprint 1 #}
{# Ce template sera remplacé en Phase 2 par le vrai dashboard manager #}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manager — MABB</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body { background: #f1f5f9; font-family: 'Segoe UI', sans-serif; }
        .topbar {
            background: linear-gradient(90deg, #063a55, #0b4fa3);
            color: #fff;
            padding: 14px 28px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .topbar .brand { font-weight: 800; font-size: 1.1rem; letter-spacing: .5px; }
        .card-stub {
            background: #fff;
            border-radius: 12px;
            padding: 40px;
            text-align: center;
            box-shadow: 0 2px 12px rgba(0,0,0,.06);
            margin-top: 40px;
        }
        .card-stub .icon { font-size: 3rem; color: #0b4fa3; margin-bottom: 16px; }
        .card-stub h2 { font-weight: 800; color: #0b1f3a; }
        .card-stub p { color: #64748b; font-size: .95rem; }
        .badge-sprint {
            display: inline-block;
            background: #fef3e2;
            color: #d97706;
            border-radius: 20px;
            font-size: .75rem;
            font-weight: 700;
            padding: 4px 14px;
            margin-bottom: 12px;
        }
    </style>
</head>
<body>
    <div class="topbar">
        <span class="brand">🏀 MABB Manager</span>
        <a href="{{ path('manager_logout') }}" class="btn btn-sm btn-outline-light rounded-pill">
            <i class="bi bi-box-arrow-right me-1"></i>Déconnexion
        </a>
    </div>

    <div class="container">
        <div class="card-stub">
            <div class="icon"><i class="bi bi-tools"></i></div>
            <div class="badge-sprint">Sprint 2 — en cours de développement</div>
            <h2>Dashboard Manager</h2>
            <p>
                Bienvenue {{ app.user.prenom ?? 'Coach' }} 👋<br>
                L'interface de gestion du club sera disponible à partir du Sprint 2.<br>
                <strong>Tu es connecté avec le rôle :</strong> {{ app.user.roles | join(', ') }}
            </p>
        </div>
    </div>
</body>
</html>
