{% extends 'manager/base.html.twig' %}

{% block title %}Tableau de bord{% endblock %}

{% block body %}
    <div class="page-header">
        <div>
            <h1>Bonjour {{ app.user.prenom }} 👋</h1>
            <p class="subtitle">Voici un aperçu rapide de ton club.</p>
        </div>
    </div>

    {# Les appels oubliés. En premier, avant tout le reste : c'est la seule chose sur
       cette page qui se perd définitivement si on ne la fait pas. Une séance passée
       sans appel, c'est la présence de chaque joueuse effacée, et avec elle son XP et
       ses badges. #}
    {% if seances_sans_appel is defined and seances_sans_appel|length > 0 %}
        <div style="margin-bottom:18px; padding:16px 18px; border-radius:12px;
                    background:#fff8f1; border:1px solid #fdba74; border-left:4px solid var(--mabb-orange);">
            <div style="font-weight:800; margin-bottom:4px;">
                {{ seances_sans_appel|length }} appel{{ seances_sans_appel|length > 1 ? 's' : '' }}
                pas encore fait{{ seances_sans_appel|length > 1 ? 's' : '' }}
            </div>
            <p style="margin:0 0 12px 0; font-size:.86rem; color:#7c5a35; line-height:1.6;">
                Sans l'appel, la présence de tes joueuses n'existe pas : ni dans leur suivi,
                ni dans leurs badges. Ça se rattrape en trente secondes.
            </p>

            <div style="display:flex; flex-direction:column; gap:6px;">
                {% for s in seances_sans_appel|slice(0, 5) %}
                    <a href="{{ path('manager_presence_seance', {id: s.id}) }}"
                       style="display:flex; align-items:center; justify-content:space-between; gap:10px;
                              padding:10px 12px; background:#fff; border:1px solid #f3ddc4; border-radius:8px;
                              text-decoration:none; color:inherit; min-height:44px;">
                        <span style="font-size:.88rem;">
                            <strong>{{ s.equipe.nom }}</strong>
                            <span style="color:#8a94a0;"> · {{ s.date|date('D d/m') }} à {{ s.date|date('H:i') }}</span>
                        </span>
                        <span style="font-weight:700; color:var(--mabb-orange); font-size:.85rem; white-space:nowrap;">
                            Faire l'appel <i class="bi bi-chevron-right"></i>
                        </span>
                    </a>
                {% endfor %}
            </div>

            {% if seances_sans_appel|length > 5 %}
                <a href="{{ path('manager_planning_semaine') }}"
                   style="display:inline-block; margin-top:10px; font-size:.85rem; font-weight:700; color:var(--mabb-orange); text-decoration:none;">
                    Voir les {{ seances_sans_appel|length - 5 }} autres dans ma semaine
                </a>
            {% endif %}
        </div>
    {% endif %}

    {# ============================================================
       [V2.4k] BANNIÈRE PREMIÈRE VISITE — visible tant que le guide
       n'a pas été ouvert (flag localStorage posé par /bienvenue).
       ============================================================ #}
    <div id="guideBanner" style="display:none; margin-bottom:16px; padding:14px 18px; border-radius:12px;
         background:linear-gradient(135deg, #fff7ed, #ffedd5); border:1px solid #fdba74;
         align-items:center; gap:14px; flex-wrap:wrap;">
        <span style="font-size:1.5rem;">🧭</span>
        <div style="flex:1; min-width:200px;">
            <strong style="font-size:.92rem;">Première fois ici ?</strong>
            <div style="font-size:.8rem; color:#9a3412;">Le tour du site en 2 minutes. Chaque étape a son bouton.</div>
        </div>
        <a href="{{ path('manager_bienvenue') }}" class="btn-mabb-orange" style="font-size:.82rem;">Suivre le guide</a>
        <button type="button" onclick="try{localStorage.setItem('mabb_guide_vu','1')}catch(e){}; this.parentElement.style.display='none';"
                style="border:none; background:none; cursor:pointer; color:#9a3412;" title="Masquer">✕</button>
    </div>
    <script>
        try { if (!localStorage.getItem('mabb_guide_vu')) { document.getElementById('guideBanner').style.display = 'flex'; } } catch (e) {}
    </script>

    {# ============================================================
       FEED "POUR TOI" — Phase 1 MVP
       Items personnalisés agrégés par App\Service\FeedAggregator :
         - Prochaine réunion à venir où je suis convoqué
         - Dernière réunion tenue dont je vois la synthèse
         - Dernier PV publié que je n'ai pas lu
       Triés par date desc (récent en premier).
       Le service prépare des FeedItem typés → le template fait juste du rendu.
       ============================================================ #}
    {% if feed_items is defined and feed_items|length > 0 %}
        <div style="margin-bottom:20px;">
            <h2 style="font-size:1.1rem; font-weight:700; color:var(--mabb-dark); margin-bottom:12px; display:flex; align-items:center; gap:8px;">
                <i class="bi bi-stars" style="color:var(--mabb-orange);"></i>
                Pour toi
                <span style="font-size:.7rem; font-weight:500; color:var(--mabb-muted); background:#f3f4f6; padding:2px 8px; border-radius:10px;">
                    {{ feed_items|length }}
                </span>
            </h2>

            <div style="display:flex; flex-direction:column; gap:10px;">
                {% for item in feed_items %}
                    {# Une card par item. Le style hérite de item.couleur (border-left)
                       pour différencier visuellement réunion/synthèse/PV au coup d'œil. #}
                    <a href="{{ item.lien }}" style="text-decoration:none; color:inherit;">
                        <div class="card-mabb"
                             style="border-left:4px solid {{ item.couleur }}; cursor:pointer; transition:transform .15s, box-shadow .15s;"
                             onmouseover="this.style.transform='translateX(3px)'; this.style.boxShadow='0 4px 12px rgba(0,0,0,.06)'"
                             onmouseout="this.style.transform='none'; this.style.boxShadow='none'">
                            <div class="card-body" style="display:flex; gap:14px; align-items:center; padding:14px 18px;">
                                {# Pastille icône colorée à gauche #}
                                <div style="width:42px; height:42px; border-radius:10px; background:{{ item.couleur }}15; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                                    <i class="bi {{ item.icone }}" style="color:{{ item.couleur }}; font-size:1.3rem;"></i>
                                </div>
                                {# Contenu central : type, titre, sous-titre #}
                                <div style="flex:1; min-width:0;">
                                    <div style="font-size:.7rem; font-weight:700; color:{{ item.couleur }}; text-transform:uppercase; letter-spacing:.05em; margin-bottom:2px;">
                                        {{ item.labelType }}
                                    </div>
                                    <div style="font-weight:600; color:var(--mabb-dark); font-size:.95rem; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                                        {{ item.titre }}
                                    </div>
                                    <div style="font-size:.78rem; color:var(--mabb-muted); margin-top:1px;">
                                        {{ item.sousTitre }}
                                    </div>
                                </div>
                                <i class="bi bi-chevron-right" style="color:var(--mabb-muted); flex-shrink:0;"></i>
                            </div>
                        </div>
                    </a>
                {% endfor %}
            </div>
        </div>
    {% endif %}

    {# ============================================================
       [V2.4k] MON ESPACE — cards MEMBRE (bénévole / parent) : mes
       missions, les postes à pourvoir (candidater), mes enfants.
       Affichées seulement si pertinentes — un dashboard qui parle
       aussi à ceux qui ne sont pas staff.
       ============================================================ #}
    {% if (mes_missions is defined and mes_missions|length > 0)
        or (postes_vacants is defined and postes_vacants|length > 0)
        or (mes_enfants is defined and (mes_enfants|length > 0 or not is_staff)) %}
    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(260px, 1fr)); gap:14px; margin-bottom:20px;">

        {# --- Mes missions de match (chrono, buvette, e-marque…) --- #}
        {% if mes_missions is defined and mes_missions|length > 0 %}
            <div class="card-mabb" style="border-top:4px solid #16a34a;">
                <div class="card-header"><i class="bi bi-person-check"></i> Mes missions</div>
                <div class="card-body" style="font-size:.84rem;">
                    {% for m in mes_missions|slice(0, 3) %}
                        <div style="display:flex; justify-content:space-between; gap:8px; padding:5px 0; border-bottom:1px solid var(--mabb-border);">
                            <span><strong>{{ m.roleLabel }}</strong>{% if m.heureRdv %} <small style="color:var(--mabb-muted);">rdv {{ m.heureRdv }}</small>{% endif %}</span>
                            <span style="color:var(--mabb-muted); white-space:nowrap;">{{ m.rencontre and m.rencontre.date ? m.rencontre.date|date('d/m H\\hi') : '' }}</span>
                        </div>
                    {% endfor %}
                    <a href="{{ path('manager_rencontre_staff_mes_missions') }}" style="font-size:.78rem; display:inline-block; margin-top:8px;">Toutes mes missions →</a>
                </div>
            </div>
        {% endif %}

        {# --- Le club cherche du monde : un bénévole peut candidater --- #}
        {% if postes_vacants is defined and postes_vacants|length > 0 %}
            <div class="card-mabb" style="border-top:4px solid var(--mabb-orange);">
                <div class="card-header"><i class="bi bi-megaphone"></i> Le club cherche du monde</div>
                <div class="card-body" style="font-size:.84rem;">
                    <p style="margin:0 0 8px; color:var(--mabb-muted);">Des postes sont à pourvoir ce week-end : chrono, buvette, e-marque. Inscris-toi en un clic.</p>
                    {% for r in postes_vacants|slice(0, 3) %}
                        <div style="display:flex; justify-content:space-between; gap:8px; padding:5px 0; border-bottom:1px solid var(--mabb-border);">
                            <span>{{ r.equipe ? r.equipe.nom : '' }} vs {{ r.adversaire }}</span>
                            <a href="{{ path('manager_rencontre_staff_show', {id: r.id}) }}" style="white-space:nowrap; font-size:.78rem;">
                                {{ r.date ? r.date|date('d/m') : '' }} · Je candidate →
                            </a>
                        </div>
                    {% endfor %}
                </div>
            </div>
        {% endif %}

        {# --- Mes enfants (liens ParentJoueur validés) --- #}
        {% if mes_enfants is defined and mes_enfants|length > 0 %}
            <div class="card-mabb" style="border-top:4px solid var(--mabb-blue);">
                <div class="card-header"><i class="bi bi-people-fill"></i> Mes enfants</div>
                <div class="card-body" style="font-size:.84rem;">
                    {% for pj in mes_enfants %}
                        {% if pj.joueur %}
                        <div style="display:flex; justify-content:space-between; gap:8px; padding:5px 0; border-bottom:1px solid var(--mabb-border);">
                            <span><strong>{{ pj.joueur.prenom }} {{ pj.joueur.nom }}</strong>{% if pj.joueur.equipe %} <small style="color:var(--mabb-muted);">{{ pj.joueur.equipe.nom }}</small>{% endif %}</span>
                            <a href="{{ path('manager_joueur_show', {id: pj.joueur.id}) }}" style="white-space:nowrap; font-size:.78rem;">Fiche &amp; bilan →</a>
                        </div>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        {% elseif mes_enfants is defined and not is_staff %}
            {# Pas d'enfant lié + pas staff → proposer le lien (parent probable) #}
            <div class="card-mabb" style="border-top:4px solid var(--mabb-blue); border-style:solid;">
                <div class="card-header"><i class="bi bi-people"></i> Parent au club ?</div>
                <div class="card-body" style="font-size:.84rem;">
                    <p style="margin:0 0 8px; color:var(--mabb-muted);">Fais le lien avec ton enfant pour suivre sa fiche, ses stats et son bilan depuis ton compte.</p>
                    <a href="https://pirb.mabb.fr/mes-enfants" target="_blank" rel="noopener" class="btn-mabb-ghost" style="font-size:.78rem;">
                        <i class="bi bi-link-45deg"></i> Être lié·e à mon enfant
                    </a>
                </div>
            </div>
        {% endif %}
    </div>
    {% endif %}

    {# ========================================================
       Bandeau "À VENIR" — séances, rencontres, événements (7 prochains jours).
       Placé EN HAUT du dashboard pour donner immédiatement la vue de ce qui arrive.
       ======================================================== #}
    {# Pré-calcul : nombre total d'items à afficher dans le bloc "À venir".
       On compte aussi les réunions (mes_reunions_avenir = convocations où l'user
       est attendu) pour ne pas casser si une seule des sources a du contenu. #}
    {% set nb_reunions = mes_reunions_avenir is defined ? mes_reunions_avenir|length : 0 %}
    {% set nb_total_avenir = prochain_seances|length + prochain_rencontres|length + prochain_evenements|length + nb_reunions %}
    {% if nb_total_avenir > 0 %}
        <div class="card-mabb" style="margin-bottom:20px; border-top:4px solid var(--mabb-orange);">
            <div class="card-header" style="display:flex; justify-content:space-between; align-items:center;">
                <span><i class="bi bi-calendar-event"></i> Les 7 prochains jours</span>
                <small style="color:var(--mabb-muted); font-weight:500;">
                    {{ nb_total_avenir }} élément{{ nb_total_avenir > 1 ? 's' : '' }}
                </small>
            </div>
            <div class="card-body">
                <div class="row g-3">

                    {# === SÉANCES === #}
                    {% if prochain_seances|length > 0 %}
                        <div class="col-md-6 col-lg-4">
                            <h4 style="font-size:.78rem; color:var(--mabb-blue); text-transform:uppercase; letter-spacing:.06em; font-weight:700; margin-bottom:10px;">
                                <i class="bi bi-calendar-week"></i> Séances ({{ prochain_seances|length }})
                            </h4>
                            {% for s in prochain_seances %}
                                <a href="{{ path('manager_seance_show', {id: s.id}) }}" style="display:flex; align-items:center; gap:10px; padding:8px 10px; border-radius:8px; text-decoration:none; color:var(--mabb-text); margin-bottom:5px; transition: background .15s;"
                                   onmouseover="this.style.background='#eff6ff'"
                                   onmouseout="this.style.background='transparent'">
                                    <div style="background:#dbeafe; color:var(--mabb-blue); border-radius:8px; padding:6px 10px; text-align:center; min-width:52px; flex-shrink:0;">
                                        <div style="font-size:.65rem; font-weight:700;">{{ s.date|date('M', 'Europe/Paris')|upper }}</div>
                                        <div style="font-size:1.1rem; font-weight:800;">{{ s.date|date('d') }}</div>
                                    </div>
                                    <div style="min-width:0; flex:1;">
                                        <div style="font-weight:600; font-size:.88rem; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">{{ s.equipe.nom }}</div>
                                        <div style="font-size:.72rem; color:var(--mabb-muted);">
                                            {{ s.date|date('H:i') }}{% if s.lieu %} · {{ s.lieu }}{% endif %}
                                        </div>
                                    </div>
                                </a>
                            {% endfor %}
                        </div>
                    {% endif %}

                    {# === RENCONTRES === #}
                    {% if prochain_rencontres|length > 0 %}
                        <div class="col-md-6 col-lg-4">
                            <h4 style="font-size:.78rem; color:var(--mabb-orange); text-transform:uppercase; letter-spacing:.06em; font-weight:700; margin-bottom:10px;">
                                <i class="bi bi-trophy"></i> Rencontres ({{ prochain_rencontres|length }})
                            </h4>
                            {% for r in prochain_rencontres %}
                                <a href="{{ path('manager_rencontre_show', {id: r.id}) }}" style="display:flex; align-items:center; gap:10px; padding:8px 10px; border-radius:8px; text-decoration:none; color:var(--mabb-text); margin-bottom:5px; transition: background .15s;"
                                   onmouseover="this.style.background='#fff7ed'"
                                   onmouseout="this.style.background='transparent'">
                                    <div style="background:#fff7ed; color:var(--mabb-orange); border-radius:8px; padding:6px 10px; text-align:center; min-width:52px; flex-shrink:0;">
                                        <div style="font-size:.65rem; font-weight:700;">{{ r.date|date('M', 'Europe/Paris')|upper }}</div>
                                        <div style="font-size:1.1rem; font-weight:800;">{{ r.date|date('d') }}</div>
                                    </div>
                                    <div style="min-width:0; flex:1;">
                                        <div style="font-weight:600; font-size:.88rem; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">{{ r.equipe.nom }} vs {{ r.adversaire }}</div>
                                        <div style="font-size:.72rem; color:var(--mabb-muted);">
                                            {{ r.date|date('H:i') }} · {{ r.domicile ? 'Domicile' : 'Extérieur' }}
                                        </div>
                                    </div>
                                </a>
                            {% endfor %}
                        </div>
                    {% endif %}

                    {# === ÉVÉNEMENTS === #}
                    {% if prochain_evenements|length > 0 %}
                        <div class="col-md-6 col-lg-4">
                            <h4 style="font-size:.78rem; color:#8b5cf6; text-transform:uppercase; letter-spacing:.06em; font-weight:700; margin-bottom:10px;">
                                <i class="bi bi-stars"></i> Événements ({{ prochain_evenements|length }})
                            </h4>
                            {% for ev in prochain_evenements %}
                                <a href="{{ path('manager_evenement_show', {id: ev.id}) }}" style="display:flex; align-items:center; gap:10px; padding:8px 10px; border-radius:8px; text-decoration:none; color:var(--mabb-text); margin-bottom:5px; transition: background .15s;"
                                   onmouseover="this.style.background='#faf5ff'"
                                   onmouseout="this.style.background='transparent'">
                                    <div style="background:#ede9fe; color:#7c3aed; border-radius:8px; padding:6px 10px; text-align:center; min-width:52px; flex-shrink:0;">
                                        <div style="font-size:.65rem; font-weight:700;">{{ ev.date|date('M', 'Europe/Paris')|upper }}</div>
                                        <div style="font-size:1.1rem; font-weight:800;">{{ ev.date|date('d') }}</div>
                                    </div>
                                    <div style="min-width:0; flex:1;">
                                        <div style="font-weight:600; font-size:.88rem; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">{{ ev.titre }}</div>
                                        <div style="font-size:.72rem; color:var(--mabb-muted);">
                                            {{ ev.date|date('H:i') }}{% if ev.lieu %} · {{ ev.lieu }}{% endif %}
                                        </div>
                                    </div>
                                </a>
                            {% endfor %}
                        </div>
                    {% endif %}

                </div>
            </div>
        </div>
    {% endif %}

    {# Modules disponibles — pour l'instant uniquement Équipes et Joueuses #}
    <div class="row g-3">
        <div class="col-md-6 col-lg-4">
            <a href="{{ path('manager_equipe_index') }}" style="text-decoration:none;">
                <div class="card-mabb" style="cursor:pointer; transition:transform .15s;">
                    <div class="card-body" style="text-align:center; padding:30px 20px;">
                        <i class="bi bi-people-fill" style="font-size:2.5rem; color:var(--mabb-blue);"></i>
                        <h3 style="margin-top:12px; color:var(--mabb-dark);">Équipes</h3>
                        <p style="color:var(--mabb-muted); font-size:.9rem; margin:0;">Créer, modifier et archiver les équipes du club.</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-6 col-lg-4">
            <a href="{{ path('manager_joueur_index') }}" style="text-decoration:none;">
                <div class="card-mabb" style="cursor:pointer; transition:transform .15s;">
                    <div class="card-body" style="text-align:center; padding:30px 20px;">
                        <i class="bi bi-person-badge" style="font-size:2.5rem; color:var(--mabb-blue);"></i>
                        <h3 style="margin-top:12px; color:var(--mabb-dark);">Joueuses</h3>
                        <p style="color:var(--mabb-muted); font-size:.9rem; margin:0;">Effectif du club : créer, affecter, archiver.</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-6 col-lg-4">
            <a href="{{ path('manager_planning_index') }}" style="text-decoration:none;">
                <div class="card-mabb" style="cursor:pointer;">
                    <div class="card-body" style="text-align:center; padding:30px 20px;">
                        <i class="bi bi-grid-3x3-gap" style="font-size:2.5rem; color:#8b5cf6;"></i>
                        <h3 style="margin-top:12px; color:var(--mabb-dark);">Planning</h3>
                        <p style="color:var(--mabb-muted); font-size:.9rem; margin:0;">Créneaux hebdo des équipes.</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-6 col-lg-4">
            <a href="{{ path('manager_seance_index') }}" style="text-decoration:none;">
                <div class="card-mabb" style="cursor:pointer;">
                    <div class="card-body" style="text-align:center; padding:30px 20px;">
                        <i class="bi bi-calendar-week" style="font-size:2.5rem; color:var(--mabb-blue);"></i>
                        <h3 style="margin-top:12px; color:var(--mabb-dark);">Séances</h3>
                        <p style="color:var(--mabb-muted); font-size:.9rem; margin:0;">Entraînements de la semaine.</p>
                    </div>
                </div>
            </a>
        </div>

        {# Bilans de compétences — coaches et staff élargi #}
        {% if club is defined and club and is_granted('CLUB_STAFF_ELARGI', club) %}
        <div class="col-md-6 col-lg-4">
            <a href="{{ path('manager_bilan_index') }}" style="text-decoration:none;">
                <div class="card-mabb" style="cursor:pointer;">
                    <div class="card-body" style="text-align:center; padding:30px 20px;">
                        <i class="bi bi-clipboard-check" style="font-size:2.5rem; color:#16a34a;"></i>
                        <h3 style="margin-top:12px; color:var(--mabb-dark);">Bilans</h3>
                        <p style="color:var(--mabb-muted); font-size:.9rem; margin:0;">Évaluations de compétences des joueuses.</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-6 col-lg-4">
            <a href="{{ path('manager_coach_dashboard') }}" style="text-decoration:none;">
                <div class="card-mabb" style="cursor:pointer;">
                    <div class="card-body" style="text-align:center; padding:30px 20px;">
                        <i class="bi bi-speedometer2" style="font-size:2.5rem; color:var(--mabb-orange);"></i>
                        <h3 style="margin-top:12px; color:var(--mabb-dark);">Dashboard Coach</h3>
                        <p style="color:var(--mabb-muted); font-size:.9rem; margin:0;">Équipes, joueuses et bilans en un coup d'œil.</p>
                    </div>
                </div>
            </a>
        </div>
        {% endif %}
        <div class="col-md-6 col-lg-4">
            <a href="{{ path('manager_seances_solo_index') }}" style="text-decoration:none;">
                <div class="card-mabb" style="cursor:pointer;">
                    <div class="card-body" style="text-align:center; padding:30px 20px;">
                        <i class="bi bi-person-walking" style="font-size:2.5rem; color:#0ea5e9;"></i>
                        <h3 style="margin-top:12px; color:var(--mabb-dark);">Séances solo</h3>
                        <p style="color:var(--mabb-muted); font-size:.9rem; margin:0;">Valider les séances solo déclarées.</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-6 col-lg-4">
            <a href="{{ path('manager_rencontre_index') }}" style="text-decoration:none;">
                <div class="card-mabb" style="cursor:pointer;">
                    <div class="card-body" style="text-align:center; padding:30px 20px;">
                        <i class="bi bi-trophy" style="font-size:2.5rem; color:var(--mabb-orange);"></i>
