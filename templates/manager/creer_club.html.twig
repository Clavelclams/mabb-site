{# templates/manager/creer_club.html.twig #}
{# Création d'un club — manager.mabb.fr — route publique manager_creer_club #}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Créer mon club — MABB Manager</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #063a55 0%, #0b4fa3 60%, #1c88b6 100%);
            font-family: 'Segoe UI', sans-serif;
            padding: 32px 16px;
        }
        .club-card {
            background: #fff;
            border-radius: 16px;
            padding: 40px 36px;
            width: 100%;
            max-width: 560px;
            box-shadow: 0 20px 60px rgba(0,0,0,.3);
        }
        .club-badge {
            display: inline-block;
            background: #eff6ff;
            color: #1d4ed8;
            border: 1px solid #bfdbfe;
            border-radius: 20px;
            font-size: .75rem;
            font-weight: 700;
            padding: 4px 12px;
            margin-bottom: 16px;
            text-transform: uppercase;
            letter-spacing: .5px;
        }
        .section-titre {
            font-size: .8rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .5px;
            color: #64748b;
            margin: 26px 0 12px;
            border-top: 1px solid #e2e8f0;
            padding-top: 18px;
        }
        .form-label { font-weight: 600; font-size: .9rem; }
        .aide { font-size: .8rem; color: #64748b; }
        .btn-mabb {
            background: #0b4fa3;
            border: none;
            font-weight: 700;
            padding: 12px;
        }
        .btn-mabb:hover { background: #063a55; }
    </style>
</head>
<body>
    <div class="club-card">
        <span class="club-badge"><i class="bi bi-shield-plus"></i> MABB Manager</span>
        <h1 class="h4 fw-bold mb-1">Créer mon club</h1>
        <p class="text-muted mb-0">
            Gratuit, en 2 minutes. Tu deviens automatiquement l'administrateur de ton club.
        </p>

        {% if erreurs is not empty %}
            <div class="alert alert-danger mt-3 mb-0">
                <ul class="mb-0 ps-3">
                    {% for erreur in erreurs %}<li>{{ erreur }}</li>{% endfor %}
                </ul>
            </div>
        {% endif %}

        <form method="post" action="{{ path('manager_creer_club') }}" class="mt-3">
            <input type="hidden" name="_token" value="{{ csrf_token('creer_club') }}">

            <div class="section-titre" style="border-top:none;padding-top:0;margin-top:8px;">Le club</div>

            <div class="mb-3">
                <label class="form-label" for="nom">Nom du club <span class="text-danger">*</span></label>
                <input type="text" id="nom" name="nom" class="form-control" required
                       value="{{ valeurs.nom }}" placeholder="Le nom complet de ton club">
            </div>

            <div class="mb-3">
                <label class="form-label" for="discipline">Discipline <span class="text-danger">*</span></label>
                <select id="discipline" name="discipline" class="form-select" required>
                    <option value="" disabled {{ valeurs.discipline is empty ? 'selected' : '' }}>Choisir…</option>
                    {% for cle, libelle in disciplines %}
                        <option value="{{ cle }}" {{ valeurs.discipline == cle ? 'selected' : '' }}>{{ libelle }}</option>
                    {% endfor %}
                </select>
            </div>

            <div class="row g-3">
                <div class="col-8">
                    <label class="form-label" for="ville">Ville</label>
                    <input type="text" id="ville" name="ville" class="form-control"
                           value="{{ valeurs.ville }}" placeholder="Ta ville">
                </div>
                <div class="col-4">
                    <label class="form-label" for="code_postal">Code postal</label>
                    <input type="text" id="code_postal" name="code_postal" class="form-control"
                           value="{{ valeurs.code_postal }}" placeholder="00000" maxlength="5">
                </div>
            </div>

            <div class="mb-1 mt-3">
                <label class="form-label" for="numero_ffbb">Numéro FFBB <span class="aide">(facultatif)</span></label>
                {# Jamais de vrai numéro en exemple ici : ce champ sert justement à prouver
                   qu'on est bien le club qu'on prétend être. Afficher un numéro valide
                   reviendrait à le tendre à quiconque voudrait usurper ce club. On donne
                   la forme, pas un cas réel. #}
                <input type="text" id="numero_ffbb" name="numero_ffbb" class="form-control"
                       value="{{ valeurs.numero_ffbb }}" placeholder="3 lettres puis 7 chiffres"
                       style="text-transform:uppercase;">
                <div class="aide mt-1">
                    <i class="bi bi-info-circle"></i>
                    Si ton club est affilié à la FFBB, renseigne son numéro de groupement : il sera
                    reconnu <strong>officiel</strong>. Tu le trouves sur ta licence ou auprès de ton
                    comité départemental. Sinon, laisse vide : ton club fonctionnera exactement pareil.
                </div>
            </div>

            {% if not deja_connecte %}
                <div class="section-titre">Ton compte administrateur</div>

                <div class="row g-3">
                    <div class="col-6">
                        <label class="form-label" for="prenom">Prénom <span class="text-danger">*</span></label>
                        <input type="text" id="prenom" name="prenom" class="form-control" required value="{{ valeurs.prenom }}">
                    </div>
                    <div class="col-6">
                        <label class="form-label" for="nom_user">Nom <span class="text-danger">*</span></label>
                        <input type="text" id="nom_user" name="nom_user" class="form-control" required value="{{ valeurs.nom_user }}">
                    </div>
                </div>

                <div class="mb-3 mt-3">
                    <label class="form-label" for="email">Email <span class="text-danger">*</span></label>
                    <input type="email" id="email" name="email" class="form-control" required value="{{ valeurs.email }}">
                </div>

                <div class="mb-3">
                    <label class="form-label" for="password">Mot de passe <span class="text-danger">*</span></label>
                    <input type="password" id="password" name="password" class="form-control" required
                           minlength="8" placeholder="8 caractères minimum">
                </div>

                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" id="rgpd" name="rgpd" value="1" required>
                    <label class="form-check-label aide" for="rgpd">
                        J'accepte que mes données soient traitées pour la gestion de mon compte
                        (<a href="{{ path('vitrine_confidentialite') }}" target="_blank" rel="noopener">politique de confidentialité</a>).
                    </label>
                </div>
            {% else %}
                <p class="aide mt-3 mb-0">
                    <i class="bi bi-person-check"></i>
                    Connecté en tant que <strong>{{ app.user.prenom }} {{ app.user.nom }}</strong> — tu seras l'administrateur de ce club.
                </p>
            {% endif %}

            <button type="submit" class="btn btn-mabb btn-primary w-100 mt-4">
                <i class="bi bi-check2-circle"></i> Créer mon club
            </button>
        </form>

        <div class="text-center mt-4 aide">
            {% if deja_connecte %}
                <a href="{{ path('manager_dashboard') }}">← Retour au tableau de bord</a>
            {% else %}
                Déjà un compte ou un club ? <a href="{{ path('manager_login') }}">Se connecter</a>
                · <a href="{{ path('manager_inscription') }}">Rejoindre un club existant</a>
            {% endif %}
        </div>
    </div>
</body>
</html>
