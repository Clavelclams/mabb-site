{% extends 'manager/base.html.twig' %}

{% block title %}{{ joueur.nomComplet }}{% endblock %}

{% block body %}
    <div class="page-header">
        <div style="display:flex; align-items:center; gap: 20px;">
            {# Avatar : photo PIRB si la joueuse en a uploadé une, sinon fallback initiales.
               La photo est gérée par la joueuse elle-même côté PIRB (RGPD : auto-détermination).
               Côté Manager, lecture seule — pas d'upload, pas de suppression. #}
            {% if joueur.photoPath %}
                <img src="{{ asset('uploads/joueurs/' ~ joueur.photoPath) }}"
                     alt="{{ joueur.nomComplet }}"
                     style="width: 80px; height: 80px; border-radius: 50%; object-fit: cover; box-shadow: 0 2px 8px rgba(0,0,0,.15);">
            {% else %}
                <div style="width: 80px; height: 80px; border-radius: 50%; background: linear-gradient(135deg, var(--mabb-blue), var(--mabb-dark)); color: white; display:flex; align-items:center; justify-content:center; font-size: 1.8rem; font-weight: 800;">
                    {{ joueur.prenom|first|upper }}{{ joueur.nom|first|upper }}
                </div>
            {% endif %}
            <div>
                <h1 style="margin:0;">{{ joueur.prenom }} {{ joueur.nom }}</h1>
                <p class="subtitle" style="margin-top: 6px;">
                    {% if joueur.equipe %}
                        <span class="badge-categorie">{{ joueur.equipe.nom }}</span>
                    {% else %}
                        <span style="color: var(--mabb-muted);">Non affectée à une équipe</span>
                    {% endif %}
                    {% if joueur.poste %}
                        <span style="color: var(--mabb-muted); margin-left: 8px;">{{ joueur.poste }}</span>
                    {% endif %}
                    {% if joueur.numeroMaillot is not null %}
                        <span style="background: var(--mabb-blue); color:white; padding: 2px 10px; border-radius: 10px; font-weight: 700; margin-left: 8px;">N° {{ joueur.numeroMaillot }}</span>
                    {% endif %}
                    {% if not joueur.isActive %}
                        <span class="badge-inactive" style="margin-left: 8px;"><i class="bi bi-archive"></i> Archivée</span>
                    {% endif %}
                </p>
            </div>
        </div>
        <div style="display:flex; gap:8px; flex-wrap:wrap;">
            <a href="{{ path('manager_joueur_index') }}" class="btn-mabb-ghost">
                <i class="bi bi-arrow-left"></i> Toutes les joueuses
            </a>
            {# V1.2d — Lien vers le profil PIRB public de cette joueuse #}
            <a href="{{ url('pirb_joueuse_public', {id: joueur.id}) }}"
               target="_blank" rel="noopener"
               class="btn-mabb-ghost"
               title="Voir le profil PIRB (style réseau social)">
                <i class="bi bi-person-vcard"></i> Profil PIRB
            </a>
            {% if is_granted('CLUB_STAFF', joueur) %}
                <a href="{{ path('manager_joueur_edit', {id: joueur.id}) }}" class="btn-mabb-primary">
                    <i class="bi bi-pencil"></i> Modifier
                </a>
                <a href="{{ path('manager_mission_new', {id: joueur.id}) }}" class="btn-mabb-orange">
                    <i class="bi bi-hand-thumbs-up"></i> Ajouter mission
                </a>
                <a href="{{ path('manager_shot_chart_joueuse', {id: joueur.id}) }}" class="btn-mabb-ghost">
                    <i class="bi bi-bullseye"></i> Shot chart
                </a>
                <a href="{{ path('manager_parents_enfants_lier_staff', {joueurId: joueur.id}) }}" class="btn-mabb-ghost">
                    <i class="bi bi-person-heart"></i> Lier un responsable
                </a>
            {% endif %}
        </div>
    </div>

    {# ========================================================
       BLOC 5 — Filtre RGPD : qui peut voir la totalité de la fiche ?
       Règle : STAFF/COACH/DIRIGEANT voient tout (gestion club).
       La JOUEUSE ELLE-MÊME voit son propre profil complet.
       Les autres (BENEVOLE, PARENT, autre JOUEUR, EMPLOYE) → vue limitée
       à l'identité publique. Préparation pour PIRB V2 où chaque joueuse
       pilotera elle-même ce qui est public sur son profil.
       ======================================================== #}
    {% set can_see_full_stats = is_granted('CLUB_STAFF', joueur)
                             or (joueur.user is not null and app.user is not null and joueur.user.id == app.user.id) %}

    {% if not can_see_full_stats %}
        {# Bandeau informatif pour les vues restreintes #}
        <div class="card-mabb" style="margin-bottom:16px; border-left:4px solid var(--mabb-blue);">
            <div class="card-body" style="display:flex; gap:14px; align-items:center; padding:14px 18px;">
                <i class="bi bi-shield-lock" style="color:var(--mabb-blue); font-size:1.4rem; flex-shrink:0;"></i>
                <div style="font-size:.88rem;">
                    <strong>Profil public</strong> — tu vois la fiche d'identité de cette joueuse.
                    <br><small style="color:var(--mabb-muted);">
                        Les stats détaillées et la gamification sont accessibles uniquement au staff
                        et à la joueuse elle-même (RGPD).
                    </small>
                </div>
            </div>
        </div>
    {% endif %}

    <div class="row g-3">
        {# ========================================================
           Colonne gauche : état civil + équipe
           ======================================================== #}
        <div class="col-md-6">
            <div class="card-mabb">
                <div class="card-header"><i class="bi bi-person-vcard"></i> État civil & licence</div>
                <div class="card-body">
                    <table class="table-mabb" style="margin: -20px;">
                        <tbody>
                            <tr>
                                <td style="font-weight: 600; color: var(--mabb-muted); width: 40%;">Prénom</td>
                                <td>{{ joueur.prenom }}</td>
                            </tr>
                            <tr>
                                <td style="font-weight: 600; color: var(--mabb-muted);">Nom</td>
                                <td>{{ joueur.nom }}</td>
                            </tr>
                            <tr>
                                <td style="font-weight: 600; color: var(--mabb-muted);">Date de naissance</td>
                                <td>
                                    {% if joueur.dateNaissance %}
                                        {{ joueur.dateNaissance|date('d/m/Y') }}
                                        {% if age %}<span style="color: var(--mabb-muted);">({{ age }} ans)</span>{% endif %}
                                    {% else %}<span style="color: var(--mabb-muted);">—</span>{% endif %}
                                </td>
                            </tr>
                            <tr>
                                <td style="font-weight: 600; color: var(--mabb-muted);">Licence FFBB</td>
                                <td>
                                    {% if joueur.licence %}
                                        <code style="background: #f1f5f9; padding: 2px 8px; border-radius: 6px;">{{ joueur.licence }}</code>
                                    {% else %}
                                        <span style="color: var(--mabb-muted);">Non renseignée</span>
                                    {% endif %}
                                </td>
                            </tr>
                            <tr>
                                <td style="font-weight: 600; color: var(--mabb-muted);">Compte utilisateur</td>
                                <td>
                                    {% if joueur.user %}
                                        <i class="bi bi-check-circle-fill" style="color:#22c55e;"></i> {{ joueur.user.email }}
                                    {% else %}
                                        <span style="color: var(--mabb-muted);"><i class="bi bi-dash-circle"></i> Pas de compte</span>
                                    {% endif %}
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        {# ========================================================
           Colonne droite : stats — VISIBLE STAFF + SELF UNIQUEMENT (RGPD)
           ======================================================== #}
        {% if can_see_full_stats %}
        <div class="col-md-6">
            <div class="card-mabb">
                <div class="card-header"><i class="bi bi-bar-chart-line"></i> Statistiques de présence</div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-6" style="text-align: center; padding: 12px;">
                            <div style="font-size: 1.6rem; font-weight: 800; color: {{ nb_seances_present > 0 ? '#22c55e' : 'var(--mabb-muted)' }};">
                                {{ nb_seances_present }}<span style="font-size:1rem; color:var(--mabb-muted);">/{{ nb_seances_total }}</span>
                            </div>
                            <div style="color: var(--mabb-muted); font-size: .8rem;">Séances présentes</div>
                        </div>
                        <div class="col-6" style="text-align: center; padding: 12px;">
                            <div style="font-size: 1.6rem; font-weight: 800; color: {{ nb_matchs_present > 0 ? 'var(--mabb-orange)' : 'var(--mabb-muted)' }};">
                                {{ nb_matchs_present }}
                            </div>
                            <div style="color: var(--mabb-muted); font-size: .8rem;">Matchs joués</div>
                        </div>
                        {# Eval moy. saison FIBA — remplace l'ancienne tuile "Moy. points" (réducteur).
                           Couleur conditionnelle pour signaler le niveau global de la joueuse :
                             >= 15 vert (dominant), 5-15 orange (solide), < 5 gris/rouge (raté). #}
                        <div class="col-6" style="text-align: center; padding: 12px;">
                            {% if performances_saison.eval_moyenne is not null %}
                                {% set eval = performances_saison.eval_moyenne %}
                                {% set color = eval >= 15 ? '#16a34a' : (eval >= 5 ? '#f59e0b' : (eval >= 0 ? '#64748b' : '#dc2626')) %}
                                <div style="font-size: 1.6rem; font-weight: 800; color: {{ color }};" title="Eval FIBA moyenne sur {{ performances_saison.nb_matchs }} matchs">
                                    {{ eval }}
                                </div>
                                <div style="color: var(--mabb-muted); font-size: .8rem;">Eval moy. saison</div>
                            {% else %}
                                <div style="font-size: 1.6rem; font-weight: 800; color: var(--mabb-muted);">—</div>
                                <div style="color: var(--mabb-muted); font-size: .8rem;">Eval moy. saison</div>
                            {% endif %}
                        </div>
                        <div class="col-6" style="text-align: center; padding: 12px;">
                            {% if taux_presence is not null %}
                                <div style="font-size: 1.6rem; font-weight: 800; color: {{ taux_presence >= 75 ? '#22c55e' : (taux_presence >= 50 ? '#f59e0b' : 'var(--mabb-red)') }};">
                                    {{ taux_presence }}%
                                </div>
                            {% else %}
                                <div style="font-size: 1.6rem; font-weight: 800; color: var(--mabb-muted);">—</div>
                            {% endif %}
                            <div style="color: var(--mabb-muted); font-size: .8rem;">Taux présence</div>
                        </div>
                    </div>
                    {% if nb_seances_total == 0 %}
                        <p style="text-align: center; color: var(--mabb-muted); font-size: .82rem; margin: 12px 0 0;">
                            <i class="bi bi-info-circle"></i> Les stats apparaîtront dès que des présences seront pointées.
                        </p>
                    {% endif %}
                </div>
            </div>
        </div>
        {% endif %} {# fin can_see_full_stats — Stats de présence #}

        {# ========================================================
           Card NOTES confidentielles — visible uniquement par le staff
           ======================================================== #}
        {% if is_granted('CLUB_STAFF', joueur) %}
            <div class="col-12">
                <div class="card-mabb" style="border-left: 4px solid var(--mabb-orange);">
                    <div class="card-header" style="display:flex; justify-content:space-between; align-items:center;">
                        <span><i class="bi bi-shield-lock"></i> Notes confidentielles (staff uniquement)</span>
                        <small style="color:var(--mabb-muted); font-size:.75rem;">Visible : coachs, staff, dirigeants</small>
                    </div>
                    <div class="card-body">
                        {% if joueur.notes %}
                            <div style="background:#fef9e7; padding:14px 18px; border-radius:8px; white-space:pre-wrap; font-size:.92rem; line-height:1.6; color:var(--mabb-text);">
                                {{ joueur.notes }}
                            </div>
                        {% else %}
                            <p style="color:var(--mabb-muted); margin:0; font-style:italic;">
                                Aucune note. <a href="{{ path('manager_joueur_edit', {id: joueur.id}) }}">Ajouter des notes</a>
                                (allergies, contact urgence, observations coach...).
                            </p>
                        {% endif %}
                    </div>
                </div>
            </div>
        {% endif %}

        {# ========================================================
           Performances Éval FIBA — affiché uniquement si au moins 1 éval saisie.
           Sinon la section reste cachée pour éviter l'effet "page vide".
           VISIBLE STAFF + SELF UNIQUEMENT (RGPD).

           Multi-équipes : si la joueuse joue dans 2+ équipes, un dropdown
           permet de basculer entre "Toutes équipes" et chaque équipe séparément.
           Le filtrage est côté serveur (données pré-calculées), l'affichage
           est géré en JS pur (show/hide des divs) sans rechargement de page.
           ======================================================== #}

        {# Macros réutilisables : tuiles de stats + tableau des derniers matchs.
           Appelées pour la vue globale ET pour chaque vue par équipe.
           path() EST disponible dans les macros Twig (c'est une fonction enregistrée
           via TwigExtension, pas une variable globale — donc pas de problème de scope). #}
        {% macro perfTuiles(perf) %}
            <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap:12px; margin-bottom:20px;">
                {% set evalMoy = perf.eval_moyenne %}
                {% set evalColor = evalMoy is not null
                    ? (evalMoy >= 15 ? '#16a34a' : (evalMoy >= 5 ? '#f59e0b' : (evalMoy >= 0 ? '#64748b' : '#dc2626')))
                    : '#94a3b8' %}
                <div style="background:{{ evalColor }}11; border:1px solid {{ evalColor }}33; padding:14px; border-radius:10px; text-align:center;">
                    <div style="font-size:1.8rem; font-weight:800; color:{{ evalColor }};">{{ evalMoy ?? '—' }}</div>
                    <div style="font-size:.72rem; color:var(--mabb-muted); margin-top:2px;">Eval moy. FIBA</div>
                </div>
                <div style="background:#fff7ed; padding:14px; border-radius:10px; text-align:center;">
                    <div style="font-size:1.8rem; font-weight:800; color:var(--mabb-orange);">{{ perf.points_moyenne ?? '—' }}</div>
                    <div style="font-size:.72rem; color:var(--mabb-muted); margin-top:2px;">Pts / match</div>
                </div>
                <div style="background:#eff6ff; padding:14px; border-radius:10px; text-align:center;">
                    <div style="font-size:1.8rem; font-weight:800; color:#0369a1;">{{ perf.rebonds_moyenne ?? '—' }}</div>
                    <div style="font-size:.72rem; color:var(--mabb-muted); margin-top:2px;">Rebonds / match</div>
                </div>
                <div style="background:#f0fdf4; padding:14px; border-radius:10px; text-align:center;">
                    <div style="font-size:1.8rem; font-weight:800; color:#15803d;">{{ perf.passes_moyenne ?? '—' }}</div>
                    <div style="font-size:.72rem; color:var(--mabb-muted); margin-top:2px;">Passes déc.</div>
                </div>
                <div style="background:#fef3c7; padding:14px; border-radius:10px; text-align:center;">
                    <div style="font-size:1.8rem; font-weight:800; color:#92400e;">
                        {% if perf.pourcentage_tirs is not null %}{{ perf.pourcentage_tirs }}<small style="font-size:1rem;">%</small>{% else %}—{% endif %}
                    </div>
                    <div style="font-size:.72rem; color:var(--mabb-muted); margin-top:2px;">% tirs réussis</div>
                </div>
                <div style="background:#fdf4ff; padding:14px; border-radius:10px; text-align:center; border:1px dashed #d8b4fe;">
                    <div style="font-size:1.8rem; font-weight:800; color:#7c3aed;">{{ perf.meilleure_eval ?? '—' }}</div>
                    <div style="font-size:.72rem; color:var(--mabb-muted); margin-top:2px;">Meilleure éval</div>
                </div>
                {% if perf.nb_matchs_dominants > 0 %}
                    <div style="background:#dcfce7; padding:14px; border-radius:10px; text-align:center;">
                        <div style="font-size:1.8rem; font-weight:800; color:#15803d;">
                            {{ perf.nb_matchs_dominants }}<small style="font-size:1rem; color:var(--mabb-muted);">/{{ perf.nb_matchs }}</small>
                        </div>
                        <div style="font-size:.72rem; color:var(--mabb-muted); margin-top:2px;">🏆 Matchs dominants</div>
                    </div>
                {% endif %}
            </div>
        {% endmacro %}

        {% macro perfTableau(evals) %}
            {% if evals|length > 0 %}
            <h4 style="margin:20px 0 10px; color:var(--mabb-dark); font-size:1rem;">
                <i class="bi bi-clock-history"></i> Derniers matchs évalués
            </h4>
            <div style="overflow-x:auto;">
                <table class="table-mabb" style="width:100%; font-size:.85rem;">
                    <thead>
                        <tr>
                            <th>Date</th><th>Adversaire</th>
                            <th style="text-align:center;">Min</th>
                            <th style="text-align:center;">Pts</th>
                            <th style="text-align:center;">Reb</th>
                            <th style="text-align:center;">PD</th>
                            <th style="text-align:center;">% Tirs</th>
                            <th style="text-align:center; background:rgba(252,112,42,.1);">EVAL</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for ev in evals %}
                            {% set r = ev.rencontre %}
                            {% set sc = ev.eval %}
                            {% set cl = sc >= 15 ? '#16a34a' : (sc >= 5 ? '#f59e0b' : (sc >= 0 ? '#64748b' : '#dc2626')) %}
                            <tr>
                                <td style="font-size:.78rem; white-space:nowrap;">
                                    <a href="{{ path('manager_rencontre_show', {id: r.id}) }}" style="color:var(--mabb-dark); text-decoration:none;">
                                        {{ r.date|date('d/m/Y') }}
                                    </a>
                                </td>
                                <td>
                                    <a href="{{ path('manager_rencontre_show', {id: r.id}) }}" style="color:var(--mabb-dark); text-decoration:none; font-weight:600;">
                                        {{ r.adversaire }}
                                        {% if not r.domicile %}<small style="color:var(--mabb-muted);">(ext.)</small>{% endif %}
                                    </a>
                                    {% if ev.isStarter %}<span title="Titulaire" style="color:var(--mabb-orange);">⭐</span>{% endif %}
                                </td>
                                <td style="text-align:center;">{{ ev.minutesJouees }}</td>
                                <td style="text-align:center; font-weight:600;">{{ ev.points }}</td>
                                <td style="text-align:center;">{{ ev.rebonds }}</td>
                                <td style="text-align:center;">{{ ev.passesDecisives }}</td>
                                <td style="text-align:center;">
                                    {% if ev.pourcentageTirs is not null %}{{ ev.pourcentageTirs }}%{% else %}—{% endif %}
                                </td>
                                <td style="text-align:center; font-weight:800; color:{{ cl }}; background:{{ cl }}0d;">{{ sc }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% endif %}
        {% endmacro %}

        {% if can_see_full_stats and performances_saison.nb_matchs > 0 %}
        <div class="col-12">
            <div class="card-mabb">
                {# === En-tête avec dropdown multi-équipes si besoin === #}
                <div class="card-header" style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:8px;">
                    <span><i class="bi bi-graph-up-arrow" style="color:var(--mabb-blue);"></i> Performances Éval — Saison {{ gamification.saison }}</span>

                    {% if performances_par_equipe|length > 1 %}
                        {# Dropdown équipe — affiche les équipes ayant au moins 1 eval #}
                        <select id="perf-equipe-select"
                                onchange="switchPerfEquipe(this.value)"
                                style="background:#f1f5f9; border:1px solid #cbd5e1; border-radius:20px;
                                       color:var(--mabb-dark); padding:5px 28px 5px 12px; font-size:.8rem;
                                       font-weight:600; cursor:pointer; appearance:none; -webkit-appearance:none;">
                            <option value="all">🏀 Toutes équipes ({{ performances_saison.nb_matchs }} matchs)</option>
                            {% for idx, item in performances_par_equipe %}
                                {% if item.performances.nb_matchs > 0 %}
                                    <option value="{{ idx }}">{{ item.equipe.nom }} ({{ item.performances.nb_matchs }} matchs)</option>
                                {% endif %}
                            {% endfor %}
                        </select>
                    {% else %}
                        <small style="color:var(--mabb-muted); font-weight:500;">
                            {{ performances_saison.nb_matchs }} match{{ performances_saison.nb_matchs > 1 ? 's' : '' }} évalué{{ performances_saison.nb_matchs > 1 ? 's' : '' }}
                        </small>
                    {% endif %}
                </div>

                <div class="card-body">
                    {# === Vue "Toutes équipes" (toujours visible par défaut) === #}
                    <div id="perf-view-all">
                        {{ _self.perfTuiles(performances_saison) }}
                        {{ _self.perfTableau(evaluations_recentes) }}
                    </div>

                    {# === Vues par équipe (cachées, activées par le dropdown) === #}
                    {% if performances_par_equipe|length > 1 %}
                        {% for idx, item in performances_par_equipe %}
                            {% if item.performances.nb_matchs > 0 %}
                            <div id="perf-view-{{ idx }}" style="display:none;">
                                <div style="margin-bottom:12px; padding:6px 12px; background:rgba(0,98,168,.07);
                                            border-left:3px solid var(--mabb-blue); border-radius:0 6px 6px 0;
                                            font-size:.8rem; font-weight:600; color:var(--mabb-blue);">
                                    <i class="bi bi-shield-fill"></i> {{ item.equipe.nom }}
                                    — {{ item.performances.nb_matchs }} match{{ item.performances.nb_matchs > 1 ? 's' : '' }}
                                </div>
                                {{ _self.perfTuiles(item.performances) }}
                                {{ _self.perfTableau(item.evaluations_recentes) }}
                            </div>
                            {% endif %}
                        {% endfor %}
                    {% endif %}

                    {# === Message pédagogique (toujours visible) === #}
                    <p style="margin:16px 0 0; padding:12px 14px; background:#fef9e7; border-left:3px solid #f59e0b; font-size:.78rem; color:#78350f; border-radius:0 6px 6px 0;">
                        <i class="bi bi-lightbulb"></i>
                        <strong>L'éval ne fait pas tout.</strong> Une joueuse peut avoir une éval faible
                        et être ESSENTIELLE pour l'équipe (défense, leadership, énergie). C'est un outil
                        pour discuter, pas pour classer.
                    </p>
                </div>
            </div>
        </div>

        {% if performances_par_equipe|length > 1 %}
        <script>
        function switchPerfEquipe(val) {
            // Cache toutes les vues
            document.querySelectorAll('[id^="perf-view-"]').forEach(function(el) {
                el.style.display = 'none';
            });
            // Affiche la vue sélectionnée
            var target = document.getElementById('perf-view-' + val);
            if (target) target.style.display = '';
        }
        </script>
        {% endif %}
        {% endif %}

        {# ========================================================
           Gamification — XP, niveau, badges (saison courante)
           VISIBLE STAFF + SELF UNIQUEMENT (RGPD).
           ======================================================== #}
        {% if can_see_full_stats %}
        <div class="col-12">
            <div class="card-mabb">
                <div class="card-header" style="display:flex; justify-content:space-between; align-items:center;">
                    <span><i class="bi bi-trophy-fill" style="color:var(--mabb-orange);"></i> Gamification — Saison {{ gamification.saison }}</span>
                    <span style="display:inline-flex; align-items:center; gap:6px; background:{{ gamification.niveau.couleur }}22; color:{{ gamification.niveau.couleur }}; padding:5px 14px; border-radius:14px; font-weight:700;">
                        <i class="bi {{ gamification.niveau.icone }}"></i>
                        Niveau {{ gamification.niveau.niveau }} · {{ gamification.niveau.nom }}
                    </span>
                </div>
                <div class="card-body">
                    {# Bandeau XP + progression #}
                    <div style="display:grid; grid-template-columns: 1fr 2fr; gap:24px; margin-bottom:24px; align-items:center;">
                        <div style="text-align:center;">
                            <div style="font-size:3rem; font-weight:800; color:{{ gamification.niveau.couleur }}; line-height:1;">
                                {{ gamification.xp_saison }}
                            </div>
                            <div style="font-size:.85rem; color:var(--mabb-muted); margin-top:4px;">XP cumulés cette saison</div>
                        </div>
                        <div>
                            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px; font-size:.85rem;">
                                <span style="color:var(--mabb-muted);">Progression vers le niveau suivant</span>
                                <span style="font-weight:700; color:{{ gamification.niveau.couleur }};">{{ gamification.niveau.progres_pct }}%</span>
                            </div>
                            <div style="background:#f1f5f9; height:14px; border-radius:7px; overflow:hidden;">
                                <div style="width:{{ gamification.niveau.progres_pct }}%; height:100%; background:linear-gradient(90deg, {{ gamification.niveau.couleur }}66, {{ gamification.niveau.couleur }}); transition: width .4s;"></div>
                            </div>
                            <div style="font-size:.75rem; color:var(--mabb-muted); margin-top:4px;">
                                {% if gamification.niveau.xp_palier_suivant %}
                                    Encore <strong>{{ gamification.niveau.xp_palier_suivant - gamification.xp_saison }} XP</strong> pour atteindre le niveau {{ gamification.niveau.niveau + 1 }}
                                {% else %}
                                    🏆 Niveau maximum atteint — Légende du club
                                {% endif %}
                            </div>
                        </div>
                    </div>

                    {# Breakdown XP #}
                    <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap:12px; margin-bottom:24px;">
                        <div style="background:#f0f9ff; padding:12px; border-radius:8px; text-align:center;">
                            <div style="font-size:1.5rem; font-weight:700; color:#0369a1;">{{ gamification.details.nb_seances_presentes }}</div>
                            <div style="font-size:.72rem; color:var(--mabb-muted);">Séances présentes</div>
                        </div>
                        <div style="background:#fff7ed; padding:12px; border-radius:8px; text-align:center;">
                            <div style="font-size:1.5rem; font-weight:700; color:var(--mabb-orange);">{{ gamification.details.nb_rencontres_presentes }}</div>
                            <div style="font-size:.72rem; color:var(--mabb-muted);">Rencontres jouées</div>
                        </div>
                        <div style="background:#fef3c7; padding:12px; border-radius:8px; text-align:center;">
                            <div style="font-size:1.5rem; font-weight:700; color:#92400e;">{{ gamification.details.streak_actuel }}</div>
                            <div style="font-size:.72rem; color:var(--mabb-muted);">Série en cours</div>
                        </div>
                        {% if gamification.details.nb_missions is defined and gamification.details.nb_missions > 0 %}
                            <div style="background:#dcfce7; padding:12px; border-radius:8px; text-align:center;">
                                <div style="font-size:1.5rem; font-weight:700; color:#16a34a;">{{ gamification.details.nb_missions }}</div>
                                <div style="font-size:.72rem; color:var(--mabb-muted);">Missions bénévolat (+{{ gamification.details.xp_missions }} XP)</div>
                            </div>
                        {% endif %}
                        {% if gamification.details.nb_seances_absent_excuse > 0 %}
                            <div style="background:#f8fafc; padding:12px; border-radius:8px; text-align:center;">
                                <div style="font-size:1.5rem; font-weight:700; color:#64748b;">{{ gamification.details.nb_seances_absent_excuse }}</div>
                                <div style="font-size:.72rem; color:var(--mabb-muted);">Absences excusées</div>
                            </div>
                        {% endif %}
                        {% if gamification.details.nb_seances_absent_non_excuse > 0 %}
                            <div style="background:#fee2e2; padding:12px; border-radius:8px; text-align:center;">
                                <div style="font-size:1.5rem; font-weight:700; color:#b91c1c;">{{ gamification.details.nb_seances_absent_non_excuse }}</div>
                                <div style="font-size:.72rem; color:var(--mabb-muted);">Absences non excusées</div>
                            </div>
                        {% endif %}
                    </div>

                    {# Badges débloqués #}
                    <h4 style="margin:0 0 12px; color:var(--mabb-dark);">
                        <i class="bi bi-award"></i> Badges débloqués
                        {% if gamification.badges|length > 0 %}
                            <span style="color:var(--mabb-muted); font-weight:500; font-size:.85rem;">({{ gamification.badges|length }})</span>
                        {% endif %}
                    </h4>
                    {% if gamification.badges is empty %}
                        <p style="color:var(--mabb-muted); font-style:italic; margin:0;">
                            Aucun badge encore débloqué cette saison. Le premier vient avec la première séance présente.
                        </p>
                    {% else %}
                        <div style="display:grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap:12px;">
                            {% for b in gamification.badges %}
                                {% set def = gamification.catalog[b.codeBadge] ?? null %}
                                {% if def %}
                                    <div title="{{ def.description }}" style="display:flex; align-items:center; gap:10px; padding:10px 12px; background:#fffbeb; border:1px solid #fcd34d; border-radius:8px;">
                                        <div style="font-size:1.8rem; color:var(--mabb-orange);"><i class="bi {{ def.icone }}"></i></div>
                                        <div style="min-width:0;">
                                            <div style="font-weight:700; color:#92400e; font-size:.85rem;">{{ def.nom }}</div>
                                            <div style="font-size:.7rem; color:var(--mabb-muted);">{{ b.debloqueAt|date('d/m/Y') }}</div>
                                        </div>
                                    </div>
                                {% endif %}
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
        {% endif %} {# fin can_see_full_stats — Gamification #}

        {# ========================================================
           Bloc Bilan saison & profil public — partial réutilisé sur page profil aussi
           is_self : true si le user connecté EST cette joueuse (compte rattaché),
           false si c'est le staff qui regarde une fiche externe.
           ======================================================== #}
        {% include 'manager/_partials/bloc_bilan_profil.html.twig' with {
            joueur: joueur,
            is_self: joueur.user is not null and app.user is not null and joueur.user.id == app.user.id,
            bilan_recent: bilan_recent
        } only %}

        {# ========================================================
           Section "Cotisation licence" — Bureau D.3.2
           RGPD strict (07/06/2026) : visible uniquement pour
             - le joueur lui-même (is_self)
             - trésorier du club (is_tresorier)
             - dirigeant du club (CLUB_ADMIN)
             - staff/coach du club (CLUB_STAFF)
           Un membre lambda (CLUB_MEMBER simple) ne doit JAMAIS voir la
           cotisation d'une autre joueuse — info financière sensible.
           ======================================================== #}
        {% if is_self or is_tresorier or is_granted('CLUB_ADMIN', club) or is_granted('CLUB_STAFF', club) %}
            {% include 'manager/joueur/_cotisation_section.html.twig' with {
                joueur:       joueur,
                cotisation:   cotisation_courante,
                is_self:      is_self,
                is_tresorier: is_tresorier
            } only %}
        {% endif %}

        {# ========================================================
           V1.6.1 — Section "Affectations équipes" (multi-équipes)
           Visible CLUB_STAFF. Affiche l'équipe principale + tous les
           surclassements / doublages / réserves. Permet d'en ajouter
           ou retirer via formulaire CSRF.
           ======================================================== #}
        {% if is_granted('CLUB_STAFF', joueur) %}
        <div class="card-mabb" style="margin-top:16px;">
            <div class="card-header" style="display:flex; justify-content:space-between; align-items:center;">
                <span><i class="bi bi-diagram-3"></i> Affectations équipes</span>
                <span style="color:var(--mabb-muted); font-size:.78rem;">
                    {{ joueur.affectations|length }} affectation{{ joueur.affectations|length > 1 ? 's' : '' }}
                </span>
            </div>
            <div class="card-body">

                {# === Liste des affectations actuelles === #}
                {% if joueur.affectations|length > 0 %}
                    <div style="display:flex; flex-direction:column; gap:8px; margin-bottom:14px;">
                        {% for aff in joueur.affectations %}
                            {% set couleur = type_couleurs[aff.type] ?? 'gray' %}
                            {% set badge_bg = {
                                'blue':   'rgba(59,130,246,.12)',
                                'orange': 'rgba(234,88,12,.12)',
                                'purple': 'rgba(168,85,247,.12)',
                                'green':  'rgba(22,163,74,.12)',
                                'gray':   'rgba(148,163,184,.12)'
                            }[couleur] %}
                            {% set badge_color = {
                                'blue':   '#3b82f6',
                                'orange': '#ea580c',
                                'purple': '#a855f7',
                                'green':  '#16a34a',
                                'gray':   '#64748b'
                            }[couleur] %}
                            <div style="display:flex; align-items:center; gap:12px; padding:10px 12px; background:#f8fafc; border:1px solid var(--mabb-border, #e2e8f0); border-radius:10px;">
                                <span style="background:{{ badge_bg }}; color:{{ badge_color }}; padding:3px 10px; border-radius:999px; font-size:.72rem; font-weight:700; text-transform:uppercase; letter-spacing:.04em; white-space:nowrap;">
                                    {{ type_labels[aff.type] ?? aff.type }}
                                </span>
                                <div style="flex:1;">
                                    <div style="font-weight:700;">{{ aff.equipe.nom }}</div>
                                    <div style="color:var(--mabb-muted); font-size:.78rem;">
                                        Saison {{ aff.saison }}
                                        {% if not aff.actif %}<span style="color:#ef4444;">• inactive</span>{% endif %}
                                        {% if aff.notes %}<br><em>{{ aff.notes }}</em>{% endif %}
                                    </div>
                                </div>
                                {% if not aff.isPrincipale %}
                                    <form method="post"
                                          action="{{ path('manager_joueur_affectation_remove', {id: joueur.id, affId: aff.id}) }}"
                                          onsubmit="return confirm('Retirer cette affectation ?');"
                                          style="margin:0;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('remove_affectation_' ~ aff.id) }}">
                                        <button type="submit" class="btn-mabb btn-ghost" style="padding:4px 10px; font-size:.78rem;" title="Retirer cette affectation">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </form>
                                {% else %}
                                    <span style="color:var(--mabb-muted); font-size:.7rem; font-style:italic;">verrouillée</span>
                                {% endif %}
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div style="padding:14px; background:#fff7ed; border-left:3px solid #ea580c; border-radius:6px; margin-bottom:14px; color:#9a3412; font-size:.85rem;">
                        ⚠️ Aucune affectation. Si la joueuse a une équipe principale, elle devrait apparaître automatiquement (auto-créée par la migration V1.6).
                    </div>
                {% endif %}

                {# === Formulaire d'ajout d'affectation === #}
                {% if equipes_disponibles|length > 0 %}
                    <details style="margin-top:10px;">
                        <summary style="cursor:pointer; font-weight:700; color:var(--mabb-accent, #ea580c); padding:8px 0;">
                            <i class="bi bi-plus-circle"></i> Ajouter une affectation (surclassement / doublage / réserve)
                        </summary>
                        <form method="post"
                              action="{{ path('manager_joueur_affectation_add', {id: joueur.id}) }}"
                              style="margin-top:12px; padding:14px; background:#f8fafc; border-radius:10px;">
                            <input type="hidden" name="_token" value="{{ csrf_token('add_affectation_joueur_' ~ joueur.id) }}">

                            <div style="display:flex; flex-direction:column; gap:10px;">

                                <div>
                                    <label for="aff_type" style="display:block; font-size:.78rem; font-weight:700; color:var(--mabb-muted); margin-bottom:4px;">Type d'affectation</label>
                                    <select name="type" id="aff_type" required class="form-control"
                                            style="width:100%; padding:8px; border:1px solid var(--mabb-border, #e2e8f0); border-radius:6px;">
                                        <option value="">— Choisir un type —</option>
                                        {% for code, label in types_affectation_disponibles %}
                                            <option value="{{ code }}">{{ label }}</option>
                                        {% endfor %}
                                    </select>
                                </div>

                                <div>
                                    <label for="aff_equipe" style="display:block; font-size:.78rem; font-weight:700; color:var(--mabb-muted); margin-bottom:4px;">Équipe</label>
                                    <select name="equipe_id" id="aff_equipe" required class="form-control"
                                            style="width:100%; padding:8px; border:1px solid var(--mabb-border, #e2e8f0); border-radius:6px;">
                                        <option value="">— Choisir une équipe —</option>
                                        {% for e in equipes_disponibles %}
                                            <option value="{{ e.id }}">
                                                {{ e.nom }}
                                                {% if e.categorie %}({{ e.categorie }}{% if e.niveau %} — {{ e.niveau }}{% endif %}){% endif %}
                                            </option>
                                        {% endfor %}
                                    </select>
                                </div>

                                <div>
                                    <label for="aff_saison" style="display:block; font-size:.78rem; font-weight:700; color:var(--mabb-muted); margin-bottom:4px;">Saison</label>
                                    <input type="text" name="saison" id="aff_saison" required
                                           value="{{ saison_courante }}" pattern="\d{4}-\d{4}"
                                           class="form-control"
                                           style="width:100%; padding:8px; border:1px solid var(--mabb-border, #e2e8f0); border-radius:6px;">
                                </div>

                                <div>
                                    <label for="aff_notes" style="display:block; font-size:.78rem; font-weight:700; color:var(--mabb-muted); margin-bottom:4px;">Notes (optionnel)</label>
                                    <textarea name="notes" id="aff_notes" rows="2"
                                              placeholder="Ex : autorisé pour les matchs à domicile uniquement, jusqu'à fin saison régulière..."
                                              class="form-control"
                                              style="width:100%; padding:8px; border:1px solid var(--mabb-border, #e2e8f0); border-radius:6px; resize:vertical;"></textarea>
                                </div>

                                <div style="display:flex; justify-content:flex-end;">
                                    <button type="submit" class="btn-mabb btn-primary">
                                        <i class="bi bi-check-lg"></i> Ajouter l'affectation
                                    </button>
                                </div>

                            </div>
                        </form>
                    </details>
                {% else %}
                    <div style="padding:10px; background:#f1f5f9; border-radius:6px; color:var(--mabb-muted); font-size:.85rem;">
                        Aucune autre équipe disponible (la joueuse est déjà affectée à toutes les équipes du club, ou il n'y en a qu'une).
                    </div>
                {% endif %}

            </div>
        </div>
        {% endif %}

        {# ========================================================
           V1.4a — Section "Compte PIRB lié"
           Visible CLUB_STAFF (DIRIGEANT + COACH + STAFF).
           Permet de lier un User PIRB existant à cette fiche Joueur.
           ======================================================== #}
        {% if is_granted('CLUB_STAFF', joueur) %}
        <div class="card-mabb" style="margin-top:16px;">
            <div class="card-header" style="display:flex; justify-content:space-between; align-items:center;">
                <span><i class="bi bi-person-vcard"></i> Compte PIRB</span>
                {% if joueur.user %}
                    <span class="pirb-badge" style="background:rgba(22,163,74,.15); color:#16a34a; padding:3px 10px; border-radius:999px; font-size:.72rem; font-weight:700;">
                        <i class="bi bi-check-circle-fill"></i> Lié
                    </span>
                {% else %}
                    <span style="color:var(--mabb-muted); font-size:.78rem;">Non lié</span>
                {% endif %}
            </div>
            <div class="card-body">

                {% if joueur.user %}
                    {# === User déjà lié : affichage + bouton délier === #}
                    <div style="display:flex; align-items:center; gap:14px; padding:10px; background:#f8fafc; border-radius:10px; margin-bottom:12px;">
                        <div style="width:50px; height:50px; border-radius:50%; background:linear-gradient(135deg, var(--mabb-blue), var(--mabb-dark)); color:#fff; display:flex; align-items:center; justify-content:center; font-weight:800; font-size:1.2rem;">
                            {{ joueur.user.prenom|first|upper }}{{ joueur.user.nom|first|upper }}
                        </div>
                        <div style="flex:1;">
                            <div style="font-weight:700;">{{ joueur.user.prenom }} {{ joueur.user.nom }}</div>
                            <div style="color:var(--mabb-muted); font-size:.85rem;">{{ joueur.user.email }}</div>
                        </div>
                        <a href="{{ url('pirb_joueuse_public', {id: joueur.id}) }}"
                           target="_blank" rel="noopener"
                           class="btn-mabb-ghost btn-sm">
                            <i class="bi bi-box-arrow-up-right"></i> Voir PIRB
                        </a>
                    </div>
                    <form method="POST" action="{{ path('manager_joueur_unlink_user', {id: joueur.id}) }}"
                          onsubmit="return confirm('Délier le compte PIRB de cette joueuse ? Le user existant ne sera pas supprimé, juste désassocié.');"
                          style="display:flex; justify-content:flex-end;">
                        <input type="hidden" name="_token" value="{{ csrf_token('unlink_user_joueur_' ~ joueur.id) }}">
                        <button type="submit" class="btn-mabb-ghost btn-sm" style="color:var(--mabb-red); border-color:var(--mabb-red);">
                            <i class="bi bi-unlink"></i> Délier
                        </button>
                    </form>

                {% else %}
                    {# === Pas lié : recherche + liste candidats === #}
                    <p style="margin:0 0 14px 0; color:var(--mabb-muted); font-size:.85rem;">
                        Lie un compte PIRB à cette fiche pour que la joueuse retrouve ses stats, photo et profil sur <strong>pirb.mabb.fr</strong>.
                    </p>

                    {# Recherche libre #}
                    <form method="GET" action="{{ path('manager_joueur_show', {id: joueur.id}) }}" style="margin-bottom:12px;">
                        <div style="display:flex; gap:8px;">
                            <input type="text" name="q_user" value="{{ recherche_user|default('') }}"
                                   placeholder="Rechercher par nom, prénom, email..."
                                   style="flex:1; padding:8px 12px; border:1px solid #d1d5db; border-radius:8px; font-size:.9rem;">
                            <button type="submit" class="btn-mabb-primary btn-sm">
                                <i class="bi bi-search"></i> Rechercher
                            </button>
                        </div>
                    </form>

                    {% if candidats_link_user is empty %}
                        <p style="text-align:center; color:var(--mabb-muted); font-size:.85rem; padding:20px;">
                            {% if recherche_user %}
                                Aucun user trouvé pour "<strong>{{ recherche_user }}</strong>".
                            {% else %}
                                Aucun user disponible. Tous les users du club sont déjà liés ou il n'y a pas encore d'inscrit.
                            {% endif %}
                        </p>
                    {% else %}
                        <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:8px;">
                            {% for c in candidats_link_user %}
                                {% set u = c.user %}
                                <form method="POST" action="{{ path('manager_joueur_link_user', {id: joueur.id}) }}"
                                      style="display:flex; align-items:center; gap:10px; padding:10px 12px;
                                             background:{{ c.score >= 100 ? '#fef3c7' : (c.score >= 30 ? '#f0f9ff' : '#fff') }};
                                             border:1px solid {{ c.score >= 100 ? '#fbbf24' : '#e5e7eb' }};
                                             border-radius:8px;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('link_user_joueur_' ~ joueur.id) }}">
                                    <input type="hidden" name="user_id" value="{{ u.id }}">

                                    <div style="width:36px; height:36px; border-radius:50%; background:linear-gradient(135deg, var(--mabb-blue), var(--mabb-dark)); color:#fff; display:flex; align-items:center; justify-content:center; font-weight:800; font-size:.85rem; flex-shrink:0;">
                                        {{ u.prenom|first|upper }}{{ u.nom|first|upper }}
                                    </div>
                                    <div style="flex:1; min-width:0;">
                                        <div style="font-weight:700; font-size:.88rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                                            {{ u.prenom }} {{ u.nom }}
                                            {% if c.score >= 100 %}<span title="Email match" style="color:#d97706; font-size:.75rem;">⭐ Suggéré</span>{% endif %}
                                            {% if c.score >= 30 and c.score < 100 %}<span title="Nom/prénom match" style="color:#0284c7; font-size:.7rem;">Possible</span>{% endif %}
                                        </div>
                                        <div style="color:var(--mabb-muted); font-size:.75rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">{{ u.email }}</div>
                                    </div>
                                    <button type="submit" class="btn-mabb-primary btn-sm" style="flex-shrink:0;"
                                            onclick="return confirm('Lier {{ u.prenom }} {{ u.nom }} à la fiche de {{ joueur.nomComplet }} ?');">
                                        <i class="bi bi-link-45deg"></i> Lier
                                    </button>
                                </form>
                            {% endfor %}
                        </div>

                        <p style="margin:14px 0 0 0; color:var(--mabb-muted); font-size:.72rem; text-align:center;">
                            <i class="bi bi-info-circle"></i> Suggestions classées par pertinence (email match d'abord, puis nom/prénom).
                        </p>
                    {% endif %}

                {% endif %}
            </div>
        </div>
        {% endif %}

        {# ========================================================
           Section "Parents / Tuteurs liés"
           Visible CLUB_STAFF uniquement.
           Affiche les liens ParentJoueur actifs/pending pour cette joueuse.
           ======================================================== #}
        {% if is_granted('CLUB_STAFF', joueur) %}
        <div class="card-mabb" style="margin-top:16px;">
            <div class="card-header" style="display:flex; justify-content:space-between; align-items:center;">
                <span><i class="bi bi-people-fill"></i> Parents / Tuteurs liés</span>
                <span style="color:var(--mabb-muted); font-size:.78rem;">
                    {% set nb_actifs = parent_joueurs|filter(p => p.statut == 'active')|length %}
                    {{ nb_actifs }} actif{{ nb_actifs != 1 ? 's' : '' }}
                </span>
            </div>
            <div class="card-body">

                {% if parent_joueurs is empty %}
                    <p style="color:var(--mabb-muted); font-size:.85rem; text-align:center; padding:16px 0; margin:0;">
                        <i class="bi bi-person-x" style="font-size:1.6rem; display:block; margin-bottom:8px;"></i>
                        Aucun parent/tuteur lié à cette joueuse.
                    </p>
                {% else %}
                    {% set statut_labels = {active: 'Actif', pending: 'En attente', rejected: 'Refusé'} %}
                    {% set statut_colors = {active: '#16a34a', pending: '#d97706', rejected: '#dc2626'} %}
                    {% set statut_bg    = {active: 'rgba(22,163,74,.08)', pending: 'rgba(217,119,6,.08)', rejected: 'rgba(220,38,38,.06)'} %}

                    <div style="display:flex; flex-direction:column; gap:8px; margin-bottom:14px;">
                        {% for pj in parent_joueurs %}
                            <div style="display:flex; align-items:center; gap:12px; padding:10px 14px;
                                        background:{{ statut_bg[pj.statut] ?? '#f8fafc' }};
                                        border:1px solid {{ statut_colors[pj.statut] ?? '#e5e7eb' }}33;
                                        border-radius:10px;">
                                <div style="width:38px; height:38px; border-radius:50%; background:linear-gradient(135deg, #7c3aed, #2563eb); color:#fff; display:flex; align-items:center; justify-content:center; font-weight:800; font-size:.9rem; flex-shrink:0;">
                                    {{ pj.parentUser.prenom|first|upper }}{{ pj.parentUser.nom|first|upper }}
                                </div>
                                <div style="flex:1;">
                                    <div style="font-weight:700; font-size:.92rem;">{{ pj.parentUser.prenom }} {{ pj.parentUser.nom }}</div>
                                    <div style="color:var(--mabb-muted); font-size:.78rem;">{{ pj.parentUser.email }}</div>
                                </div>
                                <span style="background:{{ statut_bg[pj.statut] ?? '#f1f5f9' }}; color:{{ statut_colors[pj.statut] ?? '#64748b' }}; border:1px solid {{ statut_colors[pj.statut] ?? '#cbd5e1' }}44; padding:3px 10px; border-radius:999px; font-size:.72rem; font-weight:700; white-space:nowrap;">
                                    {{ statut_labels[pj.statut] ?? pj.statut }}
                                </span>
                                {% if pj.statut == 'pending' %}
                                    {# Boutons valider/refuser (raccourci depuis la fiche joueuse) #}
                                    <a href="{{ path('manager_parents_enfants_index') }}"
                                       class="btn-mabb-ghost btn-sm" style="font-size:.78rem; white-space:nowrap;">
                                        <i class="bi bi-arrow-right-circle"></i> Gérer
                                    </a>
                                {% endif %}
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}

                {# Bouton "Ajouter un parent" → redirige vers la route dédiée #}
                <div style="border-top:1px solid #e5e7eb; padding-top:12px; text-align:center;">
                    <a href="{{ path('manager_parents_enfants_lier_staff', {joueurId: joueur.id}) }}"
                       class="btn-mabb-ghost btn-sm">
                        <i class="bi bi-person-plus"></i> Lier un parent à cette joueuse
                    </a>
                    <p style="margin:6px 0 0 0; color:var(--mabb-muted); font-size:.75rem;">
                        Les parents liés peuvent voir les stats et présences de leur enfant sur PIRB.
                    </p>
                </div>

            </div>
        </div>
        {% endif %}

    </div>
{% endblock %}
