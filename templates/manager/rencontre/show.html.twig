{% extends 'manager/base.html.twig' %}

{% block title %}{{ rencontre.equipe.nom }} vs {{ rencontre.adversaire }}{% endblock %}

{% block body %}
    <div class="page-header">
        <div>
            <h1>
                {% if rencontre.domicile %}
                    {{ rencontre.equipe.nom }} <span style="color:var(--mabb-muted);">vs</span> {{ rencontre.adversaire }}
                {% else %}
                    {{ rencontre.adversaire }} <span style="color:var(--mabb-muted);">vs</span> {{ rencontre.equipe.nom }}
                {% endif %}
            </h1>
            <p class="subtitle">
                <strong>{{ rencontre.date|date('l d F Y, H:i', 'Europe/Paris')|capitalize }}</strong>
                {% if rencontre.lieu %} — {{ rencontre.lieu }}{% endif %}
                — {{ rencontre.domicile ? 'À domicile' : 'À l\'extérieur' }}
            </p>
        </div>
        <div style="display:flex; gap:8px;">
            <a href="{{ path('manager_rencontre_index') }}" class="btn-mabb-ghost">
                <i class="bi bi-arrow-left"></i> Toutes les rencontres
            </a>
            {# 2 modes de saisie disponibles pour le staff :
                 - "Stats LIVE" : saisie temps réel pendant le match (façon Easy Stats)
                 - "Saisir les évals" : saisie rapide post-match en remplissant les compteurs FIBA
               Les 2 cohabitent : selon que la table de marque a noté ou pas. #}
            {% if is_granted('CLUB_STAFF', rencontre) %}
                {# [V2.2] Bouton "Joueuse rapide" — affiché pour rencontres non-officielles #}
                {% if rencontre.isNonOfficielle() %}
                    <button type="button" id="btn-ouvrir-jr"
                            style="display:inline-flex;align-items:center;gap:6px;padding:8px 14px;
                                   background:rgba(234,88,12,.15);border:1px solid rgba(234,88,12,.4);
                                   color:#ea580c;border-radius:8px;font-weight:700;font-size:.85rem;cursor:pointer;"
                            title="Ajouter une joueuse rapide (recrutement, open gym, adversaire)">
                        ⚡ Joueuse rapide
                    </button>
                {% endif %}
                {% if rencontre.accepteStatsLive() %}
                <a href="{{ path('manager_rencontre_stats_live', {id: rencontre.id}) }}"
                   class="btn-mabb-primary"
                   title="Saisie live pendant le match (tablette / table de marque)">
                    <i class="bi bi-broadcast"></i> Stats LIVE
                </a>
                {% endif %}
                {# V2.1d — Lien vers la page de gestion des sessions de saisie #}
                <a href="{{ path('manager_rencontre_sessions', {id: rencontre.id}) }}"
                   class="btn-mabb-ghost"
                   title="Voir les sessions de saisie et promouvoir l'officielle">
                    <i class="bi bi-collection"></i> Sessions
                </a>
                <a href="{{ path('manager_rencontre_evals', {id: rencontre.id}) }}"
                   class="btn-mabb-orange"
                   title="Saisie rapide des compteurs FIBA après le match">
                    <i class="bi bi-clipboard-data"></i> Saisir les évals
                </a>
            {% endif %}
            {# Bouton Staff — visible pour tous les membres (chacun peut voir et s'inscrire) #}
            <a href="{{ path('manager_rencontre_staff_show', {id: rencontre.id}) }}" class="btn-mabb-ghost">
                <i class="bi bi-person-badge"></i> Staff
            </a>

            {% if is_granted('CLUB_STAFF', rencontre) and not rencontre.isVerrouillee %}
                <a href="{{ path('manager_rencontre_edit', {id: rencontre.id}) }}" class="btn-mabb-primary">
                    <i class="bi bi-pencil"></i> Modifier
                </a>
            {% endif %}

            {# === V2.1c — Archiver / Désarchiver === #}
            {% if is_granted('CLUB_STAFF', rencontre) %}
                {% if rencontre.isArchivee %}
                    <form method="POST" action="{{ path('manager_rencontre_desarchiver', {id: rencontre.id}) }}" style="display:inline;">
                        <input type="hidden" name="_token" value="{{ csrf_token('desarchiver_rencontre_' ~ rencontre.id) }}">
                        <button type="submit" class="btn-mabb-ghost" title="Sortir des archives">
                            <i class="bi bi-arrow-counterclockwise"></i> Désarchiver
                        </button>
                    </form>
                {% else %}
                    <form method="POST" action="{{ path('manager_rencontre_archiver', {id: rencontre.id}) }}" style="display:inline;"
                          onsubmit="return confirm('Archiver cette rencontre ? Elle sera masquée des listes par défaut mais restera accessible via le filtre.');">
                        <input type="hidden" name="_token" value="{{ csrf_token('archiver_rencontre_' ~ rencontre.id) }}">
                        <button type="submit" class="btn-mabb-ghost" title="Archiver la rencontre">
                            <i class="bi bi-archive"></i> Archiver
                        </button>
                    </form>
                {% endif %}
            {% endif %}

            {# === V2.1c — Suppression définitive (DIRIGEANT only) === #}
            {% if is_granted('CLUB_ADMIN', rencontre) %}
                <form method="POST" action="{{ path('manager_rencontre_delete', {id: rencontre.id}) }}" style="display:inline;"
                      onsubmit="return confirm('⚠️ Supprimer définitivement cette rencontre ?\n\nCette action est IRRÉVERSIBLE. Toutes les stats, présences, évaluations associées seront perdues.\n\nPréfère l\'archivage si tu veux juste la masquer.');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_rencontre_' ~ rencontre.id) }}">
                    <button type="submit" class="btn-mabb-ghost" style="color:#dc2626; border-color:#fecaca;" title="Supprimer définitivement (irréversible)">
                        <i class="bi bi-trash"></i> Supprimer
                    </button>
                </form>
            {% endif %}
        </div>
    </div>

    {# === Badge "ARCHIVÉE" en bandeau si applicable === #}
    {% if rencontre.isArchivee %}
        <div style="background:#f3f4f6; border-left:4px solid #6b7280; padding:12px 16px; border-radius:8px; margin-bottom:16px; display:flex; align-items:center; gap:10px;">
            <i class="bi bi-archive-fill" style="color:#6b7280; font-size:1.2rem;"></i>
            <div style="flex:1;">
                <strong style="color:#374151;">Rencontre archivée</strong>
                <div style="font-size:.82rem; color:#6b7280;">Masquée des listes par défaut. Cliquer "Désarchiver" pour la remettre en circulation.</div>
            </div>
        </div>
    {% endif %}

    {# ========================================================
       Carte SCORE en gros — la donnée la plus importante
       ======================================================== #}
    <div class="card-mabb" style="margin-bottom:16px;">
        <div class="card-body" style="text-align:center; padding:30px 20px;">
            {% if rencontre.aResultat %}
                <div style="font-size:3rem; font-weight:800; color:var(--mabb-dark);">
                    <span style="color: {{ rencontre.scoreEquipe > rencontre.scoreAdverse ? '#166534' : (rencontre.scoreEquipe < rencontre.scoreAdverse ? '#991b1b' : 'var(--mabb-dark)') }};">
                        {{ rencontre.scoreEquipe }}
                    </span>
                    <span style="color:var(--mabb-muted);">-</span>
                    <span style="color: {{ rencontre.scoreAdverse > rencontre.scoreEquipe ? '#166534' : (rencontre.scoreAdverse < rencontre.scoreEquipe ? '#991b1b' : 'var(--mabb-dark)') }};">
                        {{ rencontre.scoreAdverse }}
                    </span>
                </div>
                <div style="font-size:.95rem; color:var(--mabb-muted); margin-top:8px;">
                    {{ rencontre.equipe.nom }} — {{ rencontre.adversaire }}
                </div>
                {% if rencontre.scoreEquipe > rencontre.scoreAdverse %}
                    <div style="color:#166534; font-weight:700; margin-top:12px; font-size:1.1rem;">
                        <i class="bi bi-trophy-fill"></i> Victoire de +{{ rencontre.scoreEquipe - rencontre.scoreAdverse }}
                    </div>
                {% elseif rencontre.scoreEquipe < rencontre.scoreAdverse %}
                    <div style="color:#991b1b; font-weight:700; margin-top:12px; font-size:1.1rem;">
                        Défaite de -{{ rencontre.scoreAdverse - rencontre.scoreEquipe }}
                    </div>
                {% else %}
                    <div style="color:var(--mabb-muted); font-weight:700; margin-top:12px; font-size:1.1rem;">Match nul</div>
                {% endif %}
            {% else %}
                <div style="color:var(--mabb-muted); font-style:italic;">
                    <i class="bi bi-hourglass-split" style="font-size:2rem; display:block; margin-bottom:8px;"></i>
                    Score non saisi. Modifie la rencontre pour entrer le résultat.
                </div>
            {% endif %}
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-7">
            <div class="card-mabb">
                <div class="card-header"><i class="bi bi-info-circle"></i> Informations</div>
                <div class="card-body">
                    <table class="table-mabb" style="margin:-20px;">
                        <tbody>
                            <tr><td style="font-weight:600; color:var(--mabb-muted); width:35%;">Équipe</td><td>{{ rencontre.equipe.nom }} ({{ rencontre.equipe.categorie }})</td></tr>
                            <tr><td style="font-weight:600; color:var(--mabb-muted);">Adversaire</td><td>{{ rencontre.adversaire }}</td></tr>
                            <tr><td style="font-weight:600; color:var(--mabb-muted);">Date & heure</td><td>{{ rencontre.date|date('d/m/Y H:i') }}</td></tr>
                            <tr><td style="font-weight:600; color:var(--mabb-muted);">Lieu</td><td>{{ rencontre.lieu ?: '—' }}</td></tr>
                            <tr><td style="font-weight:600; color:var(--mabb-muted);">Match</td><td>{{ rencontre.domicile ? 'À domicile' : 'À l\'extérieur' }}</td></tr>
                            <tr>
                                <td style="font-weight:600; color:var(--mabb-muted);">Statut</td>
                                <td>
                                    {% if rencontre.statut == 'brouillon' %}
                                        <span style="background:#fef3e2; color:#d97706; padding:3px 10px; border-radius:12px; font-size:.8rem; font-weight:600;">Brouillon</span>
                                    {% elseif rencontre.statut == 'valide' %}
                                        <span class="badge-active"><i class="bi bi-check-circle"></i> Validée</span>
                                    {% elseif rencontre.statut == 'verrouille' %}
                                        <span style="background:#ddd6fe; color:#5b21b6; padding:3px 10px; border-radius:12px; font-size:.8rem; font-weight:600;"><i class="bi bi-lock-fill"></i> Verrouillée</span>
                                    {% endif %}
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            {% if rencontre.notes %}
                <div class="card-mabb" style="margin-top:16px;">
                    <div class="card-header"><i class="bi bi-card-text"></i> Notes</div>
                    <div class="card-body">
                        <p style="margin:0; white-space:pre-wrap;">{{ rencontre.notes }}</p>
                    </div>
                </div>
            {% endif %}
        </div>

        <div class="col-md-5">
            {# Workflow statut — boutons selon le statut courant #}
            <div class="card-mabb">
                <div class="card-header"><i class="bi bi-shield-check"></i> Workflow feuille de match</div>
                <div class="card-body">
                    <p style="font-size:.85rem; color:var(--mabb-muted);">
                        {% if rencontre.statut == 'brouillon' %}
                            La rencontre est en brouillon. Une fois le score saisi, valide pour officialiser.
                        {% elseif rencontre.statut == 'valide' %}
                            La rencontre est validée. Un dirigeant peut la verrouiller pour empêcher toute modification ultérieure.
                        {% elseif rencontre.statut == 'verrouille' %}
                            La rencontre est verrouillée. Seul un dirigeant peut la déverrouiller.
                        {% endif %}
                    </p>

                    {# Action : passer de brouillon à validé #}
                    {% if rencontre.statut == 'brouillon' and is_granted('CLUB_STAFF', rencontre) %}
                        <form method="post" action="{{ path('manager_rencontre_statut', {id: rencontre.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('statut_rencontre_' ~ rencontre.id) }}">
                            <input type="hidden" name="action" value="valider">
                            <button type="submit" class="btn-mabb-primary" style="width:100%;">
                                <i class="bi bi-check-circle"></i> Valider la rencontre
                            </button>
                        </form>
                    {% endif %}

                    {# Action : passer de validé à verrouillé (admin only) #}
                    {% if rencontre.statut == 'valide' and is_granted('CLUB_ADMIN', rencontre) %}
                        <form method="post" action="{{ path('manager_rencontre_statut', {id: rencontre.id}) }}" onsubmit="return confirm('Verrouiller la rencontre ? Plus aucune modification ne sera possible sauf déverrouillage par un dirigeant.');">
                            <input type="hidden" name="_token" value="{{ csrf_token('statut_rencontre_' ~ rencontre.id) }}">
                            <input type="hidden" name="action" value="verrouiller">
                            <button type="submit" class="btn-mabb-primary" style="width:100%;">
                                <i class="bi bi-lock"></i> Verrouiller la feuille
                            </button>
                        </form>
                    {% endif %}

                    {# Action : dever (admin only) #}
                    {% if rencontre.statut == 'verrouille' and is_granted('CLUB_ADMIN', rencontre) %}
                        <form method="post" action="{{ path('manager_rencontre_statut', {id: rencontre.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('statut_rencontre_' ~ rencontre.id) }}">
                            <input type="hidden" name="action" value="dever">
                            <button type="submit" class="btn-mabb-ghost" style="width:100%;">
                                <i class="bi bi-unlock"></i> Déverrouiller
                            </button>
                        </form>
                    {% endif %}
                </div>
            </div>

            {# Card Présences (joueuses ayant joué) #}
            <div class="card-mabb" style="margin-top:16px;">
                <div class="card-header" style="display:flex; justify-content:space-between; align-items:center;">
                    <span><i class="bi bi-clipboard-check"></i> Présences au match</span>
                    {% if is_granted('CLUB_STAFF', rencontre) %}
                        <a href="{{ path('manager_presence_rencontre', {id: rencontre.id}) }}" class="btn-mabb-orange btn-sm">
                            <i class="bi bi-pencil-square"></i> Faire le pointage
                        </a>
                    {% endif %}
                </div>
                <div class="card-body">
                    {% set presences = rencontre.presences %}
                    {% if presences|length == 0 %}
                        <p style="color:var(--mabb-muted); margin:0; font-size:.9rem; text-align:center; padding:14px 0;">
                            <i class="bi bi-hourglass"></i> Aucun pointage saisi pour cette rencontre.
                        </p>
                    {% else %}
                        {% set nb_present = 0 %}{% set nb_absent = 0 %}
                        {% for p in presences %}
                            {% if p.isPresent %}{% set nb_present = nb_present + 1 %}{% else %}{% set nb_absent = nb_absent + 1 %}{% endif %}
                        {% endfor %}
                        <div style="display:flex; gap:18px; justify-content:center; padding:6px 0 12px;">
                            <div style="text-align:center;">
                                <div style="font-size:1.4rem; font-weight:800; color:#22c55e;">{{ nb_present }}</div>
                                <div style="font-size:.7rem; color:var(--mabb-muted); text-transform:uppercase;">Ont joué</div>
                            </div>
                            <div style="text-align:center;">
                                <div style="font-size:1.4rem; font-weight:800; color:var(--mabb-red);">{{ nb_absent }}</div>
                                <div style="font-size:.7rem; color:var(--mabb-muted); text-transform:uppercase;">Absentes</div>
                            </div>
                        </div>
                        <div style="max-height:220px; overflow-y:auto; font-size:.85rem;">
                            {% for p in presences %}
                                <div style="padding:5px 2px; border-bottom:1px dashed #e2e8f0; display:flex; justify-content:space-between; align-items:center;">
                                    <span>{{ p.joueur.prenom }} {{ p.joueur.nom }}{% if p.motifAbsence %} <small style="color:var(--mabb-muted);">({{ p.motifAbsence }})</small>{% endif %}</span>
                                    {% if p.isPresent %}
                                        <span style="color:#22c55e;"><i class="bi bi-check-circle-fill"></i></span>
                                    {% else %}
                                        <span style="color:var(--mabb-red);"><i class="bi bi-x-circle-fill"></i></span>
                                    {% endif %}
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
            </div>

            {# ===== Officiels du match (arbitres, marqueur, chrono, etc.) ===== #}
            <div class="card-mabb" style="margin-top:16px;">
                <div class="card-header">
                    <i class="bi bi-people-fill"></i> Officiels du match
                </div>
                <div class="card-body" style="padding:8px 16px 16px;">
                    {% if rencontre.arbitreExterneDesigne %}
                        <div style="background:#eff6ff; border-left:4px solid var(--mabb-blue); padding:10px 14px; border-radius:6px; margin-bottom:14px;">
                            <strong><i class="bi bi-info-circle"></i> Arbitre FFBB désigné</strong>
                            {% if rencontre.arbitreExterneNom %}
                                : <strong>{{ rencontre.arbitreExterneNom }}</strong>
                            {% endif %}
                            <div style="font-size:.78rem; color:var(--mabb-muted); margin-top:4px;">
                                Les rôles Arbitre 1/2 sont gérés par la FFBB pour ce match.
                            </div>
                        </div>
                    {% endif %}

                    {% set roles_codes = ['arbitre_1', 'arbitre_2', 'resp_salle', 'marqueur', 'chrono', 'emarque', 'stats'] %}
                    {% set roles_libelles = {
                        'arbitre_1':  'Arbitre 1',
                        'arbitre_2':  'Arbitre 2',
                        'resp_salle': 'Responsable de salle',
                        'marqueur':   'Marqueur',
                        'chrono':     'Chronométreur',
                        'emarque':    'Opérateur e-marque',
                        'stats':      'Stats live MABB',
                    } %}
                    {% set roles_icones = {
                        'arbitre_1':  'bi-whistle',
                        'arbitre_2':  'bi-whistle',
                        'resp_salle': 'bi-shield-check',
                        'marqueur':   'bi-pencil-square',
                        'chrono':     'bi-stopwatch',
                        'emarque':    'bi-display',
                        'stats':      'bi-graph-up',
                    } %}

                    {% for code in roles_codes %}
                        {% set rr = rencontre.getRoleParCode(code) %}
                        {% set est_arbitre = code in ['arbitre_1', 'arbitre_2'] %}
                        {% set bloque_ffbb = est_arbitre and rencontre.arbitreExterneDesigne %}

                        <div style="display:flex; align-items:center; gap:10px; padding:10px 6px; border-bottom:1px solid var(--mabb-border);">
                            <div style="width:32px; text-align:center; color:var(--mabb-blue);">
                                <i class="bi {{ roles_icones[code] }}" style="font-size:1.2rem;"></i>
                            </div>
                            <div style="flex:1; min-width:0;">
                                <div style="font-weight:600; font-size:.9rem;">{{ roles_libelles[code] }}</div>
                                {% if rr %}
                                    <div style="font-size:.78rem; color:var(--mabb-muted);">
                                        <i class="bi bi-person-check"></i> {{ rr.user.prenom }} {{ rr.user.nom }}
                                        {% if rr.present %}
                                            <span style="color:#16a34a; font-weight:600; margin-left:6px;">
                                                <i class="bi bi-check-circle-fill"></i> Validé présent
                                            </span>
                                        {% endif %}
                                    </div>
                                {% elseif bloque_ffbb %}
                                    <div style="font-size:.72rem; color:var(--mabb-muted); font-style:italic;">
                                        Géré par la FFBB
                                    </div>
                                {% else %}
                                    <div style="font-size:.72rem; color:var(--mabb-muted); font-style:italic;">
                                        Personne d'inscrit
                                    </div>
                                {% endif %}
                            </div>
                            <div>
                                {% if rr %}
                                    {# Inscrit : afficher actions désinscrire (user lui-même ou staff) et valider (staff) #}
                                    <div style="display:flex; gap:4px;">
                                        {% if is_granted('CLUB_STAFF', rencontre) and not rr.present %}
                                            <form method="post" action="{{ path('manager_rencontre_role_valider', {id: rencontre.id, role: code}) }}" style="display:inline;">
                                                <input type="hidden" name="_token" value="{{ csrf_token('valider_role_' ~ rencontre.id ~ '_' ~ code) }}">
                                                <button type="submit" class="btn-mabb-primary btn-sm" title="Valider sa présence (déclenche la mission gamification)">
                                                    <i class="bi bi-check-lg"></i> Valider
                                                </button>
                                            </form>
                                        {% endif %}
                                        {% if not rr.present %}
                                            <form method="post" action="{{ path('manager_rencontre_role_desinscrire', {id: rencontre.id, role: code}) }}" style="display:inline;"
                                                  onsubmit="return confirm('Désinscrire {{ rr.user.prenom }} de ce rôle ?');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('desinscrire_role_' ~ rencontre.id ~ '_' ~ code) }}">
                                                <button type="submit" class="btn-mabb-ghost btn-sm" style="color:var(--mabb-red); border-color:var(--mabb-red);" title="Retirer du rôle">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>
                                            </form>
                                        {% endif %}
                                    </div>
                                {% elseif bloque_ffbb %}
                                    <span style="background:#f1f5f9; color:var(--mabb-muted); padding:5px 10px; border-radius:6px; font-size:.75rem; font-weight:600;">
                                        <i class="bi bi-lock"></i> Verrouillé FFBB
                                    </span>
                                {% elseif rencontre.passee %}
                                    {# [B22 12/06/2026] Match terminé : inscriptions closes (sauf STAFF qui peut corriger après) #}
                                    {% if is_granted('CLUB_STAFF', rencontre) %}
                                        <form method="post" action="{{ path('manager_rencontre_role_sinscrire', {id: rencontre.id, role: code}) }}" style="display:inline;">
                                            <input type="hidden" name="_token" value="{{ csrf_token('role_' ~ rencontre.id ~ '_' ~ code) }}">
                                            <button type="submit" class="btn-mabb-ghost btn-sm" title="Match terminé — inscription staff possible pour corriger">
                                                <i class="bi bi-clock-history"></i> Inscrire (post-match)
                                            </button>
                                        </form>
                                    {% else %}
                                        <span style="background:#f1f5f9; color:var(--mabb-muted); padding:5px 10px; border-radius:6px; font-size:.75rem; font-weight:600;" title="Match terminé, inscription close">
                                            <i class="bi bi-clock-history"></i> Inscriptions closes
                                        </span>
                                    {% endif %}
                                {% else %}
                                    {# Libre : bouton "Je m'inscris" (match à venir) #}
                                    <form method="post" action="{{ path('manager_rencontre_role_sinscrire', {id: rencontre.id, role: code}) }}" style="display:inline;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('role_' ~ rencontre.id ~ '_' ~ code) }}">
                                        <button type="submit" class="btn-mabb-orange btn-sm">
                                            <i class="bi bi-hand-thumbs-up"></i> Je m'inscris
                                        </button>
                                    </form>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>

            <div class="card-mabb" style="margin-top:16px; opacity:.55;">
                <div class="card-header"><i class="bi bi-people-fill"></i> Convocations joueuses (à venir)</div>
                <div class="empty-state" style="padding:30px 20px;">
                    <i class="bi bi-clock-history"></i>
                    <p style="margin:0; font-size:.9rem;">Module convocations dans une prochaine itération.</p>
                </div>
            </div>

            {# ========================================================
               Documents officiels FFBB — résumé, feuille de match, positions tirs
               RGPD strict (07/06/2026) : visible UNIQUEMENT pour staff/coach/dirigeant.
               Les joueuses lambda et parents ne voient PAS ces documents qui
               contiennent les stats individuelles de toutes les joueuses.
               TODO #105 : si une joueuse marque ses stats publiques, ses lignes
               doivent rester visibles à tous (à implémenter avec visibilité 5 paliers).
               ======================================================== #}
            {% if is_granted('CLUB_STAFF', rencontre) or is_granted('CLUB_ADMIN', rencontre) %}
                <div class="card-mabb" style="margin-top:16px;">
                    <div class="card-header" style="display:flex; justify-content:space-between; align-items:center;">
                        <span><i class="bi bi-file-earmark-pdf-fill" style="color:var(--mabb-red);"></i> Documents officiels FFBB</span>
                        <small style="color:var(--mabb-muted); font-weight:500;">PDFs exportés depuis Easy Stats / e-marque</small>
                    </div>
                    <div class="card-body" style="display:grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap:12px;">
                        {{ _self.pdfUploadCard(rencontre, 'resume',    'Résumé du match',   'bi-list-ol',          'Stats individuelles (points, tirs, LF, fautes)') }}
                        {{ _self.pdfUploadCard(rencontre, 'feuille',   'Feuille de match',  'bi-file-earmark-text','Table de marque officielle action par action') }}
                        {{ _self.pdfUploadCard(rencontre, 'positions', 'Positions des tirs','bi-bullseye',          'Shot chart — carte des tirs sur le terrain') }}
                    </div>
                </div>

                {# ========================================================
                   [B22b-bis 14/06/2026] Validation manuelle Stats FFBB
                   Le coach déclare avoir comparé sa saisie EvaluationMatch
                   avec le PDF officiel. Affiché ensuite côté PIRB comme
                   un badge ✓ "Stats officielles validées".
                   Visible uniquement si match passé + PDF resume uploadé.
                   ======================================================== #}
                {% if rencontre.isPassee() and rencontre.resumePath is not null %}
                    <div class="card-mabb" style="margin-top:16px; {% if rencontre.isFfbbStatsValidated() %}border-left:4px solid var(--mabb-success, #10b981);{% else %}border-left:4px solid var(--mabb-warning, #f59e0b);{% endif %}">
                        <div class="card-header">
                            {% if rencontre.isFfbbStatsValidated() %}
                                <i class="bi bi-check-circle-fill" style="color:#10b981;"></i> Stats FFBB validées
                            {% else %}
                                <i class="bi bi-clipboard-check" style="color:#f59e0b;"></i> Validation Stats FFBB
                            {% endif %}
                        </div>
                        <div class="card-body">
                            {% if rencontre.isFfbbStatsValidated() %}
                                <p style="margin:0 0 10px 0; color:var(--mabb-text);">
                                    Validé par <strong>{{ rencontre.ffbbStatsValidatedBy.prenom }} {{ rencontre.ffbbStatsValidatedBy.nom }}</strong>
                                    le <strong>{{ rencontre.ffbbStatsValidatedAt|date('d/m/Y à H:i') }}</strong>.
                                </p>
                                {% if rencontre.ffbbStatsValidationNote %}
                                    <div style="padding:10px; background:rgba(0,0,0,.04); border-radius:6px; margin-bottom:10px; font-style:italic;">
                                        « {{ rencontre.ffbbStatsValidationNote }} »
                                    </div>
                                {% endif %}
                                <p style="font-size:0.85rem; color:var(--mabb-muted); margin:0 0 10px 0;">
                                    Les joueuses voient le badge ✓ sur leur page stats du match.
                                </p>
                                <form method="post" action="{{ path('manager_rencontre_invalider_stats_ffbb', {id: rencontre.id}) }}" onsubmit="return confirm('Annuler la validation des stats FFBB pour ce match ?');" style="margin:0;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('invalider_stats_ffbb_' ~ rencontre.id) }}">
                                    <button type="submit" class="btn-mabb-ghost" style="color:var(--mabb-red, #ef4444); border-color:var(--mabb-red, #ef4444);">
                                        <i class="bi bi-x-circle"></i> Annuler la validation
                                    </button>
                                </form>
                            {% else %}
                                <p style="margin:0 0 12px 0; color:var(--mabb-text);">
                                    En cliquant ci-dessous, tu déclares avoir <strong>comparé ta saisie EvaluationMatch avec le PDF resume FFBB officiel</strong> et que les stats correspondent (ou bien que tu as documenté un écart ci-dessous).
                                </p>
                                <form method="post" action="{{ path('manager_rencontre_valider_stats_ffbb', {id: rencontre.id}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('valider_stats_ffbb_' ~ rencontre.id) }}">
                                    <div style="margin-bottom:10px;">
                                        <label for="validation_note" style="display:block; font-size:0.85rem; color:var(--mabb-muted); margin-bottom:4px;">Commentaire (optionnel) — ex : "Écart 2pts pour Jody, table mal saisie, ma saisie est bonne"</label>
                                        <textarea name="validation_note" id="validation_note" rows="2" placeholder="Aucun écart. Stats conformes au PDF officiel." style="width:100%; padding:8px; border:1px solid var(--mabb-border); border-radius:6px; font-family:inherit;"></textarea>
                                    </div>
                                    <button type="submit" class="btn-mabb-primary">
                                        <i class="bi bi-check-circle"></i> J'ai vérifié, je valide les Stats FFBB
                                    </button>
                                </form>
                            {% endif %}
                        </div>
                    </div>
                {% endif %}
            {% endif %}

            {% if is_granted('CLUB_ADMIN', rencontre) %}
                <div class="card-mabb" style="margin-top:16px; border-left:4px solid var(--mabb-red);">
                    <div class="card-header"><i class="bi bi-exclamation-triangle"></i> Zone dangereuse</div>
                    <div class="card-body">
                        <form method="post" action="{{ path('manager_rencontre_delete', {id: rencontre.id}) }}" onsubmit="return confirm('Supprimer définitivement cette rencontre ? Si le score est saisi, cela impactera les stats.');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_rencontre_' ~ rencontre.id) }}">
                            <button type="submit" class="btn-mabb-ghost" style="color:var(--mabb-red); border-color:var(--mabb-red);">
                                <i class="bi bi-trash"></i> Supprimer la rencontre
                            </button>
                        </form>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>

    {# [V2.2] Section joueuses éphémères — visible si rencontre non-officielle #}
    {% if rencontre.isNonOfficielle() and joueuses_ephemeres|length > 0 %}
        <div style="margin-top:24px; padding:16px 20px; background:rgba(234,88,12,.06); border:1px solid rgba(234,88,12,.2); border-radius:12px;">
            <h3 style="font-size:.9rem; font-weight:800; text-transform:uppercase; letter-spacing:.05em; color:#ea580c; margin:0 0 12px;">
                ⚡ Joueuses éphémères ({{ joueuses_ephemeres|length }})
            </h3>
            <div style="display:flex; flex-wrap:wrap; gap:8px;">
                {% for j in joueuses_ephemeres %}
                    <div id="jr-card-{{ j.id }}" style="display:flex;align-items:center;gap:8px;padding:8px 12px;background:rgba(255,255,255,.05);border-radius:8px;border:1px solid rgba(255,255,255,.08);">
                        <span style="width:10px;height:10px;border-radius:50%;background:{{ j.couleurMaillot ?? '#6b7280' }};flex-shrink:0;"></span>
                        <div>
                            <div style="font-weight:700;font-size:.88rem;">
                                {{ j.nomComplet }}{% if j.numeroMaillot %} <span style="opacity:.6">#{{ j.numeroMaillot }}</span>{% endif %}
                            </div>
                            {% if j.isEphemereAdverse() %}
                                <span style="font-size:.72rem;background:rgba(239,68,68,.15);color:#ef4444;padding:1px 6px;border-radius:4px;">
                                    Adverse · {{ j.equipeEphemere }}
                                </span>
                            {% else %}
                                <span style="font-size:.72rem;background:rgba(59,130,246,.15);color:#3b82f6;padding:1px 6px;border-radius:4px;">
                                    Notre équipe
                                </span>
                            {% endif %}
                        </div>
                        {% if is_granted('CLUB_STAFF', rencontre) %}
                            {# Bouton "Recruter" pour les joueuses de notre équipe seulement #}
                            {% if not j.isEphemereAdverse() %}
                                <form method="POST" action="{{ path('manager_joueur_recruter', {id: j.id}) }}" style="display:inline;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('recruter_joueur_' ~ j.id) }}">
                                    <input type="hidden" name="equipeId" value="{{ rencontre.equipe.id }}">
                                    <button type="submit" title="Recruter dans l'effectif officiel"
                                            style="background:rgba(16,185,129,.15);border:1px solid rgba(16,185,129,.4);color:#10b981;padding:3px 8px;border-radius:5px;font-size:.75rem;cursor:pointer;font-weight:700;">
                                        ✓ Recruter
                                    </button>
                                </form>
                            {% endif %}
                            <button type="button" onclick="supprimerEphemere({{ j.id }}, this)"
                                    style="background:none;border:1px solid rgba(239,68,68,.3);color:#ef4444;border-radius:5px;padding:3px 8px;font-size:.75rem;cursor:pointer;">
                                ✕
                            </button>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        </div>
    {% endif %}

    {# [V2.2] Modale "Ajouter joueuse rapide" #}
    {% if rencontre.isNonOfficielle() and is_granted('CLUB_STAFF', rencontre) %}
        {{ include('manager/rencontre/_modale_joueur_rapide.html.twig') }}
    {% endif %}

{% endblock %}

{# ========================================================
   MACRO : carte d'upload PDF
   - Si pas de PDF : zone drag-drop avec form upload
   - Si PDF présent : preview iframe + actions Voir/Supprimer
   - Visible CLUB_MEMBER en lecture, upload/delete réservés CLUB_STAFF
   ======================================================== #}
{% macro pdfUploadCard(rencontre, type, libelle, icone, description) %}
    {% set path = rencontre.pdfPath(type) %}
    <div style="background:#fff; border:1px solid #e5e7eb; border-radius:10px; padding:14px; display:flex; flex-direction:column; gap:10px;">
        <div style="display:flex; align-items:center; gap:8px;">
            <i class="bi {{ icone }}" style="color:var(--mabb-blue); font-size:1.3rem;"></i>
            <strong style="font-size:.95rem;">{{ libelle }}</strong>
        </div>
        <p style="margin:0; color:var(--mabb-muted); font-size:.78rem; line-height:1.4;">{{ description }}</p>

        {% if path %}
            {# PDF présent — actions : voir / remplacer / supprimer #}
            <div style="display:flex; gap:6px; flex-wrap:wrap; margin-top:auto;">
                <a href="{{ path('manager_rencontre_pdf_serve', {id: rencontre.id, type: type}) }}"
                   target="_blank" rel="noopener"
                   class="btn-mabb-primary"
                   style="font-size:.78rem; padding:6px 12px;">
                    <i class="bi bi-eye"></i> Voir
                </a>
                {% if is_granted('CLUB_STAFF', rencontre) %}
                    <form method="post" action="{{ path('manager_rencontre_pdf_delete', {id: rencontre.id, type: type}) }}"
                          onsubmit="return confirm('Supprimer ce PDF ?');" style="display:inline;">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_pdf_' ~ type ~ '_' ~ rencontre.id) }}">
                        <button type="submit" class="btn-mabb-ghost" style="font-size:.78rem; padding:6px 12px; color:var(--mabb-red); border-color:var(--mabb-red);">
                            <i class="bi bi-trash"></i>
                        </button>
                    </form>
                {% endif %}
            </div>
        {% else %}
            {# PDF absent — bouton upload (staff uniquement) #}
            {% if is_granted('CLUB_STAFF', rencontre) %}
                <form method="post"
                      action="{{ path('manager_rencontre_pdf_upload', {id: rencontre.id, type: type}) }}"
                      enctype="multipart/form-data"
                      style="margin-top:auto;">
                    <input type="hidden" name="_token" value="{{ csrf_token('upload_pdf_' ~ type ~ '_' ~ rencontre.id) }}">
                    <label style="display:block; padding:10px; background:#f3f4f6; border:2px dashed #d1d5db; border-radius:8px; text-align:center; cursor:pointer; transition:background .15s, border-color .15s;"
                           onmouseover="this.style.background='#eff6ff'; this.style.borderColor='var(--mabb-blue)'"
                           onmouseout="this.style.background='#f3f4f6'; this.style.borderColor='#d1d5db'">
                        <i class="bi bi-cloud-upload" style="font-size:1.4rem; display:block; color:var(--mabb-muted); margin-bottom:4px;"></i>
                        <small style="font-weight:600;">Choisir un PDF</small>
                        <input type="file" name="pdf" accept="application/pdf"
                               onchange="this.form.submit();"
                               style="display:none;">
                    </label>
                </form>
            {% else %}
                <p style="margin:0; color:var(--mabb-muted); font-size:.78rem; font-style:italic;">
                    <i class="bi bi-dash-circle"></i> Pas encore uploadé.
                </p>
            {% endif %}
        {% endif %}
    </div>
{% endmacro %}
