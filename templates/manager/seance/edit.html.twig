{% extends 'manager/base.html.twig' %}

{% block title %}Modifier la séance{% endblock %}

{% block body %}
    <div class="page-header">
        <div>
            <h1><i class="bi bi-calendar-plus"></i> Modifier la séance</h1>
        </div>
        <a href="{{ path('manager_seance_index') }}" class="btn-mabb-ghost">
            <i class="bi bi-arrow-left"></i> Retour
        </a>
    </div>

    <div class="card-mabb">
        <div class="card-body form-mabb" style="max-width: 850px; margin: 0 auto;">
            {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}
                <div class="form-required-info">
                    Les champs marqués <strong>*</strong> sont obligatoires.
                </div>
                {% if not form.vars.valid %}
                    <div class="flash flash-error" style="margin-bottom: 20px;">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        <strong>Le formulaire contient des erreurs :</strong>
                        <ul style="margin:6px 0 0; padding-left:24px;">
                            {% for child in form.children %}
                                {% for error in child.vars.errors %}
                                    <li><strong>{{ child.vars.label ?: child.vars.name }}</strong> : {{ error.message }}</li>
                                {% endfor %}
                            {% endfor %}
                        </ul>
                    </div>
                {% endif %}

                <div class="form-section">
                    <h4 class="form-section-title"><i class="bi bi-people-fill"></i> Équipe & date</h4>
                    <div class="row row-form g-3">
                        <div class="col-md-6">{{ form_row(form.equipe) }}</div>
                        <div class="col-md-6">{{ form_row(form.date) }}</div>
                    </div>
                </div>

                <div class="form-section">
                    <h4 class="form-section-title"><i class="bi bi-geo-alt"></i> Lieu & durée</h4>
                    <div class="row row-form g-3">
                        <div class="col-md-6">{{ form_row(form.lieu) }}</div>
                        <div class="col-md-3">{{ form_row(form.dureeMinutes) }}</div>
                        <div class="col-md-3">{{ form_row(form.type) }}</div>
                    </div>
                </div>

                <div class="form-section">
                    <h4 class="form-section-title"><i class="bi bi-card-text"></i> Notes (optionnel)</h4>
                    {{ form_row(form.notes) }}
                </div>

                <div style="margin-top:24px; padding-top:20px; border-top:1px solid var(--mabb-border); display:flex; gap:12px; justify-content:flex-end;">
                    <a href="{{ path('manager_seance_index') }}" class="btn-mabb-ghost">Annuler</a>
                    <button type="submit" class="btn-mabb-primary">
                        <i class="bi bi-check-lg"></i> Enregistrer
                    </button>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
